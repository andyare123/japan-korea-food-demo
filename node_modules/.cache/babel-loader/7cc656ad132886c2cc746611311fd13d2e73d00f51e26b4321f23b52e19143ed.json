ly(() => {\n          this.isLoading = false;\n        });\n    },\n\n    addToCart(productId) {\n      userApi.addToCart(productId)\n        .then((res) => {\n          alert(res.data.message || '已加入購物車');\n        });\n    },\n\n    toggleFavorite(product) {\n      const index = this.favorites.findIndex((item) => item.id === product.id);\n\n      if (index === -1) {\n        this.favorites.push(product);\n      } else {\n        this.favorites.splice(index, 1);\n      }\n\n      localStorage.setItem('favorites', JSON.stringify(this.favorites));\n    },\n\n    isFavorite(productId) {\n      return this.favorites.some((item) => item.id === productId);\n    },\n  },\n  mounted() {\n    this.getProducts();\n  },\n};\n</script>\n\n<style scoped>\n.products-header {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n}\n\n@media (max-width: 768px) {\n  .products-header {\n    flex-direction: column;\n    align-items: flex-start;\n    gap: 16px;\n  }\n}\n</style>"],"mappings":";;;;;;;;;;;AAuCA,OAAOA,WAAU,MAAO,8BAA8B;AACtD,OAAOC,OAAM,MAAO,eAAe;AAEnC,eAAe;EACbC,IAAI,EAAE,cAAc;EACpBC,UAAU,EAAE;IACVH,WAAW,EAAXA;EACF,CAAC;EACDI,IAAI,WAAJA,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,QAAQ,EAAE,EAAE;MACZC,SAAS,EAAEC,IAAI,CAACC,KAAK,CAACC,YAAY,CAACC,OAAO,CAAC,WAAW,CAAC,KAAK,EAAE;MAC9DC,SAAS,EAAE;IACb,CAAC;EACH,CAAC;EACDC,OAAO,EAAE;IACPC,WAAW,WAAXA,WAAWA,CAAA,EAAG;MAAA,IAAAC,KAAA;MACZ,IAAI,CAACH,SAAQ,GAAI,IAAI;MAErBV,OAAO,CAACY,WAAW,CAAC,EACjBE,IAAI,CAAC,UAACC,GAAG,EAAK;QACbF,KAAI,CAACT,QAAO,GAAIW,GAAG,CAACZ,IAAI,CAACC,QAAQ;MACnC,CAAC,YACO,CAAC,YAAM;QACbS,KAAI,CAACH,SAAQ,GAAI,KAAK;MACxB,CAAC,CAAC;IACN,CAAC;IAEDM,SAAS,WAATA,SAASA,CAACC,SAAS,EAAE;MACnBjB,OAAO,CAACgB,SAAS,CAACC,SAAS,EACxBH,IAAI,CAAC,UAACC,GAAG,EAAK;QACbG,KAAK,CAACH,GAAG,CAACZ,IAAI,CAACgB,OAAM,IAAK,QAAQ,CAAC;MACrC,CAAC,CAAC;IACN,CAAC;IAEDC,cAAc,WAAdA,cAAcA,CAACC,OAAO,EAAE;MACtB,IAAMC,KAAI,GAAI,IAAI,CAACjB,SAAS,CAACkB,SAAS,CAAC,UAACC,IAAI;QAAA,OAAKA,IAAI,CAACC,EAAC,KAAMJ,OAAO,CAACI,EAAE;MAAA,EAAC;MAExE,IA