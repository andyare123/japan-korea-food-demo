ar _this3 = this;\n      var url = \"\".concat(VUE_APP_API, \"/api/\").concat(VUE_APP_PATH, \"/cart/\").concat(id);\n      this.status.loadingItem = id;\n      this.isLoading = true;\n      this.$http[\"delete\"](url).then(function (response) {\n        _this3.$httpMessageState(response, '移除購物車品項');\n        _this3.getCart();\n        window.dispatchEvent(new Event('cart-updated'));\n      })[\"finally\"](function () {\n        _this3.status.loadingItem = '';\n        _this3.isLoading = false;\n      });\n    },\n    addCouponCode: function addCouponCode() {\n      var _this4 = this;\n      if (!this.cart.carts.length) {\n        alert('購物車目前沒有餐點，請先加入餐點後再套用優惠券');\n        return;\n      }\n      if (!this.coupon_code.trim()) {\n        alert('請輸入優惠券代碼');\n        return;\n      }\n      var url = \"\".concat(VUE_APP_API, \"/api/\").concat(VUE_APP_PATH, \"/coupon\");\n      var coupon = {\n        code: this.coupon_code.trim()\n      };\n      this.isLoading = true;\n      this.$http.post(url, {\n        data: coupon\n      }).then(function (response) {\n        _this4.$httpMessageState(response, '套用優惠券');\n        if (response.data.success) {\n          _this4.getCart();\n        } else {\n          alert(response.data.message || '優惠券套用失敗，請確認優惠碼是否正確或是否已啟用');\n        }\n      })[\"catch\"](function (error) {\n        console.log(error);\n        alert('優惠券套用失敗，請確認後台是否有建立並啟用這張優惠券');\n      })[\"finally\"](function () {\n        _this4.isLoading = false;\n      });\n    },\n    goCheckoutProcess: function goCheckoutProcess() {\n      if (!this.cart.carts || !this.cart.carts.length) {\n        alert('購物車目前沒有餐點，請先加入餐點');\n        return;\n      }\n      this.$router.push('/checkout-process');\n    }\n  },\n  created: function created() {\n    this.getCart();\n  }\n};","map":{"version":3,"names":["_process$env","process","env","VUE_APP_API","VUE_APP_PATH","data","isLoading","status","loadingItem","cart","carts","total","final_total","coupon_code","defaultImage","methods","getCart","_this","url","concat","$http","get","then","response","updateCart","item","_this2","qty","id","product_id","put","res","$httpMessageState","window","dispatchEvent","Event","removeCartItem","_this3","addCouponCode","_this4","length","alert","trim","coupon","code","post","success","message","error","console","log","goCheckoutProcess","$router","push","created"],"sources":["C:\\Users\\ROG Strix\\Desktop\\vue cli\\gui-demo\\src\\views\\UserCart.vue"],"sourcesContent":["<!-- eslint-disable vue/no-multiple-template-root -->\n<template>\n  <Loading :active=\"isLoading\"></Loading>\n\n  <div class=\"food-cart-page\">\n    <div class=\"container py-5\">\n      <!-- 頁面標題 -->\n      <div class=\"page-hero mb-5\">\n        <div class=\"hero-content\">\n          <span class=\"hero-badge\">YOUR ORDER</span>\n          <h1 class=\"fw-bold mt-3 mb-3\">\n            我的餐點購物車\n          </h1>\n          <p class=\"text-muted mb-0\">\n            請確認餐點數量、套用優惠券，確認無誤後即可進入完成訂購流程。\n          </p>\n        </div>\n      </div>\n\n      <div class=\"row justify-content-center\">\n        <!-- 購物車 -->\n        <div class=\"col-lg-8 col-xl-7\">\n          <div class=\"cart-panel\">\n            <div class=\"cart-header mb-3\">\n              <div>\n                <span class=\"small text-danger fw-bold\">CART DETAIL</span>\n                <h4 class=\"fw-bold mb-1\">我的餐點購物車</h4>\n                <p class=\"text-muted mb-0 small\">\n                  確認餐點數量後，可套用優惠券並進入下一步。\n                </p>\n              </div>\n            </div>\n\n            <div class=\"mb-4\">\n              <router-link to=\"/products\" class=\"btn btn-outline-secondary w-100\">\n                <i class=\"bi bi-arrow-left me-1\"></i>\n                繼續挑選日韓料理\n              </router-link>\n            </div>\n\n            <div v-if=\"cart.carts && cart.carts.length\">\n              <div\n                class=\"cart-item\"\n                v-for=\"item in cart.carts\"\n                :key=\"item.id\"\n              >\n                <button\n                  type=\"button\"\n                  class=\"btn btn-outline-danger btn-sm cart-remove\"\n                  :disabled=\"status.loadingItem === item.id\"\n                  @click=\"removeCartItem(item.id)\"\n                >\n                  <i class=\"bi bi-x\"></i>\n                </button>\n\n                <div\n                  class=\"cart-thumb\"\n                  :style=\"{ backgroundImage: `url(${item.product?.imageUrl || defaultImage})` }\"\n                ></div>\n\n                <div class=\"cart-info\">\n                  <div class=\"d-flex align-items-center gap-2 mb-1\">\n                    <span class=\"cart-category\">\n                      {{ item.product?.category || '料理' }}\n                    </span>\n\n                    <span class=\"text-success small\" v-if=\"item.coupon\">\n                      已套用優惠\n                    </span>\n                  </div>\n\n                  <h6 class=\"fw-bold mb-2\">\n                    {{ item.product?.title || '未命名餐點' }}\n                  </h6>\n\n                  <div class=\"input-group input-group-sm cart-qty\">\n                    <input\n                      type=\"number\"\n                      class=\"form-control\"\n                      min=\"1\"\n                      :disabled=\"item.id === status.loadingItem\"\n                      @change=\"updateCart(item)\"\n                      v-model.number=\"item.qty\"\n                    >\n\n                    <div class=\"input-group-text\">\n                      {{ item.product?.unit || '份' }}\n                    </div>\n                  </div>\n                </div>\n\n                <div class=\"cart-price text-end\">\n                  <small\n                    v-if=\"cart.final_total !== cart.total\"\n                    class=\"text-success d-block\"\n                  >\n                    折扣價\n                  </small>\n\n                  <strong>\n                    {{ $filters.currency(item.final_total) }}\n                  </strong>\n                </div>\n              </div>\n            </div>\n\n            <div v-else class=\"empty-cart\">\n              <i class=\"bi bi-bag-x\"></i>\n              <h5 class=\"fw-bold mt-3 mb-2\">購物車目前沒有餐點</h5>\n              <p class=\"text-muted mb-4\">\n                還沒有加入任何日韓料理，先回到料理列表挑選想吃的餐點吧。\n              </p>\n\n              <router-link to=\"/products\" class=\"btn btn-danger\">\n                <i class=\"bi bi-search me-1\"></i>\n                前往挑選料理\n              </router-link>\n            </div>\n\n            <!-- 金額 -->\n            <div class=\"cart-summary mt-4\">\n              <div class=\"d-flex justify-content-between mb-2\">\n                <span>餐點小計</span>\n                <strong>{{ $filters.currency(cart.total || 0) }}</strong>\n              </div>\n\n              <div\n                class=\"d-flex justify-content-between text-success\"\n                v-if=\"cart.final_total !== cart.total\"\n              >\n                <span>優惠後金額</span>\n                <strong>{{ $filters.currency(cart.final_total || 0) }}</strong>\n              </div>\n\n              <hr>\n\n              <div class=\"d-flex justify-content-between total-line\">\n                <span>應付總額</span>\n                <strong>{{ $filters.currency(cart.final_total || cart.total || 0) }}</strong>\n              </div>\n            </div>\n\n            <!-- 優惠券介紹 -->\n            <div class=\"coupon-box mt-4 mb-3\">\n              <div>\n                <h5 class=\"fw-bold mb-1\">日韓美食優惠券</h5>\n                <p class=\"mb-0 text-muted\">\n                  輸入優惠碼\n                  <strong class=\"text-danger\">JPKR100</strong>\n                  ，滿額享折扣優惠。\n                </p>\n              </div>\n            </div>\n\n            <!-- 優惠券輸入 -->\n            <div class=\"input-group mb-3 coupon-input-group\">\n              <input\n                type=\"text\"\n                class=\"form-control\"\n                v-model.trim=\"coupon_code\"\n                placeholder=\"請輸入優惠碼\"\n                @keyup.enter=\"addCouponCode\"\n              >\n\n              <button\n                class=\"btn btn-outline-danger\"\n                type=\"button\"\n                :disabled=\"isLoading || !cart.carts.length\"\n                @click=\"addCouponCode\"\n              >\n                套用優惠碼\n              </button>\n            </div>\n\n            <div class=\"d-grid mt-4\">\n              <button\n                type=\"button\"\n                class=\"btn btn-danger btn-lg next-checkout-btn\"\n                :disabled=\"!cart.carts || !cart.carts.length\"\n                @click=\"goCheckoutProcess\"\n              >\n                下一步，完成訂購流程\n                <i class=\"bi bi-arrow-right ms-1\"></i>\n              </button>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </div>\n</template>\n\n<script>\nconst { VUE_APP_API, VUE_APP_PATH } = process.env;\n\nexport default {\n  data() {\n    return {\n      isLoading: false,\n      status: {\n        loadingItem: '',\n      },\n      cart: {\n        carts: [],\n        total: 0,\n        final_total: 0,\n      },\n      coupon_code: '',\n      defaultImage: 'https://images.unsplash.com/photo-1546069901-ba9599a7e63c?w=800',\n    };\n  },\n  methods: {\n    getCart() {\n      const url = `${VUE_APP_API}/api/${VUE_APP_PATH}/cart`;\n\n      this.isLoading = true;\n\n      this.$http.get(url)\n        .then((response) => {\n          this.cart = response.data.data || {\n            carts: [],\n            total: 0,\n            final_total: 0,\n          };\n        })\n        .finally(() => {\n          this.isLoading = false;\n        });\n    },\n\n    updateCart(item) {\n      if (item.qty < 1) {\n        // eslint-disable-next-line no-param-reassign\n        item.qty = 1;\n      }\n\n      const url = `${VUE_APP_API}/api/${VUE_APP_PATH}/cart/${item.id}`;\n\n      this.isLoading = true;\n      this.status.loadingItem = item.id;\n\n      const cart = {\n        product_id: item.product_id,\n        qty: item.qty,\n      };\n\n      this.$http.put(url, { data: cart })\n        .then((res) => {\n          this.$httpMessageState(res, '更新購物車');\n          this.getCart();\n          window.dispatchEvent(new Event('cart-updated'));\n        })\n        .finally(() => {\n          this.status.loadingItem = '';\n          this.isLoading = false;\n        });\n    },\n\n    removeCartItem(id) {\n      const url = `${VUE_APP_API}/api/${VUE_APP_PATH}/cart/${id}`;\n\n      this.status.loadingItem = id;\n      this.isLoading = true;\n\n      this.$http.delete(url)\n        .then((response) => {\n          this.$httpMessageState(response, '移除購物車品項');\n          this.getCart();\n          window.dispatchEvent(new Event('cart-updated'));\n        })\n        .finally(() => {\n          this.status.loadingItem = '';\n          this.isLoading = false;\n        });\n    },\n\n    addCouponCode() {\n      if (!this.cart.carts.length) {\n        alert('購物車目前沒有餐點，請先加入餐點後再套用優惠券');\n        return;\n      }\n\n      if (!this.coupon_code.trim()) {\n        alert('請輸入優惠券代碼');\n        return;\n      }\n\n      const url = `${VUE_APP_API}/api/${VUE_APP_PATH}/coupon`;\n\n      const coupon = {\n        code: this.coupon_code.trim(),\n      };\n\n      this.isLoading = true;\n\n      this.$http.post(url, { data: coupon })\n        .then((response) => {\n          this.$httpMessageState(response, '套用優惠券');\n\n          if (response.data.success) {\n            this.getCart();\n          } else {\n            alert(response.data.message || '優惠券套用失敗，請確認優惠碼是否正確或是否已啟用');\n          }\n        })\n        .catch((error) => {\n          console.log(error);\n          alert('優惠券套用失敗，請確認後台是否有建立並啟用這張優惠券');\n        })\n        .finally(() => {\n          this.isLoading = false;\n        });\n    },\n\n    goCheckoutProcess() {\n      if (!this.cart.carts || !this.cart.carts.length) {\n        alert('購物車目前沒有餐點，請先加入餐點');\n        return;\n      }\n\n      this.$router.push('/checkout-process');\n    },\n  },\n  created() {\n    this.getCart();\n  },\n};\n</script>\n\n<style scoped>\n.food-cart-page {\n  min-height: 100vh;\n  background:\n    radial-gradient(circle at top left, rgba(220, 53, 69, 0.12), transparent 32%),\n    linear-gradient(180deg, #fff7ef 0%, #ffffff 44%, #fffaf5 100%);\n}\n\n.page-hero {\n  position: relative;\n  overflow: hidden;\n  padding: 44px;\n  border-radius: 30px;\n  background:\n    linear-gradient(135deg, rgba(178, 58, 46, 0.14), rgba(255, 255, 255, 0.96)),\n    #ffffff;\n  border: 1px solid #f1d8ca;\n  box-shadow: 0 18px 45px rgba(110, 58, 30, 0.12);\n}\n\n.page-hero::after {\n  content: \"🛒\";\n  position: absolute;\n  right: 38px;\n  bottom: 20px;\n  font-size: 72px;\n  opacity: 0.16;\n}\n\n.hero-content {\n  max-width: 720px;\n}\n\n.hero-badge {\n  display: inline-block;\n  padding: 8px 14px;\n  border-radius: 999px;\n  color: #b23a2e;\n  background: #fff0e7;\n  font-weight: 800;\n  letter-spacing: 1px;\n}\n\n.cart-panel {\n  padding: 28px;\n  border-radius: 30px;\n  background: #ffffff;\n  border: 1px solid #f1d8ca;\n  box-shadow: 0 18px 48px rgba(120, 54, 28, 0.13);\n}\n\n.cart-header {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  gap: 12px;\n}\n\n.cart-item {\n  position: relative;\n  display: flex;\n  align-items: center;\n  gap: 14px;\n  padding: 16px 0;\n  border-bottom: 1px solid #f1e4dc;\n}\n\n.cart-remove {\n  flex: 0 0 auto;\n  width: 34px;\n  height: 34px;\n  border-radius: 50%;\n}\n\n.cart-thumb {\n  flex: 0 0 auto;\n  width: 72px;\n  height: 72px;\n  border-radius: 18px;\n  background-size: cover;\n  background-position: center;\n  background-color: #fff4ec;\n  border: 1px solid #f1d8ca;\n}\n\n.cart-info {\n  flex: 1;\n  min-width: 0;\n}\n\n.cart-category {\n  display: inline-block;\n  padding: 