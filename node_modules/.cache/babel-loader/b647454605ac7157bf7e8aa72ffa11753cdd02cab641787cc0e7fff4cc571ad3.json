uccess) {\n          _this.order = _objectSpread({\n            products: [],\n            user: {},\n            total: 0,\n            is_paid: false\n          }, res.data.order);\n        } else {\n          alert(res.data.message || '找不到訂單資料');\n          _this.$router.push('/user/cart');\n        }\n      })[\"finally\"](function () {\n        _this.isLoading = false;\n      });\n    },\n    payOrder: function payOrder() {\n      var _this2 = this;\n      if (this.order.is_paid) {\n        return;\n      }\n      var url = \"\".concat(process.env.VUE_APP_API, \"/api/\").concat(process.env.VUE_APP_PATH, \"/pay/\").concat(this.orderId);\n      this.isLoading = true;\n      this.$http.post(url).then(function (res) {\n        _this2.$httpMessageState(res, '付款');\n        if (res.data.success) {\n          _this2.getOrder();\n        } else {\n          alert(res.data.message || '付款失敗');\n        }\n      })[\"finally\"](function () {\n        _this2.isLoading = false;\n      });\n    }\n  },\n  created: function created() {\n    this.orderId = this.$route.params.orderId;\n    this.getOrder();\n  }\n};","map":{"version":3,"names":["data","order","products","user","total","is_paid","orderId","isLoading","defaultImage","computed","orderProducts","Array","isArray","_typeof","Object","values","orderProductCount","reduce","item","Number","qty","methods","getOrder","_this","alert","$router","push","url","concat","process","env","VUE_APP_API","VUE_APP_PATH","$http","get","then","res","success","_objectSpread","message","payOrder","_this2","post","$httpMessageState","created","$route","params"],"sources":["C:\\Users\\ROG Strix\\Desktop\\vue cli\\gui-demo\\src\\views\\UserCheckout.vue"],"sourcesContent":["<!-- eslint-disable vue/no-multiple-template-root -->\n<template>\n  <Loading :active=\"isLoading\"></Loading>\n\n  <div class=\"checkout-pay-page\">\n    <div class=\"container py-5\">\n      <!-- 頁首 -->\n      <div class=\"pay-hero mb-5\">\n        <span class=\"pay-badge\">PAYMENT CONFIRMATION</span>\n        <h1 class=\"fw-bold mt-3 mb-3\">\n          確認付款\n        </h1>\n        <p class=\"text-muted mb-0\">\n          請再次確認餐點明細、訂購資料與付款狀態，確認無誤後即可完成付款。\n        </p>\n      </div>\n\n      <div v-if=\"orderId\" class=\"row g-4 align-items-start\">\n        <!-- 左側：訂單明細 -->\n        <div class=\"col-lg-8\">\n          <div class=\"checkout-card mb-4\">\n            <div class=\"card-title-row mb-4\">\n              <div>\n                <span class=\"section-label\">ORDER ITEMS</span>\n                <h4 class=\"fw-bold mb-1\">餐點明細</h4>\n                <p class=\"text-muted mb-0 small\">\n                  以下為本次訂單的餐點與數量。\n                </p>\n              </div>\n\n              <span\n                class=\"status-pill\"\n                :class=\"order.is_paid ? 'paid' : 'unpaid'\"\n              >\n                {{ order.is_paid ? '付款完成' : '尚未付款' }}\n              </span>\n            </div>\n\n            <div v-if=\"order.products && order.products.length\">\n              <div\n                v-for=\"item in order.products\"\n                :key=\"item.id\"\n                class=\"order-item\"\n              >\n                <div\n                  class=\"order-img\"\n                  :style=\"{ backgroundImage: `url(${item.product.imageUrl || defaultImage})` }\"\n                ></div>\n\n                <div class=\"order-info\">\n                  <span class=\"food-category\">\n                    {{ item.product.category || '精選料理' }}\n                  </span>\n\n                  <h5 class=\"fw-bold mt-2 mb-1\">\n                    {{ item.product.title }}\n                  </h5>\n\n                  <p class=\"text-muted small mb-0\">\n                    數量：{{ item.qty }} {{ item.product.unit || '份' }}\n                  </p>\n                </div>\n\n                <div class=\"order-price text-end\">\n                  <small class=\"text-muted d-block\">小計</small>\n                  <strong class=\"text-danger\">\n                    {{ $filters.currency(item.final_total) }}\n                  </strong>\n                </div>\n              </div>\n            </div>\n\n            <div v-else class=\"empty-box text-center\">\n              <div class=\"display-5 mb-3\">🍱</div>\n              <h5 class=\"fw-bold\">目前沒有訂單餐點</h5>\n              <p class=\"text-muted mb-0\">\n                請返回購物車重新建立訂單。\n              </p>\n            </div>\n          </div>\n\n          <!-- 訂購人資料 -->\n          <div class=\"checkout-card\">\n            <div class=\"card-title-row mb-4\">\n              <div>\n                <span class=\"section-label\">CUSTOMER INFO</span>\n                <h4 class=\"fw-bold mb-1\">訂購資料</h4>\n                <p class=\"text-muted mb-0 small\">\n                  請確認聯絡資訊是否正確。\n                </p>\n              </div>\n            </div>\n\n            <div class=\"info-grid\">\n              <div class=\"info-item\">\n                <span>Email</span>\n                <strong>{{ order.user.email || '未填寫' }}</strong>\n              </div>\n\n              <div class=\"info-item\">\n                <span>姓名</span>\n                <strong>{{ order.user.name || '未填寫' }}</strong>\n              </div>\n\n              <div class=\"info-item\">\n                <span>收件人電話</span>\n                <strong>{{ order.user.tel || '未填寫' }}</strong>\n              </div>\n\n              <div class=\"info-item\">\n                <span>收件人地址</span>\n                <strong>{{ order.user.address || '未填寫' }}</strong>\n              </div>\n\n              <div class=\"info-item full\">\n                <span>付款狀態</span>\n                <strong :class=\"order.is_paid ? 'text-success' : 'text-danger'\">\n                  {{ order.is_paid ? '付款完成' : '尚未付款' }}\n                </strong>\n              </div>\n            </div>\n          </div>\n        </div>\n\n        <!-- 右側：付款摘要 -->\n        <div class=\"col-lg-4\">\n          <form class=\"summary-card sticky-lg-top\" @submit.prevent=\"payOrder\">\n            <span class=\"section-label\">PAYMENT</span>\n\n            <h3 class=\"fw-bold mt-2 mb-3\">\n              付款摘要\n            </h3>\n\n            <div class=\"summary-line\">\n              <span>訂單編號</span>\n              <strong class=\"order-id-text\">{{ orderId }}</strong>\n            </div>\n\n            <div class=\"summary-line\">\n              <span>餐點數量</span>\n              <strong>{{ orderProductCount }} 份</strong>\n            </div>\n\n            <div class=\"summary-line\">\n              <span>付款狀態</span>\n              <strong :class=\"order.is_paid ? 'text-success' : 'text-danger'\">\n                {{ order.is_paid ? '付款完成' : '尚未付款' }}\n              </strong>\n            </div>\n\n            <hr>\n\n            <div class=\"summary-total\">\n              <span>應付總額</span>\n              <strong>{{ $filters.currency(order.total) }}</strong>\n            </div>\n\n            <div class=\"pay-notice mt-4\">\n              <h6 class=\"fw-bold mb-2\">\n                <i class=\"bi bi-shield-check me-1\"></i>\n                付款提醒\n              </h6>\n              <p class=\"mb-0\">\n                確認付款後，訂單狀態會更新為付款完成。\n              </p>\n            </div>\n\n            <div class=\"d-grid gap-2 mt-4\">\n              <button\n                v-if=\"order.is_paid === false\"\n                class=\"btn btn-danger btn-lg\"\n                type=\"submit\"\n                :disabled=\"isLoading || !order.products.length\"\n              >\n                <span\n                  v-if=\"isLoading\"\n                  class=\"spinner-grow spinner-grow-sm me-1\"\n                ></span>\n                確認付款\n              </button>\n\n              <button\n                v-else\n                class=\"btn btn-success btn-lg\"\n                type=\"button\"\n                disabled\n              >\n                <i class=\"bi bi-check-circle me-1\"></i>\n                已完成付款\n              </button>\n\n              <router-link to=\"/products\" class=\"btn btn-outline-dark\">\n                繼續選購料理\n              </router-link>\n\n              <router-link to=\"/user/cart\" class=\"btn btn-outline-secondary\">\n                返回購物車\n              </router-link>\n            </div>\n          </form>\n        </div>\n      </div>\n\n      <div v-else-if=\"!isLoading\" class=\"empty-box text-center\">\n        <div class=\"display-5 mb-3\">🧾</div>\n        <h4 class=\"fw-bold\">找不到訂單編號</h4>\n        <p class=\"text-muted\">\n          請先從購物車建立訂單，再前往付款頁。\n        </p>\n        <router-link to=\"/user/cart\" class=\"btn btn-danger\">\n          返回購物車\n        </router-link>\n      </div>\n    </div>\n  </div>\n</template>\n\n<script>\nexport default {\n  data() {\n    return {\n      order: {\n        products: [],\n        user: {},\n        total: 0,\n        is_paid: false,\n      },\n      orderId: '',\n      isLoading: false,\n      defaultImage: 'https://images.unsplash.com/photo-1546069901-ba9599a7e63c?w=800',\n    };\n  },\n  computed: {\n    orderProducts() {\n      if (Array.isArray(this.order.products)) {\n        return this.order.products;\n      }\n\n      if (this.order.products && typeof this.order.products === 'object') {\n        return Object.values(this.order.products);\n      }\n\n      return [];\n    },\n\n    orderProductCount() {\n      return this.orderProducts.reduce(\n        (total, item) => total + Number(item.qty || 0),\n        0,\n      );\n    },\n  },\n  methods: {\n    getOrder() {\n      if (!this.orderId) {\n        alert('找不到訂單編號，請先建立訂單');\n        this.$router.push('/user/cart');\n        return;\n      }\n\n      const url = `${process.env.VUE_APP_API}/api/${process.env.VUE_APP_PATH}/order/${this.orderId}`;\n\n      this.isLoading = true;\n\n      this.$http.get(url)\n        .then((res) => {\n          if (res.data.success) {\n            this.order = {\n              products: [],\n              user: {},\n              total: 0,\n              is_paid: false,\n              ...res.data.order,\n            };\n          } else {\n            alert(res.data.message || '找不到訂單資料');\n            this.$router.push('/user/cart');\n          }\n        })\n        .finally(() => {\n          this.isLoading = false;\n        });\n    },\n\n    payOrder() {\n      if (this.order.is_paid) {\n        return;\n      }\n\n      const url = `${process.env.VUE_APP_API}/api/${process.env.VUE_APP_PATH}/pay/${this.orderId}`;\n\n      this.isLoading = true;\n\n      this.$http.post(url)\n        .then((res) => {\n          this.$httpMessageState(res, '付款');\n\n          if (res.data.success) {\n            this.getOrder();\n          } else {\n            alert(res.data.message || '付款失敗');\n          }\n        })\n        .finally(() => {\n          this.isLoading = false;\n        });\n    },\n  },\n  created() {\n    this.orderId = this.$route.params.orderId;\n    this.getOrder();\n  },\n};\n</script>\n\n<style scoped>\n.checkout-pay-page {\n  min-height: 100vh;\n  background:\n    radial-gradient(circle at top left, rgba(220, 53, 69, 0.12), transparent 32%),\n    linear-gradient(180deg, #fff7ef 0%, #ffffff 44%, #fffaf5 100%);\n}\n\n.pay-hero {\n  padding: 42px;\n  border-radius: 30px;\n  background:\n    linear-gradient(135deg, rgba(178, 58, 46, 0.14), rgba(255, 255, 255, 0.96)),\n    #ffffff;\n  border: 1px solid #f1d8ca;\n  box-shadow: 0 18px 45px rgba(110, 58, 30, 0.12);\n}\n\n.pay-badge,\n.section-label {\n  display: inline-block;\n  color: #b23a2e;\n  font-size: 13px;\n  font-weight: 900;\n  letter-spacing: 1px;\n}\n\n.pay-badge {\n  padding: 8px 14px;\n  border-radius: 999px;\n  background: #fff0e7;\n}\n\n.checkout-card,\n.summary-card {\n  padding: 30px;\n  border-radius: 28px;\n  background: #ffffff;\n  border: 1px solid #f1d8ca;\n  box-shadow: 0 16px 42px rgba(120, 54, 28, 0.1);\n}\n\n.summary-card {\n  top: 24px;\n}\n\n.card-title-row {\n  display: flex;\n  justify-content: space-between;\n  align-items: flex-start;\n  gap: 18px;\n}\n\n.status-pill {\n  flex: 0 0 auto;\n  padding: 8px 14px;\n  border-radius: 999px;\n  font-size: 14px;\n  font-weight: 900;\n}\n\n.status-pill.unpaid {\n  color: #b23a2e;\n  background: #fff0e7;\n}\n\n.status-pill.paid {\n  color: #198754;\n  background: #e9f8ef;\n}\n\n.order-item {\n  display: flex;\n  align-items: center;\n  gap: 18px;\n  padding: 18px 0;\n  border-bottom: 1px solid #f1e4dc;\n}\n\n.order-item:last-child {\n  border-bottom: 0;\n}\n\n.order-img {\n  flex: 0 0 auto;\n  width: 90px;\n  height: 90px;\n  border-radius: 22px;\n  background-size: cover;\n  background-position: center;\n  background-color: #fff4ec;\n  border: 1px solid #f1d8ca;\n}\n\n.order-info {\n  flex: 1;\n  min-width: 0;\n}\n\n.food-category {\n  display: inline-block;\n  padding: 5px 10px;\n  border-radius: 999px;\n  color: #b23a2e;\n  background: #fff0e7;\n  font-size: 12px;\n  font-weight: 800;\n}\n\n.order-price {\n  flex: 0 0 120px;\n}\n\n.info-grid {\n  display: grid;\n  grid-template-columns: repeat(2, minmax(0, 1fr));\n  gap: 14px;\n}\n\n.info-item {\n  padding: 16px;\n  border-radius: 16px;\n  background: #fffaf6;\n  border: 1px solid #f1e4dc;\n}\n\n.info-item.full {\n  grid-column: 1 / -1;\n}\n\n.info-item span {\n  display: block;\n  margin-bottom: 6px;\n  color: #888;\n  font-size: 13px;\n}\n\n.info-item strong {\n  display: block;\n  color: #333;\n  line-height: 1.6;\n  word-break: break-word;\n}\n\n.summary-line,\n.summary-total {\n  display: flex;\n  justify-content: space-between;\n  gap: 14px;\n  padding: 12px 0;\n}\n\n.summary-line span,\n.summary-total span {\n  color: #777;\n}\n\n.summary-total {\n  align-items: center;\n  color: #b23a2e;\n}\n\n.summary-total strong {\n  font-size: 28px;\n}\n\n.order-id-text {\n  max-width: 160px;\n  text-align: right;\n  word-break: break-all;\n  font-size: 13px;\n}\n\n.pay-notice {\n  padding: 18px;\n  border-radius: 18px;\n  color: #6c5b50;\n  background: #fff8e1;\n  border: 1px solid #ffe0a1;\n}\n\n.empty-box {\n  padding: 80px 24px;\n  border-radius: 30px;\n  background: #ffffff;\n  border: 1px solid #f1d8ca;\n  box-shadow: 0 16px 42px rgba(120, 54, 28, 0.1);\n}\n\n@media (max-width: 991px) {\n  .sticky-lg-top {\n    position: static !important;\n  }\n\n  .summary-card {\n    margin-top: 10px;\n  }\n}\n\n@media (max-width: 768px) {\n  .pay-hero {\n    padding: 28px 22px;\n    border-radius: 22px;\n  }\n\n  .checkout-card,\n  .summary-card {\n    padding: 22px;\n    border-radius: 22px;\n  }\n\n  .card-title-row {\n    flex-direction: column;\n  }\n\n  .order-item {\n    flex-wrap: wrap;\n    align-items: flex-start;\n  }\n\n  .order-price {\n    flex-basis: 100%;\n    text-align: left !important;\n    padding-left: 108px;\n  }\n\n  .info-grid {\n    grid-template-columns: 1fr;\n  }\n\n  .summary-total strong {\n    font-size: 24px;\n  }\n}\n</style>"],"mappings":";;;;;;;;;;;AA0NA,eAAe;EACbA,IAAI,WAAJA,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,KAAK,EAAE;QACLC,QAAQ,EAAE,EAAE;QACZC,IAAI,EAAE,CAAC,CAAC;QACRC,KAAK,EAAE,CAAC;QACRC,OAAO,EAAE;MACX,CAAC;MACDC,OAAO,EAAE,EAAE;MACXC,SAAS,EAAE,KAAK;MAChBC,YAAY,EAAE;IAChB,CAAC;EACH,CAAC;EACDC,QAAQ,EAAE;IACRC,aAAa,WAAbA,aAAaA,CAAA,EAAG;MACd,IAAIC,KAAK,CAACC,OAAO,CAAC,IAAI,CAACX,KAAK,CAACC,QAAQ,CAAC,EAAE;QACtC,OAAO,IAAI,CAACD,KAAK,CAACC,QAAQ;MAC5B;MAEA,IAAI,IAAI,CAACD,KAAK,CAACC,QAAO,IAAKW,OAAA,CAAO,IAAI,CAACZ,KAAK,CAACC,QAAO,MAAM,QAAQ,EAAE;QAClE,OAAOY,MAAM,CAACC,MAAM,CAAC,IAAI,CAACd,KAAK,CAACC,QAAQ,CAAC;MAC3C;MAEA,OAAO,EAAE;IACX,CAAC;IAEDc,iBAAiB,WAAjBA,iBAAiBA,CAAA,EAAG;MAClB,OAAO,IAAI,CAACN,aAAa,CAACO,MAAM,CAC9B,UAACb,KAAK,EAAEc,IAAI;QAAA,OAAKd,KAAI,GAAIe,MAAM,CAACD,IAAI,CAACE,GAAE,IAAK,CAAC,CAAC;MAAA,GAC9C,CACF,CAAC;IACH;EACF,CAAC;EACDC,OAAO,EAAE;IACPC,QAAQ,WAARA,QAAQA,CAAA,EAAG;MAAA,IAAAC,KAAA;MACT,IAAI,CAAC,IAAI,CAACjB,OAAO,EAAE;QACjBkB,KAAK,CAAC,gBAAgB,CAAC;QACvB,IAAI,CAACC,OAAO,CAACC,IAAI,CAAC,YAAY,CAAC;QAC/B;MACF;MAEA,IAAMC,GAAE,MAAAC,MAAA,CAAOC,OAAO,CAACC,GAAG,