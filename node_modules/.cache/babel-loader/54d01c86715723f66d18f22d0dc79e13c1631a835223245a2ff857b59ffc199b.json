productId) {\n      var _this3 = this;\n      this.isLoading = true;\n      userApi.addToCart(productId).then(function (res) {\n        alert(res.data.message || '已加入購物車');\n        if (res.data.success) {\n          _this3.getCart();\n          _this3.$router.push('/cart');\n        }\n      })[\"finally\"](function () {\n        _this3.isLoading = false;\n      });\n    },\n    toggleFavorite: function toggleFavorite(product) {\n      var index = this.favorites.findIndex(function (item) {\n        return item.id === product.id;\n      });\n      if (index === -1) {\n        this.favorites.push(product);\n      } else {\n        this.favorites.splice(index, 1);\n      }\n      localStorage.setItem('favorites', JSON.stringify(this.favorites));\n    },\n    isFavorite: function isFavorite(productId) {\n      return this.favorites.some(function (item) {\n        return item.id === productId;\n      });\n    }\n  },\n  mounted: function mounted() {\n    this.getProducts();\n    this.getCart();\n  }\n};","map":{"version":3,"names":["ProductCard","userApi","name","components","data","products","favorites","JSON","parse","localStorage","getItem","cart","carts","total","final_total","isLoading","computed","cartCount","reduce","item","Number","qty","methods","getProducts","_this","then","res","getCart","_this2","addToCart","productId","_this3","alert","message","success","$router","push","toggleFavorite","product","index","findIndex","id","splice","setItem","stringify","isFavorite","some","mounted"],"sources":["C:\\Users\\ROG Strix\\Desktop\\vue cli\\gui-demo\\src\\views\\Products.vue"],"sourcesContent":["<!-- eslint-disable import/extensions -->\n<!-- eslint-disable vue/no-multiple-template-root -->\n<template>\n  <Loading :active=\"isLoading\"></Loading>\n\n  <main class=\"products-page\">\n    <section class=\"products-hero\">\n      <div class=\"container\">\n        <div class=\"products-hero-card\">\n          <div>\n            <span class=\"hero-badge\">線上課程商城</span>\n            <h1 class=\"fw-bold mt-3 mb-3\">\n              探索適合你的課程，開始累積作品集能力\n            </h1>\n            <p class=\"text-muted mb-0\">\n              精選前端開發、API 串接、後台管理與響應式網頁課程，幫助你從學習走向實作。\n            </p>\n          </div>\n\n          <div class=\"hero-actions\">\n            <!-- 購物車 Icon 按鈕 -->\n            <router-link\n              to=\"/cart\"\n              class=\"cart-icon-btn\"\n              title=\"查看購物車\"\n            >\n              <i class=\"bi bi-cart3\"></i>\n              <span\n                v-if=\"cartCount > 0\"\n                class=\"cart-badge\"\n              >\n                {{ cartCount }}\n              </span>\n            </router-link>\n\n            <router-link to=\"/favorite\" class=\"btn btn-outline-danger btn-lg\">\n              <i class=\"bi bi-heart me-1\"></i>\n              我的最愛\n            </router-link>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    <section class=\"container py-5\">\n      <div class=\"coupon-alert mb-5\">\n        <div>\n          <h5 class=\"fw-bold mb-1\">限時學習優惠</h5>\n          <p class=\"mb-0\">\n            結帳輸入優惠碼\n            <strong class=\"text-danger\">COURSE88</strong>\n            ，享課程折扣優惠。\n          </p>\n        </div>\n        <i class=\"bi bi-ticket-perforated coupon-icon\"></i>\n      </div>\n\n      <div class=\"section-heading mb-4\">\n        <div>\n          <h2 class=\"fw-bold mb-2\">熱門課程</h2>\n          <p class=\"text-muted mb-0\">\n            選擇一門課程，開始打造可以放進履歷的專案能力。\n          </p>\n        </div>\n      </div>\n\n      <div class=\"row g-4\" v-if=\"products.length\">\n        <div\n          class=\"col-12 col-md-6 col-lg-4\"\n          v-for=\"item in products\"\n          :key=\"item.id\"\n        >\n          <ProductCard\n            :product=\"item\"\n            :is-favorite=\"isFavorite(item.id)\"\n            @toggle-favorite=\"toggleFavorite\"\n            @add-cart=\"addToCart\"\n          />\n        </div>\n      </div>\n\n      <div v-else-if=\"!isLoading\" class=\"empty-products mt-4\">\n        <i class=\"bi bi-journal-bookmark\"></i>\n        <h5 class=\"fw-bold mt-3 mb-2\">目前尚無課程資料</h5>\n        <p class=\"text-muted mb-0\">\n          請稍後再回來查看最新課程。\n        </p>\n      </div>\n    </section>\n  </main>\n</template>\n\n<script>\nimport ProductCard from '@/components/ProductCard.vue';\nimport userApi from '@/api/userApi';\n\nexport default {\n  name: 'ProductsView',\n  components: {\n    ProductCard,\n  },\n  data() {\n    return {\n      products: [],\n      favorites: JSON.parse(localStorage.getItem('favorites')) || [],\n      cart: {\n        carts: [],\n        total: 0,\n        final_total: 0,\n      },\n      isLoading: false,\n    };\n  },\n  computed: {\n    cartCount() {\n      if (!this.cart.carts) {\n        return 0;\n      }\n\n      return this.cart.carts.reduce((total, item) => total + Number(item.qty || 0), 0);\n    },\n  },\n  methods: {\n    getProducts() {\n      this.isLoading = true;\n\n      userApi.getProducts()\n        .then((res) => {\n          this.products = res.data.products || [];\n        })\n        .finally(() => {\n          this.isLoading = false;\n        });\n    },\n\n    getCart() {\n      userApi.getCart()\n        .then((res) => {\n          this.cart = res.data.data || {\n            carts: [],\n            total: 0,\n            final_total: 0,\n          };\n        });\n    },\n\n    addToCart(productId) {\n      this.isLoading = true;\n\n      userApi.addToCart(productId)\n        .then((res) => {\n          alert(res.data.message || '已加入購物車');\n\n          if (res.data.success) {\n            this.getCart();\n            this.$router.push('/cart');\n          }\n        })\n        .finally(() => {\n          this.isLoading = false;\n        });\n    },\n\n    toggleFavorite(product) {\n      const index = this.favorites.findIndex((item) => item.id === product.id);\n\n      if (index === -1) {\n        this.favorites.push(product);\n      } else {\n        this.favorites.splice(index, 1);\n      }\n\n      localStorage.setItem('favorites', JSON.stringify(this.favorites));\n    },\n\n    isFavorite(productId) {\n      return this.favorites.some((item) => item.id === productId);\n    },\n  },\n  mounted() {\n    this.getProducts();\n    this.getCart();\n  },\n};\n</script>\n\n<style scoped>\n.products-page {\n  min-height: 100vh;\n  background: linear-gradient(180deg, #f5f8ff 0%, #ffffff 42%, #f8f9fa 100%);\n}\n\n.products-hero {\n  padding: 56px 0 24px;\n}\n\n.products-hero-card {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  gap: 32px;\n  padding: 42px;\n  border-radius: 32px;\n  background:\n    linear-gradient(135deg, rgba(13, 110, 253, 0.13), rgba(255, 255, 255, 0.95)),\n    #ffffff;\n  box-shadow: 0 18px 45px rgba(30, 60, 120, 0.12);\n}\n\n.products-hero-card h1 {\n  max-width: 720px;\n  font-size: 40px;\n  line-height: 1.35;\n}\n\n.products-hero-card p {\n  max-width: 680px;\n  font-size: 17px;\n  line-height: 1.8;\n}\n\n.hero-badge {\n  display: inline-block;\n  padding: 8px 14px;\n  border-radius: 999px;\n  color: #0d6efd;\n  background: #eaf2ff;\n  font-weight: 700;\n}\n\n.hero-actions {\n  display: flex;\n  align-items: center;\n  gap: 12px;\n  flex-shrink: 0;\n}\n\n.cart-icon-btn {\n  position: relative;\n  width: 58px;\n  height: 58px;\n  border-radius: 50%;\n  display: inline-flex;\n  align-items: center;\n  justify-content: center;\n  color: #ffffff;\n  background: #0d6efd;\n  text-decoration: none;\n  box-shadow: 0 12px 28px rgba(13, 110, 253, 0.28);\n  transition: transform 0.2s ease, box-shadow 0.2s ease;\n}\n\n.cart-icon-btn:hover {\n  color: #ffffff;\n  transform: translateY(-3px);\n  box-shadow: 0 16px 34px rgba(13, 110, 253, 0.36);\n}\n\n.cart-icon-btn i {\n  font-size: 26px;\n}\n\n.cart-badge {\n  position: absolute;\n  top: -6px;\n  right: -6px;\n  min-width: 24px;\n  height: 24px;\n  padding: 0 6px;\n  border-radius: 999px;\n  background: #dc3545;\n  color: #ffffff;\n  font-size: 13px;\n  font-weight: 800;\n  display: inline-flex;\n  align-items: center;\n  justify-content: center;\n  border: 2px solid #ffffff;\n}\n\n.coupon-alert {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  gap: 24px;\n  padding: 24px 28px;\n  border-radius: 24px;\n  background: #fff8e1;\n  border: 1px solid #ffe4a3;\n  box-shadow: 0 12px 30px rgba(130, 96, 20, 0.08);\n}\n\n.coupon-alert p {\n  color: #6c757d;\n}\n\n.coupon-icon {\n  font-size: 42px;\n  color: #f0ad00;\n}\n\n.section-heading {\n  display: flex;\n  justify-content: space-between;\n  align-items: end;\n}\n\n.empty-products {\n  padding: 48px 20px;\n  border-radius: 24px;\n  text-align: center;\n  color: #6c757d;\n  background: #ffffff;\n  border: 1px dashed #d8dee8;\n}\n\n.empty-products i {\n  font-size: 42px;\n  color: #adb5bd;\n}\n\n@media (max-width: 991px) {\n  .products-hero-card {\n    flex-direction: column;\n    align-items: flex-start;\n  }\n\n  .hero-actions {\n    width: 100%;\n  }\n\n  .hero-actions .btn {\n    flex: 1;\n  }\n}\n\n@media (max-width: 768px) {\n  .products-hero {\n    padding: 32px 0 16px;\n  }\n\n  .products-hero-card {\n    padding: 28px 22px;\n    border-radius: 24px;\n  }\n\n  .products-hero-card h1 {\n    font-size: 28px;\n  }\n\n  .products-hero-card p {\n    font-size: 15px;\n  }\n\n  .hero-actions {\n    width: 100%;\n    justify-content: space-between;\n  }\n\n  .hero-actions .btn {\n    flex: 1;\n  }\n\n  .cart-icon-btn {\n    width: 52px;\n    height: 52px;\n    flex: 0 0 52px;\n  }\n\n  .coupon-alert {\n    align-items: flex-start;\n    padding: 20px;\n  }\n\n  .coupon-icon {\n    display: none;\n  }\n}\n</style>"],"mappings":";;;;;;;;;;;;;;AA6FA,OAAOA,WAAU,MAAO,8BAA8B;AACtD,OAAOC,OAAM,MAAO,eAAe;AAEnC,eAAe;EACbC,IAAI,EAAE,cAAc;EACpBC,UAAU,EAAE;IACVH,WAAW,EAAXA;EACF,CAAC;EACDI,IAAI,WAAJA,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,QAAQ,EAAE,EAAE;MACZC,SAAS,EAAEC,IAAI,CAACC,KAAK,CAACC,YAAY,CAACC,OAAO,CAA