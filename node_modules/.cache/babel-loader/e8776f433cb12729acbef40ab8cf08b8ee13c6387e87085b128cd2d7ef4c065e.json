this;\n      this.isLoading = true;\n      this.$http.get(\"\".concat(VUE_APP_API, \"/api/\").concat(VUE_APP_PATH, \"/products/all\")).then(function (res) {\n        _this2.products = res.data.products || [];\n        _this2.currentPage = 1;\n      })[\"finally\"](function () {\n        _this2.isLoading = false;\n      });\n    },\n    changeCategory: function changeCategory(category) {\n      this.selectedCategory = category;\n      this.currentPage = 1;\n    },\n    changePage: function changePage(page) {\n      if (page < 1 || page > this.totalPages) {\n        return;\n      }\n      this.currentPage = page;\n      window.scrollTo({\n        top: 0,\n        behavior: 'smooth'\n      });\n    },\n    addToCart: function addToCart(id) {\n      var _this3 = this;\n      var qty = arguments.length > 1 && arguments[1] !== undefined ? arguments[1] : 1;\n      var data = {\n        product_id: id,\n        qty: qty\n      };\n      this.isLoading = true;\n      this.$http.post(\"\".concat(VUE_APP_API, \"/api/\").concat(VUE_APP_PATH, \"/cart\"), {\n        data: data\n      }).then(function () {\n        alert('已加入購物車');\n      })[\"finally\"](function () {\n        _this3.isLoading = false;\n      });\n    },\n    toggleFavorite: function toggleFavorite(item) {\n      var index = this.favorites.findIndex(function (food) {\n        return food.id === item.id;\n      });\n      if (index === -1) {\n        this.favorites.push(item);\n      } else {\n        this.favorites.splice(index, 1);\n      }\n      localStorage.setItem('favoriteFoods', JSON.stringify(this.favorites));\n    },\n    isFavorite: function isFavorite(id) {\n      return this.favorites.some(function (item) {\n        return item.id === id;\n      });\n    }\n  },\n  mounted: function mounted() {\n    this.getProducts();\n  }\n};","map":{"version":3,"names":["_process$env","process","env","VUE_APP_API","VUE_APP_PATH","data","products","favorites","JSON","parse","localStorage","getItem","selectedCategory","isLoading","defaultImage","cartQty","currentPage","perPage","computed","filteredProducts","_this","filter","item","category","totalPages","Math","ceil","length","pagedProducts","start","end","slice","methods","getProducts","_this2","$http","get","concat","then","res","changeCategory","changePage","page","window","scrollTo","top","behavior","addToCart","id","_this3","qty","arguments","undefined","product_id","post","alert","toggleFavorite","index","findIndex","food","push","splice","setItem","stringify","isFavorite","some","mounted"],"sources":["C:\\Users\\ROG Strix\\Desktop\\vue cli\\gui-demo\\src\\views\\UserProduct.vue"],"sourcesContent":["<!-- eslint-disable vue/no-multiple-template-root -->\n<template>\n  <Loading :active=\"isLoading\" />\n\n  <div class=\"container py-5\">\n    <div class=\"page-header mb-4\">\n      <span class=\"badge bg-danger mb-3\">人氣日韓料理訂購</span>\n      <h1 class=\"fw-bold\">今天想吃日式還是韓式？</h1>\n      <p class=\"text-muted mb-0\">\n        精選主廚推薦料理，支援收藏、加入購物車與優惠券折抵。\n      </p>\n    </div>\n\n    <div class=\"coupon-box mb-4\">\n      <div>\n        <h5 class=\"fw-bold mb-1\">限時優惠券</h5>\n        <p class=\"mb-0 text-muted\">\n          輸入優惠碼 <strong>JPKR100</strong>，滿 699 現折 100 元。\n        </p>\n      </div>\n\n      <router-link to=\"/user/cart\" class=\"btn btn-danger\">\n        前往購物車使用\n      </router-link>\n    </div>\n\n    <div class=\"category-tabs mb-4\">\n      <button\n        class=\"btn\"\n        :class=\"selectedCategory === '全部' ? 'btn-dark' : 'btn-outline-dark'\"\n        @click=\"changeCategory('全部')\"\n      >\n        全部\n      </button>\n\n      <button\n        class=\"btn\"\n        :class=\"selectedCategory === '日式料理' ? 'btn-danger' : 'btn-outline-danger'\"\n        @click=\"changeCategory('日式料理')\"\n      >\n        日式料理\n      </button>\n\n      <button\n        class=\"btn\"\n        :class=\"selectedCategory === '韓式料理' ? 'btn-warning' : 'btn-outline-warning'\"\n        @click=\"changeCategory('韓式料理')\"\n      >\n        韓式料理\n      </button>\n    </div>\n\n    <div class=\"d-flex justify-content-between align-items-center mb-3\">\n      <p class=\"text-muted mb-0\">\n        共 {{ filteredProducts.length }} 道料理，\n        目前第 {{ currentPage }} / {{ totalPages }} 頁\n      </p>\n\n      <p class=\"text-muted mb-0\">\n        每頁顯示 {{ perPage }} 道\n      </p>\n    </div>\n\n    <div class=\"row g-4\">\n      <div\n        v-for=\"item in pagedProducts\"\n        :key=\"item.id\"\n        class=\"col-md-6 col-lg-4\"\n      >\n        <div class=\"food-card\">\n          <div\n            class=\"food-img\"\n            :style=\"{ backgroundImage: `url(${item.imageUrl || defaultImage})` }\"\n          >\n            <button class=\"favorite-btn\" @click=\"toggleFavorite(item)\">\n              {{ isFavorite(item.id) ? '❤️' : '🤍' }}\n            </button>\n          </div>\n\n          <div class=\"p-4\">\n            <div class=\"d-flex justify-content-between align-items-center mb-2\">\n              <span class=\"badge bg-light text-dark\">\n                {{ item.category }}\n              </span>\n              <small class=\"text-muted\">已售出 {{ item.num || 0 }} 份</small>\n            </div>\n\n            <h5 class=\"fw-bold mb-2\">\n              {{ item.title }}\n            </h5>\n\n            <p class=\"text-muted food-desc\">\n              {{ item.description || item.content }}\n            </p>\n\n            <div class=\"mb-3\">\n              <del class=\"text-muted me-2\">\n                NT$ {{ item.origin_price }}\n              </del>\n              <span class=\"h5 text-danger fw-bold\">\n                NT$ {{ item.price }}\n              </span>\n            </div>\n\n           <div class=\"input-group input-group-sm mb-3\">\n              <button\n                type=\"button\"\n                class=\"btn btn-outline-secondary\"\n                @click=\"decreaseQty(item.id)\"\n              >\n                -\n              </button>\n\n              <input\n                type=\"number\"\n                class=\"form-control text-center\"\n                min=\"1\"\n                v-model.number=\"cartQty[item.id]\"\n              >\n\n              <button\n                type=\"button\"\n                class=\"btn btn-outline-secondary\"\n                @click=\"increaseQty(item.id)\"\n              >\n                +\n              </button>\n\n              <span class=\"input-group-text\">\n                {{ item.unit || '份' }}\n              </span>\n            </div>\n\n            <div class=\"d-flex gap-2\">\n              <router-link\n                :to=\"`/product/${item.id}`\"\n                class=\"btn btn-outline-dark flex-fill\"\n              >\n                查看詳情\n              </router-link>\n\n              <button\n                type=\"button\"\n                class=\"btn btn-danger flex-fill\"\n                @click=\"addToCart(item.id)\"\n              >\n                加入購物車\n              </button>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n\n    <div v-if=\"!filteredProducts.length\" class=\"text-center py-5 text-muted\">\n      目前沒有符合的料理。\n    </div>\n\n    <!-- 頁碼 -->\n    <nav\n      v-if=\"totalPages > 1\"\n      class=\"mt-5 d-flex justify-content-center\"\n      aria-label=\"料理頁碼\"\n    >\n      <ul class=\"pagination pagination-lg\">\n        <li class=\"page-item\" :class=\"{ disabled: currentPage === 1 }\">\n          <button\n            class=\"page-link\"\n            type=\"button\"\n            @click=\"changePage(currentPage - 1)\"\n          >\n            上一頁\n          </button>\n        </li>\n\n        <li\n          v-for=\"page in totalPages\"\n          :key=\"page\"\n          class=\"page-item\"\n          :class=\"{ active: currentPage === page }\"\n        >\n          <button\n            class=\"page-link\"\n            type=\"button\"\n            @click=\"changePage(page)\"\n          >\n            {{ page }}\n          </button>\n        </li>\n\n        <li class=\"page-item\" :class=\"{ disabled: currentPage === totalPages }\">\n          <button\n            class=\"page-link\"\n            type=\"button\"\n            @click=\"changePage(currentPage + 1)\"\n          >\n            下一頁\n          </button>\n        </li>\n      </ul>\n    </nav>\n  </div>\n</template>\n\n<script>\nconst { VUE_APP_API, VUE_APP_PATH } = process.env;\n\nexport default {\n  data() {\n    return {\n      products: [],\n      favorites: JSON.parse(localStorage.getItem('favoriteFoods')) || [],\n      selectedCategory: '全部',\n      isLoading: false,\n      defaultImage: 'https://images.unsplash.com/photo-1546069901-ba9599a7e63c?w=800',\n\n      // 數量設定\n      cartQty: {},\n\n      // 分頁設定\n      currentPage: 1,\n      perPage: 10,\n    };\n  },\n  computed: {\n    filteredProducts() {\n      if (this.selectedCategory === '全部') {\n        return this.products;\n      }\n\n      return this.products.filter((item) => item.category === this.selectedCategory);\n    },\n\n    totalPages() {\n      return Math.ceil(this.filteredProducts.length / this.perPage) || 1;\n    },\n\n    pagedProducts() {\n      const start = (this.currentPage - 1) * this.perPage;\n      const end = start + this.perPage;\n\n      return this.filteredProducts.slice(start, end);\n    },\n  },\n  methods: {\n    getProducts() {\n      this.isLoading = true;\n\n      this.$http\n        .get(`${VUE_APP_API}/api/${VUE_APP_PATH}/products/all`)\n        .then((res) => {\n          this.products = res.data.products || [];\n          this.currentPage = 1;\n        })\n        .finally(() => {\n          this.isLoading = false;\n        });\n    },\n\n    changeCategory(category) {\n      this.selectedCategory = category;\n      this.currentPage = 1;\n    },\n\n    changePage(page) {\n      if (page < 1 || page > this.totalPages) {\n        return;\n      }\n\n      this.currentPage = page;\n      window.scrollTo({\n        top: 0,\n        behavior: 'smooth',\n      });\n    },\n\n    addToCart(id, qty = 1) {\n      const data = {\n        product_id: id,\n        qty,\n      };\n\n      this.isLoading = true;\n\n      this.$http\n        .post(`${VUE_APP_API}/api/${VUE_APP_PATH}/cart`, { data })\n        .then(() => {\n          alert('已加入購物車');\n        })\n        .finally(() => {\n          this.isLoading = false;\n        });\n    },\n\n    toggleFavorite(item) {\n      const index = this.favorites.findIndex((food) => food.id === item.id);\n\n      if (index === -1) {\n        this.favorites.push(item);\n      } else {\n        this.favorites.splice(index, 1);\n      }\n\n      localStorage.setItem('favoriteFoods', JSON.stringify(this.favorites));\n    },\n\n    isFavorite(id) {\n      return this.favorites.some((item) => item.id === id);\n    },\n  },\n  mounted() {\n    this.getProducts();\n  },\n};\n</script>\n\n<style scoped>\n.page-header {\n  padding: 36px;\n  border-radius: 28px;\n  background: linear-gradient(135deg, #fff4ec, #ffffff);\n  border: 1px solid #f2dfd0;\n}\n\n.coupon-box {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  gap: 16px;\n  padding: 24px;\n  border-radius: 22px;\n  background: #fff8e8;\n  border: 1px dashed #d39b37;\n}\n\n.category-tabs {\n  display: flex;\n  flex-wrap: wrap;\n  gap: 12px;\n}\n\n.food-card {\n  height: 100%;\n  overflow: hidden;\n  border-radius: 24px;\n  background: #fff;\n  border: 1px solid #eee;\n  box-shadow: 0 14px 32px rgba(0, 0, 0, 0.08);\n  transition: transform 0.25s ease, box-shadow 0.25s ease;\n}\n\n.food-card:hover {\n  transform: translateY(-6px);\n  box-shadow: 0 20px 46px rgba(0, 0, 0, 0.12);\n}\n\n.food-img {\n  position: relative;\n  height: 230px;\n  background-size: cover;\n  background-position: center;\n}\n\n.favorite-btn {\n  position: absolute;\n  top: 16px;\n  right: 16px;\n  width: 44px;\n  height: 44px;\n  border: 0;\n  border-radius: 50%;\n  background: #fff;\n  box-shadow: 0 8px 18px rgba(0, 0, 0, 0.18);\n}\n\n.food-desc {\n  min-height: 48px;\n}\n\n.pagination .page-link {\n  color: #b23a2e;\n  font-weight: 700;\n}\n\n.pagination .active .page-link {\n  color: #fff;\n  background-color: #b23a2e;\n  border-color: #b23a2e;\n}\n\n.pagination .page-link:focus {\n  box-shadow: 0 0 0 0.2rem rgba(178, 58, 46, 0.18);\n}\n\n@media (max-width: 768px) {\n  .coupon-box {\n    flex-direction: column;\n    align-items: flex-start;\n  }\n\n  .coupon-box .btn {\n    width: 100%;\n  }\n\n  .pagination {\n    flex-wrap: wrap;\n    gap: 6px;\n  }\n}\n</style>"],"mappings":";;;;;;;;;;;;;;;AA6MA,IAAAA,YAAA,GAAsCC,OAAO,CAACC,GAAG;EAAzCC,WAAW,GAAAH,YAAA,CAAXG,WAAW;EAAEC,YAAW,GAAAJ,YAAA,CAAXI,YAAW;AAEhC,eAAe;EACbC,IAAI,WAAJA,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,QAAQ,EAAE,EAAE;MACZC,SAAS,EAAEC,IAAI,CAACC,KAAK,CAACC,YAAY,CAACC,OAAO,CAAC,eAAe,CAAC,KAAK,EAAE;MAClEC,gBAAgB,EAAE,IAAI;MACtBC,SAAS,EAAE,KAAK;MAChBC,YAAY,EAAE,iEAAiE;MAE/E;MACAC,OAAO,EAAE,CAAC,CAAC;MAEX;MACAC,WAAW,EAAE,CAAC;MACdC,OAAO,EAAE;IACX,CAAC;EACH,CAAC;EACDC,QAAQ,EAAE;IACRC,gBAAgB,WAAhBA,gBAAgBA,CAAA,EAAG;MAAA,IAAAC,KAAA;MACjB,IAAI,IAAI,CAACR,gBAAe,KAAM,IAAI,EAAE;QAClC,OAAO,IAAI,CAACN,QAAQ;MACtB;MAEA,OAAO,IAAI,CAACA,QAAQ,CAACe,MAAM,CAAC,UAACC,IAAI;QAAA,OAAKA,IAAI,CAACC,QAAO,KAAMH,KAAI,CAACR,gBAAgB;MAAA,EAAC;IAChF,CAAC;IAEDY,UAAU,WAAVA,UAAUA,CAAA,EAAG;MACX,OAAOC,IAAI,CAACC,IAAI,CAAC,IAAI,CAACP,gBAAgB,CAACQ,MAAK,GAAI,IAAI,CAACV,OAAO,KAAK,CAAC;IACpE,CAAC;IAEDW,aAAa,WAAbA,aAAaA,CAAA,EAAG;MACd,IAAMC,KAAI,GAAI,CAAC,IAAI,CAACb,WAAU,GAAI,CAAC,IAAI,IAAI,CAACC,OAAO;MACnD,IAAMa,GAAE,GAAID,KAAI,GAAI,IAAI,CAACZ,OAAO;MAEhC,OAAO,IAAI,CAACE,gBAAgB,CAACY,KAAK,CAACF,KAAK,EAAEC,GAAG,CAAC;IAChD;EACF,CAAC;EACDE,OAAO,EAAE;IACPC,WAAW,WAAXA,WAAWA,CAAA,EAAG;MAAA,IAAAC,MAAA;MACZ,IAAI,CAACrB,SAAQ,GAAI,IAAI;MAErB,IAAI,CAACsB,KAAI,CACNC,GAAG,IAAAC,MAAA,CAAIlC,WAAW,WAAAkC,MAAA,CAAQjC,YAAY,kBAAe,EACrDkC,IAAI,CAAC,UAACC,GAAG,EAAK;QACbL,MAAI,CAAC5B,QAAO,GAAIiC,GAAG,CAAClC,IAAI,CAACC,QAAO,IAAK,EAAE;QACvC4B,MAAI,CAAClB,WAAU,G