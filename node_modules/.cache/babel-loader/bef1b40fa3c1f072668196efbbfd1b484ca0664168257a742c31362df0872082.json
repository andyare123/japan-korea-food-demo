   return result;\n    }\n  },\n  methods: {\n    getProducts: function getProducts() {\n      var _this2 = this;\n      var url = \"\".concat(VUE_APP_API, \"/api/\").concat(VUE_APP_PATH, \"/admin/products/all\");\n      this.isLoading = true;\n      this.$http.get(url).then(function (res) {\n        _this2.products = res.data.products || [];\n      })[\"finally\"](function () {\n        _this2.isLoading = false;\n      });\n    },\n    openModal: function openModal(isNew, item) {\n      this.isNew = isNew;\n      if (isNew) {\n        this.tempProduct = {\n          title: '',\n          category: '日式料理',\n          origin_price: 0,\n          price: 0,\n          unit: '份',\n          description: '',\n          content: '',\n          imageUrl: '',\n          is_enabled: 1\n        };\n      } else {\n        this.tempProduct = _objectSpread({}, item);\n      }\n      this.productModal.show();\n    },\n    hideModal: function hideModal() {\n      this.productModal.hide();\n    },\n    openDelModal: function openDelModal(item) {\n      this.tempProduct = _objectSpread({}, item);\n      this.delModal.show();\n    },\n    hideDelModal: function hideDelModal() {\n      this.delModal.hide();\n    },\n    updateProduct: function updateProduct() {\n      var _this3 = this;\n      if (!this.tempProduct.title) {\n        alert('請輸入料理名稱');\n        return;\n      }\n      var productData = {\n        title: this.tempProduct.title,\n        category: this.tempProduct.category || '日式料理',\n        origin_price: Number(this.tempProduct.origin_price) || 0,\n        price: Number(this.tempProduct.price) || 0,\n        unit: this.tempProduct.unit || '份',\n        description: this.tempProduct.description || '',\n        content: this.tempProduct.content || '',\n        imageUrl: this.tempProduct.imageUrl || '',\n        is_enabled: Number(this.tempProduct.is_enabled) || 0\n      };\n      var url = \"\".concat(VUE_APP_API, \"/api/\").concat(VUE_APP_PATH, \"/admin/product\");\n      var httpMethod = 'post';\n      if (!this.isNew) {\n        url = \"\".concat(VUE_APP_API, \"/api/\").concat(VUE_APP_PATH, \"/admin/product/\").concat(this.tempProduct.id);\n        httpMethod = 'put';\n      }\n      console.log('儲存料理 API:', url);\n      console.log('儲存料理資料:', productData);\n      this.isLoading = true;\n      this.$http[httpMethod](url, {\n        data: productData\n      }).then(function (res) {\n        console.log('儲存料理回傳:', res.data);\n        _this3.$httpMessageState(res, _this3.isNew ? '新增料理' : '更新料理');\n        if (res.data.success) {\n          alert(_this3.isNew ? '新增料理成功' : '更新料理成功');\n          _this3.hideModal();\n          _this3.getProducts();\n        } else {\n          alert(res.data.message || '儲存失敗');\n        }\n      })[\"catch\"](function (error) {\n        console.error('儲存料理失敗:', error);\n        if (error.response) {\n          console.log('錯誤狀態:', error.response.status);\n          console.log('錯誤內容:', error.response.data);\n          alert(error.response.data.message || \"\\u5132\\u5B58\\u5931\\u6557\\uFF0C\\u72C0\\u614B\\u78BC\\uFF1A\".concat(error.response.status));\n        } else {\n          alert('儲存失敗，請查看 console 錯誤訊息');\n        }\n      })[\"finally\"](function () {\n        _this3.isLoading = false;\n      });\n    },\n    deleteProduct: function deleteProduct() {\n      var _this4 = this;\n      var url = \"\".concat(VUE_APP_API, \"/api/\").concat(VUE_APP_PATH, \"/admin/product/\").concat(this.tempProduct.id);\n      this.isLoading = true;\n      this.$http[\"delete\"](url).then(function (res) {\n        _this4.$httpMessageState(res, '刪除料理');\n        if (res.data.success) {\n          _this4.hideDelModal();\n          _this4.getProducts();\n        }\n      })[\"finally\"](function () {\n        _this4.isLoading = false;\n      });\n    },\n    resetFilter: function resetFilter() {\n      this.selectedCategory = '全部';\n      this.keyword = '';\n    }\n  },\n  mounted: function mounted() {\n    var token = document.cookie.replace(/(?:(?:^|.*;\\s*)hexToken\\s*=\\s*([^;]*).*$)|^.*$/, '$1');\n    if (!token) {\n      alert('請先登入後台');\n      this.$router.push('/login');\n      return;\n    }\n    this.$http.defaults.headers.common.Authorization = token;\n    this.productModal = new Modal(this.$refs.productModal);\n    this.delModal = new Modal(this.$refs.delModal);\n    this.getProducts();\n  }\n};","map":{"version":3,"names":["Modal","_process$env","process","env","VUE_APP_API","VUE_APP_PATH","name","data","products","tempProduct","isNew","isLoading","productModal","delModal","selectedCategory","keyword","defaultImage","computed","filteredProducts","_this","result","filter","item","category","toLowerCase","text","title","description","content","join","includes","methods","getProducts","_this2","url","concat","$http","get","then","res","openModal","origin_price","price","unit","imageUrl","is_enabled","_objectSpread","show","hideModal","hide","openDelModal","hideDelModal","updateProduct","_this3","alert","productData","Number","httpMethod","id","console","log","$httpMessageState","success","message","error","response","status","deleteProduct","_this4","resetFilter","mounted","token","document","cookie","replace","$router","push","defaults","headers","common","Authorization","$refs"],"sources":["C:\\Users\\ROG Strix\\Desktop\\vue cli\\gui-demo\\src\\views\\Products.vue"],"sourcesContent":["<!-- eslint-disable vue/no-multiple-template-root -->\n<template>\n  <Loading :active=\"isLoading\"></Loading>\n\n  <div class=\"admin-food-page\">\n    <div class=\"container py-5\">\n      <div class=\"admin-header mb-4\">\n        <div>\n          <span class=\"badge bg-danger mb-3\">後台管理</span>\n          <h1 class=\"fw-bold mb-2\">料理商品管理</h1>\n          <p class=\"text-muted mb-0\">\n            管理日式料理與韓式料理商品，可新增、編輯、刪除與設定是否啟用。\n          </p>\n        </div>\n\n        <button\n          type=\"button\"\n          class=\"btn btn-danger btn-lg\"\n          @click=\"openModal(true)\"\n        >\n          新增料理\n        </button>\n      </div>\n\n      <div class=\"filter-card mb-4\">\n        <div class=\"row g-3 align-items-end\">\n          <div class=\"col-md-4\">\n            <label class=\"form-label fw-bold\">分類篩選</label>\n            <select v-model=\"selectedCategory\" class=\"form-select\">\n              <option value=\"全部\">全部料理</option>\n              <option value=\"日式料理\">日式料理</option>\n              <option value=\"韓式料理\">韓式料理</option>\n            </select>\n          </div>\n\n          <div class=\"col-md-5\">\n            <label class=\"form-label fw-bold\">搜尋料理</label>\n            <input\n              v-model.trim=\"keyword\"\n              type=\"text\"\n              class=\"form-control\"\n              placeholder=\"輸入料理名稱、分類或文案\"\n            >\n          </div>\n\n          <div class=\"col-md-3\">\n            <button\n              type=\"button\"\n              class=\"btn btn-outline-secondary w-100\"\n              @click=\"resetFilter\"\n            >\n              清除篩選\n            </button>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"table-card\">\n        <div class=\"table-responsive\">\n          <table class=\"table align-middle mb-0\">\n            <thead>\n              <tr>\n                <th width=\"120\">圖片</th>\n                <th>料理資訊</th>\n                <th width=\"120\">分類</th>\n                <th width=\"120\">原價</th>\n                <th width=\"120\">售價</th>\n                <th width=\"100\">狀態</th>\n                <th width=\"180\" class=\"text-end\">操作</th>\n              </tr>\n            </thead>\n\n            <tbody>\n              <tr v-for=\"item in filteredProducts\" :key=\"item.id\">\n                <td>\n                  <div\n                    class=\"food-thumb\"\n                    :style=\"{ backgroundImage: `url(${item.imageUrl || defaultImage})` }\"\n                  ></div>\n                </td>\n\n                <td>\n                  <h6 class=\"fw-bold mb-1\">\n                    {{ item.title }}\n                  </h6>\n                  <p class=\"text-muted small mb-0 food-description\">\n                    {{ item.description || item.content || '尚未填寫料理文案' }}\n                  </p>\n                </td>\n\n                <td>\n                  <span\n                    class=\"badge\"\n                    :class=\"item.category === '韓式料理' ? 'bg-warning text-dark' : 'bg-danger'\"\n                  >\n                    {{ item.category || '未分類' }}\n                  </span>\n                </td>\n\n                <td>\n                  {{ $filters.currency(item.origin_price) }}\n                </td>\n\n                <td class=\"text-danger fw-bold\">\n                  {{ $filters.currency(item.price) }}\n                </td>\n\n                <td>\n                  <span v-if=\"item.is_enabled\" class=\"text-success fw-bold\">\n                    啟用\n                  </span>\n                  <span v-else class=\"text-muted\">\n                    未啟用\n                  </span>\n                </td>\n\n                <td class=\"text-end\">\n                  <div class=\"btn-group\">\n                    <button\n                      type=\"button\"\n                      class=\"btn btn-outline-dark btn-sm\"\n                      @click=\"openModal(false, item)\"\n                    >\n                      編輯\n                    </button>\n\n                    <button\n                      type=\"button\"\n                      class=\"btn btn-outline-danger btn-sm\"\n                      @click=\"openDelModal(item)\"\n                    >\n                      刪除\n                    </button>\n                  </div>\n                </td>\n              </tr>\n            </tbody>\n          </table>\n        </div>\n\n        <div\n          v-if=\"!filteredProducts.length && !isLoading\"\n          class=\"empty-box text-center\"\n        >\n          目前沒有符合條件的料理商品。\n        </div>\n      </div>\n    </div>\n\n    <!-- 新增 / 編輯 Modal -->\n    <div\n      ref=\"productModal\"\n      class=\"modal fade\"\n      tabindex=\"-1\"\n      aria-hidden=\"true\"\n    >\n      <div class=\"modal-dialog modal-xl modal-dialog-centered\">\n        <div class=\"modal-content rounded-4\">\n          <div class=\"modal-header\">\n            <h5 class=\"modal-title fw-bold\">\n              {{ isNew ? '新增料理商品' : '編輯料理商品' }}\n            </h5>\n            <button\n              type=\"button\"\n              class=\"btn-close\"\n              @click=\"hideModal\"\n            ></button>\n          </div>\n\n          <div class=\"modal-body\">\n            <div class=\"row g-4\">\n              <div class=\"col-md-4\">\n                <label class=\"form-label fw-bold\">圖片網址</label>\n                <input\n                  v-model=\"tempProduct.imageUrl\"\n                  type=\"text\"\n                  class=\"form-control mb-3\"\n                  placeholder=\"請輸入圖片網址\"\n                >\n\n                <div\n                  v-if=\"tempProduct.imageUrl\"\n                  class=\"preview-img\"\n                  :style=\"{ backgroundImage: `url(${tempProduct.imageUrl})` }\"\n                ></div>\n\n                <div v-else class=\"preview-empty\">\n                  尚未輸入圖片\n                </div>\n              </div>\n\n              <div class=\"col-md-8\">\n                <div class=\"row g-3\">\n                  <div class=\"col-md-6\">\n                    <label class=\"form-label fw-bold\">料理名稱</label>\n                    <input\n                      v-model=\"tempProduct.title\"\n                      type=\"text\"\n                      class=\"form-control\"\n                      placeholder=\"例如：炙燒鮭魚握壽司套餐\"\n                    >\n                  </div>\n\n                  <div class=\"col-md-6\">\n                    <label class=\"form-label fw-bold\">分類</label>\n                    <select v-model=\"tempProduct.category\" class=\"form-select\">\n                      <option value=\"日式料理\">日式料理</option>\n                      <option value=\"韓式料理\">韓式料理</option>\n                    </select>\n                  </div>\n\n                  <div class=\"col-md-4\">\n                    <label class=\"form-label fw-bold\">單位</label>\n                    <input\n                      v-model=\"tempProduct.unit\"\n                      type=\"text\"\n                      class=\"form-control\"\n                      placeholder=\"份 / 套 / 鍋\"\n                    >\n                  </div>\n\n                  <div class=\"col-md-4\">\n                    <label class=\"form-label fw-bold\">原價</label>\n                    <input\n                      v-model.number=\"tempProduct.origin_price\"\n                      type=\"number\"\n                      class=\"form-control\"\n                    >\n                  </div>\n\n                  <div class=\"col-md-4\">\n                    <label class=\"form-label fw-bold\">售價</label>\n                    <input\n                      v-model.number=\"tempProduct.price\"\n                      type=\"number\"\n                      class=\"form-control\"\n                    >\n                  </div>\n\n                  <div class=\"col-12\">\n                    <label class=\"form-label fw-bold\">短文案</label>\n                    <input\n                      v-model=\"tempProduct.description\"\n                      type=\"text\"\n                      class=\"form-control\"\n                      placeholder=\"例如：外酥內嫩韓式炸雞，裹上甜辣醬超涮嘴。\"\n                    >\n                  </div>\n\n                  <div class=\"col-12\">\n                    <label class=\"form-label fw-bold\">料理介紹</label>\n                    <textarea\n                      v-model=\"tempProduct.content\"\n                      class=\"form-control\"\n                      rows=\"5\"\n                      placeholder=\"請輸入吸引用戶購買的料理介紹\"\n                    ></textarea>\n                  </div>\n\n                  <div class=\"col-12\">\n                    <div class=\"form-check form-switch\">\n                      <input\n                        id=\"isEnabled\"\n                        v-model=\"tempProduct.is_enabled\"\n                        class=\"form-check-input\"\n                        type=\"checkbox\"\n                        :true-value=\"1\"\n                        :false-value=\"0\"\n                      >\n                      <label class=\"form-check-label fw-bold\" for=\"isEnabled\">\n                        是否啟用於前台\n                      </label>\n                    </div>\n                    <p class=\"text-muted small mt-1 mb-0\">\n                      若未啟用，前台可能會顯示找不到產品。\n                    </p>\n                  </div>\n                </div>\n              </div>\n            </div>\n          </div>\n\n          <div class=\"modal-footer\">\n            <button\n              type=\"button\"\n              class=\"btn btn-outline-secondary\"\n              @click=\"hideModal\"\n            >\n              取消\n            </button>\n\n            <button\n              type=\"button\"\n              class=\"btn btn-danger\"\n              @click=\"updateProduct\"\n            >\n              儲存料理\n            </button>\n          </div>\n        </div>\n      </div>\n    </div>\n\n    <!-- 刪除 Modal -->\n    <div\n      ref=\"delModal\"\n      class=\"modal fade\"\n      tabindex=\"-1\"\n      aria-hidden=\"true\"\n    >\n      <div class=\"modal-dialog modal-dialog-centered\">\n        <div class=\"modal-content rounded-4\">\n          <div class=\"modal-header\">\n            <h5 class=\"modal-title fw-bold text-danger\">\n              刪除料理商品\n            </h5>\n            <button\n              type=\"button\"\n              class=\"btn-close\"\n              @click=\"hideDelModal\"\n            ></button>\n          </div>\n\n          <div class=\"modal-body\">\n            確定要刪除\n            <strong>{{ tempProduct.title }}</strong>\n            嗎？刪除後將無法復原。\n          </div>\n\n          <div class=\"modal-footer\">\n            <button\n              type=\"button\"\n              class=\"btn btn-outline-secondary\"\n              @click=\"hideDelModal\"\n            >\n              取消\n            </button>\n\n            <button\n              type=\"button\"\n              class=\"btn btn-danger\"\n              @click=\"deleteProduct\"\n            >\n              確認刪除\n            </button>\n          </div>\n        </div>\n      </div>\n    </div>\n  </div>\n</template>\n\n<script>\nimport Modal from 'bootstrap/js/dist/modal';\n\nconst { VUE_APP_API, VUE_APP_PATH } = process.env;\n\nexport default {\n  name: 'AdminProducts',\n  data() {\n    return {\n      products: [],\n      tempProduct: {},\n      isNew: false,\n      isLoading: false,\n      productModal: null,\n      delModal: null,\n      selectedCategory: '全部',\n      keyword: '',\n      defaultImage: 'https://images.unsplash.com/photo-1546069901-ba9599a7e63c?w=800',\n    };\n  },\n  computed: {\n    filteredProducts() {\n      let result = this.products;\n\n      if (this.selectedCategory !== '全部') {\n        result = result.filter((item) => item.category === this.selectedCategory);\n      }\n\n      if (this.keyword) {\n        const keyword = this.keyword.toLowerCase();\n        result = result.filter((item) => {\n          const text = [\n            item.title,\n            item.category,\n            item.description,\n            item.content,\n          ].join(' ').toLowerCase();\n\n          return text.includes(keyword);\n        });\n      }\n\n      return result;\n    },\n  },\n  methods: {\n    getProducts() {\n      const url = `${VUE_APP_API}/api/${VUE_APP_PATH}/admin/products/all`;\n\n      this.isLoading = true;\n\n      this.$http.get(url)\n        .then((res) => {\n          this.products = res.data.products || [];\n        })\n        .finally(() => {\n          this.isLoading = false;\n        });\n    },\n\n    openModal(isNew, item) {\n      this.isNew = isNew;\n\n      if (isNew) {\n        this.tempProduct = {\n          title: '',\n          category: '日式料理',\n          origin_price: 0,\n          price: 0,\n          unit: '份',\n          description: '',\n          content: '',\n          imageUrl: '',\n          is_enabled: 1,\n        };\n      } else {\n        this.tempProduct = { ...item };\n      }\n\n      this.productModal.show();\n    },\n\n    hideModal() {\n      this.productModal.hide();\n    },\n\n    openDelModal(item) {\n      this.tempProduct = { ...item };\n      this.delModal.show();\n    },\n\n    hideDelModal() {\n      this.delModal.hide();\n    },\n\n    updateProduct() {\n      if (!this.tempProduct.title) {\n        alert('請輸入料理名稱');\n        return;\n      }\n\n      const productData = {\n        title: this.tempProduct.title,\n        category: this.tempProduct.category || '日式料理',\n        origin_price: Number(this.tempProduct.origin_price) || 0,\n        price: Number(this.tempProduct.price) || 0,\n        unit: this.tempProduct.unit || '份',\n        description: this.tempProduct.description || '',\n        content: this.tempProduct.content || '',\n        imageUrl: this.tempProduct.imageUrl || '',\n        is_enabled: Number(this.tempProduct.is_enabled) || 0,\n      };\n\n      let url = `${VUE_APP_API}/api/${VUE_APP_PATH}/admin/product`;\n      let httpMethod = 'post';\n\n      if (!this.isNew) {\n        url = `${VUE_APP_API}/api/${VUE_APP_PATH}/admin/product/${this.tempProduct.id}`;\n        httpMethod = 'put';\n      }\n\n      console.log('儲存料理 API:', url);\n      console.log('儲存料理資料:', productData);\n\n      this.isLoading = true;\n\n      this.$http[httpMethod](url, { data: productData })\n        .then((res) => {\n          console.log('儲存料理回傳:', res.data);\n\n          this.$httpMessageState(res, this.isNew ? '新增料理' : '更新料理');\n\n          if (res.data.success) {\n            alert(this.isNew ? '新增料理成功' : '更新料理成功');\n            this.hideModal();\n            this.getProducts();\n          } else {\n            alert(res.data.message || '儲存失敗');\n          }\n        })\n        .catch((error) => {\n          console.error('儲存料理失敗:', error);\n\n          if (error.response) {\n            console.log('錯誤狀態:', error.response.status);\n            console.log('錯誤內容:', error.response.data);\n\n            alert(error.response.data.message || `儲存失敗，狀態碼：${error.response.status}`);\n          } else {\n            alert('儲存失敗，請查看 console 錯誤訊息');\n          }\n        })\n        .finally(() => {\n          this.isLoading = false;\n        });\n    },\n\n    deleteProduct() {\n      const url = `${VUE_APP_API}/api/${VUE_APP_PATH}/admin/product/${this.tempProduct.id}`;\n\n      this.isLoading = true;\n\n      this.$http.delete(url)\n        .then((res) => {\n          this.$httpMessageState(res, '刪除料理');\n\n          if (res.data.success) {\n            this.hideDelModal();\n            this.getProducts();\n          }\n        })\n        .finally(() => {\n          this.isLoading = false;\n        });\n    },\n\n    resetFilter() {\n      this.selectedCategory = '全部';\n      this.keyword = '';\n    },\n  },\n  mounted() {\n    const token = document.cookie.replace(\n      /(?:(?:^|.*;\\s*)hexToken\\s*=\\s*([^;]*).*$)|^.*$/,\n      '$1',\n    );\n\n    if (!token) {\n      alert('請先登入後台');\n      this.$router.push('/login');\n      return;\n    }\n\n    this.$http.defaults.headers.common.Authorization = token;\n\n    this.productModal = new Modal(this.$refs.productModal);\n    this.delModal = new Modal(this.$refs.delModal);\n    this.getProducts();\n  },\n};\n</script>\n\n<style scoped>\n.admin-food-page {\n  min-height: 100vh;\n  background:\n    radial-gradient(circle at top left, rgba(220, 53, 69, 0.1), transparent 32%),\n    linear-gradient(180deg, #fff7ef 0%, #ffffff 42%, #fffaf5 