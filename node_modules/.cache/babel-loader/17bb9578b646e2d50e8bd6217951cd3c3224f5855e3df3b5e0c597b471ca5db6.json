   })[\"catch\"](function (error) {\n        console.error('更新付款狀態失敗:', error);\n        alert('更新付款狀態失敗，請稍後再試');\n        if (_this5.latestPaidOrderId) {\n          _this5.getOnlyPaidOrder(_this5.latestPaidOrderId);\n        } else {\n          _this5.getOrders(_this5.currentPage);\n        }\n      })[\"finally\"](function () {\n        _this5.isLoading = false;\n      });\n    },\n    clearOrdersDisplay: function clearOrdersDisplay() {\n      this.orders = {};\n      this.pagination = {};\n      this.latestPaidOrderId = '';\n      this.isOrderDisplayCleared = true;\n      localStorage.removeItem('latestPaidOrderId');\n      localStorage.setItem('orderDisplayCleared', '1');\n      window.dispatchEvent(new Event('orders-cleared'));\n    },\n    handleOrdersCleared: function handleOrdersCleared() {\n      this.orders = {};\n      this.pagination = {};\n      this.latestPaidOrderId = '';\n      this.isOrderDisplayCleared = true;\n      localStorage.removeItem('latestPaidOrderId');\n    },\n    handleOrdersDisplayReset: function handleOrdersDisplayReset(event) {\n      var _event$detail;\n      var paidOrderId = (event === null || event === void 0 || (_event$detail = event.detail) === null || _event$detail === void 0 ? void 0 : _event$detail.orderId) || localStorage.getItem('latestPaidOrderId') || '';\n      this.isOrderDisplayCleared = false;\n      this.latestPaidOrderId = paidOrderId;\n      localStorage.removeItem('orderDisplayCleared');\n      if (paidOrderId) {\n        localStorage.setItem('latestPaidOrderId', paidOrderId);\n        this.getOnlyPaidOrder(paidOrderId);\n      } else {\n        this.getOrders(this.currentPage);\n      }\n    }\n  },\n  created: function created() {\n    if (!this.isOrderDisplayCleared) {\n      if (this.latestPaidOrderId) {\n        this.getOnlyPaidOrder(this.latestPaidOrderId);\n      } else {\n        this.getOrders();\n      }\n    }\n  },\n  mounted: function mounted() {\n    window.addEventListener('orders-cleared', this.han