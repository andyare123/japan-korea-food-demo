{"ast":null,"code":"import \"core-js/modules/es.array.concat.js\";\nimport \"core-js/modules/es.array.push.js\";\nimport \"core-js/modules/es.function.name.js\";\nimport \"core-js/modules/es.object.to-string.js\";\nimport \"core-js/modules/web.timers.js\";\nexport default {\n  inject: ['emitter'],\n  data: function data() {\n    return {\n      isLoading: false,\n      status: {\n        loadingItem: ''\n      },\n      form: {\n        user: {\n          name: '',\n          email: '',\n          tel: '',\n          address: ''\n        },\n        message: ''\n      },\n      cart: {\n        carts: [],\n        total: 0,\n        final_total: 0\n      },\n      checkoutStep: 1,\n      defaultImage: 'https://images.unsplash.com/photo-1546069901-ba9599a7e63c?w=800'\n    };\n  },\n  methods: {\n    pushToast: function pushToast(title) {\n      var content = arguments.length > 1 && arguments[1] !== undefined ? arguments[1] : '';\n      var style = arguments.length > 2 && arguments[2] !== undefined ? arguments[2] : 'danger';\n      this.emitter.emit('push-message', {\n        style: style,\n        title: title,\n        content: content\n      });\n    },\n    getCart: function getCart() {\n      var _this = this;\n      var url = \"\".concat(process.env.VUE_APP_API, \"/api/\").concat(process.env.VUE_APP_PATH, \"/cart\");\n      this.isLoading = true;\n      this.$http.get(url).then(function (response) {\n        _this.cart = response.data.data || {\n          carts: [],\n          total: 0,\n          final_total: 0\n        };\n      })[\"catch\"](function (error) {\n        console.error('取得購物車失敗:', error);\n        _this.pushToast('取得購物車失敗', '請稍後再試，或重新整理頁面。', 'danger');\n      })[\"finally\"](function () {\n        _this.isLoading = false;\n      });\n    },\n    updateCart: function updateCart(item) {\n      var _this2 = this;\n      if (item.qty < 1) {\n        // eslint-disable-next-line no-param-reassign\n        item.qty = 1;\n        this.pushToast('數量錯誤', '餐點數量至少需要 1 份。', 'warning');\n      }\n      var url = \"\".concat(process.env.VUE_APP_API, \"/api/\").concat(process.env.VUE_APP_PATH, \"/cart/\").concat(item.id);\n      this.isLoading = true;\n      this.status.loadingItem = item.id;\n      var cart = {\n        product_id: item.product_id,\n        qty: item.qty\n      };\n      this.$http.put(url, {\n        data: cart\n      }).then(function (res) {\n        _this2.$httpMessageState(res, '更新購物車');\n        if (res.data.success) {\n          var _item$product;\n          _this2.pushToast('更新購物車成功', \"\".concat(((_item$product = item.product) === null || _item$product === void 0 ? void 0 : _item$product.title) || '餐點', \" \\u6578\\u91CF\\u5DF2\\u66F4\\u65B0\\u3002\"), 'success');\n          _this2.getCart();\n          window.dispatchEvent(new Event('cart-updated'));\n        } else {\n          _this2.pushToast('更新購物車失敗', res.data.message || '請稍後再試。', 'danger');\n        }\n      })[\"catch\"](function (error) {\n        console.error('更新購物車失敗:', error);\n        _this2.pushToast('更新購物車失敗', '請確認網路連線或稍後再試。', 'danger');\n      })[\"finally\"](function () {\n        _this2.status.loadingItem = '';\n        _this2.isLoading = false;\n      });\n    },\n    removeCartItem: function removeCartItem(id) {\n      var _this3 = this;\n      var url = \"\".concat(process.env.VUE_APP_API, \"/api/\").concat(process.env.VUE_APP_PATH, \"/cart/\").concat(id);\n      this.status.loadingItem = id;\n      this.isLoading = true;\n      this.$http[\"delete\"](url).then(function (response) {\n        _this3.$httpMessageState(response, '移除購物車品項');\n        if (response.data.success) {\n          _this3.pushToast('已移除餐點', '餐點已從購物車移除。', 'success');\n          _this3.getCart();\n          window.dispatchEvent(new Event('cart-updated'));\n        } else {\n          _this3.pushToast('移除餐點失敗', response.data.message || '請稍後再試。', 'danger');\n        }\n      })[\"catch\"](function (error) {\n        console.error('移除購物車品項失敗:', error);\n        _this3.pushToast('移除餐點失敗', '請確認網路連線或稍後再試。', 'danger');\n      })[\"finally\"](function () {\n        _this3.status.loadingItem = '';\n        _this3.isLoading = false;\n      });\n    },\n    nextStep: function nextStep() {\n      if (this.checkoutStep === 1 && !this.cart.carts.length) {\n        this.pushToast('購物車目前沒有餐點', '請先加入餐點後再進入下一步。', 'warning');\n        return;\n      }\n      if (this.checkoutStep < 3) {\n        this.checkoutStep += 1;\n        window.scrollTo({\n          top: 0,\n          behavior: 'smooth'\n        });\n      }\n    },\n    prevStep: function prevStep() {\n      if (this.checkoutStep > 1) {\n        this.checkoutStep -= 1;\n        window.scrollTo({\n          top: 0,\n          behavior: 'smooth'\n        });\n      }\n    },\n    createOrder: function createOrder() {\n      var _this4 = this;\n      if (!this.cart.carts.length) {\n        this.pushToast('購物車目前沒有餐點', '請先加入餐點後再建立訂單。', 'warning');\n        this.checkoutStep = 1;\n        return;\n      }\n      var _this$form$user = this.form.user,\n        name = _this$form$user.name,\n        email = _this$form$user.email,\n        tel = _this$form$user.tel,\n        address = _this$form$user.address;\n      if (!name || !email || !tel || !address) {\n        this.pushToast('請先填寫完整訂購資料', '姓名、Email、電話與地址皆為必填。', 'warning');\n        this.checkoutStep = 2;\n        return;\n      }\n      var url = \"\".concat(process.env.VUE_APP_API, \"/api/\").concat(process.env.VUE_APP_PATH, \"/order\");\n      var order = this.form;\n      this.isLoading = true;\n      this.$http.post(url, {\n        data: order\n      }).then(function (res) {\n        if (res.data.success) {\n          var orderId = res.data.orderId;\n          _this4.pushToast('訂單建立成功', '即將前往付款頁面。', 'success');\n          localStorage.removeItem('orderDisplayCleared');\n          window.dispatchEvent(new Event('cart-updated'));\n          window.dispatchEvent(new Event('orders-display-reset'));\n          window.dispatchEvent(new Event('orders-updated'));\n          setTimeout(function () {\n            _this4.$router.push(\"/checkout/\".concat(orderId));\n          }, 800);\n        } else {\n          _this4.pushToast('訂單建立失敗', res.data.message || '請稍後再試。', 'danger');\n        }\n      })[\"catch\"](function (error) {\n        console.error('建立訂單失敗:', error);\n        _this4.pushToast('訂單建立失敗', '請確認網路連線或稍後再試。', 'danger');\n      })[\"finally\"](function () {\n        _this4.isLoading = false;\n      });\n    }\n  },\n  created: function created() {\n    this.getCart();\n  }\n};","map":{"version":3,"names":["inject","data","isLoading","status","loadingItem","form","user","name","email","tel","address","message","cart","carts","total","final_total","checkoutStep","defaultImage","methods","pushToast","title","content","arguments","length","undefined","style","emitter","emit","getCart","_this","url","concat","process","env","VUE_APP_API","VUE_APP_PATH","$http","get","then","response","error","console","updateCart","item","_this2","qty","id","product_id","put","res","$httpMessageState","success","_item$product","product","window","dispatchEvent","Event","removeCartItem","_this3","nextStep","scrollTo","top","behavior","prevStep","createOrder","_this4","_this$form$user","order","post","orderId","localStorage","removeItem","setTimeout","$router","push","created"],"sources":["C:\\Users\\ROG Strix\\Desktop\\vue cli\\gui-demo\\src\\views\\CheckoutProcess.vue"],"sourcesContent":["<!-- eslint-disable vue/no-multiple-template-root -->\n<template>\n  <Loading :active=\"isLoading\"></Loading>\n\n  <div class=\"checkout-process-page\">\n    <div class=\"container py-5\">\n      <div class=\"page-hero mb-5\">\n        <span class=\"hero-badge\">CHECKOUT STEP</span>\n        <h1 class=\"fw-bold mt-3 mb-3\">完成訂購流程</h1>\n        <p class=\"text-muted mb-0\">\n          請確認餐點內容、填寫訂購資料，最後確認無誤後建立訂單並前往付款。\n        </p>\n      </div>\n\n      <div class=\"checkout-steps mb-4\">\n        <div class=\"step-item\" :class=\"{ active: checkoutStep >= 1 }\">\n          <div class=\"step-circle\">1</div>\n          <div>\n            <strong>確認購物車</strong>\n            <small>確認餐點與數量</small>\n          </div>\n        </div>\n\n        <div class=\"step-line\" :class=\"{ active: checkoutStep >= 2 }\"></div>\n\n        <div class=\"step-item\" :class=\"{ active: checkoutStep >= 2 }\">\n          <div class=\"step-circle\">2</div>\n          <div>\n            <strong>填寫資料</strong>\n            <small>填寫收件資訊</small>\n          </div>\n        </div>\n\n        <div class=\"step-line\" :class=\"{ active: checkoutStep >= 3 }\"></div>\n\n        <div class=\"step-item\" :class=\"{ active: checkoutStep >= 3 }\">\n          <div class=\"step-circle\">3</div>\n          <div>\n            <strong>最後確認</strong>\n            <small>確認後建立訂單</small>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"checkout-card\">\n        <!-- STEP 1 -->\n        <div v-if=\"checkoutStep === 1\">\n          <div class=\"checkout-card-header mb-4\">\n            <div>\n              <span class=\"small text-danger fw-bold\">STEP 1</span>\n              <h4 class=\"fw-bold mb-1\">確認購物車餐點</h4>\n              <p class=\"text-muted mb-0\">\n                請確認餐點、數量與金額是否正確，確認後再進入下一步。\n              </p>\n            </div>\n          </div>\n\n          <div v-if=\"cart.carts && cart.carts.length\">\n            <div\n              class=\"confirm-item\"\n              v-for=\"item in cart.carts\"\n              :key=\"item.id\"\n            >\n              <div\n                class=\"confirm-img\"\n                :style=\"{ backgroundImage: `url(${item.product.imageUrl || defaultImage})` }\"\n              ></div>\n\n              <div class=\"confirm-info\">\n                <h6 class=\"fw-bold mb-1\">\n                  {{ item.product.title }}\n                </h6>\n\n                <p class=\"text-muted small mb-2\">\n                  {{ item.product.description || item.product.content || '日韓人氣料理。' }}\n                </p>\n\n                <div class=\"input-group input-group-sm confirm-qty\">\n                  <input\n                    type=\"number\"\n                    class=\"form-control\"\n                    min=\"1\"\n                    :disabled=\"item.id === status.loadingItem\"\n                    @change=\"updateCart(item)\"\n                    v-model.number=\"item.qty\"\n                  >\n                  <span class=\"input-group-text\">\n                    {{ item.product.unit || '份' }}\n                  </span>\n                </div>\n              </div>\n\n              <div class=\"confirm-price text-end\">\n                <button\n                  type=\"button\"\n                  class=\"btn btn-outline-danger btn-sm mb-2\"\n                  :disabled=\"status.loadingItem === item.id\"\n                  @click=\"removeCartItem(item.id)\"\n                >\n                  移除\n                </button>\n\n                <div class=\"fw-bold text-danger\">\n                  {{ $filters.currency(item.final_total) }}\n                </div>\n              </div>\n            </div>\n\n            <div class=\"checkout-summary mt-4\">\n              <div class=\"d-flex justify-content-between mb-2\">\n                <span>餐點小計</span>\n                <strong>{{ $filters.currency(cart.total) }}</strong>\n              </div>\n\n              <div\n                class=\"d-flex justify-content-between text-success\"\n                v-if=\"cart.final_total !== cart.total\"\n              >\n                <span>優惠後金額</span>\n                <strong>{{ $filters.currency(cart.final_total) }}</strong>\n              </div>\n\n              <hr>\n\n              <div class=\"d-flex justify-content-between total-line\">\n                <span>應付總額</span>\n                <strong>{{ $filters.currency(cart.final_total || cart.total) }}</strong>\n              </div>\n            </div>\n\n            <div class=\"d-flex justify-content-between mt-4\">\n              <router-link to=\"/user/cart\" class=\"btn btn-outline-secondary btn-lg\">\n                <i class=\"bi bi-arrow-left me-1\"></i>\n                返回購物車\n              </router-link>\n\n              <button\n                type=\"button\"\n                class=\"btn btn-danger btn-lg\"\n                @click=\"nextStep\"\n              >\n                下一步，填寫訂購資料\n                <i class=\"bi bi-arrow-right ms-1\"></i>\n              </button>\n            </div>\n          </div>\n\n          <div v-else class=\"empty-cart\">\n            <i class=\"bi bi-bag-x\"></i>\n            <h5 class=\"fw-bold mt-3 mb-2\">購物車目前沒有餐點</h5>\n            <p class=\"text-muted mb-4\">\n              請先加入日韓料理後再進行結帳。\n            </p>\n            <router-link to=\"/products\" class=\"btn btn-danger\">\n              前往挑選料理\n            </router-link>\n          </div>\n        </div>\n\n        <!-- STEP 2 -->\n        <div v-if=\"checkoutStep === 2\">\n          <div class=\"checkout-card-header mb-4\">\n            <div>\n              <span class=\"small text-danger fw-bold\">STEP 2</span>\n              <h4 class=\"fw-bold mb-1\">填寫訂購資料</h4>\n              <p class=\"text-muted mb-0\">\n                請填寫正確的聯絡資訊，方便後續通知與配送。\n              </p>\n            </div>\n          </div>\n          <Form\n            v-slot=\"{ errors, meta, validate }\"\n            :validate-on-mount=\"true\"\n            @submit.prevent\n          >\n            <div class=\"row g-3\">\n              <div class=\"col-md-6\">\n                <label for=\"email\" class=\"form-label fw-bold\">\n                  Email <span class=\"text-danger\">*</span>\n                </label>\n\n                <Field\n                  id=\"email\"\n                  name=\"Email\"\n                  type=\"email\"\n                  class=\"form-control form-control-lg\"\n                  :class=\"{\n                    'is-invalid': errors.Email,\n                    'is-valid': !errors.Email && form.user.email,\n                  }\"\n                  placeholder=\"請輸入 Email\"\n                  rules=\"required|email\"\n                  v-model=\"form.user.email\"\n                ></Field>\n\n                <ErrorMessage name=\"Email\" class=\"invalid-feedback\"></ErrorMessage>\n              </div>\n\n              <div class=\"col-md-6\">\n                <label for=\"name\" class=\"form-label fw-bold\">\n                  收件人姓名 <span class=\"text-danger\">*</span>\n                </label>\n\n                <Field\n                  id=\"name\"\n                  name=\"姓名\"\n                  type=\"text\"\n                  class=\"form-control form-control-lg\"\n                  :class=\"{\n                    'is-invalid': errors['姓名'],\n                    'is-valid': !errors['姓名'] && form.user.name,\n                  }\"\n                  placeholder=\"請輸入姓名\"\n                  rules=\"required|min:2\"\n                  v-model=\"form.user.name\"\n                ></Field>\n\n                <ErrorMessage name=\"姓名\" class=\"invalid-feedback\"></ErrorMessage>\n              </div>\n\n              <div class=\"col-md-6\">\n                <label for=\"tel\" class=\"form-label fw-bold\">\n                  收件人電話 <span class=\"text-danger\">*</span>\n                </label>\n\n                <Field\n                  id=\"tel\"\n                  name=\"電話\"\n                  type=\"tel\"\n                  class=\"form-control form-control-lg\"\n                  :class=\"{\n                    'is-invalid': errors['電話'],\n                    'is-valid': !errors['電話'] && form.user.tel,\n                  }\"\n                  placeholder=\"請輸入手機號碼，例如：0912345678\"\n                  rules=\"required|twMobile\"\n                  v-model=\"form.user.tel\"\n                ></Field>\n\n                <ErrorMessage name=\"電話\" class=\"invalid-feedback\"></ErrorMessage>\n\n                <small class=\"text-muted d-block mt-1\">\n                  請輸入 09 開頭的 10 碼手機號碼。\n                </small>\n              </div>\n\n              <div class=\"col-md-6\">\n                <label for=\"address\" class=\"form-label fw-bold\">\n                  收件人地址 <span class=\"text-danger\">*</span>\n                </label>\n\n                <Field\n                  id=\"address\"\n                  name=\"地址\"\n                  type=\"text\"\n                  class=\"form-control form-control-lg\"\n                  :class=\"{\n                    'is-invalid': errors['地址'],\n                    'is-valid': !errors['地址'] && form.user.address,\n                  }\"\n                  placeholder=\"請輸入完整地址\"\n                  rules=\"required|min:6\"\n                  v-model=\"form.user.address\"\n                ></Field>\n\n                <ErrorMessage name=\"地址\" class=\"invalid-feedback\"></ErrorMessage>\n              </div>\n\n              <div class=\"col-12\">\n                <label for=\"message\" class=\"form-label fw-bold\">備註</label>\n\n                <textarea\n                  id=\"message\"\n                  class=\"form-control\"\n                  rows=\"5\"\n                  placeholder=\"例如：不要辣、餐具數量、外送備註、希望送達時間\"\n                  v-model=\"form.message\"\n                ></textarea>\n              </div>\n            </div>\n\n            <div class=\"form-checkout-alert mt-4\" v-if=\"!meta.valid\">\n              <i class=\"bi bi-exclamation-circle me-1\"></i>\n              請確認以下欄位：\n\n              <ul class=\"mb-0 mt-2 ps-4\">\n                <li v-for=\"(message, field) in errors\" :key=\"field\">\n                  {{ field }}：{{ message }}\n                </li>\n              </ul>\n            </div>\n\n            <div class=\"d-flex justify-content-between mt-4\">\n              <button\n                type=\"button\"\n                class=\"btn btn-outline-secondary btn-lg\"\n                @click=\"prevStep\"\n              >\n                <i class=\"bi bi-arrow-left me-1\"></i>\n                上一步\n              </button>\n\n              <button\n                type=\"button\"\n                class=\"btn btn-danger btn-lg\"\n                :disabled=\"isLoading || !meta.valid\"\n                @click=\"validate().then((result) => { if (result.valid) nextStep(); })\"\n              >\n                下一步，確認訂單\n                <i class=\"bi bi-arrow-right ms-1\"></i>\n              </button>\n            </div>\n          </Form>\n        </div>\n\n        <!-- STEP 3 -->\n        <div v-if=\"checkoutStep === 3\">\n          <div class=\"checkout-card-header mb-4\">\n            <div>\n              <span class=\"small text-danger fw-bold\">STEP 3</span>\n              <h4 class=\"fw-bold mb-1\">最後確認訂單</h4>\n              <p class=\"text-muted mb-0\">\n                請確認餐點、金額與訂購資料是否正確，確認後即可建立訂單並前往付款。\n              </p>\n            </div>\n          </div>\n\n          <div class=\"final-section mb-4\">\n            <h5 class=\"fw-bold mb-3\">\n              <i class=\"bi bi-bag-check me-1 text-danger\"></i>\n              餐點明細\n            </h5>\n\n            <div\n              class=\"final-item\"\n              v-for=\"item in cart.carts\"\n              :key=\"item.id\"\n            >\n              <div>\n                <strong>{{ item.product.title }}</strong>\n                <div class=\"text-muted small\">\n                  數量：{{ item.qty }} {{ item.product.unit || '份' }}\n                </div>\n              </div>\n\n              <strong class=\"text-danger\">\n                {{ $filters.currency(item.final_total) }}\n              </strong>\n            </div>\n\n            <div class=\"checkout-summary mt-3\">\n              <div class=\"d-flex justify-content-between mb-2\">\n                <span>餐點小計</span>\n                <strong>{{ $filters.currency(cart.total) }}</strong>\n              </div>\n\n              <div\n                class=\"d-flex justify-content-between text-success\"\n                v-if=\"cart.final_total !== cart.total\"\n              >\n                <span>優惠後金額</span>\n                <strong>{{ $filters.currency(cart.final_total) }}</strong>\n              </div>\n\n              <hr>\n\n              <div class=\"d-flex justify-content-between total-line\">\n                <span>應付總額</span>\n                <strong>{{ $filters.currency(cart.final_total || cart.total) }}</strong>\n              </div>\n            </div>\n          </div>\n\n          <div class=\"final-section mb-4\">\n            <h5 class=\"fw-bold mb-3\">\n              <i class=\"bi bi-person-lines-fill me-1 text-danger\"></i>\n              訂購資料\n            </h5>\n\n            <div class=\"info-grid\">\n              <div>\n                <span>Email</span>\n                <strong>{{ form.user.email }}</strong>\n              </div>\n\n              <div>\n                <span>姓名</span>\n                <strong>{{ form.user.name }}</strong>\n              </div>\n\n              <div>\n                <span>電話</span>\n                <strong>{{ form.user.tel }}</strong>\n              </div>\n\n              <div>\n                <span>地址</span>\n                <strong>{{ form.user.address }}</strong>\n              </div>\n\n              <div class=\"full\">\n                <span>備註</span>\n                <strong>{{ form.message || '無備註' }}</strong>\n              </div>\n            </div>\n          </div>\n\n          <div class=\"d-flex justify-content-between mt-4\">\n            <button\n              type=\"button\"\n              class=\"btn btn-outline-secondary btn-lg\"\n              @click=\"prevStep\"\n            >\n              <i class=\"bi bi-arrow-left me-1\"></i>\n              上一步修改\n            </button>\n\n            <button\n              type=\"button\"\n              class=\"btn btn-danger btn-lg\"\n              :disabled=\"isLoading || !cart.carts.length\"\n              @click=\"createOrder\"\n            >\n              <span\n                v-if=\"isLoading\"\n                class=\"spinner-grow spinner-grow-sm me-1\"\n              ></span>\n              建立訂單並前往付款\n            </button>\n          </div>\n        </div>\n      </div>\n    </div>\n  </div>\n</template>\n\n<script>\nexport default {\n  inject: ['emitter'],\n  data() {\n    return {\n      isLoading: false,\n      status: {\n        loadingItem: '',\n      },\n      form: {\n        user: {\n          name: '',\n          email: '',\n          tel: '',\n          address: '',\n        },\n        message: '',\n      },\n      cart: {\n        carts: [],\n        total: 0,\n        final_total: 0,\n      },\n      checkoutStep: 1,\n      defaultImage: 'https://images.unsplash.com/photo-1546069901-ba9599a7e63c?w=800',\n    };\n  },\n  methods: {\n    pushToast(title, content = '', style = 'danger') {\n      this.emitter.emit('push-message', {\n        style,\n        title,\n        content,\n      });\n    },\n\n    getCart() {\n      const url = `${process.env.VUE_APP_API}/api/${process.env.VUE_APP_PATH}/cart`;\n\n      this.isLoading = true;\n\n      this.$http.get(url)\n        .then((response) => {\n          this.cart = response.data.data || {\n            carts: [],\n            total: 0,\n            final_total: 0,\n          };\n        })\n        .catch((error) => {\n          console.error('取得購物車失敗:', error);\n\n          this.pushToast(\n            '取得購物車失敗',\n            '請稍後再試，或重新整理頁面。',\n            'danger',\n          );\n        })\n        .finally(() => {\n          this.isLoading = false;\n        });\n    },\n\n    updateCart(item) {\n      if (item.qty < 1) {\n        // eslint-disable-next-line no-param-reassign\n        item.qty = 1;\n\n        this.pushToast(\n          '數量錯誤',\n          '餐點數量至少需要 1 份。',\n          'warning',\n        );\n      }\n\n      const url = `${process.env.VUE_APP_API}/api/${proces