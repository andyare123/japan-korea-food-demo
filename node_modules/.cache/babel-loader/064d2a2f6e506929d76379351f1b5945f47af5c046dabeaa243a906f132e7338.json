{"ast":null,"code":"export default {\n  name: 'ProductCard',\n  props: {\n    product: {\n      type: Object,\n      required: true\n    },\n    isFavorite: {\n      type: Boolean,\n      \"default\": false\n    }\n  }\n};","map":{"version":3,"names":["name","props","product","type","Object","required","isFavorite","Boolean"],"sources":["C:\\Users\\ROG Strix\\Desktop\\vue cli\\gui-demo\\src\\components\\ProductCard.vue"],"sourcesContent":["<template>\n  <div class=\"product-card h-100\">\n    <div\n      class=\"product-img\"\n      :style=\"{ backgroundImage: `url(${product.imageUrl})` }\"\n    >\n      <button\n        type=\"button\"\n        class=\"favorite-btn\"\n        @click.stop=\"$emit('toggle-favorite', product)\"\n      >\n        <i :class=\"isFavorite ? 'bi bi-heart-fill' : 'bi bi-heart'\"></i>\n      </button>\n    </div>\n\n    <div class=\"product-body\">\n      <span class=\"product-category\">{{ product.category }}</span>\n\n      <h5 class=\"product-title\">\n        {{ product.title }}\n      </h5>\n\n      <p class=\"product-description\">\n        {{ product.description || '精選實用課程，幫助你快速掌握核心技能。' }}\n      </p>\n\n      <div class=\"product-price\">\n        <del v-if=\"product.origin_price !== product.price\">\n          NT$ {{ product.origin_price }}\n        </del>\n        <strong>NT$ {{ product.price }}</strong>\n      </div>\n\n      <div class=\"d-grid gap-2 mt-3\">\n        <router-link\n          :to=\"`/product/${product.id}`\"\n          class=\"btn btn-outline-primary\"\n        >\n          查看課程\n        </router-link>\n\n        <button\n          type=\"button\"\n          class=\"btn btn-primary\"\n          @click=\"$emit('add-cart', product.id)\"\n        >\n          加入購物車\n        </button>\n      </div>\n    </div>\n  </div>\n</template>\n\n<script>\nexport default {\n  name: 'ProductCard',\n  props: {\n    product: {\n      type: Object,\n      required: true,\n    },\n    isFavorite: {\n      type: Boolean,\n      default: false,\n    },\n  },\n};\n</script>\n\n<style scoped>\n.product-card {\n  border-radius: 24px;\n  overflow: hidden;\n  background: #ffffff;\n  box-shadow: 0 12px 30px rgba(0, 0, 0, 0.08);\n  transition: transform 0.25s ease, box-shadow 0.25s ease;\n}\n\n.product-card:hover {\n  transform: translateY(-6px);\n  box-shadow: 0 18px 42px rgba(0, 0, 0, 0.12);\n}\n\n.product-img {\n  position: relative;\n  height: 220px;\n  background-size: cover;\n  background-position: center;\n}\n\n.favorite-btn {\n  position: absolute;\n  top: 14px;\n  right: 14px;\n  width: 42px;\n  height: 42px;\n  border: none;\n  border-radius: 50%;\n  background: #ffffff;\n  color: #dc3545;\n  box-shadow: 0 8px 20px rgba(0, 0, 0, 0.16);\n}\n\n.product-body {\n  padding: 22px;\n}\n\n.product-category {\n  display: inline-block;\n  margin-bottom: 10px;\n  color: #0d6efd;\n  font-size: 14px;\n  font-weight: 700;\n}\n\n.product-title {\n  font-weight: 800;\n  line-height: 1.5;\n}\n\n.product-description {\n  min-height: 72px;\n  color: #6c757d;\n  line-height: 1.7;\n}\n\n.product-price {\n  display: flex;\n  align-items: center;\n  gap: 12px;\n}\n\n.product-price del {\n  color: #999;\n}\n\n.product-price strong {\n  color: #dc3545;\n  font-size: 22px;\n}\n\n@media (max-width: 768px) {\n  .product-img {\n    height: 180px;\n  }\n\n  .product-body {\n    padding: 18px;\n  }\n\n  .product-description {\n    min-height: auto;\n  }\n}\n</style>"],"mappings":"AAsDA,eAAe;EACbA,IAAI,EAAE,aAAa;EACnBC,KAAK,EAAE;IACLC,OAAO,EAAE;MACPC,IAAI,EAAEC,MAAM;MACZC,QAAQ,EAAE;IACZ,CAAC;IACDC,UAAU,EAAE;MACVH,IAAI,EAAEI,OAAO;MACb,WAAS;IACX;EACF;AACF,CAAC","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}