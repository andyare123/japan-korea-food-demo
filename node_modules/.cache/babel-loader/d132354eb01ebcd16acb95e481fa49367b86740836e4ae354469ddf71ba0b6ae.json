etOnlyPaidOrder(paidOrderId);\n    },\n    handleOrdersCleared: function handleOrdersCleared() {\n      this.orders = {};\n      this.latestPaidOrderId = '';\n      this.isOrderDisplayCleared = true;\n      localStorage.removeItem('latestPaidOrderId');\n      localStorage.setItem('orderDisplayCleared', '1');\n    }\n  },\n  mounted: function mounted() {\n    this.getCart();\n    this.getFavorites();\n    if (!this.isOrderDisplayCleared && this.latestPaidOrderId) {\n      this.getOnlyPaidOrder(this.latestPaidOrderId);\n    } else {\n      this.orders = {};\n    }\n    window.addEventListener('cart-updated', this.getCart);\n    window.addEventListener('favorites-updated', this.getFavorites);\n    window.addEventListener('orders-updated', this.getOrders);\n    window.addEventListener('orders-display-reset', this.handleOrdersDisplayReset);\n    window.addEventListener('orders-cleared', this.handleOrdersCleared);\n  },\n  beforeUnmount: function beforeUnmount() {\n    window.removeEventListener('cart-updated', this.getCart);\n    window.removeEventListener('favorites-updated', this.getFavorites);\n    window.removeEventListener('orders-updated', this.getOrders);\n    window.removeEventListener('orders-display-reset', this.handleOrdersDisplayReset);\n    window.removeEventListener('orders-cleared', this.handleOrdersCleared);\n  }\n};","map":{"version":3,"names":["_process$env","process","env","VUE_APP_API","VUE_APP_PATH","data","cart","carts","total","final_total","favorites","orders","showCartPreview","showFavoritePreview","showOrderPreview","latestPaidOrderId","localStorage","getItem","isOrderDisplayCleared","defaultImage","status","loadingItem","computed","cartCount","reduce","item","Number","qty","favoriteCount","length","orderList","Array","isArray","_typeof","Object","values","orderCount","methods","getCart","_this","url","concat","$http","get","then","response","error","console","log","getFavorites","JSON","parse","increaseCartQty","updateCart","decreaseCartQty","removeCartItem","id","getOrders","getOnlyPaidOrder","orderId","_this2","page","arguments","undefined","ordersObject","pagination","ordersArray","matchedOrder","find","order","String","_defineProperty","has_next","total_pages","clearOrderPreview","removeItem","setItem","window","dispatchEvent","Event","_this3","product_id","put","res","$httpMessageState","_this4","removeFavorite","filter","stringify","openOrderPreview","isOrderPaid","is_paid","handleOrdersDisplayReset","event","_event$detail","paidOrderId","detail","handleOrdersCleared","mounted","addEventListener","beforeUnmount","removeEventListener"],"sources":["C:\\Users\\ROG Strix\\Desktop\\vue cli\\gui-demo\\src\\components\\Navbar.vue"],"sourcesContent":["<template>\n  <nav class=\"navbar navbar-expand-lg navbar-light bg-white shadow-sm sticky-top main-navbar\">\n    <div class=\"container\">\n      <router-link class=\"navbar-brand fw-bold brand-text\" to=\"/\">\n        和韓食堂\n      </router-link>\n\n      <button\n        class=\"navbar-toggler\"\n        type=\"button\"\n        data-bs-toggle=\"collapse\"\n        data-bs-target=\"#mainNavbar\"\n        aria-controls=\"mainNavbar\"\n        aria-expanded=\"false\"\n        aria-label=\"Toggle navigation\"\n      >\n        <span class=\"navbar-toggler-icon\"></span>\n      </button>\n\n      <div id=\"mainNavbar\" class=\"collapse navbar-collapse\">\n        <ul class=\"navbar-nav ms-auto align-items-lg-center gap-lg-2\">\n          <li class=\"nav-item\">\n            <router-link class=\"nav-link\" to=\"/products\">\n              日韓料理\n            </router-link>\n          </li>\n\n          <!-- 我的最愛 -->\n          <li\n            class=\"nav-item preview-wrapper\"\n            @mouseenter=\"showFavoritePreview = true\"\n            @mouseleave=\"showFavoritePreview = false\"\n          >\n            <router-link class=\"nav-link icon-link\" to=\"/favorites\">\n              <i class=\"bi bi-heart-fill me-1\"></i>\n              我的最愛\n              <span v-if=\"favoriteCount > 0\" class=\"nav-badge favorite-badge\">\n                {{ favoriteCount }}\n              </span>\n            </router-link>\n\n            <div v-if=\"showFavoritePreview\" class=\"preview-panel\">\n              <div class=\"preview-header\">\n                <strong>我的最愛</strong>\n                <small>{{ favoriteCount }} 項</small>\n              </div>\n\n              <div v-if=\"favorites.length\">\n                <div\n                  v-for=\"item in favorites\"\n                  :key=\"item.id\"\n                  class=\"preview-item\"\n                >\n                  <div\n                    class=\"preview-img\"\n                    :style=\"{ backgroundImage: `url(${item.imageUrl || defaultImage})` }\"\n                  ></div>\n\n                  <div class=\"preview-info\">\n                    <router-link\n                      class=\"preview-title\"\n                      :to=\"`/product/${item.id}`\"\n                    >\n                      {{ item.title }}\n                    </router-link>\n\n                    <div class=\"text-danger fw-bold small\">\n                      {{ $filters.currency(item.price || item.origin_price) }}\n                    </div>\n                  </div>\n\n                  <button\n                    type=\"button\"\n                    class=\"btn btn-outline-danger btn-sm\"\n                    @click.prevent=\"removeFavorite(item.id)\"\n                  >\n                    移除\n                  </button>\n                </div>\n\n                <router-link to=\"/favorites\" class=\"btn btn-danger w-100 mt-3\">\n                  查看我的最愛\n                </router-link>\n              </div>\n\n              <div v-else class=\"preview-empty\">\n                <i class=\"bi bi-heart\"></i>\n                <p class=\"mb-2\">我的最愛暫無資料</p>\n                <router-link to=\"/products\" class=\"btn btn-outline-danger btn-sm\">\n                  去收藏料理\n                </router-link>\n              </div>\n            </div>\n          </li>\n\n          <!-- 購物車 -->\n          <li\n            class=\"nav-item preview-wrapper\"\n            @mouseenter=\"showCartPreview = true\"\n            @mouseleave=\"showCartPreview = false\"\n          >\n            <router-link class=\"nav-link icon-link\" to=\"/user/cart\">\n              <i class=\"bi bi-bag-heart-fill me-1\"></i>\n              購物車\n              <span v-if=\"cartCount > 0\" class=\"nav-badge\">\n                {{ cartCount }}\n              </span>\n            </router-link>\n\n            <div v-if=\"showCartPreview\" class=\"preview-panel cart-preview-panel\">\n              <div class=\"preview-header\">\n                <strong>購物車</strong>\n                <small>{{ cartCount }} 份</small>\n              </div>\n\n              <div v-if=\"cart.carts && cart.carts.length\">\n                <div\n                  v-for=\"item in cart.carts\"\n                  :key=\"item.id\"\n                  class=\"preview-item cart-preview-item\"\n                >\n                  <div\n                    class=\"preview-img\"\n                    :style=\"{ backgroundImage: `url(${item.product.imageUrl || defaultImage})` }\"\n                  ></div>\n\n                  <div class=\"preview-info\">\n                    <router-link\n                      class=\"preview-title\"\n                      :to=\"`/product/${item.product.id || item.product_id}`\"\n                    >\n                      {{ item.product.title }}\n                    </router-link>\n\n                    <div class=\"text-danger fw-bold small\">\n                      {{ $filters.currency(item.final_total) }}\n                    </div>\n\n                    <div class=\"input-group input-group-sm qty-mini mt-2\">\n                      <button\n                        type=\"button\"\n                        class=\"btn btn-outline-secondary\"\n                        :disabled=\"status.loadingItem === item.id\"\n                        @click.prevent=\"decreaseCartQty(item)\"\n                      >\n                        -\n                      </button>\n\n                      <input\n                        type=\"number\"\n                        min=\"1\"\n                        class=\"form-control text-center\"\n                        v-model.number=\"item.qty\"\n                        :disabled=\"status.loadingItem === item.id\"\n                        @change=\"updateCart(item)\"\n                      >\n\n                      <button\n                        type=\"button\"\n                        class=\"btn btn-outline-secondary\"\n                        :disabled=\"status.loadingItem === item.id\"\n                        @click.prevent=\"increaseCartQty(item)\"\n                      >\n                        +\n                      </button>\n                    </div>\n                  </div>\n\n                  <button\n                    type=\"button\"\n                    class=\"btn btn-outline-danger btn-sm\"\n                    :disabled=\"status.loadingItem === item.id\"\n                    @click.prevent=\"removeCartItem(item.id)\"\n                  >\n                    移除\n                  </button>\n                </div>\n\n                <div class=\"preview-total\">\n                  <span>應付金額</span>\n                  <strong>{{ $filters.currency(cart.final_total || cart.total) }}</strong>\n                </div>\n\n                <router-link to=\"/user/cart\" class=\"btn btn-danger w-100 mt-3\">\n                  查看購物車內容\n                </router-link>\n              </div>\n\n              <div v-else class=\"preview-empty\">\n                <i class=\"bi bi-bag-x\"></i>\n                <p class=\"mb-2\">購物車暫無商品</p>\n                <router-link to=\"/products\" class=\"btn btn-outline-danger btn-sm\">\n                  去挑選料理\n                </router-link>\n              </div>\n            </div>\n          </li>\n\n          <!-- 訂單查詢 -->\n          <li\n            class=\"nav-item preview-wrapper\"\n            @mouseenter=\"openOrderPreview\"\n            @mouseleave=\"showOrderPreview = false\"\n          >\n            <router-link class=\"nav-link icon-link\" to=\"/admin/orders\">\n              <i class=\"bi bi-receipt-cutoff me-1\"></i>\n              訂單查詢\n              <span v-if=\"orderCount > 0\" class=\"nav-badge order-badge\">\n                {{ orderCount }}\n              </span>\n            </router-link>\n\n            <div v-if=\"showOrderPreview\" class=\"preview-panel order-preview-panel\">\n              <div class=\"preview-header\">\n                <strong>訂單查詢</strong>\n\n                <div class=\"d-flex align-items-center gap-2\">\n                  <small>{{ orderCount }} 筆</small>\n\n                  <button\n                    v-if=\"orderCount > 0\"\n                    type=\"button\"\n                    class=\"btn btn-outline-danger btn-sm clear-order-btn\"\n                    @click.prevent=\"clearOrderPreview\"\n                  >\n                    清空顯示\n                  </button>\n                </div>\n              </div>\n\n              <div v-if=\"orderList.length\">\n                <div\n                  v-for=\"item in orderList.slice(0, 5)\"\n                  :key=\"item.id\"\n                  class=\"preview-item order-preview-item\"\n                >\n                  <div class=\"order-icon-box\">\n                    <i class=\"bi bi-receipt\"></i>\n                  </div>\n\n                  <div class=\"preview-info\">\n                    <router-link\n                      class=\"preview-title\"\n                      to=\"/admin/orders\"\n                    >\n                      {{ item.user?.name || '未填寫姓名' }}\n                    </router-link>\n\n                    <div class=\"small text-muted\">\n                      {{ item.user?.email || '未填寫 Email' }}\n                    </div>\n\n                    <div class=\"small mt-1\">\n                      <span\n                        class=\"mini-status\"\n                        :class=\"isOrderPaid(item) ? 'paid' : 'unpaid'\"\n                      >\n                        {{ isOrderPaid(item) ? '已付款' : '未付款' }}\n                      </span>\n\n                      <strong class=\"text-danger ms-2\">\n                        {{ $filters.currency(item.total || 0) }}\n                      </strong>\n                    </div>\n                  </div>\n\n                  <router-link\n                    to=\"/admin/orders\"\n                    class=\"btn btn-outline-primary btn-sm\"\n                  >\n                    查看\n                  </router-link>\n                </div>\n\n                <router-link to=\"/admin/orders\" class=\"btn btn-danger w-100 mt-3\">\n                  查看全部訂單\n                </router-link>\n              </div>\n\n              <div v-else class=\"preview-empty\">\n                <i class=\"bi bi-receipt\"></i>\n                <p class=\"mb-2\">目前沒有訂單資料</p>\n                <router-link to=\"/products\" class=\"btn btn-outline-danger btn-sm\">\n                  前往點餐\n                </router-link>\n              </div>\n            </div>\n          </li>\n\n          <li class=\"nav-item ms-lg-2\">\n            <router-link class=\"btn btn-danger order-btn\" to=\"/products\">\n              立即點餐\n            </router-link>\n          </li>\n        </ul>\n      </div>\n    </div>\n  </nav>\n</template>\n\n<script>\nconst { VUE_APP_API, VUE_APP_PATH } = process.env;\n\nexport default {\n  data() {\n    return {\n      cart: {\n        carts: [],\n        total: 0,\n        final_total: 0,\n      },\n      favorites: [],\n      orders: {},\n      showCartPreview: false,\n      showFavoritePreview: false,\n      showOrderPreview: false,\n      latestPaidOrderId: localStorage.getItem('latestPaidOrderId') || '',\n      isOrderDisplayCleared: localStorage.getItem('orderDisplayCleared') === '1',\n      defaultImage: 'https://images.unsplash.com/photo-1546069901-ba9599a7e63c?w=800',\n      status: {\n        loadingItem: '',\n      },\n    };\n  },\n  computed: {\n    cartCount() {\n      if (!this.cart.carts) {\n        return 0;\n      }\n\n      return this.cart.carts.reduce((total, item) => total + Number(item.qty || 0), 0);\n    },\n\n    favoriteCount() {\n      return this.favorites.length;\n    },\n\n    orderList() {\n      if (this.isOrderDisplayCleared) {\n        return [];\n      }\n\n      if (Array.isArray(this.orders)) {\n        return this.orders;\n      }\n\n      if (this.orders && typeof this.orders === 'object') {\n        return Object.values(this.orders);\n      }\n\n      return [];\n    },\n\n    orderCount() {\n      return this.orderList.length;\n    },\n  },\n  methods: {\n    getCart() {\n      const url = `${VUE_APP_API}/api/${VUE_APP_PATH}/cart`;\n\n      this.$http.get(url)\n        .then((response) => {\n          this.cart = response.data.data || {\n            carts: [],\n            total: 0,\n            final_total: 0,\n          };\n        })\n        .catch((error) => {\n          console.log('Navbar 取得購物車失敗', error);\n        });\n    },\n\n    getFavorites() {\n      this.favorites = JSON.parse(localStorage.getItem('favoriteFoods')) || [];\n    },\n\n    increaseCartQty(item) {\n      // eslint-disable-next-line no-param-reassign\n      item.qty = Number(item.qty || 1) + 1;\n      this.updateCart(item);\n    },\n\n    decreaseCartQty(item) {\n      const qty = Number(item.qty || 1);\n\n      if (qty <= 1) {\n        this.removeCartItem(item.id);\n        return;\n      }\n\n      // eslint-disable-next-line no-param-reassign\n      item.qty = qty - 1;\n      this.updateCart(item);\n    },\n\n    getOrders() {\n      if (this.isOrderDisplayCleared) {\n        this.orders = {};\n        return;\n      }\n\n      this.latestPaidOrderId = localStorage.getItem('latestPaidOrderId') || '';\n\n      if (!this.latestPaidOrderId) {\n        this.orders = {};\n        return;\n      }\n\n      this.getOnlyPaidOrder(this.latestPaidOrderId);\n    },\n\n    getOnlyPaidOrder(orderId, page = 1) {\n      if (!orderId) {\n        this.orders = {};\n        return;\n      }\n\n      const url = `${VUE_APP_API}/api/${VUE_APP_PATH}/admin/orders?page=${page}`;\n\n      this.$http.get(url)\n        .then((response) => {\n          const ordersObject = response.data.orders || {};\n          const pagination = response.data.pagination || {};\n          const ordersArray = Object.values(ordersObject);\n\n          const matchedOrder = ordersArray.find((order) => String(order.id) === String(orderId));\n\n          if (matchedOrder) {\n            this.orders = {\n              [matchedOrder.id]: matchedOrder,\n            };\n            return;\n          }\n\n          if (pagination.has_next && page < pagination.total_pages) {\n            this.getOnlyPaidOrder(orderId, page + 1);\n            return;\n          }\n\n          this.orders = {};\n        })\n        .catch((error) => {\n          console.log('Navbar 取得指定訂單失敗', error);\n          this.orders = {};\n        });\n    },\n\n    clearOrderPreview() {\n      this.orders = {};\n      this.latestPaidOrderId = '';\n      this.isOrderDisplayCleared = true;\n\n      localStorage.removeItem('latestPaidOrderId');\n      localStorage.setItem('orderDisplayCleared', '1');\n\n      window.dispatchEvent(new Event('orders-cleared'));\n    },\n\n    updateCart(item) {\n      if (!item.id) {\n        return;\n      }\n\n      if (Number(item.qty) < 1) {\n        this.removeCartItem(item.id);\n        return;\n      }\n\n      const url = `${VUE_APP_API}/api/${VUE_APP_PATH}/cart/${item.id}`;\n\n      const cart = {\n        product_id: item.product_id,\n        qty: Number(item.qty),\n      };\n\n      this.status.loadingItem = item.id;\n\n      this.$http.put(url,