{"ast":null,"code":"import \"core-js/modules/es.array.filter.js\";\nimport \"core-js/modules/es.date.to-json.js\";\nimport \"core-js/modules/es.iterator.constructor.js\";\nimport \"core-js/modules/es.iterator.filter.js\";\nimport \"core-js/modules/es.json.parse.js\";\nimport \"core-js/modules/es.json.stringify.js\";\nimport \"core-js/modules/es.object.keys.js\";\nimport \"core-js/modules/es.object.to-string.js\";\nexport default {\n  data: function data() {\n    return {\n      favorites: JSON.parse(localStorage.getItem('favoriteFoods')) || [],\n      defaultImage: 'https://images.unsplash.com/photo-1546069901-ba9599a7e63c?w=800'\n    };\n  },\n  methods: {\n    removeFavorite: function removeFavorite(id) {\n      this.favorites = this.favorites.filter(function (item) {\n        return item.id !== id;\n      });\n      localStorage.setItem('favoriteFoods', JSON.stringify(this.favorites));\n      window.dispatchEvent(new Event('favorites-updated'));\n    }\n  }\n};","map":{"version":3,"names":["data","favorites","JSON","parse","localStorage","getItem","defaultImage","methods","removeFavorite","id","filter","item","setItem","stringify","window","dispatchEvent","Event"],"sources":["C:\\Users\\ROG Strix\\Desktop\\vue cli\\gui-demo\\src\\views\\Favorite.vue"],"sourcesContent":["<template>\n  <div class=\"container py-5\">\n    <h1 class=\"fw-bold mb-2\">我的最愛</h1>\n    <p class=\"text-muted mb-4\">\n      收藏喜歡的日韓料理，下次快速回購。\n    </p>\n\n    <div v-if=\"favorites.length\" class=\"row g-4\">\n      <div\n        v-for=\"item in favorites\"\n        :key=\"item.id\"\n        class=\"col-md-6 col-lg-4\"\n      >\n        <div class=\"card h-100 border-0 shadow-sm rounded-4 overflow-hidden\">\n          <div\n            class=\"favorite-img\"\n            :style=\"{ backgroundImage: `url(${item.imageUrl || defaultImage})` }\"\n          ></div>\n\n          <div class=\"card-body\">\n            <span class=\"badge bg-light text-dark mb-2\">\n              {{ item.category }}\n            </span>\n\n            <h5 class=\"fw-bold\">{{ item.title }}</h5>\n            <p class=\"text-muted\">{{ item.description || item.content }}</p>\n            <p class=\"text-danger fw-bold h5\">NT$ {{ item.price }}</p>\n\n            <div class=\"d-flex gap-2\">\n              <router-link\n                :to=\"`/product/${item.id}`\"\n                class=\"btn btn-outline-dark flex-fill\"\n              >\n                查看\n              </router-link>\n\n              <button\n                class=\"btn btn-outline-danger flex-fill\"\n                @click=\"removeFavorite(item.id)\"\n              >\n                移除\n              </button>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n\n    <div v-else class=\"empty-box text-center\">\n      <div class=\"display-4 mb-3\">🤍</div>\n      <h4 class=\"fw-bold\">目前沒有收藏料理</h4>\n      <p class=\"text-muted\">\n        去日韓料理頁面看看，把喜歡的料理加入我的最愛吧。\n      </p>\n      <router-link to=\"/products\" class=\"btn btn-danger\">\n        前往日韓料理\n      </router-link>\n    </div>\n  </div>\n</template>\n\n<script>\nexport default {\n  data() {\n    return {\n      favorites: JSON.parse(localStorage.getItem('favoriteFoods')) || [],\n      defaultImage: 'https://images.unsplash.com/photo-1546069901-ba9599a7e63c?w=800',\n    };\n  },\n  methods: {\n    removeFavorite(id) {\n      this.favorites = this.favorites.filter((item) => item.id !== id);\n      localStorage.setItem('favoriteFoods', JSON.stringify(this.favorites));\n      window.dispatchEvent(new Event('favorites-updated'));\n    },\n  },\n};\n</script>\n\n<style scoped>\n.favorite-img {\n  height: 220px;\n  background-size: cover;\n  background-position: center;\n}\n\n.empty-box {\n  padding: 80px 24px;\n  border-radius: 28px;\n  background: #fff8f3;\n}\n</style>"],"mappings":";;;;;;;;AA8DA,eAAe;EACbA,IAAI,WAAJA,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,SAAS,EAAEC,IAAI,CAACC,KAAK,CAACC,YAAY,CAACC,OAAO,CAAC,eAAe,CAAC,KAAK,EAAE;MACl