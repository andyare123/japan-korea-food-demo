ateElementVNode(\"div\", {\n    \"class\": \"display-5 mb-3\"\n  }, \"🧾\", -1 /* CACHED */), _createElementVNode(\"h5\", {\n    \"class\": \"fw-bold\"\n  }, \"目前沒有訂單資料\", -1 /* CACHED */), _createElementVNode(\"p\", {\n    \"class\": \"text-muted mb-0\"\n  }, \" 尚未有顧客建立訂單，或目前頁面沒有資料。 \", -1 /* CACHED */)]))))]), !$data.isOrderDisplayCleared && $options.orderList.length ? (_openBlock(), _createElementBlock(\"div\", _hoisted_36, [_createVNode(_component_Pagination, {\n    pages: $data.pagination,\n    onEmitPages: $options.getOrders\n  }, null, 8 /* PROPS */, [\"pages\", \"onEmitPages\"])])) : _createCommentVNode(\"v-if\", true)])]), _createVNode(_component_OrderModal, {\n    ref: \"orderModal\",\n    order: $data.tempOrder,\n    onUpdateOrder: $options.updatePaid\n  }, null, 8 /* PROPS */, [\"order\", \"onUpdateOrder\"])], 64 /* STABLE_FRAGMENT */);\n}","map":{"version":3,"names":["_createVNode","_component_Loading","active","$data","isLoading","_createElementVNode","_hoisted_1","_hoisted_2","_createCommentVNode","_hoisted_3","_hoisted_4","type","disabled","isOrderDisplayCleared","onClick","_cache","$event","$options","getOrders","currentPage","clearOrdersDisplay","apply","arguments","_hoisted_7","_hoisted_8","_hoisted_9","_toDisplayString","orderList","length","_hoisted_10","_hoisted_11","paidCount","_hoisted_12","_hoisted_13","unpaidCount","_hoisted_14","_createElementBlock","_hoisted_15","_hoisted_16","_Fragment","_renderList","item","key","id","_normalizeClass","isOrderPaid","_hoisted_17","_hoisted_18","create_at","_ctx","$filters","date","_hoisted_19","user","_hoisted_20","_hoisted_21","email","_hoisted_22","name","_hoisted_23","_hoisted_24","getOrderProducts","products","product","_product$product","_product$product2","_hoisted_25","title","_hoisted_26","qty","unit","_hoisted_27","_hoisted_28","_hoisted_29","currency","total","_hoisted_30","_hoisted_31","_hoisted_32","_hoisted_33","openModal","_hoisted_35","_toConsumableArray","_hoisted_36","_component_Pagination","pages","pagination","onEmitPages","_component_OrderModal","ref","order","tempOrder","onUpdateOrder","updatePaid"],"sources":["C:\\Users\\ROG Strix\\Desktop\\vue cli\\gui-demo\\src\\views\\AdminOrders.vue"],"sourcesContent":["<!-- eslint-disable vue/no-v-for-template-key -->\n<!-- eslint-disable vue/no-multiple-template-root -->\n<!-- eslint-disable vuejs-accessibility/label-has-for -->\n<template>\n  <Loading :active=\"isLoading\"></Loading>\n\n  <div class=\"admin-orders-page\">\n    <div class=\"container-fluid py-4\">\n      <!-- 頁面標題 -->\n      <div class=\"admin-hero mb-4\">\n        <div>\n          <span class=\"admin-badge\">ORDER SEARCH</span>\n          <h2 class=\"fw-bold mt-2 mb-2\">訂單查詢</h2>\n          <p class=\"text-muted mb-0\">\n            查看顧客訂單、付款狀態與選購料理內容，此頁僅提供查詢與檢視。\n          </p>\n        </div>\n\n        <div class=\"d-flex gap-2\">\n          <button\n            type=\"button\"\n            class=\"btn btn-outline-danger refresh-btn\"\n            :disabled=\"isLoading || isOrderDisplayCleared\"\n            @click=\"getOrders(currentPage)\"\n          >\n            <i class=\"bi bi-arrow-clockwise me-1\"></i>\n            重新整理\n          </button>\n\n          <button\n            type=\"button\"\n            class=\"btn btn-danger refresh-btn\"\n            :disabled=\"isLoading || isOrderDisplayCleared\"\n            @click=\"clearOrdersDisplay\"\n          >\n            <i class=\"bi bi-x-circle me-1\"></i>\n            清空顯示\n          </button>\n        </div>\n      </div>\n\n      <!-- 統計卡片 -->\n      <div class=\"row g-3 mb-4\">\n        <div class=\"col-md-4\">\n          <div class=\"stat-card\">\n            <span>本頁訂單數</span>\n            <strong>{{ orderList.length }}</strong>\n          </div>\n        </div>\n\n        <div class=\"col-md-4\">\n          <div class=\"stat-card paid\">\n            <span>已付款</span>\n            <strong>{{ paidCount }}</strong>\n          </div>\n        </div>\n\n        <div class=\"col-md-4\">\n          <div class=\"stat-card unpaid\">\n            <span>未付款</span>\n            <strong>{{ unpaidCount }}</strong>\n          </div>\n        </div>\n      </div>\n\n      <!-- 訂單列表 -->\n      <div class=\"orders-card\">\n        <div class=\"orders-card-header\">\n          <div>\n            <h4 class=\"fw-bold mb-1\">訂單列表</h4>\n            <p class=\"text-muted mb-0 small\">\n              可點擊檢視查看完整訂單內容，此頁不提供刪除功能。\n            </p>\n          </div>\n        </div>\n\n        <div v-if=\"orderList.length\" class=\"table-responsive\">\n          <table class=\"table align-middle admin-order-table mb-0\">\n            <thead>\n              <tr>\n                <th>購買時間</th>\n                <th>Email</th>\n                <th>購買款項</th>\n                <th class=\"text-end\">應付金額</th>\n                <th class=\"text-center\">付款狀態</th>\n                <th class=\"text-end\">操作</th>\n              </tr>\n            </thead>\n\n            <tbody>\n              <tr\n                v-for=\"item in orderList\"\n                :key=\"item.id\"\n                :class=\"{ 'unpaid-row': !isOrderPaid(item) }\"\n              >\n                <td class=\"order-time\">\n                  <div class=\"fw-bold\">\n                    {{ item.create_at ? $filters.date(item.create_at) : '未取得時間' }}\n                  </div>\n                  <small class=\"text-muted\">\n                    {{ item.id }}\n                  </small>\n                </td>\n\n                <td>\n                  <div v-if=\"item.user\">\n                    <div class=\"fw-bold\">\n                      {{ item.user.email || '未填寫 Email' }}\n                    </div>\n                    <small class=\"text-muted\">\n                      {{ item.user.name || '未填寫姓名' }}\n                    </small>\n                  </div>\n\n                  <span v-else class=\"text-muted\">\n                    無用戶資料\n                  </span>\n                </td>\n\n                <td>\n                  <div class=\"product-list\">\n                    <div\n                      v-for=\"product in getOrderProducts(item.products)\"\n                      :key=\"product.id\"\n                      class=\"product-pill\"\n                    >\n                      <span class=\"product-dot\"></span>\n                      <span class=\"product-title\">\n                        {{ product.product?.title || '未命名商品' }}\n                      </span>\n                      <span class=\"product-qty\">\n                        x {{ product.qty || 0 }} {{ product.product?.unit || '份' }}\n                      </span>\n                    </div>\n\n                    <span\n                      v-if=\"!getOrderProducts(item.products).length\"\n                      class=\"text-muted\"\n                    >\n                      無商品資料\n                    </span>\n                  </div>\n                </td>\n\n                <td class=\"text-end\">\n                  <strong class=\"order-total\">\n                    {{ $filters.currency(item.total || 0) }}\n                  </strong>\n                </td>\n\n                <td class=\"text-center\">\n                  <div class=\"payment-control\">\n                    <span\n                      class=\"payment-badge\"\n                      :class=\"isOrderPaid(item) ? 'paid' : 'unpaid'\"\n                    >\n                      {{ isOrderPaid(item) ? '已付款' : '未付款' }}\n                    </span>\n                  </div>\n                </td>\n\n                <td class=\"text-end\">\n                  <div class=\"btn-group action-group\">\n                    <button\n                      type=\"button\"\n                      class=\"btn btn-outline-primary btn-sm\"\n                      @click=\"openModal(false, item)\"\n                    >\n                      <i class=\"bi bi-eye me-1\"></i>\n                      檢視\n                    </button>\n                  </div>\n                </td>\n              </tr>\n            </tbody>\n          </table>\n        </div>\n\n        <div v-else class=\"empty-orders\">\n          <div class=\"display-5 mb-3\">🧾</div>\n          <h5 class=\"fw-bold\">目前沒有訂單資料</h5>\n          <p class=\"text-muted mb-0\">\n            尚未有顧客建立訂單，或目前頁面沒有資料。\n          </p>\n        </div>\n      </div>\n\n      <div class=\"mt-4\" v-if=\"!isOrderDisplayCleared && orderList.length\">\n        <Pagination\n          :pages=\"pagination\"\n          @emit-pages=\"getOrders\"\n        ></Pagination>\n      </div>\n    </div>\n  </div>\n\n  <OrderModal\n    ref=\"orderModal\"\n    :order=\"tempOrder\"\n    @update-order=\"updatePaid\"\n  ></OrderModal>\n</template>\n\n<script>\nimport OrderModal from '@/components/orderModal.vue';\nimport Pagination from '@/components/Pagination.vue';\n\nexport default {\n  name: 'AdminOrders',\n  components: {\n    Pagination,\n    OrderModal,\n  },\n  data() {\n    return {\n      orders: {},\n      isNew: false,\n      pagination: {},\n      isLoading: false,\n      tempOrder: {},\n      currentPage: 1,\n      latestPaidOrderId: '',\n      isOrderDisplayCleared: localStorage.getItem('orderDisplayCleared') === '1',\n    };\n  },\n  computed: {\n    orderList() {\n      if (this.isOrderDisplayCleared) {\n        return [];\n      }\n\n      if (Array.isArray(this.orders)) {\n        return this.orders;\n      }\n\n      if (this.orders && typeof this.orders === 'object') {\n        return Object.values(this.orders);\n      }\n\n      return [];\n    },\n\n    paidCount() {\n      return this.orderList.filter((item) => this.isOrderPaid(item)).length;\n    },\n\n    unpaidCount() {\n      return this.orderList.filter((item) => !this.isOrderPaid(item)).length;\n    },\n  },\n  methods: {\n    isOrderPaid(order) {\n      return order.is_paid === true\n        || order.is_paid === 1\n        || order.is_paid === '1'\n        || order.is_paid === 'true';\n    },\n\n    syncLatestPaidOrderId() {\n      const routeOrderId = this.$route.query.orderId || '';\n      const storageOrderId = localStorage.getItem('latestPaidOrderId') || '';\n      const finalOrderId = routeOrderId || storageOrderId;\n\n      this.latestPaidOrderId = finalOrderId;\n\n      if (finalOrderId) {\n        localStorage.removeItem('orderDisplayCleared');\n        localStorage.setItem('latestPaidOrderId', finalOrderId);\n        this.isOrderDisplayCleared = false;\n      }\n\n      return finalOrderId;\n    },\n\n    getOrderProducts(products) {\n      if (Array.isArray(products)) {\n        return products;\n      }\n\n      if (products && typeof products === 'object') {\n        return Object.values(products);\n      }\n\n      return [];\n    },\n\n    getOrders() {\n      if (this.isOrderDisplayCleared) {\n        this.orders = {};\n        this.pagination = {};\n        return;\n      }\n\n      const orderId = this.syncLatestPaidOrderId();\n\n      if (!orderId) {\n        this.orders = {};\n        this.pagination = {};\n        return;\n      }\n\n      this.getOnlyPaidOrder(orderId);\n    },\n\n    getOnlyPaidOrder(orderId) {\n      if (!orderId) {\n        this.orders = {};\n        this.pagination = {};\n        return;\n      }\n\n      const url = `${process.env.VUE_APP_API}/api/${process.env.VUE_APP_PATH}/order/${orderId}`;\n\n      this.isLoading = true;\n\n      this.$http.get(url)\n        .then((response) => {\n          if (response.data.success && response.data.order) {\n            const order = {\n              id: orderId,\n              ...response.data.order,\n            };\n\n            this.orders = {\n              [orderId]: order,\n            };\n\n            this.pagination = {};\n            this.currentPage = 1;\n            return;\n          }\n\n          this.orders = {};\n          this.pagination = {};\n\n          console.warn('找不到指定訂單：', orderId);\n        })\n        .catch((error) => {\n          console.err