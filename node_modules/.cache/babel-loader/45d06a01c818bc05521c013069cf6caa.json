ate>\n  <div class=\"container mt-5\">\n    <form class=\"row justify-content-center\" @submit.prevent=\"signin\">\n      <div class=\"col-md-6\">\n        <h1 class=\"h3 mb-3 font-weight-normal\">請先登入</h1>\n\n        <div class=\"mb-2\">\n          <label for=\"inputEmail\" class=\"sr-only\">Email address</label>\n          <input\n            id=\"inputEmail\"\n            v-model=\"user.username\"\n            type=\"email\"\n            class=\"form-control\"\n            placeholder=\"Email address\"\n            required\n            autofocus\n          />\n        </div>\n\n        <div class=\"mb-2\">\n          <label for=\"inputPassword\" class=\"sr-only\">Password</label>\n          <input\n            id=\"inputPassword\"\n            v-model=\"user.password\"\n            type=\"password\"\n            class=\"form-control\"\n            placeholder=\"Password\"\n            required\n          />\n        </div>\n\n        <div class=\"text-end mt-4\">\n          <button class=\"btn btn-lg btn-primary btn-block\" type=\"submit\">\n            登入\n          </button>\n        </div>\n      </div>\n    </form>\n  </div>\n</template>\n\n<script>\n// eslint-disable-next-line import/extensions\nimport emitter from '@/methods/emitter.js';\n\nexport default {\n  data() {\n    return {\n      user: {\n        username: '',\n        password: '',\n      },\n    };\n  },\n  methods: {\n    signin() {\n      const api = `${process.env.VUE_APP_API}/admin/signin`;\n\n      this.$http.post(api, this.user)\n        .then((res) => {\n          if (res.data.success) {\n            const { token, expired } = res.data;\n\n            document.cookie = `hexToken=${token}; expires=${new Date(expired).toUTCString()}; path=/`;\n\n            this.$router.push('/dashboard/products')\n              .then(() => {\n                emitter.emit('push-message', {\n                  style: 'success',\n                  title: '登入成功',\n                  content: '歡迎回來',\n                });\n              });\n          } else {\n            emitter.emit('push-message', {\n              style: 'danger',\n              title: '登入失敗',\n              content: res.data.message || '請確認帳號密碼是否正確',\n            });\n          }\n        })\n        .catch(() => {\n          emitter.emit('push-message', {\n            style: 'danger',\n            title: '登入失敗',\n            content: '伺服器錯誤，請稍後再試',\n          });\n        });\n    },\n  },\n};\n</script>\n"],"mappings":";AA8CA;AACA,OAAOA,OAAM,MAAO,sBAAsB;AAE1C,eAAe;EACbC,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,IAAI,EAAE;QACJC,QAAQ,EAAE,EAAE;QACZC,QAAQ,EAAE;MACZ;IACF,CAAC;EACH,CAAC;EACDC,OAAO,EAAE;IACPC,MAAMA,CAAA,EAAG;MACP,MAAMC,GAAE,GAAI,GAAGC,OAAO,CAACC,GAAG,CAACC,WAAW,eAAe;MAErD,IAAI,CAACC,KAAK,CAACC,IAAI,CAACL,GAAG,EAAE,IAAI,CAACL,IAAI,EAC3BW,IAAI,CAAEC,GAAG,IAAK;QACb,IAAIA,GAAG,CAACb,IAAI,CAACc,OAAO,EAAE;UACpB,MAAM;YAAEC,KAAK;YAAEC;UAAQ,IAAIH,GAAG,CAACb,IAAI;UAEnCiB,QAAQ,CAACC,MAAK,GAAI,YAAYH,KAAK,aAAa,IAAII,IAAI,CAACH,OAAO,CAAC,CAACI,WAAW,CAAC,CAAC,UAAU;UAEzF,IAAI,CAACC,OAAO,CAACC,IAAI,CAAC,qBAAqB,EACpCV,IAAI,CAAC,MAAM;YACVb,OAAO,CAACwB,IAAI,CAAC,cAAc,EAAE;cAC3BC,KAAK,EAAE,SAAS;cAChBC,KAAK,EAAE,MAAM;cACbC,OAAO,EAAE;YACX,CAAC,CAAC;UACJ,CAAC,CAAC;QACN,OAAO;UACL3B,OAAO,CAACwB,IAAI,CAAC,cAAc,EAAE;YAC3BC,KAAK,EAAE,QAAQ;YACfC,KAAK,EAAE,MAAM;YACbC,OAAO,EAAEb,GAAG,CAACb,IAAI,CAAC2B,OAAM,IAAK;UAC/B,CAAC,CAAC;QACJ;MACF,CAAC,EACAC,KAAK,CAAC,MAAM;QACX7B,OAAO,CAACwB,IAAI,CAAC,cAAc,EAAE;UAC3BC,KAAK,EAAE,QAAQ;UACfC,KAAK,EAAE,MAAM;UACbC,OAAO,EAAE;QACX,CAAC,CAAC;MACJ,CAAC,CAAC;IACN;EACF;AACF,CAAC","ignoreList":[]}]}