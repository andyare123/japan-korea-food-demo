{"ast":null,"code":"import \"core-js/modules/es.array.concat.js\";\nimport \"core-js/modules/es.array.push.js\";\nimport \"core-js/modules/es.object.to-string.js\";\nexport default {\n  data: function data() {\n    return {\n      product: {},\n      id: '',\n      isLoading: false,\n      defaultImage: 'https://images.unsplash.com/photo-1546069901-ba9599a7e63c?w=800'\n    };\n  },\n  methods: {\n    getProduct: function getProduct() {\n      var _this = this;\n      this.id = this.$route.params.id;\n      if (!this.id) {\n        alert('找不到產品編號');\n        this.$router.push('/products');\n        return;\n      }\n      var api = \"\".concat(process.env.VUE_APP_API, \"/api/\").concat(process.env.VUE_APP_PATH, \"/product/\").concat(this.id);\n      this.isLoading = true;\n      this.$http.get(api).then(function (response) {\n        console.log(response.data);\n        if (response.data.success) {\n          _this.product = response.data.product;\n        } else {\n          _this.product = {};\n          alert(response.data.message || '找不到產品');\n        }\n      })[\"finally\"](function () {\n        _this.isLoading = false;\n      });\n    },\n    addToCart: function addToCart(id) {\n      var _this2 = this;\n      var qty = arguments.length > 1 && arguments[1] !== undefined ? arguments[1] : 1;\n      if (!id) {\n        alert('找不到產品，無法加入購物車');\n        return;\n      }\n      var url = \"\".concat(process.env.VUE_APP_API, \"/api/\").concat(process.env.VUE_APP_PATH, \"/cart\");\n      var cart = {\n        product_id: id,\n        qty: qty\n      };\n      this.isLoading = true;\n      this.$http.post(url, {\n        data: cart\n      }).then(function (response) {\n        _this2.$httpMessageState(response, '加入購物車');\n        if (response.data.success) {\n          _this2.$router.push('/user/cart');\n        }\n      })[\"finally\"](function () {\n        _this2.isLoading = false;\n      });\n    }\n  },\n  created: function created() {\n    this.getProduct();\n  }\n};","map":{"version":3,"names":["data","product","id","isLoading","defaultImage","methods","getProduct","_this","$route","params","alert","$router","push","api","concat","process","env","VUE_APP_API","VUE_APP_PATH","$http","get","then","response","console","log","success","message","addToCart","_this2","qty","arguments","length","undefined","url","cart","product_id","post","$httpMessageState","created"],"sources":["C:\\Users\\ROG Strix\\Desktop\\vue cli\\gui-demo\\src\\views\\ProductDetail.vue"],"sourcesContent":["<!-- eslint-disable vue/no-multiple-template-root -->\n<template>\n  <Loading :active=\"isLoading\"></Loading>\n\n  <div class=\"food-detail-page\">\n    <div class=\"container py-5\">\n      <nav aria-label=\"breadcrumb\" class=\"mb-4\">\n        <ol class=\"breadcrumb\">\n          <li class=\"breadcrumb-item\">\n            <router-link to=\"/\">首頁</router-link>\n          </li>\n          <li class=\"breadcrumb-item\">\n            <router-link to=\"/products\">日韓料理</router-link>\n          </li>\n          <li class=\"breadcrumb-item active\" aria-current=\"page\">\n            {{ product.title || '料理詳情' }}\n          </li>\n        </ol>\n      </nav>\n\n      <div v-if=\"product.id\" class=\"row g-5 align-items-start\">\n        <article class=\"col-lg-7\">\n          <div\n            class=\"food-image mb-4\"\n            :style=\"{ backgroundImage: `url(${product.imageUrl})` }\"\n          ></div>\n\n          <div class=\"content-card\">\n            <span class=\"food-tag\">\n              {{ product.category || '人氣料理' }}\n            </span>\n\n            <h2 class=\"fw-bold mt-3 mb-3\">\n              {{ product.title }}\n            </h2>\n\n            <p class=\"lead text-muted\">\n              {{ product.description || '嚴選食材現點現做，適合午餐、晚餐、聚餐與追劇宵夜。' }}\n            </p>\n\n            <hr>\n\n            <h5 class=\"fw-bold mb-3\">料理介紹</h5>\n            <p class=\"food-content mb-0\">\n              {{ product.content || '精選日式與韓式人氣餐點，從主餐到聚餐分享都很適合。下單後即可加入購物車，快速完成訂購。' }}\n            </p>\n          </div>\n        </article>\n\n        <aside class=\"col-lg-5\">\n          <div class=\"order-card sticky-lg-top\">\n            <span class=\"small text-danger fw-bold\">FOOD ORDER</span>\n\n            <h3 class=\"fw-bold mt-2 mb-3\">\n              {{ product.title }}\n            </h3>\n\n            <div class=\"price-box mb-4\">\n              <div class=\"h5 text-muted\" v-if=\"!product.price\">\n                {{ $filters.currency(product.origin_price) }}\n              </div>\n\n              <del class=\"text-muted\" v-if=\"product.price\">\n                原價 {{ $filters.currency(product.origin_price) }}\n              </del>\n\n              <div class=\"display-6 fw-bold text-danger\" v-if=\"product.price\">\n                {{ $filters.currency(product.price) }}\n              </div>\n\n              <div class=\"text-muted\">\n                / {{ product.unit || '份' }}\n              </div>\n            </div>\n\n            <div class=\"notice-box mb-4\">\n              <h6 class=\"fw-bold mb-2\">推薦理由</h6>\n              <ul class=\"mb-0\">\n                <li>精選日韓人氣料理，適合正餐與聚餐。</li>\n                <li>可加入購物車後套用優惠券。</li>\n                <li>訂單成立後可前往付款頁完成付款。</li>\n              </ul>\n            </div>\n\n            <div class=\"d-grid gap-2\">\n              <button\n                type=\"button\"\n                class=\"btn btn-danger btn-lg\"\n                :disabled=\"isLoading\"\n                @click=\"addToCart(product.id)\"\n              >\n                <span\n                  v-if=\"isLoading\"\n                  class=\"spinner-grow spinner-grow-sm me-1\"\n                ></span>\n                加入購物車\n              </button>\n\n              <router-link to=\"/products\" class=\"btn btn-outline-dark\">\n                繼續挑選料理\n              </router-link>\n            </div>\n          </div>\n        </aside>\n      </div>\n\n      <div v-else-if=\"!isLoading\" class=\"empty-box text-center\">\n        <div class=\"display-5 mb-3\">🍱</div>\n        <h4 class=\"fw-bold\">找不到這項料理</h4>\n        <p class=\"text-muted\">\n          這項商品可能已下架，請回到日韓料理列表重新選擇。\n        </p>\n        <router-link to=\"/products\" class=\"btn btn-danger\">\n          返回日韓料理\n        </router-link>\n      </div>\n    </div>\n  </div>\n</template>\n\n<script>\nexport default {\n  data() {\n    return {\n      product: {},\n      id: '',\n      isLoading: false,\n      defaultImage: 'https://images.unsplash.com/photo-1546069901-ba9599a7e63c?w=800',\n    };\n  },\n  methods: {\n    getProduct() {\n      this.id = this.$route.params.id;\n\n      if (!this.id) {\n        alert('找不到產品編號');\n        this.$router.push('/products');\n        return;\n      }\n\n      const api = `${process.env.VUE_APP_API}/api/${process.env.VUE_APP_PATH}/product/${this.id}`;\n\n      this.isLoading = true;\n\n      this.$http.get(api)\n        .then((response) => {\n          console.log(response.data);\n\n          if (response.data.success) {\n            this.product = response.data.product;\n          } else {\n            this.product = {};\n            alert(response.data.message || '找不到產品');\n          }\n        })\n        .finally(() => {\n          this.isLoading = false;\n        });\n    },\n\n    addToCart(id, qty = 1) {\n      if (!id) {\n        alert('找不到產品，無法加入購物車');\n        return;\n      }\n\n      const url = `${process.env.VUE_APP_API}/api/${process.env.VUE_APP_PATH}/cart`;\n\n      const cart = {\n        product_id: id,\n        qty,\n      };\n\n      this.isLoading = true;\n\n      this.$http.post(url, { data: cart })\n        .then((response) => {\n          this.$httpMessageState(response, '加入購物車');\n\n          if (response.data.success) {\n            this.$router.push('/user/cart');\n          }\n        })\n        .finally(() => {\n          this.isLoading = false;\n        });\n    },\n  },\n  created() {\n    this.getProduct();\n  },\n};\n</script>\n\n<style scoped>\n.food-detail-page {\n  min-height: 100vh;\n  background:\n    radial-gradient(circle at top left, rgba(220, 53, 69, 0.1), transparent 30%),\n    linear-gradient(180deg, #fff7ef 0%, #ffffff 45%, #fffaf5 100%);\n}\n\n.breadcrumb a {\n  color: #b23a2e;\n  text-decoration: none;\n  font-weight: 600;\n}\n\n.food-image {\n  min-height: 460px;\n  border-radius: 30px;\n  background-size: cover;\n  background-position: center;\n  background-color: #fff2e8;\n  border: 1px solid #f1d8ca;\n  box-shadow: 0 18px 46px rgba(120, 54, 28, 0.14);\n}\n\n.content-card,\n.order-card {\n  padding: 30px;\n  border-radius: 28px;\n  background: #ffffff;\n  border: 1px solid #f1d8ca;\n  box-shadow: 0 16px 42px rgba(120, 54, 28, 0.1);\n}\n\n.order-card {\n  top: 24px;\n}\n\n.food-tag {\n  display: inline-block;\n  padding: 8px 14px;\n  border-radius: 999px;\n  color: #b23a2e;\n  background: #fff0e7;\n  font-weight: 800;\n}\n\n.food-content {\n  color: #555;\n  line-height: 1.9;\n  font-size: 16px;\n}\n\n.price-box {\n  padding: 22px;\n  border-radius: 22px;\n  background: #fff8f2;\n  border: 1px solid #f1d8ca;\n}\n\n.notice-box {\n  padding: 20px;\n  border-radius: 20px;\n  background: #fff8e1;\n  border: 1px solid #ffe0a1;\n}\n\n.notice-box li {\n  margin-bottom: 6px;\n  color: #6c5b50;\n}\n\n.empty-box {\n  padding: 80px 24px;\n  border-radius: 30px;\n  background: #ffffff;\n  border: 1px solid #f1d8ca;\n  box-shadow: 0 16px 42px rgba(120, 54, 28, 0.1);\n}\n\n@media (max-width: 991px) {\n  .sticky-lg-top {\n    position: static !important;\n  }\n\n  .food-image {\n    min-height: 340px;\n  }\n}\n\n@media (max-width: 768px) {\n  .food-image {\n    min-height: 260px;\n    border-radius: 22px;\n  }\n\n  .content-card,\n  .order-card {\n    padding: 22px;\n    border-radius: 22px;\n  }\n}\n</style>"],"mappings":";;;AAyHA,eAAe;EACbA,IAAI,WAAJA,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,OAAO,EAAE,CAAC,CAAC;MACXC,EAAE,EAAE,EAAE;MACNC,SAAS,EAAE,KAAK;MAChBC,YAAY,EAAE;IAChB,CAAC;EA