easeQty() {\n      if (this.qty <= 1) {\n        this.qty = 1;\n        return;\n      }\n      this.qty -= 1;\n    },\n    addToCart: function addToCart(id) {\n      var _this2 = this;\n      if (!id) {\n        this.pushToast('無法加入購物車', '找不到產品資料，請重新選擇料理。', 'danger');\n        return;\n      }\n      var qty = Number(this.qty) || 1;\n      if (qty < 1) {\n        this.qty = 1;\n        this.pushToast('數量錯誤', '餐點數量至少需要 1 份。', 'warning');\n        return;\n      }\n      var url = \"\".concat(process.env.VUE_APP_API, \"/api/\").concat(process.env.VUE_APP_PATH, \"/cart\");\n      var cart = {\n        product_id: id,\n        qty: qty\n      };\n      this.isLoading = true;\n      this.$http.post(url, {\n        data: cart\n      }).then(function (response) {\n        _this2.$httpMessageState(response, '加入購物車');\n        if (response.data.success) {\n          window.dispatchEvent(new Event('cart-updated'));\n          _this2.pushToast('已加入購物車', \"\\u5DF2\\u6210\\u529F\\u52A0\\u5165 \".concat(qty, \" \").concat(_this2.product.unit || '份', \" \").concat(_this2.product.title || '料理', \"\\u3002\"), 'success');\n          setTimeout(function () {\n            _this2.$router.push('/user/cart');\n          }, 800);\n        } else {\n          _this2.pushToast('加入購物車失敗', response.data.message || '請稍後再試。', 'danger');\n        }\n      })[\"catch\"](function (error) {\n        console.error('加入購物車失敗:', error);\n        _this2.pushToast('加入購物車失敗', '請確認網路連線或稍後再試。', 'danger');\n      })[\"finally\"](function () {\n        _this2.isLoading = false;\n      });\n    }\n  },\n  created: function created() {\n    this.getProduct();\n  }\n};","map":{"version":3,"names":["inject","data","product","id","qty","isLoading","defaultImage","methods","pushToast","title","content","arguments","length","undefined","style","emitter","emit","getProduct","_this","$route","params","$router","push","api","concat","process","env","VUE_APP_API","VUE_APP_PATH","$http","get","then","response","success","message","error","console","increaseQty","decreaseQty","addToCart","_this2","Number","url","cart","product_id","post","$httpMessageState","window","dispatchEvent","Event","unit","setTimeout","created"],"sources":["C:\\Users\\ROG Strix\\Desktop\\vue cli\\gui-demo\\src\\views\\ProductDetail.vue"],"sourcesContent":["<!-- eslint-disable vue/no-multiple-template-root -->\n<template>\n  <Loading :active=\"isLoading\"></Loading>\n\n  <div class=\"food-detail-page\">\n    <div class=\"container py-5\">\n      <nav aria-label=\"breadcrumb\" class=\"mb-4\">\n        <ol class=\"breadcrumb\">\n          <li class=\"breadcrumb-item\">\n            <router-link to=\"/\">首頁</router-link>\n          </li>\n          <li class=\"breadcrumb-item\">\n            <router-link to=\"/products\">日韓料理</router-link>\n          </li>\n          <li class=\"breadcrumb-item active\" aria-current=\"page\">\n            {{ product.title || '料理詳情' }}\n          </li>\n        </ol>\n      </nav>\n\n      <div v-if=\"product.id\" class=\"row g-5 align-items-start\">\n        <article class=\"col-lg-7\">\n          <div\n            class=\"food-image mb-4\"\n            :style=\"{ backgroundImage: `url(${product.imageUrl || defaultImage})` }\"\n          ></div>\n\n          <div class=\"content-card\">\n            <span class=\"food-tag\">\n              {{ product.category || '人氣料理' }}\n            </span>\n\n            <h2 class=\"fw-bold mt-3 mb-3\">\n              {{ product.title }}\n            </h2>\n\n            <p class=\"lead text-muted\">\n              {{ product.description || '嚴選食材現點現做，適合午餐、晚餐、聚餐與追劇宵夜。' }}\n            </p>\n\n            <hr>\n\n            <h5 class=\"fw-bold mb-3\">料理介紹</h5>\n            <p class=\"food-content mb-0\">\n              {{ product.content || '精選日式與韓式人氣餐點，從主餐到聚餐分享都很適合。下單後即可加入購物車，快速完成訂購。' }}\n            </p>\n          </div>\n        </article>\n\n        <aside class=\"col-lg-5\">\n          <div class=\"order-card sticky-lg-top\">\n            <span class=\"small text-danger fw-bold\">FOOD ORDER</span>\n\n            <h3 class=\"fw-bold mt-2 mb-3\">\n              {{ product.title }}\n            </h3>\n\n            <div class=\"price-box mb-4\">\n              <div class=\"h5 text-muted\" v-if=\"!product.price\">\n                {{ $filters.currency(product.origin_price) }}\n              </div>\n\n              <del class=\"text-muted\" v-if=\"product.price\">\n                原價 {{ $filters.currency(product.origin_price) }}\n              </del>\n\n              <div class=\"display-6 fw-bold text-danger\" v-if=\"product.price\">\n                {{ $filters.currency(product.price) }}\n              </div>\n\n              <div class=\"text-muted\">\n                / {{ product.unit || '份' }}\n              </div>\n            </div>\n\n            <div class=\"notice-box mb-4\">\n              <h6 class=\"fw-bold mb-2\">推薦理由</h6>\n              <ul class=\"mb-0\">\n                <li>精選日韓人氣料理，適合正餐與聚餐。</li>\n                <li>可加入購物車後套用優惠券。</li>\n                <li>訂單成立後可前往付款頁完成付款。</li>\n              </ul>\n            </div>\n\n            <div class=\"mb-4\">\n              <label class=\"form-label fw-bold\">選擇數量</label>\n\n              <div class=\"input-group qty-group\">\n                <button\n                  type=\"button\"\n                  class=\"btn btn-outline-secondary\"\n                  @click=\"decreaseQty\"\n                >\n                  -\n                </button>\n\n                <input\n                  type=\"number\"\n                  class=\"form-control text-center\"\n                  min=\"1\"\n                  v-model.number=\"qty\"\n                >\n\n                <button\n                  type=\"button\"\n                  class=\"btn btn-outline-secondary\"\n                  @click=\"increaseQty\"\n                >\n                  +\n                </button>\n\n                <span class=\"input-group-text\">\n                  {{ product.unit || '份' }}\n                </span>\n              </div>\n            </div>\n\n            <div class=\"d-grid gap-2\">\n              <button\n                type=\"button\"\n                class=\"btn btn-danger btn-lg\"\n                :disabled=\"isLoading\"\n                @click=\"addToCart(product.id)\"\n              >\n                <span\n                  v-if=\"isLoading\"\n                  class=\"spinner-grow spinner-grow-sm me-1\"\n                ></span>\n                加入購物車\n              </button>\n\n              <router-link to=\"/products\" class=\"btn btn-outline-dark\">\n                繼續挑選料理\n              </router-link>\n            </div>\n          </div>\n        </aside>\n      </div>\n\n      <div v-else-if=\"!isLoading\" class=\"empty-box text-center\">\n        <div class=\"display-5 mb-3\">🍱</div>\n        <h4 class=\"fw-bold\">找不到這項料理</h4>\n        <p class=\"text-muted\">\n          這項商品可能已下架，請回到日韓料理列表重新選擇。\n        </p>\n        <router-link to=\"/products\" class=\"btn btn-danger\">\n          返回日韓料理\n        </router-link>\n      </div>\n    </div>\n  </div>\n  <!-- 你可能喜歡的料理 -->\n  <section class=\"recommend-section mt-5\">\n    <div class=\"recommend-header mb-4\">\n      <div>\n        <span class=\"section-label\">RECOMMENDED FOR YOU</span>\n        <h3 class=\"fw-bold mt-2 mb-1\">你可能喜歡的料理</h3>\n        <p class=\"text-muted mb-0\">\n          依照這道料理的分類、口味特色與價格區間，推薦相近的日韓料理。\n        </p>\n      </div>\n\n      <router-link to=\"/products\" class=\"btn btn-outline-danger\">\n        查看更多料理\n      </router-link>\n    </div>\n\n    <div v-if=\"recommendedProducts.length\" class=\"row g-4\">\n      <div\n        v-for=\"item in recommendedProducts\"\n        :key=\"item.id\"\n        class=\"col-md-6 col-lg-4\"\n      >\n        <div class=\"recommend-card\">\n          <div\n            class=\"recommend-img\"\n            :style=\"{ backgroundImage: `url(${item.imageUrl || defaultImage})` }\"\n          >\n            <button\n              type=\"button\"\n              class=\"favorite-btn\"\n              @click=\"toggleFavorite(item)\"\n            >\n              {{ isFavorite(item.id) ? '❤️' : '🤍' }}\n            </button>\n          </div>\n\n          <div class=\"p-4\">\n            <div class=\"d-flex justify-content-between align-items-center mb-2\">\n              <span class=\"badge bg-light text-dark\">\n                {{ item.category || '精選料理' }}\n              </span>\n\n              <small class=\"text-muted\">\n                已售出 {{ item.num || 0 }} 份\n              </small>\n            </div>\n\n            <h5 class=\"fw-bold mb-2\">\n              {{ item.title }}\n            </h5>\n\n            <p class=\"recommend-reason mb-2\">\n              <i class=\"bi bi-stars me-1\"></i>\n              {{ getRecommendReason(item) }}\n            </p>\n\n            <p class=\"text-muted recommend-desc\">\n              {{ item.description || item.content || '日韓人氣料理。' }}\n            </p>\n\n            <div class=\"mb-3\">\n              <del\n                v-if=\"item.origin_price && item.origin_price !== item.price\"\n                class=\"text-muted me-2\"\n              >\n                NT$ {{ item.origin_price }}\n              </del>\n\n              <span class=\"h5 text-danger fw-bold\">\n                NT$ {{ item.price }}\n              </span>\n            </div>\n\n            <div class=\"d-flex gap-2\">\n              <router-link\n                :to=\"`/product/${item.id}`\"\n                class=\"btn btn-outline-dark flex-fill\"\n              >\n                查看詳情\n              </router-link>\n\n              <button\n                type=\"button\"\n                class=\"btn btn-danger flex-fill\"\n                @click=\"addToCart(item.id)\"\n              >\n                加入購物車\n              </button>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n\n    <div v-else class=\"recommend-empty text-center\">\n      <div class=\"display-5 mb-3\">🍱</div>\n      <h5 class=\"fw-bold\">目前沒有其他推薦料理</h5>\n      <p class=\"text-muted mb-0\">\n        你可以回到日韓料理頁面查看更多餐點。\n      </p>\n    </div>\n  </section>\n</template>\n\n<script>\nexport default {\n  inject: ['emitter'],\n  data() {\n    return {\n      product: {},\n      id: '',\n      qty: 1,\n      isLoading: false,\n      defaultImage: 'https://images.unsplash.com/photo-1546069901-ba9599a7e63c?w=800',\n    };\n  },\n  methods: {\n    pushToast(title, content = '', style = 'danger') {\n      this.emitter.emit('push-message', {\n        style,\n        title,\n        content,\n      });\n    },\n\n    getProduct() {\n      this.id = this.$route.params.id;\n\n      if (!this.id) {\n        this.pushToast(\n          '找不到產品編號',\n          '請回到日韓料理列表重新選擇料理。',\n          'danger',\n        );\n\n        this.$router.push('/products');\n        return;\n      }\n\n      const api = `${process.env.VUE_APP_API}/api/${process.env.VUE_APP_PATH}/product/${this.id}`;\n\n      this.isLoading = true;\n\n      this.$http.get(api)\n        .then((response) => {\n          if (response.data.success) {\n            this.product = response.data.product;\n          } else {\n            this.product = {};\n\n            this.pushToast(\n              '找不到產品',\n              response.data.message || '這項商品可能已下架，請重新選擇料理。',\n              'danger',\n            );\n          }\n        })\n        .catch((error) => {\n          console.error('取得料理詳情失敗:', error);\n\n          this.product = {};\n\n          this.pushToast(\n            '取得料理詳情失敗',\n            '請稍後再試，或回到日韓料理列表重新選擇。',\n            'danger',\n          );\n        })\n        .finally(() => {\n          this.isLoading = false;\n        });\n    },\n\n    increaseQty() {\n      this.qty += 1;\n    },\n\n    decreaseQty() {\n      if (this.qty <= 1) {\n        this.qty = 1;\n        return;\n      }\n\n      this.qty -= 1;\n    },\n\n    addToCart(id) {\n      if (!id) {\n        this.pushToast(\n          '無法加入購物車',\n          '找不到產品資料，請重新選擇料理。',\n          'danger',\n        );\n        return;\n      }\n\n      const qty = Number(this.qty) || 1;\n\n      if (qty < 1) {\n        this.qty = 1;\n\n        this.pushToast(\n          '數量錯誤',\n          '餐點數量至少需要 1 份。',\n          'warning',\n        );\n        return;\n      }\n\n      const url = `${process.env.VUE_APP_API}/api/${process.env.VUE_APP_PATH}/cart`;\n\n      const cart = {\n        product_id: id,\n        qty,\n      };\n\n      this.isLoading = true;\n\n      this.$http.post(url, { data: cart })\n        .then((response) => {\n          this.$httpMessageState(response, '加入購物車');\n\n          if (response.data.success) {\n            window.dispatchEvent(new Event('cart-updated'));\n\n            this.pushToast(\n              '已加入購物車',\n              `已成功加入 ${qty} ${this.product.unit || '份'} ${this.product.title || '料理'}。`,\n              'success',\n            );\n\n            setTimeout(() => {\n              this.$router.push('/user/cart');\n            }, 800);\n          } else {\n            this.pushToast(\n              '加入購物車失敗',\n              response.data.message || '請稍後再試。',\n              'danger',\n            );\n          }\n        })\n        .catch((error) => {\n          console.error('加入購物車失敗:', error);\n\n          this.pushToast(\n            '加入購物車失敗',\n            '請確認網路連線或稍後再試。',\n            'danger',\n          );\n        })\n        .finally(() => {\n          this.isLoading = false;\n        });\n    },\n  },\n  created() {\n    this.getProduct();\n  },\n};\n</script>\n\n<style scoped>\n.food-detail-page {\n  min-height: 100vh;\n  background:\n    radial-gradient(circle at top left, rgba(220, 53, 69, 0.1), transparent 30%),\n    linear-gradient(180deg, #fff7ef 0%, #ffffff 45%, #fffaf5 100%);\n}\n\n.breadcrumb a {\n  color: #b23a2e;\n  text-decoration: none;\n  font-weight: 600;\n}\n\n.food-image {\n  min-height: 460px;\n  border-radius: 30px;\n  background-size: cover;\n  background-position: center;\n  background-color: #fff2e8;\n  border: 1px solid #f1d8ca;\n  box-shadow: 0 18px 46px rgba(120, 54, 28, 0.14);\n}\n\n.content-card,\n.order-card {\n  padding: 30px;\n  border-radius: 28px;\n  background: #ffffff;\n  border: 1px solid #f1d8ca;\n  box-shadow: 0 16px 42px rgba(120, 54, 28, 0.1);\n}\n\n.order-card {\n  top: 24px;\n}\n\n.food-tag {\n  display: inline-block;\n  padding: 8px 14px;\n  border-radius: 999px;\n  color: #b23a2e;\n  background: #fff0e7;\n  font-weight: 800;\n}\n\n.food-content {\n  color: #555;\n  line-height: 1.9;\n  font-size: 16px;\n}\n\n.price-box {\n  padding: 22px;\n  border-radius: 22px;\n  background: #fff8f2;\n  border: 1px solid #f1d8ca;\n}\n\n.notice-box {\n  padding: 20px;\n  border-radius: 20px;\n  background: #fff8e1;\n  border: 1px solid #ffe0a1;\n}\n\n.notice-box li {\n  margin-bottom: 6px;\n  color: #6c5b50;\n}\n\n.empty-box {\n  padding: 80px 24px;\n  border-radius: 30px;\n  background: #ffffff;\n  border: 1px solid #f1d8ca;\n  box-shadow: 0 16px 42px rgba(120, 54, 28, 0.1);\n}\n.qty-group {\n  max-width: 260px;\n}\n\n.qty-group .form-control {\n  font-weight: 700;\n}\n@media (max-width: 991px) {\n  .sticky-lg-top {\n    position: static !important;\n  }\n\n  .food-image {\n    min-height: 340px;\n  }\n}\n\n@media (max-width: 768px) {\n  .food-image {\n    min-height: 260px;\n    border-radius: 22px;\n  }\n\n  .content-card,\n  .order-card {\n    padding: 22px;\n    border-radius: 22px;\n  }\n}\n</style>"],"mappings":";;;;;AAgQA,eAAe;EACbA,MAAM,EAAE,CAAC,SAAS,CAAC;EACnBC,IAAI,WAAJA,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,OAAO,EAAE,CAAC,CAAC;MACXC,EAAE,EAAE,EAAE;MACNC,GAAG,EAAE,CAAC;MACNC,SAAS,EAAE,KAAK;MAChBC,YAAY,EAAE;IAChB,CAAC;EACH,CAAC;EACDC,OAAO,EAAE;IACPC,SAAS,WAATA,SAASA,CAACC,KAAK,EAAkC;MAAA,IAAhCC,OAAM,GAAAC,SAAA,CAAAC,MAAA,QAAAD,SAAA,QAAAE,SAAA,GAAAF,SAAA,MAAI,EAAE;MAAA,IAAEG,KAAI,GAAAH,SAAA,CAAAC,MAAA,QAAAD,SAAA,QAAAE,SAAA,GAAAF,SAAA,MA