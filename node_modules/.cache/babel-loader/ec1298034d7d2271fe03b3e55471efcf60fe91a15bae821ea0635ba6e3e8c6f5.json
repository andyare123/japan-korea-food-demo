{"ast":null,"code":"import \"core-js/modules/es.array.concat.js\";\nimport \"core-js/modules/es.object.to-string.js\";\nexport default {\n  name: 'AdminProducts',\n  data: function data() {\n    return {\n      isLoading: false,\n      products: []\n    };\n  },\n  methods: {\n    getProducts: function getProducts() {\n      var _this = this;\n      var url = \"\".concat(process.env.VUE_APP_API, \"/api/\").concat(process.env.VUE_APP_PATH, \"/admin/products/all\");\n      this.isLoading = true;\n      this.$http.get(url).then(function (res) {\n        _this.products = res.data.products || [];\n      })[\"finally\"](function () {\n        _this.isLoading = false;\n      });\n    },\n    editProduct: function editProduct(item) {\n      alert(\"\\u4E4B\\u5F8C\\u53EF\\u4EE5\\u63A5\\u7DE8\\u8F2F\\u8AB2\\u7A0B\\u9801\\uFF1A\".concat(item.title));\n    },\n    deleteProduct: function deleteProduct(id) {\n      var _this2 = this;\n      var confirmDelete = window.confirm('確定要刪除這門課程嗎？');\n      if (!confirmDelete) {\n        return;\n      }\n      var url = \"\".concat(process.env.VUE_APP_API, \"/api/\").concat(process.env.VUE_APP_PATH, \"/admin/product/\").concat(id);\n      this.isLoading = true;\n      this.$http[\"delete\"](url).then(function (res) {\n        _this2.$httpMessageState(res, '刪除課程');\n        if (res.data.success) {\n          _this2.getProducts();\n        }\n      })[\"finally\"](function () {\n        _this2.isLoading = false;\n      });\n    }\n  },\n  created: function created() {\n    this.getProducts();\n  }\n};","map":{"version":3,"names":["name","data","isLoading","products","methods","getProducts","_this","url","concat","process","env","VUE_APP_API","VUE_APP_PATH","$http","get","then","res","editProduct","item","alert","title","deleteProduct","id","_this2","confirmDelete","window","confirm","$httpMessageState","success","created"],"sources":["C:\\Users\\ROG Strix\\Desktop\\vue cli\\gui-demo\\src\\views\\AdminProducts.vue"],"sourcesContent":["<!-- eslint-disable vue/no-multiple-template-root -->\n<template>\n  <Loading :active=\"isLoading\"></Loading>\n\n  <main class=\"admin-products-page\">\n    <div class=\"container py-5\">\n      <div class=\"page-header mb-4\">\n        <div>\n          <span class=\"page-badge\">後台管理</span>\n          <h1 class=\"fw-bold mt-3 mb-2\">課程管理</h1>\n          <p class=\"text-muted mb-0\">\n            管理前台顯示的所有程式設計課程，可新增、編輯或刪除課程。\n          </p>\n        </div>\n\n        <router-link to=\"/dashboard/create-course\" class=\"btn btn-primary btn-lg\">\n          <i class=\"bi bi-plus-circle me-1\"></i>\n          新增課程\n        </router-link>\n      </div>\n\n      <div class=\"admin-card\">\n        <div class=\"table-responsive\">\n          <table class=\"table align-middle mb-0\">\n            <thead>\n              <tr>\n                <th width=\"120\">圖片</th>\n                <th>課程名稱</th>\n                <th width=\"140\">分類</th>\n                <th width=\"120\">售價</th>\n                <th width=\"100\">狀態</th>\n                <th width=\"180\" class=\"text-end\">操作</th>\n              </tr>\n            </thead>\n\n            <tbody>\n              <tr v-for=\"item in products\" :key=\"item.id\">\n                <td>\n                  <div\n                    class=\"product-thumb\"\n                    :style=\"{ backgroundImage: `url(${item.imageUrl})` }\"\n                  ></div>\n                </td>\n\n                <td>\n                  <div class=\"fw-bold\">\n                    {{ item.title }}\n                  </div>\n                  <small class=\"text-muted\">\n                    {{ item.description || '尚未填寫課程描述' }}\n                  </small>\n                </td>\n\n                <td>\n                  <span class=\"category-badge\">\n                    {{ item.category || '未分類' }}\n                  </span>\n                </td>\n\n                <td class=\"fw-bold text-danger\">\n                  {{ $filters.currency(item.price) }}\n                </td>\n\n                <td>\n                  <span v-if=\"item.is_enabled\" class=\"text-success fw-bold\">\n                    啟用\n                  </span>\n                  <span v-else class=\"text-muted\">\n                    未啟用\n                  </span>\n                </td>\n\n                <td class=\"text-end\">\n                  <div class=\"btn-group btn-group-sm\">\n                    <button\n                      type=\"button\"\n                      class=\"btn btn-outline-primary\"\n                      @click=\"editProduct(item)\"\n                    >\n                      編輯\n                    </button>\n\n                    <button\n                      type=\"button\"\n                      class=\"btn btn-outline-danger\"\n                      @click=\"deleteProduct(item.id)\"\n                    >\n                      刪除\n                    </button>\n                  </div>\n                </td>\n              </tr>\n\n              <tr v-if=\"!products.length && !isLoading\">\n                <td colspan=\"6\">\n                  <div class=\"empty-box\">\n                    <i class=\"bi bi-journal-code\"></i>\n                    <h5 class=\"fw-bold mt-3 mb-2\">目前尚無課程</h5>\n                    <p class=\"text-muted mb-3\">\n                      請先新增一門程式設計課程，讓前台可以顯示商品。\n                    </p>\n\n                    <router-link to=\"/dashboard/create-course\" class=\"btn btn-primary\">\n                      新增第一門課程\n                    </router-link>\n                  </div>\n                </td>\n              </tr>\n            </tbody>\n          </table>\n        </div>\n      </div>\n    </div>\n  </main>\n</template>\n\n<script>\nexport default {\n  name: 'AdminProducts',\n  data() {\n    return {\n      isLoading: false,\n      products: [],\n    };\n  },\n  methods: {\n    getProducts() {\n      const url = `${process.env.VUE_APP_API}/api/${process.env.VUE_APP_PATH}/admin/products/all`;\n\n      this.isLoading = true;\n\n      this.$http.get(url)\n        .then((res) => {\n          this.products = res.data.products || [];\n        })\n        .finally(() => {\n          this.isLoading = false;\n        });\n    },\n\n    editProduct(item) {\n      alert(`之後可以接編輯課程頁：${item.title}`);\n    },\n\n    deleteProduct(id) {\n      const confirmDelete = window.confirm('確定要刪除這門課程嗎？');\n\n      if (!confirmDelete) {\n        return;\n      }\n\n      const url = `${process.env.VUE_APP_API}/api/${process.env.VUE_APP_PATH}/admin/product/${id}`;\n\n      this.isLoading = true;\n\n      this.$http.delete(url)\n        .then((res) => {\n          this.$httpMessageState(res, '刪除課程');\n\n          if (res.data.success) {\n            this.getProducts();\n          }\n        })\n        .finally(() => {\n          this.isLoading = false;\n        });\n    },\n  },\n  created() {\n    this.getProducts();\n  },\n};\n</script>\n\n<style scoped>\n.admin-products-page {\n  min-height: 100vh;\n  background: linear-gradient(180deg, #f5f8ff 0%, #ffffff 44%, #f8f9fa 100%);\n}\n\n.page-header {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  gap: 24px;\n  padding: 36px;\n  border-radius: 28px;\n  background:\n    linear-gradient(135deg, rgba(13, 110, 253, 0.12), rgba(255, 255, 255, 0.96)),\n    #ffffff;\n  box-shadow: 0 18px 45px rgba(30, 60, 120, 0.1);\n}\n\n.page-header h1 {\n  font-size: 40px;\n}\n\n.page-badge {\n  display: inline-block;\n  padding: 8px 14px;\n  border-radius: 999px;\n  color: #0d6efd;\n  background: #eaf2ff;\n  font-weight: 700;\n}\n\n.admin-card {\n  padding: 24px;\n  border-radius: 28px;\n  background: #ffffff;\n  box-shadow: 0 18px 45px rgba(30, 60, 120, 0.1);\n}\n\n.product-thumb {\n  width: 96px;\n  height: 64px;\n  border-radius: 14px;\n  background-size: cover;\n  background-position: center;\n  background-color: #f1f3f5;\n}\n\n.category-badge {\n  display: inline-block;\n  padding: 6px 10px;\n  border-radius: 999px;\n  color: #0d6efd;\n  background: #eaf2ff;\n  font-size: 13px;\n  font-weight: 700;\n}\n\n.empty-box {\n  padding: 48px 20px;\n  text-align: center;\n  color: #6c757d;\n}\n\n.empty-box i {\n  font-size: 44px;\n  color: #adb5bd;\n}\n\n@media (max-width: 768px) {\n  .container {\n    padding-left: 18px;\n    padding-right: 18px;\n  }\n\n  .page-header {\n    flex-direction: column;\n    align-items: flex-start;\n    padding: 28px 22px;\n    border-radius: 24px;\n  }\n\n  .page-header h1 {\n    font-size: 30px;\n  }\n\n  .page-header .btn {\n    width: 100%;\n  }\n\n  .admin-card {\n    padding: 16px;\n    border-radius: 22px;\n  }\n}\n</style>"],"mappings":";;AAqHA,eAAe;EACbA,IAAI,EAAE,eAAe;EACrBC,IAAI,WAAJA,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,SAAS,EAAE,KAAK;MAChBC,QAAQ,EAAE;IACZ,CAAC;EACH,CAAC;EACDC,OAAO,EAAE;IACPC,WAAW,WAAXA,WAAWA,CAAA,EAAG;MAAA,IAAAC,KAAA;MACZ,IAAMC,GAAE,MAAAC,MAAA,CAAOC,OAAO,CAACC,GAAG,CAACC,WAAW,WAAAH,MAAA,CAAQC,OAAO,CAACC,GAAG,CAACE,YAAY,wBAAqB;MAE3F,IAAI,CAACV,SAAQ,GAAI,IAAI;MAErB,IAAI,CAACW,KAAK,CAACC,GAAG,CAACP,GAAG,EACfQ,IAAI,CAAC,UAACC,GAAG,EAAK;QACbV,KAAI,CAACH,QAAO,GAAIa,GAAG,CAACf,IAAI,CAACE,QAAO,IAAK,EAAE;MACzC,CAAC,YACO,CAAC,YAAM;QACbG,KAAI,CAACJ,SAAQ,GAAI,KAAK;MACxB,CAAC,CAAC;IACN,CAAC;IAEDe,WAAW,WAAXA,WAAWA,CAACC,IAAI,EAAE;MAChBC,KAAK,sEAAAX,MAAA,CAAeU,IAAI,CAACE,KAAK,CAAE,CAAC;IACnC,CAAC;IAEDC,aAAa,WAAbA,aAAaA,CAACC,EAAE,EAAE;MAAA,IAAAC,MAAA;MAChB,IAAMC,aAAY,GAAIC,MAAM,CAACC,OAAO,CAAC,aAAa,CAAC;MAEnD,IAAI,CAACF,aAAa,EAAE;QAClB;MACF;MAEA,IAAMjB,GAAE,MAAAC,MAAA,CAAOC,OAAO,CAACC,GAAG,CAACC,WAAW,WAAAH,MAAA,CAAQC,OAAO,CAACC,GAAG,CAACE,YAAY,qBAAAJ,MAAA,CAAkBc,EAAE,CAAE;MAE5F,IAAI,CAACpB,SAAQ,GAAI,IAAI;MAErB,IAAI,CAACW,KAAK,UAAO,CAACN,GAAG,EAClBQ,IAAI,CAAC,UAACC,GAAG,EAAK;QACbO,MAAI,CAACI,iBAAiB,CAACX,GAAG,EAAE,MAAM,CAAC;QAEnC,IAAIA,GAAG,CAACf,IAAI,CAAC2B,OAAO,EAAE;UACpBL,MAAI,CAAClB,WAAW,CAAC,CAAC;QACpB;MACF,CAAC,YACO,CAAC,YAAM;QACbkB,MAAI,CAACrB,SAAQ,GAAI,KAAK;MACxB,CAAC,CAAC;IACN;EACF,CAAC;EACD2B,OAAO,WAAPA,OAAOA,CAAA,EA