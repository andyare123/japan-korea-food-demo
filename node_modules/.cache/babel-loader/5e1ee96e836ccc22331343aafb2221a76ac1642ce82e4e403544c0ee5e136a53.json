trong>\n            ，享課程折扣優惠。\n          </p>\n        </div>\n        <i class=\"bi bi-ticket-perforated coupon-icon\"></i>\n      </div>\n\n      <div class=\"section-heading mb-4\">\n        <div>\n          <h2 class=\"fw-bold mb-2\">熱門課程</h2>\n          <p class=\"text-muted mb-0\">\n            選擇一門課程，開始打造可以放進履歷的專案能力。\n          </p>\n        </div>\n      </div>\n\n      <div class=\"row g-4\">\n        <div\n          class=\"col-12 col-md-6 col-lg-4\"\n          v-for=\"item in products\"\n          :key=\"item.id\"\n        >\n          <ProductCard\n            :product=\"item\"\n            :is-favorite=\"isFavorite(item.id)\"\n            @toggle-favorite=\"toggleFavorite\"\n            @add-cart=\"addToCart\"\n          />\n        </div>\n      </div>\n\n      <div v-if=\"!products.length && !isLoading\" class=\"empty-products mt-4\">\n        目前尚無課程資料。\n      </div>\n    </section>\n  </main>\n</template>\n\n<script>\nimport ProductCard from '@/components/ProductCard.vue';\nimport userApi from '@/api/userApi';\n\nexport default {\n  name: 'ProductsView',\n  components: {\n    ProductCard,\n  },\n  data() {\n    return {\n      products: [],\n      favorites: JSON.parse(localStorage.getItem('favorites')) || [],\n      isLoading: false,\n    };\n  },\n  methods: {\n    getProducts() {\n      this.isLoading = true;\n\n      userApi.getProducts()\n        .then((res) => {\n          this.products = res.data.products || [];\n        })\n        .finally(() => {\n          this.isLoading = false;\n        });\n    },\n\n    addToCart(productId) {\n      this.isLoading = true;\n\n      userApi.addToCart(productId)\n        .then((res) => {\n          alert(res.data.message || '已加入購物車');\n\n          if (res.data.success) {\n            this.$router.push('/cart');\n          }\n        })\n        .finally(() => {\n          this.isLoading = false;\n        });\n    },\n\n    toggleFavorite(product) {\n      const index = this.favorites.findIndex((item) => item.id === product.id);\n\n      if (index === -1) {\n        this.favorites.push(product);\n      } else {\n        this.favorites.splice(index, 1);\n      }\n\n      localStorage.setItem('favorites', JSON.stringify(this.favorites));\n    },\n\n    isFavorite(productId) {\n      return this.favorites.some((item) => item.id === productId);\n    },\n  },\n  mounted() {\n    this.getProducts();\n  },\n};\n</script>\n\n<style scoped>\n.products-page {\n  min-height: 100vh;\n  background: linear-gradient(180deg, #f5f8ff 0%, #ffffff 42%, #f8f9fa 100%);\n}\n\n.products-hero {\n  padding: 56px 0 24px;\n}\n\n.products-hero-card {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  gap: 32px;\n  padding: 42px;\n  border-radius: 32px;\n  background:\n    linear-gradient(135deg, rgba(13, 110, 253, 0.13), rgba(255, 255, 255, 0.95)),\n    #ffffff;\n  box-shadow: 0 18px 45px rgba(30, 60, 120, 0.12);\n}\n\n.products-hero-card h1 {\n  max-width: 720px;\n  font-size: 40px;\n  line-height: 1.35;\n}\n\n.products-hero-card p {\n  max-width: 680px;\n  font-size: 17px;\n  line-height: 1.8;\n}\n\n.hero-badge {\n  display: inline-block;\n  padding: 8px 14px;\n  border-radius: 999px;\n  color: #0d6efd;\n  background: #eaf2ff;\n  font-weight: 700;\n}\n\n.hero-actions {\n  display: flex;\n  gap: 12px;\n  flex-shrink: 0;\n}\n\n.coupon-alert {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  gap: 24px;\n  padding: 24px 28px;\n  border-radius: 24px;\n  background: #fff8e1;\n  border: 1px solid #ffe4a3;\n  box-shadow: 0 12px 30px rgba(130, 96, 20, 0.08);\n}\n\n.coupon-alert p {\n  color: #6c757d;\n}\n\n.coupon-icon {\n  font-size: 42px;\n  color: #f0ad00;\n}\n\n.section-heading {\n  display: flex;\n  justify-content: space-between;\n  align-items: end;\n}\n\n.empty-products {\n  padding: 40px 20px;\n  border-radius: 20px;\n  text-align: center;\n  color: #6c757d;\n  background: #ffffff;\n  border: 1px dashed #d8dee8;\n}\n\n@media (max-width: 991px) {\n  .products-hero-card {\n    flex-direction: column;\n    align-items: flex-start;\n  }\n\n  .hero-actions {\n    width: 100%;\n  }\n\n  .hero-actions .btn {\n    flex: 1;\n  }\n}\n\n@media (max-width: 768px) {\n  .products-hero {\n    padding: 32px 0 16px;\n  }\n\n  .products-hero-card {\n    padding: 28px 22px;\n    border-radius: 24px;\n  }\n\n  .products-hero-card h1 {\n    font-size: 28px;\n  }\n\n  .products-hero-card p {\n    font-size: 15px;\n  }\n\n  .hero-actions {\n    flex-direction: column;\n  }\n\n  .hero-actions .btn {\n    width: 100%;\n  }\n\n  .coupon-alert {\n    align-items: flex-start;\n    padding: 20px;\n  }\n\n  .coupon-icon {\n    display: none;\n  }\n}\n</style>"],"mappings":";;;;;;;;;;;AA8EA,OAAOA,WAAU,MAAO,8BAA8B;AACtD,OAAOC,OAAM,MAAO,eAAe;AAEnC,eAAe;EACbC,IAAI,EAAE,cAAc;EACpBC,UAAU,EAAE;IACVH,WAAW,EAAXA;EACF,CAAC;EACDI,IAAI,WAAJA,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,QAAQ,EAAE,EAAE;MACZC,SAAS,EAAEC,IAAI,CAACC,KAAK,CAACC,YAAY,CAACC,OAAO,CAAC,WAAW,CAAC,KAAK,EAAE;MAC9DC,SAAS,EAAE;IACb,CAAC;EACH,CAAC;EACDC,OAAO,EAAE;IACPC,WAAW,WAAXA,WAAWA,CAAA,EAAG;MAAA,IAAAC,KAAA;MACZ,IAAI,CAACH,SAAQ,GAAI,IAAI;MAErBV,OAAO,CAACY,WAAW,CAAC,EACjBE,IAAI,CAAC,UAACC,GAAG,EAAK;QACbF,KAAI,CAACT,QAAO,GAAIW,GAAG,CAACZ,IAAI,CAACC,QAAO,IAAK,EAAE;MACzC,CAAC,YACO,CAAC,YAAM;QACbS,KAAI,CAACH,SAAQ,GAAI,KAAK;MACxB,CAAC,CAAC;IACN,CAAC;IAEDM,SAAS,WAATA,SAASA,CAACC,SAAS,EAAE;MAAA,IAAAC,MAAA;MACnB,IAAI,CAACR,SAAQ,GAAI,IAAI;MAErBV,OAAO,CAACgB,SAAS,CAACC,SAAS,EACxBH,IAAI,CAAC,UAACC,GAAG,EAAK;QACbI,KAAK,CAACJ,GAAG,CAACZ,IAAI,CAACiB,OAAM,IAAK,QAAQ,CAAC;QAEnC,IAAIL,GAAG,CAACZ,IAAI,CAACkB,OAAO,EAAE;UACpBH,MAAI,CAACI,OAAO,CAACC,IAAI,CAAC,OAAO,CAAC;QAC5B;MACF,CAAC,YACO,CAAC,YAAM;QACbL,MAAI,CAACR,SAAQ,GAAI,KAAK;MACxB,CAAC,CAAC;IACN,CAAC;IAEDc,cAAc,WAAdA,cAAcA,CAACC,OAAO,EAAE;MACtB,IAAMC,KAAI,GAAI,IAAI,CAACrB,SAAS,CAACsB,SAAS,CAAC,UAACC,IAAI;QAAA,OAAKA,IAAI,CAACC,EAAC,KAAMJ,OAAO,CAACI,EAAE;MAAA,EAAC;MAExE,IAAIH,KAAI,KAAM,CAAC,CAAC,EAAE;QAChB,IAAI,CAACrB,SAAS,CAACkB,IAAI,CAACE,OAAO