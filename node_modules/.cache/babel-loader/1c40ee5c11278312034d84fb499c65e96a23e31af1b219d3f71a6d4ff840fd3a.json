{"ast":null,"code":"import \"core-js/modules/es.array.filter.js\";\nimport \"core-js/modules/es.date.to-json.js\";\nimport \"core-js/modules/es.iterator.constructor.js\";\nimport \"core-js/modules/es.iterator.filter.js\";\nimport \"core-js/modules/es.json.parse.js\";\nimport \"core-js/modules/es.json.stringify.js\";\nimport \"core-js/modules/es.object.keys.js\";\nimport \"core-js/modules/es.object.to-string.js\";\nimport ProductCard from '@/components/ProductCard.vue';\n// eslint-disable-next-line import/extensions\nimport userApi from '@/api/userApi';\nexport default {\n  name: 'FavoriteView',\n  components: {\n    ProductCard: ProductCard\n  },\n  data: function data() {\n    return {\n      favorites: JSON.parse(localStorage.getItem('favorites')) || []\n    };\n  },\n  methods: {\n    removeFavorite: function removeFavorite(product) {\n      this.favorites = this.favorites.filter(function (item) {\n        return item.id !== product.id;\n      });\n      localStorage.setItem('favorites', JSON.stringify(this.favorites));\n    },\n    addToCart: function addToCart(productId) {\n      userApi.addToCart(productId).then(function (res) {\n        alert(res.data.message || '已加入購物車');\n      });\n    }\n  }\n};","map":{"version":3,"names":["ProductCard","userApi","name","components","data","favorites","JSON","parse","localStorage","getItem","methods","removeFavorite","product","filter","item","id","setItem","stringify","addToCart","productId","then","res","alert","message"],"sources":["C:\\Users\\ROG Strix\\Desktop\\vue cli\\gui-demo\\src\\views\\Favorite.vue"],"sourcesContent":["<!-- eslint-disable import/extensions -->\n<template>\n  <main class=\"container py-5\">\n    <h1 class=\"fw-bold mb-3\">我的最愛</h1>\n    <p class=\"text-muted mb-4\">\n      收藏感興趣的課程，之後可以快速回來比較與購買。\n    </p>\n\n    <div v-if=\"favorites.length\" class=\"row\">\n      <div\n        class=\"col-12 col-md-6 col-lg-4 mb-4\"\n        v-for=\"item in favorites\"\n        :key=\"item.id\"\n      >\n        <ProductCard\n          :product=\"item\"\n          :is-favorite=\"true\"\n          @toggle-favorite=\"removeFavorite\"\n          @add-cart=\"addToCart\"\n        />\n      </div>\n    </div>\n\n    <div v-else class=\"empty-favorite\">\n      <h4 class=\"fw-bold\">目前尚未收藏課程</h4>\n      <p class=\"text-muted\">去探索課程，收藏你感興趣的學習內容。</p>\n      <router-link to=\"/products\" class=\"btn btn-primary\">\n        探索課程\n      </router-link>\n    </div>\n  </main>\n</template>\n\n<script>\nimport ProductCard from '@/components/ProductCard.vue';\n// eslint-disable-next-line import/extensions\nimport userApi from '@/api/userApi';\n\nexport default {\n  name: 'FavoriteView',\n  components: {\n    ProductCard,\n  },\n  data() {\n    return {\n      favorites: JSON.parse(localStorage.getItem('favorites')) || [],\n    };\n  },\n  methods: {\n    removeFavorite(product) {\n      this.favorites = this.favorites.filter((item) => item.id !== product.id);\n      localStorage.setItem('favorites', JSON.stringify(this.favorites));\n    },\n\n    addToCart(productId) {\n      userApi.addToCart(productId)\n        .then((res) => {\n          alert(res.data.message || '已加入購物車');\n        });\n    },\n  },\n};\n</script>\n\n<style scoped>\n.empty-favorite {\n  padding: 56px 24px;\n  border-radius: 24px;\n  text-align: center;\n  background: #f8f9fa;\n}\n</style>"],"mappings":";;;;;;;;AAkCA,OAAOA,WAAU,MAAO,8BAA8B;AACtD;AACA,OAAOC,OAAM,MAAO,eAAe;AAEnC,eAAe;EACbC,IAAI,EAAE,cAAc;EACpBC,UAAU,EAAE;IACVH,WAAW,EAAXA;EACF,CAAC;EACDI,IAAI,WAAJA,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,SAAS,EAAEC,IAAI,CAACC,KAAK,CAACC,YAAY,CAACC,OAAO,CAAC,WAAW,CAAC,KAAK;IAC9D,CAAC;EACH,CAAC;EACDC,OAAO,EAAE;IACPC,cAAc,WAAdA,cAAcA,CAACC,OAAO,EAAE;MACtB,IAAI,CAACP,SAAQ,GAAI,IAAI,CAACA,SAAS,CAACQ,MAAM,CAAC,UAACC,IAAI;QAAA,OAAKA,IAAI,CAACC,EAAC,KAAMH,OAAO,CAACG,EAAE;MAAA,EAAC;MACxEP,YAAY,CAACQ,OAAO,CAAC,WAAW,EAAEV,IAAI,CAACW,SAAS,CAAC,IAAI,CAACZ,SAAS,CAAC,CAAC;IACnE,CAAC;IAEDa,SAAS,WAATA,SAASA,CAACC,SAAS,EAAE;MACnBlB,OAAO,CAACiB,