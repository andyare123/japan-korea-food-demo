{"ast":null,"code":"export default {\n  name: 'AboutView',\n  data: function data() {\n    return {\n      stats: [{\n        value: '2',\n        title: '主打料理類型',\n        text: '精選日式料理與韓式料理，讓顧客快速找到喜歡的餐點。'\n      }, {\n        value: '4',\n        title: '完整訂餐功能',\n        text: '支援料理瀏覽、收藏、購物車與訂單查詢流程。'\n      }, {\n        value: '100%',\n        title: '清楚透明流程',\n        text: '從加入購物車到付款完成，每一步都清楚呈現。'\n      }],\n      features: [{\n        icon: 'bi bi-bag-heart-fill',\n        title: '快速點餐',\n        text: '清楚的料理卡片、價格與分類，幫助顧客快速完成選購。'\n      }, {\n        icon: 'bi bi-heart-fill',\n        title: '收藏清單',\n        text: '喜歡的料理可以加入我的最愛，下次回購更加方便。'\n      }, {\n        icon: 'bi bi-ticket-perforated-fill',\n        title: '優惠折抵',\n        text: '支援優惠券套用，讓顧客在結帳時享有更多彈性。'\n      }, {\n        icon: 'bi bi-receipt-cutoff',\n        title: '訂單查詢',\n        text: '付款狀態與訂單內容清楚呈現，方便後續查詢與管理。'\n      }],\n      process: [{\n        title: '瀏覽日韓料理',\n        text: '依照日式、韓式分類快速瀏覽料理，查看餐點內容與價格。'\n      }, {\n        title: '加入我的最愛或購物車',\n        text: '想回購的料理可加入收藏，確定要購買的餐點可加入購物車。'\n      }, {\n        title: '確認餐點與填寫資料',\n        text: '在購物車確認數量與金額，接著填寫訂購人資訊。'\n      }, {\n        title: '完成付款與訂單查詢',\n        text: '付款完成後可查看訂單狀態，確認本次訂購內容。'\n      }]\n    };\n  }\n};","map":{"version":3,"names":["name","data","stats","value","title","text","features","icon","process"],"sources":["C:\\Users\\ROG Strix\\Desktop\\vue cli\\gui-demo\\src\\views\\AboutView.vue"],"sourcesContent":["<template>\n  <div class=\"about-page\">\n    <!-- Hero 區塊 -->\n    <section class=\"about-hero\">\n      <div class=\"container\">\n        <div class=\"row align-items-center g-5\">\n          <div class=\"col-lg-6\">\n            <span class=\"hero-badge\">ABOUT WAKAN DINING</span>\n\n            <h1 class=\"fw-bold mt-3 mb-4\">\n              關於和韓食堂\n            </h1>\n\n            <p class=\"hero-text mb-4\">\n              和韓食堂是一個專為日式與韓式料理打造的線上訂餐平台，\n              我們嚴選人氣餐點、簡化訂購流程，讓顧客能快速找到喜歡的料理，\n              輕鬆完成收藏、加入購物車、結帳與訂單查詢。\n            </p>\n\n            <div class=\"hero-actions\">\n              <router-link to=\"/products\" class=\"btn btn-danger btn-lg\">\n                立即瀏覽料理\n                <i class=\"bi bi-arrow-right ms-1\"></i>\n              </router-link>\n\n              <router-link to=\"/favorites\" class=\"btn btn-outline-dark btn-lg\">\n                查看我的最愛\n              </router-link>\n            </div>\n          </div>\n\n          <div class=\"col-lg-6\">\n            <div class=\"hero-image-card\">\n              <div class=\"hero-image\"></div>\n\n              <div class=\"floating-card\">\n                <i class=\"bi bi-stars\"></i>\n                <div>\n                  <strong>日韓料理精選平台</strong>\n                  <span>快速點餐・收藏料理・安心付款</span>\n                </div>\n              </div>\n            </div>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    <!-- 數據特色 -->\n    <section class=\"stats-section\">\n      <div class=\"container\">\n        <div class=\"row g-4\">\n          <div\n            v-for=\"item in stats\"\n            :key=\"item.title\"\n            class=\"col-md-4\"\n          >\n            <div class=\"stat-card\">\n              <strong>{{ item.value }}</strong>\n              <span>{{ item.title }}</span>\n              <p>{{ item.text }}</p>\n            </div>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    <!-- 品牌理念 -->\n    <section class=\"brand-section\">\n      <div class=\"container\">\n        <div class=\"section-title text-center mb-5\">\n          <span>OUR VALUE</span>\n          <h2 class=\"fw-bold mt-2\">我們重視的，不只是餐點</h2>\n          <p class=\"text-muted mb-0\">\n            從料理選擇到訂單完成，我們希望每一步都簡單、清楚又安心。\n          </p>\n        </div>\n\n        <div class=\"row g-4\">\n          <div\n            v-for=\"feature in features\"\n            :key=\"feature.title\"\n            class=\"col-md-6 col-lg-3\"\n          >\n            <div class=\"feature-card\">\n              <div class=\"feature-icon\">\n                <i :class=\"feature.icon\"></i>\n              </div>\n\n              <h5 class=\"fw-bold mt-4 mb-3\">\n                {{ feature.title }}\n              </h5>\n\n              <p class=\"text-muted mb-0\">\n                {{ feature.text }}\n              </p>\n            </div>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    <!-- 平台服務 -->\n    <section class=\"service-section\">\n      <div class=\"container\">\n        <div class=\"row align-items-center g-5\">\n          <div class=\"col-lg-5\">\n            <span class=\"section-label\">PLATFORM SERVICE</span>\n\n            <h2 class=\"fw-bold mt-3 mb-4\">\n              打造更順暢的線上點餐體驗\n            </h2>\n\n            <p class=\"text-muted service-text\">\n              和韓食堂整合料理瀏覽、我的最愛、購物車、優惠券、付款確認與訂單查詢，\n              讓顧客不用在複雜流程中來回切換，就能完成完整訂餐流程。\n            </p>\n\n            <router-link to=\"/products\" class=\"btn btn-danger mt-3\">\n              開始點餐\n            </router-link>\n          </div>\n\n          <div class=\"col-lg-7\">\n            <div class=\"process-list\">\n              <div\n                v-for=\"(step, index) in process\"\n                :key=\"step.title\"\n                class=\"process-item\"\n              >\n                <div class=\"process-number\">\n                  {{ index + 1 }}\n                </div>\n\n                <div>\n                  <h5 class=\"fw-bold mb-2\">\n                    {{ step.title }}\n                  </h5>\n\n                  <p class=\"text-muted mb-0\">\n                    {{ step.text }}\n                  </p>\n                </div>\n              </div>\n            </div>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    <!-- 品牌承諾 -->\n    <section class=\"promise-section\">\n      <div class=\"container\">\n        <div class=\"promise-card\">\n          <div>\n            <span class=\"section-label\">OUR PROMISE</span>\n\n            <h2 class=\"fw-bold mt-3 mb-3\">\n              用心整理每一道料理，讓每一次點餐都更安心\n            </h2>\n\n            <p class=\"mb-0\">\n              我們希望讓日式與韓式料理不只是選項，而是一種簡單、快速、愉快的日常享受。\n              從第一眼看到料理，到完成付款與查詢訂單，和韓食堂都會陪你完成每一步。\n            </p>\n          </div>\n\n          <router-link to=\"/products\" class=\"btn btn-light btn-lg\">\n            前往日韓料理\n          </router-link>\n        </div>\n      </div>\n    </section>\n  </div>\n</template>\n\n<script>\nexport default {\n  name: 'AboutView',\n  data() {\n    return {\n      stats: [\n        {\n          value: '2',\n          title: '主打料理類型',\n          text: '精選日式料理與韓式料理，讓顧客快速找到喜歡的餐點。',\n        },\n        {\n          value: '4',\n          title: '完整訂餐功能',\n          text: '支援料理瀏覽、收藏、購物車與訂單查詢流程。',\n        },\n        {\n          value: '100%',\n          title: '清楚透明流程',\n          text: '從加入購物車到付款完成，每一步都清楚呈現。',\n        },\n      ],\n      features: [\n        {\n          icon: 'bi bi-bag-heart-fill',\n          title: '快速點餐',\n          text: '清楚的料理卡片、價格與分類，幫助顧客快速完成選購。',\n        },\n        {\n          icon: 'bi bi-heart-fill',\n          title: '收藏清單',\n          text: '喜歡的料理可以加入我的最愛，下次回購更加方便。',\n        },\n        {\n          icon: 'bi bi-ticket-perforated-fill',\n          title: '優惠折抵',\n          text: '支援優惠券套用，讓顧客在結帳時享有更多彈性。',\n        },\n        {\n          icon: 'bi bi-receipt-cutoff',\n          title: '訂單查詢',\n          text: '付款狀態與訂單內容清楚呈現，方便後續查詢與管理。',\n        },\n      ],\n      process: [\n        {\n          title: '瀏覽日韓料理',\n          text: '依照日式、韓式分類快速瀏覽料理，查看餐點內容與價格。',\n        },\n        {\n          title: '加入我的最愛或購物車',\n          text: '想回購的料理可加入收藏，確定要購買的餐點可加入購物車。',\n        },\n        {\n          title: '確認餐點與填寫資料',\n          text: '在購物車確認數量與金額，接著填寫訂購人資訊。',\n        },\n        {\n          title: '完成付款與訂單查詢',\n          text: '付款完成後可查看訂單狀態，確認本次訂購內容。',\n        },\n      ],\n    };\n  },\n};\n</script>\n\n<style scoped>\n.about-page {\n  min-height: 100vh;\n  background:\n    radial-gradient(circle at top left, rgba(220, 53, 69, 0.12), transparent 30%),\n    linear-gradient(180deg, #fff7ef 0%, #ffffff 45%, #fffaf5 100%);\n}\n\n.about-hero {\n  padding: 90px 0 70px;\n}\n\n.hero-badge,\n.section-label,\n.section-title span {\n  display: inline-block;\n  color: #b23a2e;\n  font-size: 13px;\n  font-weight: 900;\n  letter-spacing: 1.5px;\n}\n\n.hero-badge {\n  padding: 8px 14px;\n  border-radius: 999px;\n  background: #fff0e7;\n}\n\n.about-hero h1 {\n  color: #2d201a;\n  font-size: clamp(38px, 5vw, 64px);\n  line-height: 1.18;\n  letter-spacing: 1px;\n}\n\n.hero-text {\n  max-width: 620px;\n  color: #6c5b50;\n  font-size: 18px;\n  line-height: 1.9;\n}\n\n.hero-actions {\n  display: flex;\n  flex-wrap: wrap;\n  gap: 14px;\n}\n\n.hero-image-card {\n  position: relative;\n  padding: 16px;\n  border-radius: 34px;\n  background: #ffffff;\n  border: 1px solid #f1d8ca;\n  box-shadow: 0 24px 60px rgba(120, 54, 28, 0.16);\n}\n\n.hero-image {\n  min-height: 430px;\n  border-radius: 26px;\n  background:\n    linear-gradient(180deg, rgba(45, 32, 26, 0.05), rgba(45, 32, 26, 0.28)),\n    url('https://images.unsplash.com/photo-1546069901-ba9599a7e63c?w=1200') center/cover;\n}\n\n.floating-card {\n  position: absolute;\n  left: -18px;\n  bottom: 34px;\n  display: flex;\n  align-items: center;\n  gap: 14px;\n  max-width: 320px;\n  padding: 16px 18px;\n  border-radius: 20px;\n  background: #ffffff;\n  box-shadow: 0 18px 44px rgba(60, 40, 30, 0.2);\n}\n\n.floating-card i {\n  width: 44px;\n  height: 44px;\n  border-radius: 50%;\n  display: inline-flex;\n  align-items: center;\n  justify-content: center;\n  color: #ffffff;\n  background: #b23a2e;\n  font-size: 22px;\n}\n\n.floating-card strong,\n.floating-card span {\n  display: block;\n}\n\n.floating-card strong {\n  color: #2d201a;\n}\n\n.floating-card span {\n  color: #777;\n  font-size: 14px;\n}\n\n.stats-section {\n  padding: 0 0 70px;\n}\n\n.stat-card {\n  height: 100%;\n  padding: 28px;\n  border-radius: 26px;\n  background: #ffffff;\n  border: 1px solid #f1d8ca;\n  box-shadow: 0 14px 36px rgba(120, 54, 28, 0.09);\n}\n\n.stat-card strong {\n  display: block;\n  color: #b23a2e;\n  font-size: 42px;\n  line-height: 1;\n}\n\n.stat-card span {\n  display: block;\n  margin-top: 12px;\n  color: #2d201a;\n  font-size: 18px;\n  font-weight: 900;\n}\n\n.stat-card p {\n  margin: 12px 0 0;\n  color: #7a6a60;\n  line-height: 1.7;\n}\n\n.brand-section {\n  padding: 80px 0;\n  background: #ffffff;\n}\n\n.section-title h2,\n.service-section h2,\n.promise-section h2 {\n  color: #2d201a;\n}\n\n.feature-card {\n  height: 100%;\n  padding: 30px;\n  border-radius: 28px;\n  background: #fffaf6;\n  border: 1px solid #f1d8ca;\n  transition: transform 0.25s ease, box-shadow 0.25s ease;\n}\n\n.feature-card:hover {\n  transform: translateY(-6px);\n  box-shadow: 0 18px 44px rgba(120, 54, 28, 0.12);\n}\n\n.feature-icon {\n  width: 58px;\n  height: 58px;\n  border-radius: 18px;\n  display: inline-flex;\n  align-items: center;\n  justify-content: center;\n  color: #ffffff;\n  background: linear-gradient(135deg, #b23a2e, #df6b4f);\n  font-size: 26px;\n}\n\n.feature-card p {\n  line-height: 1.8;\n}\n\n.service-section {\n  padding: 90px 0;\n}\n\n.service-text {\n  font-size: 17px;\n  line-height: 1.9;\n}\n\n.process-list {\n  display: grid;\n  gap: 18px;\n}\n\n.process-item {\n  display: flex;\n  gap: 18px;\n  padding: 24px;\n  border-radius: 24px;\n  background: #ffffff;\n  border: 1px solid #f1d8ca;\n  box-shadow: 0 12px 32px rgba(120, 54, 28, 0.08);\n}\n\n.process-number {\n  flex: 0 0 auto;\n  width: 48px;\n  height: 48px;\n  border-radius: 50%;\n  display: inline-flex;\n  align-items: center;\n  justify-content: center;\n  color: #ffffff;\n  background: #b23a2e;\n  font-weight: 900;\n  font-size: 20px;\n}\n\n.process-item p {\n  line-height: 1.8;\n}\n\n.promise-section {\n  padding: 0 0 90px;\n}\n\n.promise-card {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  gap: 28px;\n  padding: 44px;\n  border-radius: 32px;\n  color: #ffffff;\n  background:\n    linear-gradient(135deg, rgba(178, 58, 46, 0.96), rgba(45, 32, 26, 0.96)),\n    #b23a2e;\n  box-shadow: 0 24px 60px rgba(120, 54, 28, 0.18);\n}\n\n.promise-card .section-label,\n.promise-card h2,\n.promise-card p {\n  color: #ffffff;\n}\n\n.promise-card p {\n  max-width: 780px;\n  line-height: 1.9;\n  opacity: 0.9;\n}\n\n.promise-card .btn {\n  flex: 0 0 auto;\n  color: #b23a2e;\n  font-weight: 900;\n  border-radius: 999px;\n}\n\n.btn-danger {\n  background: #b23a2e;\n  border-color: #b23a2e;\n}\n\n.btn-danger:hover {\n  background: #982f25;\n  border-color: #982f25;\n}\n\n.btn-outline-dark {\n  border-color: #2d201a;\n  color: #2d201a;\n}\n\n.btn-outline-dark:hover {\n  background: #2d201a;\n  border-color: #2d201a;\n}\n\n@media (max-width: 991px) {\n  .about-hero {\n    padding: 64px 0 50px;\n  }\n\n  .hero-image {\n    min-height: 340px;\n  }\n\n  .floating-card {\n    left: 24px;\n    right: 24px;\n    bottom: 24px;\n    max-width: none;\n  }\n\n  .promise-card {\n    flex-direction: column;\n    align-items: flex-start;\n  }\n\n  .promise-card .btn {\n    width: 100%;\n  }\n}\n\n@media (max-width: 768px) {\n  .about-hero h1 {\n    font-size: 38px;\n  }\n\n  .hero-text {\n    font-size: 16px;\n  }\n\n  .hero-actions .btn {\n    width: 100%;\n  }\n\n  .hero-image {\n    min-height: 280px;\n  }\n\n  .floating-card {\n    position: static;\n    margin-top: 14px;\n  }\n\n  .brand-section,\n  .service-section {\n    padding: 60px 0;\n  }\n\n  .process-item {\n    flex-direction: column;\n  }\n\n  .promise-card {\n    padding: 30px 24px;\n    border-radius: 24px;\n  }\n}\n</style>\n"],"mappings":"AAiLA,eAAe;EACbA,IAAI,EAAE,WAAW;EACjBC,IAAI,WAAJA,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,KAAK,EAAE,CACL;QACEC,KAAK,EAAE,GAAG;QACVC,KAAK,EAAE,QAAQ;QACfC,IAAI,EAAE;MACR,CAAC,EACD;QACEF,KAAK,EAAE,GAAG;QACVC,KAAK,EAAE,QAAQ;QACfC,IAAI,EAAE;MACR,CAAC,EACD;QACEF,KAAK,EAAE,MAAM;QACbC,KAAK,EAAE,QAAQ;QACfC,IAAI,EAAE;MACR,CAAC,CACF;MACDC,QAAQ,EAAE,CACR;QACEC,IAAI,EAAE,sBAAsB;QAC5BH,KAAK,EAAE,MAAM;QACbC,IAAI,EAAE;MACR,CAAC,EACD;QACEE,IAAI,EAAE,kBAAkB;QACxBH,KAAK,EAAE,MAAM;QACbC,IAAI,EAAE;MACR,CAAC,EACD;QACEE,IAAI,EAAE,8BAA8B;QACpCH,KAAK,EAAE,MAAM;QACbC,IAAI,EAAE;MACR,CAAC,EACD;QACEE,IAAI,EAAE,sBAAsB;QAC5BH,KAAK,EAAE,MAAM;QACbC,IAAI,EAAE;MACR,CAAC,CACF;MACDG,OAAO,EAAE,CACP;QACEJ,KAAK,EAAE,QAAQ;QACfC,IAAI,EAAE;MACR,CAAC,EACD;QACED,KAAK,EAAE,YAAY;QACnBC,IAAI,EAAE;MACR,CAAC,EACD;QACED,KAAK,EAAE,WAAW;QAClBC,IAAI,EAAE;MACR,CAAC,EACD;QACED,KAAK,EAAE,WAAW;QAClBC,IAAI,EAAE;MACR,CAAC;IAEL,CAAC;EACH;AACF,CAAC","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}