0\"\n                     v-model=\"tempCoupon.is_enabled\" id=\"is_enabled\">\n              <label class=\"form-check-label\" for=\"is_enabled\">\n                是否啟用\n              </label>\n            </div>\n          </div>\n        </div>\n        <div class=\"modal-footer\">\n          <button type=\"button\" class=\"btn btn-secondary\" data-bs-dismiss=\"modal\">Close</button>\n          <button type=\"button\" class=\"btn btn-primary\"\n                  @click=\"$emit('update-coupon', tempCoupon)\">更新優惠券\n          </button>\n        </div>\n      </div>\n    </div>\n  </div>\n</template>\n<script>\nimport modalMixin from '@/mixins/modalMixins';\n\nexport default {\n  name: 'couponModal',\n  props: {\n    coupon: {},\n  },\n  data() {\n    return {\n      tempCoupon: {},\n      due_date: '',\n    };\n  },\n  emits: ['update-coupon'],\n  watch: {\n    coupon() {\n      this.tempCoupon = this.coupon;\n      // 將時間格式改為 YYYY-MM-DD\n      console.log(this.tempCoupon.due_date);\n      const dateAndTime = new Date(this.tempCoupon.due_date * 1000)\n        .toISOString().split('T');\n      [this.due_date] = dateAndTime;\n    },\n    due_date() {\n      this.tempCoupon.due_date = Math.floor(new Date(this.due_date) / 1000);\n    },\n  },\n  mixins: [modalMixin],\n};\n</script>\n"],"mappings":";;EAEOA,KAAK,EAAC,YAAY;EAACC,EAAE,EAAC,aAAa;EAACC,QAAQ,EAAC,IAAI;EAACC,IAAI,EAAC,QAAQ;EAC/D,iBAAe,EAAC,mBAAmB;EAAC,aAAW,EAAC,MAAM;EAACC,GAAG,EAAC;;;EACzDJ,KAAK,EAAC,cAAc;EAACG,IAAI,EAAC;;;EACxBH,KAAK,EAAC;AAAe;;EAMnBA,KAAK,EAAC;AAAY;;EAChBA,KAAK,EAAC;AAAM;;EAKZA,KAAK,EAAC;AAAM;;EAKZA,KAAK,EAAC;AAAM;;EAKZA,KAAK,EAAC;AAAM;;EAKZA,KAAK,EAAC;AAAM;;EACVA,KAAK,EAAC;AAAY;;EAWtBA,KAAK,EAAC;AAAc;;uBA1C/BK,mBAAA,CAkDM,OAlDNC,UAkDM,GAhDJC,mBAAA,CA+CM,OA/CNC,UA+CM,GA9CJD,mBAAA,CA6CM,OA7CNE,UA6CM,G,4BA5CJF,mBAAA,CAIM;IAJDP,KAAK,EAAC;EAAc,IACvBO,mBAAA,CAAuD;IAAnDP,KAAK,EAAC,aAAa;IAACC,EAAE,EAAC;KAAoB,KAAG,GAClDM,mBAAA,CAC4D;IADpDG,IAAI,EAAC,QAAQ;IAACV,KAAK,EAAC,WAAW;IAC/B,iBAAe,EAAC,OAAO;IA