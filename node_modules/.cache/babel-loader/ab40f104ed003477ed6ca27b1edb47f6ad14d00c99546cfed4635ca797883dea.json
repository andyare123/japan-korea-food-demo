{"ast":null,"code":"import \"core-js/modules/es.array.concat.js\";\nimport \"core-js/modules/es.array.push.js\";\nimport \"core-js/modules/es.object.to-string.js\";\nexport default {\n  data: function data() {\n    return {\n      product: {},\n      isLoading: false,\n      status: {\n        loadingItem: ''\n      }\n    };\n  },\n  methods: {\n    getProduct: function getProduct() {\n      var _this = this;\n      var id = this.$route.params.id;\n      var url = \"\".concat(process.env.VUE_APP_API, \"/api/\").concat(process.env.VUE_APP_PATH, \"/product/\").concat(id);\n      this.isLoading = true;\n      this.$http.get(url).then(function (response) {\n        _this.product = response.data.product;\n      })[\"finally\"](function () {\n        _this.isLoading = false;\n      });\n    },\n    addCart: function addCart(id) {\n      var _this2 = this;\n      var url = \"\".concat(process.env.VUE_APP_API, \"/api/\").concat(process.env.VUE_APP_PATH, \"/cart\");\n      this.status.loadingItem = id;\n      var cart = {\n        product_id: id,\n        qty: 1\n      };\n      this.$http.post(url, {\n        data: cart\n      }).then(function (res) {\n        _this2.$httpMessageState(res, '加入購物車');\n        if (res.data.success) {\n          _this2.$router.push('/cart');\n        }\n      })[\"finally\"](function () {\n        _this2.status.loadingItem = '';\n      });\n    }\n  },\n  created: function created() {\n    this.getProduct();\n  }\n};","map":{"version":3,"names":["data","product","isLoading","status","loadingItem","methods","getProduct","_this","id","$route","params","url","concat","process","env","VUE_APP_API","VUE_APP_PATH","$http","get","then","response","addCart","_this2","cart","product_id","qty","post","res","$httpMessageState","success","$router","push","created"],"sources":["C:\\Users\\ROG Strix\\Desktop\\vue cli\\gui-demo\\src\\views\\ProductDetail.vue"],"sourcesContent":["<!-- eslint-disable vue/no-multiple-template-root -->\n<template>\n  <Loading :active=\"isLoading\"></Loading>\n\n  <main class=\"detail-page\">\n    <div class=\"container py-5\">\n      <div v-if=\"product.id\">\n        <div class=\"detail-card\">\n          <div class=\"row g-5 align-items-center\">\n            <div class=\"col-lg-6\">\n              <div class=\"image-wrap\">\n                <img\n                  :src=\"product.imageUrl\"\n                  :alt=\"product.title\"\n                  class=\"product-image\"\n                >\n              </div>\n            </div>\n\n            <div class=\"col-lg-6\">\n              <span class=\"badge bg-primary mb-3\">\n                {{ product.category || '精選課程' }}\n              </span>\n\n              <h1 class=\"product-title fw-bold mb-3\">\n                {{ product.title }}\n              </h1>\n\n              <p class=\"product-description text-muted\">\n                {{ product.description || '這門課程適合想提升技能、累積作品集，並快速掌握實務應用的學習者。' }}\n              </p>\n\n              <div class=\"course-benefits mb-4\">\n                <h5 class=\"fw-bold mb-3\">這門課適合你，如果你想要：</h5>\n                <div class=\"benefit-item\">\n                  <i class=\"bi bi-check-circle-fill\"></i>\n                  <span>學會完整課程內容與實務應用</span>\n                </div>\n                <div class=\"benefit-item\">\n                  <i class=\"bi bi-check-circle-fill\"></i>\n                  <span>累積可以放入履歷作品集的專案能力</span>\n                </div>\n                <div class=\"benefit-item\">\n                  <i class=\"bi bi-check-circle-fill\"></i>\n                  <span>理解 API 串接、購物流程與前台互動設計</span>\n                </div>\n              </div>\n\n              <div class=\"price-box mb-4\">\n                <div>\n                  <small class=\"text-muted\">課程價格</small>\n\n                  <div>\n                    <del\n                      v-if=\"product.origin_price !== product.price\"\n                      class=\"text-muted me-2\"\n                    >\n                      {{ $filters.currency(product.origin_price) }}\n                    </del>\n\n                    <span class=\"text-danger fw-bold fs-2\">\n                      {{ $filters.currency(product.price) }}\n                    </span>\n                  </div>\n                </div>\n\n                <span class=\"discount-tag\">\n                  限時優惠\n                </span>\n              </div>\n\n              <div class=\"d-grid gap-3 d-md-flex\">\n                <button\n                  type=\"button\"\n                  class=\"btn btn-primary btn-lg\"\n                  :disabled=\"status.loadingItem === product.id\"\n                  @click=\"addCart(product.id)\"\n                >\n                  <span\n                    v-if=\"status.loadingItem === product.id\"\n                    class=\"spinner-grow spinner-grow-sm me-1\"\n                    role=\"status\"\n                  ></span>\n                  加入購物車\n                </button>\n\n                <router-link\n                  to=\"/cart\"\n                  class=\"btn btn-outline-primary btn-lg\"\n                >\n                  查看購物車\n                </router-link>\n\n                <router-link\n                  to=\"/products\"\n                  class=\"btn btn-outline-secondary btn-lg\"\n                >\n                  返回課程列表\n                </router-link>\n              </div>\n            </div>\n          </div>\n        </div>\n\n        <section class=\"learning-section mt-5\">\n          <div class=\"row g-4\">\n            <div class=\"col-md-4\">\n              <div class=\"info-card\">\n                <h5 class=\"fw-bold\">實務導向</h5>\n                <p>透過實際功能操作，理解前台購物流程與 API 串接方式。</p>\n              </div>\n            </div>\n\n            <div class=\"col-md-4\">\n              <div class=\"info-card\">\n                <h5 class=\"fw-bold\">作品集加分</h5>\n                <p>完成後可作為履歷作品，展示 Vue、Router、API 與 RWD 能力。</p>\n              </div>\n            </div>\n\n            <div class=\"col-md-4\">\n              <div class=\"info-card\">\n                <h5 class=\"fw-bold\">彈性學習</h5>\n                <p>依照自己的進度學習，適合想轉職或補強技能的學習者。</p>\n              </div>\n            </div>\n          </div>\n        </section>\n      </div>\n\n      <div v-else class=\"loading-box text-center text-muted py-5\">\n        讀取課程資料中...\n      </div>\n    </div>\n  </main>\n</template>\n\n<script>\nexport default {\n  data() {\n    return {\n      product: {},\n      isLoading: false,\n      status: {\n        loadingItem: '',\n      },\n    };\n  },\n  methods: {\n    getProduct() {\n      const { id } = this.$route.params;\n      const url = `${process.env.VUE_APP_API}/api/${process.env.VUE_APP_PATH}/product/${id}`;\n\n      this.isLoading = true;\n\n      this.$http.get(url)\n        .then((response) => {\n          this.product = response.data.product;\n        })\n        .finally(() => {\n          this.isLoading = false;\n        });\n    },\n\n    addCart(id) {\n      const url = `${process.env.VUE_APP_API}/api/${process.env.VUE_APP_PATH}/cart`;\n\n      this.status.loadingItem = id;\n\n      const cart = {\n        product_id: id,\n        qty: 1,\n      };\n\n      this.$http.post(url, { data: cart })\n        .then((res) => {\n          this.$httpMessageState(res, '加入購物車');\n\n          if (res.data.success) {\n            this.$router.push('/cart');\n          }\n        })\n        .finally(() => {\n          this.status.loadingItem = '';\n        });\n    },\n  },\n  created() {\n    this.getProduct();\n  },\n};\n</script>\n\n<style scoped>\n.detail-page {\n  min-height: 100vh;\n  background: linear-gradient(180deg, #f5f8ff 0%, #ffffff 48%, #f8f9fa 100%);\n}\n\n.detail-card {\n  padding: 40px;\n  border-radius: 32px;\n  background: #ffffff;\n  box-shadow: 0 18px 48px rgba(30, 60, 120, 0.12);\n}\n\n.image-wrap {\n  overflow: hidden;\n  border-radius: 28px;\n  background: #f8f9fa;\n  box-shadow: 0 14px 36px rgba(30, 60, 120, 0.12);\n}\n\n.product-image {\n  width: 100%;\n  height: 440px;\n  object-fit: cover;\n  display: block;\n}\n\n.product-title {\n  font-size: 40px;\n  line-height: 1.35;\n}\n\n.product-description {\n  font-size: 18px;\n  line-height: 1.8;\n}\n\n.course-benefits {\n  padding: 22px;\n  border-radius: 22px;\n  background: #f8fbff;\n  border: 1px solid #e5efff;\n}\n\n.benefit-item {\n  display: flex;\n  align-items: center;\n  gap: 10px;\n  color: #495057;\n  margin-bottom: 10px;\n}\n\n.benefit-item:last-child {\n  margin-bottom: 0;\n}\n\n.benefit-item i {\n  color: #198754;\n}\n\n.price-box {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  gap: 18px;\n  padding: 22px;\n  border-radius: 22px;\n  background: #fff8f3;\n  border: 1px solid #ffe1cf;\n}\n\n.discount-tag {\n  padding: 8px 12px;\n  border-radius: 999px;\n  color: #dc3545;\n  background: #ffe8e8;\n  font-weight: 700;\n  white-space: nowrap;\n}\n\n.info-card {\n  height: 100%;\n  padding: 28px;\n  border-radius: 24px;\n  background: #ffffff;\n  box-shadow: 0 14px 34px rgba(30, 60, 120, 0.09);\n}\n\n.info-card p {\n  color: #6c757d;\n  line-height: 1.7;\n  margin-bottom: 0;\n}\n\n.loading-box {\n  border-radius: 24px;\n  background: #ffffff;\n}\n\n@media (max-width: 768px) {\n  .detail-card {\n    padding: 24px 18px;\n    border-radius: 24px;\n  }\n\n  .product-image {\n    height: 260px;\n  }\n\n  .product-title {\n    font-size: 30px;\n  }\n\n  .product-description {\n    font-size: 16px;\n  }\n\n  .price-box {\n    flex-direction: column;\n    align-items: flex-start;\n  }\n\n  .d-md-flex .btn,\n  .d-grid .btn {\n    width: 100%;\n  }\n}\n</style>"],"mappings":";;;AA0IA,eAAe;EACbA,IAAI,WAAJA,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,OAAO,EAAE,CAAC,CAAC;MACXC,SAAS,EAAE,KAAK;MAChBC,MAAM,EAAE;QACNC,WAAW,EAAE;MACf;IACF,CAAC;EACH,CAAC;EACDC,OAAO,EAAE;IACPC,UAAU,WAAVA,UAAUA,CAAA,EAAG;MAAA,IAAAC,KAAA;MACX,IAAQC,EAAC,GAAM,IAAI,CAACC,MAAM,CAACC,MAAM,CAAzBF,EAAC;MACT,IAAMG,GAAE,MAAAC,MAAA,CAAOC,OA