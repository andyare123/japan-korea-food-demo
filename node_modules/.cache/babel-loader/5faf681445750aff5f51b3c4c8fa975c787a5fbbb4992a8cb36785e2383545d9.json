{"ast":null,"code":"export default {\n  name: 'AboutView',\n  data: function data() {\n    return {\n      stats: [{\n        value: '2',\n        title: '主打料理類型',\n        text: '精選日式料理與韓式料理，讓顧客快速找到喜歡的餐點。'\n      }, {\n        value: '4',\n        title: '完整訂餐功能',\n        text: '支援料理瀏覽、收藏、購物車與訂單查詢流程。'\n      }, {\n        value: '100%',\n        title: '清楚透明流程',\n        text: '從加入購物車到付款完成，每一步都清楚呈現。'\n      }],\n      features: [{\n        icon: 'bi bi-bag-heart-fill',\n        title: '快速點餐',\n        text: '清楚的料理卡片、價格與分類，幫助顧客快速完成選購。'\n      }, {\n        icon: 'bi bi-heart-fill',\n        title: '收藏清單',\n        text: '喜歡的料理可以加入我的最愛，下次回購更加方便。'\n      }, {\n        icon: 'bi bi-ticket-perforated-fill',\n        title: '優惠折抵',\n        text: '支援優惠券套用，讓顧客在結帳時享有更多彈性。'\n      }, {\n        icon: 'bi bi-receipt-cutoff',\n        title: '訂單查詢',\n        text: '付款狀態與訂單內容清楚呈現，方便後續查詢與管理。'\n      }],\n      process: [{\n        title: '瀏覽日韓料理',\n        text: '依照日式、韓式分類快速瀏覽料理，查看餐點內容與價格。'\n      }, {\n        title: '加入我的最愛或購物車',\n        text: '想回購的料理可加入收藏，確定要購買的餐點可加入購物車。'\n      }, {\n        title: '確認餐點與填寫資料',\n        text: '在購物車確認數量與金額，接著填寫訂購人資訊。'\n      }, {\n        title: '完成付款與訂單查詢',\n        text: '付款完成後可查看訂單狀態，確認本次訂購內容。'\n      }]\n    };\n  }\n};","map":{"version":3,"names":["name","data","stats","value","title","text","features","icon","process"],"sources":["C:\\Users\\ROG Strix\\Desktop\\vue cli\\gui-demo\\src\\views\\AboutView.vue"],"sourcesContent":["<template>\r\n  <div class=\"about-page\">\r\n    <!-- Hero 區塊 -->\r\n    <section class=\"about-hero\">\r\n      <div class=\"container\">\r\n        <div class=\"row align-items-center g-5\">\r\n          <div class=\"col-lg-6\">\r\n            <span class=\"hero-badge\">ABOUT WAKAN DINING</span>\r\n\r\n            <h1 class=\"fw-bold mt-3 mb-4\">\r\n              關於和韓食堂\r\n            </h1>\r\n\r\n            <p class=\"hero-text mb-4\">\r\n              和韓食堂是一個專為日式與韓式料理打造的線上訂餐平台，\r\n              我們嚴選人氣餐點、簡化訂購流程，讓顧客能快速找到喜歡的料理，\r\n              輕鬆完成收藏、加入購物車、結帳與訂單查詢。\r\n            </p>\r\n\r\n            <div class=\"hero-actions\">\r\n              <router-link to=\"/products\" class=\"btn btn-danger btn-lg\">\r\n                立即瀏覽料理\r\n                <i class=\"bi bi-arrow-right ms-1\"></i>\r\n              </router-link>\r\n\r\n              <router-link to=\"/favorites\" class=\"btn btn-outline-dark btn-lg\">\r\n                查看我的最愛\r\n              </router-link>\r\n            </div>\r\n          </div>\r\n\r\n          <div class=\"col-lg-6\">\r\n            <div class=\"hero-image-card\">\r\n              <div class=\"hero-image\"></div>\r\n\r\n              <div class=\"floating-card\">\r\n                <i class=\"bi bi-stars\"></i>\r\n                <div>\r\n                  <strong>日韓料理精選平台</strong>\r\n                  <span>快速點餐・收藏料理・安心付款</span>\r\n                </div>\r\n              </div>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </section>\r\n\r\n    <!-- 數據特色 -->\r\n    <section class=\"stats-section\">\r\n      <div class=\"container\">\r\n        <div class=\"row g-4\">\r\n          <div\r\n            v-for=\"item in stats\"\r\n            :key=\"item.title\"\r\n            class=\"col-md-4\"\r\n          >\r\n            <div class=\"stat-card\">\r\n              <strong>{{ item.value }}</strong>\r\n              <span>{{ item.title }}</span>\r\n              <p>{{ item.text }}</p>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </section>\r\n\r\n    <!-- 品牌理念 -->\r\n    <section class=\"brand-section\">\r\n      <div class=\"container\">\r\n        <div class=\"section-title text-center mb-5\">\r\n          <span>OUR VALUE</span>\r\n          <h2 class=\"fw-bold mt-2\">我們重視的，不只是餐點</h2>\r\n          <p class=\"text-muted mb-0\">\r\n            從料理選擇到訂單完成，我們希望每一步都簡單、清楚又安心。\r\n          </p>\r\n        </div>\r\n\r\n        <div class=\"row g-4\">\r\n          <div\r\n            v-for=\"feature in features\"\r\n            :key=\"feature.title\"\r\n            class=\"col-md-6 col-lg-3\"\r\n          >\r\n            <div class=\"feature-card\">\r\n              <div class=\"feature-icon\">\r\n                <i :class=\"feature.icon\"></i>\r\n              </div>\r\n\r\n              <h5 class=\"fw-bold mt-4 mb-3\">\r\n                {{ feature.title }}\r\n              </h5>\r\n\r\n              <p class=\"text-muted mb-0\">\r\n                {{ feature.text }}\r\n              </p>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </section>\r\n\r\n    <!-- 平台服務 -->\r\n    <section class=\"service-section\">\r\n      <div class=\"container\">\r\n        <div class=\"row align-items-center g-5\">\r\n          <div class=\"col-lg-5\">\r\n            <span class=\"section-label\">PLATFORM SERVICE</span>\r\n\r\n            <h2 class=\"fw-bold mt-3 mb-4\">\r\n              打造更順暢的線上點餐體驗\r\n            </h2>\r\n\r\n            <p class=\"text-muted service-text\">\r\n              和韓食堂整合料理瀏覽、我的最愛、購物車、優惠券、付款確認與訂單查詢，\r\n              讓顧客不用在複雜流程中來回切換，就能完成完整訂餐流程。\r\n            </p>\r\n\r\n            <router-link to=\"/products\" class=\"btn btn-danger mt-3\">\r\n              開始點餐\r\n            </router-link>\r\n          </div>\r\n\r\n          <div class=\"col-lg-7\">\r\n            <div class=\"process-list\">\r\n              <div\r\n                v-for=\"(step, index) in process\"\r\n                :key=\"step.title\"\r\n                class=\"process-item\"\r\n              >\r\n                <div class=\"process-number\">\r\n                  {{ index + 1 }}\r\n                </div>\r\n\r\n                <div>\r\n                  <h5 class=\"fw-bold mb-2\">\r\n                    {{ step.title }}\r\n                  </h5>\r\n\r\n                  <p class=\"text-muted mb-0\">\r\n                    {{ step.text }}\r\n                  </p>\r\n                </div>\r\n              </div>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </section>\r\n\r\n    <!-- 品牌承諾 -->\r\n    <section class=\"promise-section\">\r\n      <div class=\"container\">\r\n        <div class=\"promise-card\">\r\n          <div>\r\n            <span class=\"section-label\">OUR PROMISE</span>\r\n\r\n            <h2 class=\"fw-bold mt-3 mb-3\">\r\n              用心整理每一道料理，讓每一次點餐都更安心\r\n            </h2>\r\n\r\n            <p class=\"mb-0\">\r\n              我們希望讓日式與韓式料理不只是選項，而是一種簡單、快速、愉快的日常享受。\r\n              從第一眼看到料理，到完成付款與查詢訂單，和韓食堂都會陪你完成每一步。\r\n            </p>\r\n          </div>\r\n\r\n          <router-link to=\"/products\" class=\"btn btn-light btn-lg\">\r\n            前往日韓料理\r\n          </router-link>\r\n        </div>\r\n      </div>\r\n    </section>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  name: 'AboutView',\r\n  data() {\r\n    return {\r\n      stats: [\r\n        {\r\n          value: '2',\r\n          title: '主打料理類型',\r\n          text: '精選日式料理與韓式料理，讓顧客快速找到喜歡的餐點。',\r\n        },\r\n        {\r\n          value: '4',\r\n          title: '完整訂餐功能',\r\n          text: '支援料理瀏覽、收藏、購物車與訂單查詢流程。',\r\n        },\r\n        {\r\n          value: '100%',\r\n          title: '清楚透明流程',\r\n          text: '從加入購物車到付款完成，每一步都清楚呈現。',\r\n        },\r\n      ],\r\n      features: [\r\n        {\r\n          icon: 'bi bi-bag-heart-fill',\r\n          title: '快速點餐',\r\n          text: '清楚的料理卡片、價格與分類，幫助顧客快速完成選購。',\r\n        },\r\n        {\r\n          icon: 'bi bi-heart-fill',\r\n          title: '收藏清單',\r\n          text: '喜歡的料理可以加入我的最愛，下次回購更加方便。',\r\n        },\r\n        {\r\n          icon: 'bi bi-ticket-perforated-fill',\r\n          title: '優惠折抵',\r\n          text: '支援優惠券套用，讓顧客在結帳時享有更多彈性。',\r\n        },\r\n        {\r\n          icon: 'bi bi-receipt-cutoff',\r\n          title: '訂單查詢',\r\n          text: '付款狀態與訂單內容清楚呈現，方便後續查詢與管理。',\r\n        },\r\n      ],\r\n      process: [\r\n        {\r\n          title: '瀏覽日韓料理',\r\n          text: '依照日式、韓式分類快速瀏覽料理，查看餐點內容與價格。',\r\n        },\r\n        {\r\n          title: '加入我的最愛或購物車',\r\n          text: '想回購的料理可加入收藏，確定要購買的餐點可加入購物車。',\r\n        },\r\n        {\r\n          title: '確認餐點與填寫資料',\r\n          text: '在購物車確認數量與金額，接著填寫訂購人資訊。',\r\n        },\r\n        {\r\n          title: '完成付款與訂單查詢',\r\n          text: '付款完成後可查看訂單狀態，確認本次訂購內容。',\r\n        },\r\n      ],\r\n    };\r\n  },\r\n};\r\n</script>\r\n\r\n<style scoped>\r\n.about-page {\r\n  min-height: 100vh;\r\n  background:\r\n    radial-gradient(circle at top left, rgba(220, 53, 69, 0.12), transparent 30%),\r\n    linear-gradient(180deg, #fff7ef 0%, #ffffff 45%, #fffaf5 100%);\r\n}\r\n\r\n.about-hero {\r\n  padding: 90px 0 70px;\r\n}\r\n\r\n.hero-badge,\r\n.section-label,\r\n.section-title span {\r\n  display: inline-block;\r\n  color: #b23a2e;\r\n  font-size: 13px;\r\n  font-weight: 900;\r\n  letter-spacing: 1.5px;\r\n}\r\n\r\n.hero-badge {\r\n  padding: 8px 14px;\r\n  border-radius: 999px;\r\n  background: #fff0e7;\r\n}\r\n\r\n.about-hero h1 {\r\n  color: #2d201a;\r\n  font-size: clamp(38px, 5vw, 64px);\r\n  line-height: 1.18;\r\n  letter-spacing: 1px;\r\n}\r\n\r\n.hero-text {\r\n  max-width: 620px;\r\n  color: #6c5b50;\r\n  font-size: 18px;\r\n  line-height: 1.9;\r\n}\r\n\r\n.hero-actions {\r\n  display: flex;\r\n  flex-wrap: wrap;\r\n  gap: 14px;\r\n}\r\n\r\n.hero-image-card {\r\n  position: relative;\r\n  padding: 16px;\r\n  border-radius: 34px;\r\n  background: #ffffff;\r\n  border: 1px solid #f1d8ca;\r\n  box-shadow: 0 24px 60px rgba(120, 54, 28, 0.16);\r\n}\r\n\r\n.hero-image {\r\n  min-height: 430px;\r\n  border-radius: 26px;\r\n  background:\r\n    linear-gradient(180deg, rgba(45, 32, 26, 0.05), rgba(45, 32, 26, 0.28)),\r\n    url('https://images.unsplash.com/photo-1546069901-ba9599a7e63c?w=1200') center/cover;\r\n}\r\n\r\n.floating-card {\r\n  position: absolute;\r\n  left: -18px;\r\n  bottom: 34px;\r\n  display: flex;\r\n  align-items: center;\r\n  gap: 14px;\r\n  max-width: 320px;\r\n  padding: 16px 18px;\r\n  border-radius: 20px;\r\n  background: #ffffff;\r\n  box-shadow: 0 18px 44px rgba(60, 40, 30, 0.2);\r\n}\r\n\r\n.floating-card i {\r\n  width: 44px;\r\n  height: 44px;\r\n  border-radius: 50%;\r\n  display: inline-flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  color: #ffffff;\r\n  background: #b23a2e;\r\n  font-size: 22px;\r\n}\r\n\r\n.floating-card strong,\r\n.floating-card span {\r\n  display: block;\r\n}\r\n\r\n.floating-card strong {\r\n  color: #2d201a;\r\n}\r\n\r\n.floating-card span {\r\n  color: #777;\r\n  font-size: 14px;\r\n}\r\n\r\n.stats-section {\r\n  padding: 0 0 70px;\r\n}\r\n\r\n.stat-card {\r\n  height: 100%;\r\n  padding: 28px;\r\n  border-radius: 26px;\r\n  background: #ffffff;\r\n  border: 1px solid #f1d8ca;\r\n  box-shadow: 0 14px 36px rgba(120, 54, 28, 0.09);\r\n}\r\n\r\n.stat-card strong {\r\n  display: block;\r\n  color: #b23a2e;\r\n  font-size: 42px;\r\n  line-height: 1;\r\n}\r\n\r\n.stat-card span {\r\n  display: block;\r\n  margin-top: 12px;\r\n  color: #2d201a;\r\n  font-size: 18px;\r\n  font-weight: 900;\r\n}\r\n\r\n.stat-card p {\r\n  margin: 12px 0 0;\r\n  color: #7a6a60;\r\n  line-height: 1.7;\r\n}\r\n\r\n.brand-section {\r\n  padding: 80px 0;\r\n  background: #ffffff;\r\n}\r\n\r\n.section-title h2,\r\n.service-section h2,\r\n.promise-section h2 {\r\n  color: #2d201a;\r\n}\r\n\r\n.feature-card {\r\n  height: 100%;\r\n  padding: 30px;\r\n  border-radius: 28px;\r\n  background: #fffaf6;\r\n  border: 1px solid #f1d8ca;\r\n  transition: transform 0.25s ease, box-shadow 0.25s ease;\r\n}\r\n\r\n.feature-card:hover {\r\n  transform: translateY(-6px);\r\n  box-shadow: 0 18px 44px rgba(120, 54, 28, 0.12);\r\n}\r\n\r\n.feature-icon {\r\n  width: 58px;\r\n  height: 58px;\r\n  border-radius: 18px;\r\n  display: inline-flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  color: #ffffff;\r\n  background: linear-gradient(135deg, #b23a2e, #df6b4f);\r\n  font-size: 26px;\r\n}\r\n\r\n.feature-card p {\r\n  line-height: 1.8;\r\n}\r\n\r\n.service-section {\r\n  padding: 90px 0;\r\n}\r\n\r\n.service-text {\r\n  font-size: 17px;\r\n  line-height: 1.9;\r\n}\r\n\r\n.process-list {\r\n  display: grid;\r\n  gap: 18px;\r\n}\r\n\r\n.process-item {\r\n  display: flex;\r\n  gap: 18px;\r\n  padding: 24px;\r\n  border-radius: 24px;\r\n  background: #ffffff;\r\n  border: 1px solid #f1d8ca;\r\n  box-shadow: 0 12px 32px rgba(120, 54, 28, 0.08);\r\n}\r\n\r\n.process-number {\r\n  flex: 0 0 auto;\r\n  width: 48px;\r\n  height: 48px;\r\n  border-radius: 50%;\r\n  display: inline-flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  color: #ffffff;\r\n  background: #b23a2e;\r\n  font-weight: 900;\r\n  font-size: 20px;\r\n}\r\n\r\n.process-item p {\r\n  line-height: 1.8;\r\n}\r\n\r\n.promise-section {\r\n  padding: 0 0 90px;\r\n}\r\n\r\n.promise-card {\r\n  display: flex;\r\n  justify-content: space-between;\r\n  align-items: center;\r\n  gap: 28px;\r\n  padding: 44px;\r\n  border-radius: 32px;\r\n  color: #ffffff;\r\n  background:\r\n    linear-gradient(135deg, rgba(178, 58, 46, 0.96), rgba(45, 32, 26, 0.96)),\r\n    #b23a2e;\r\n  box-shadow: 0 24px 60px rgba(120, 54, 28, 0.18);\r\n}\r\n\r\n.promise-card .section-label,\r\n.promise-card h2,\r\n.promise-card p {\r\n  color: #ffffff;\r\n}\r\n\r\n.promise-card p {\r\n  max-width: 780px;\r\n  line-height: 1.9;\r\n  opacity: 0.9;\r\n}\r\n\r\n.promise-card .btn {\r\n  flex: 0 0 auto;\r\n  color: #b23a2e;\r\n  font-weight: 900;\r\n  border-radius: 999px;\r\n}\r\n\r\n.btn-danger {\r\n  background: #b23a2e;\r\n  border-color: #b23a2e;\r\n}\r\n\r\n.btn-danger:hover {\r\n  background: #982f25;\r\n  border-color: #982f25;\r\n}\r\n\r\n.btn-outline-dark {\r\n  border-color: #2d201a;\r\n  color: #2d201a;\r\n}\r\n\r\n.btn-outline-dark:hover {\r\n  background: #2d201a;\r\n  border-color: #2d201a;\r\n}\r\n\r\n@media (max-width: 991px) {\r\n  .about-hero {\r\n    padding: 64px 0 50px;\r\n  }\r\n\r\n  .hero-image {\r\n    min-height: 340px;\r\n  }\r\n\r\n  .floating-card {\r\n    left: 24px;\r\n    right: 24px;\r\n    bottom: 24px;\r\n    max-width: none;\r\n  }\r\n\r\n  .promise-card {\r\n    flex-direction: column;\r\n    align-items: flex-start;\r\n  }\r\n\r\n  .promise-card .btn {\r\n    width: 100%;\r\n  }\r\n}\r\n\r\n@media (max-width: 768px) {\r\n  .about-hero h1 {\r\n    font-size: 38px;\r\n  }\r\n\r\n  .hero-text {\r\n    font-size: 16px;\r\n  }\r\n\r\n  .hero-actions .btn {\r\n    width: 100%;\r\n  }\r\n\r\n  .hero-image {\r\n    min-height: 280px;\r\n  }\r\n\r\n  .floating-card {\r\n    position: static;\r\n    margin-top: 14px;\r\n  }\r\n\r\n  .brand-section,\r\n  .service-section {\r\n    padding: 60px 0;\r\n  }\r\n\r\n  .process-item {\r\n    flex-direction: column;\r\n  }\r\n\r\n  .promise-card {\r\n    padding: 30px 24px;\r\n    border-radius: 24px;\r\n  }\r\n}\r\n</style>\r\n"],"mappings":"AAiLA,eAAe;EACbA,IAAI,EAAE,WAAW;EACjBC,IAAI,WAAJA,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,KAAK,EAAE,CACL;QACEC,KAAK,EAAE,GAAG;QACVC,KAAK,EAAE,QAAQ;QACfC,IAAI,EAAE;MACR,CAAC,EACD;QACEF,KAAK,EAAE,GAAG;QACVC,KAAK,EAAE,QAAQ;QACfC,IAAI,EAAE;MACR,CAAC,EACD;QACEF,KAAK,EAAE,MAAM;QACbC,KAAK,EAAE,QAAQ;QACfC,IAAI,EAAE;MACR,CAAC,CACF;MACDC,QAAQ,EAAE,CACR;QACEC,IAAI,EAAE,sBAAsB;QAC5BH,KAAK,EAAE,MAAM;QACbC,IAAI,EAAE;MACR,CAAC,EACD;QACEE,IAAI,EAAE,kBAAkB;QACxBH,KAAK,EAAE,MAAM;QACbC,IAAI,EAAE;MACR,CAAC,EACD;QACEE,IAAI,EAAE,8BAA8B;QACpCH,KAAK,EAAE,MAAM;QACbC,IAAI,EAAE;MACR,CAAC,EACD;QACEE,IAAI,EAAE,sBAAsB;QAC5BH,KAAK,EAAE,MAAM;QACbC,IAAI,EAAE;MACR,CAAC,CACF;MACDG,OAAO,EAAE,CACP;QACEJ,KAAK,EAAE,QAAQ;QACfC,IAAI,EAAE;MACR,CAAC,EACD;QACED,KAAK,EAAE,YAAY;QACnBC,IAAI,EAAE;MACR,CAAC,EACD;QACED,KAAK,EAAE,WAAW;QAClBC,IAAI,EAAE;MACR,CAAC,EACD;QACED,KAAK,EAAE,WAAW;QAClBC,IAAI,EAAE;MACR,CAAC;IAEL,CAAC;EACH;AACF,CAAC","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}