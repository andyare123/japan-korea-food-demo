, {\n        data: this.tempProduct\n      }).then(function () {\n        alert(_this2.isNew ? '新增成功' : '更新成功');\n        _this2.hideModal();\n        _this2.getProducts();\n      })[\"finally\"](function () {\n        _this2.isLoading = false;\n      });\n    },\n    deleteProduct: function deleteProduct(item) {\n      var _this3 = this;\n      var confirmDelete = window.confirm(\"\\u78BA\\u5B9A\\u8981\\u522A\\u9664\\u300C\".concat(item.title, \"\\u300D\\u55CE\\uFF1F\"));\n      if (!confirmDelete) return;\n      this.isLoading = true;\n      this.$http[\"delete\"](\"\".concat(VUE_APP_API, \"/api/\").concat(VUE_APP_PATH, \"/admin/product/\").concat(item.id)).then(function () {\n        alert('刪除成功');\n        _this3.getProducts();\n      })[\"finally\"](function () {\n        _this3.isLoading = false;\n      });\n    }\n  },\n  mounted: function mounted() {\n    this.productModal = new Modal(this.$refs.productModal);\n    this.getProducts();\n  }\n};","map":{"version":3,"names":["Modal","_process$env","process","env","VUE_APP_API","VUE_APP_PATH","data","products","tempProduct","isNew","isLoading","productModal","methods","getProducts","_this","$http","get","concat","then","res","openModal","item","title","category","origin_price","price","unit","description","content","imageUrl","is_enabled","_objectSpread","show","hideModal","hide","updateProduct","_this2","url","httpMethod","id","alert","deleteProduct","_this3","confirmDelete","window","confirm","mounted","$refs"],"sources":["C:\\Users\\ROG Strix\\Desktop\\vue cli\\gui-demo\\src\\views\\AdminProducts.vue"],"sourcesContent":["<!-- eslint-disable vue/no-multiple-template-root -->\n<template>\n  <Loading :active=\"isLoading\" />\n\n  <div class=\"container py-5\">\n    <div class=\"d-flex justify-content-between align-items-center mb-4 admin-header\">\n      <div>\n        <h2 class=\"fw-bold mb-1\">料理商品管理</h2>\n        <p class=\"text-muted mb-0\">\n          管理前台顯示的日式料理與韓式料理商品。\n        </p>\n      </div>\n\n      <button class=\"btn btn-danger\" @click=\"openModal(true)\">\n        新增料理\n      </button>\n    </div>\n\n    <div class=\"table-responsive\">\n      <table class=\"table align-middle\">\n        <thead>\n          <tr>\n            <th>圖片</th>\n            <th>分類</th>\n            <th>料理名稱</th>\n            <th>原價</th>\n            <th>售價</th>\n            <th>是否啟用</th>\n            <th class=\"text-end\">操作</th>\n          </tr>\n        </thead>\n\n        <tbody>\n          <tr v-for=\"item in products\" :key=\"item.id\">\n            <td>\n              <div\n                class=\"admin-img\"\n                :style=\"{ backgroundImage: `url(${item.imageUrl})` }\"\n              ></div>\n            </td>\n\n            <td>\n              <span class=\"badge bg-light text-dark\">\n                {{ item.category }}\n              </span>\n            </td>\n\n            <td>\n              <strong>{{ item.title }}</strong>\n              <p class=\"text-muted small mb-0\">\n                {{ item.description || item.content }}\n              </p>\n            </td>\n\n            <td>NT$ {{ item.origin_price }}</td>\n            <td class=\"text-danger fw-bold\">NT$ {{ item.price }}</td>\n\n            <td>\n              <span v-if=\"item.is_enabled\" class=\"text-success\">啟用</span>\n              <span v-else class=\"text-muted\">未啟用</span>\n            </td>\n\n            <td class=\"text-end\">\n              <button class=\"btn btn-outline-dark btn-sm me-2\" @click=\"openModal(false, item)\">\n                編輯\n              </button>\n              <button class=\"btn btn-outline-danger btn-sm\" @click=\"deleteProduct(item)\">\n                刪除\n              </button>\n            </td>\n          </tr>\n        </tbody>\n      </table>\n    </div>\n\n    <!-- Modal -->\n    <div\n      ref=\"productModal\"\n      class=\"modal fade\"\n      tabindex=\"-1\"\n    >\n      <div class=\"modal-dialog modal-xl modal-dialog-centered\">\n        <div class=\"modal-content rounded-4\">\n          <div class=\"modal-header\">\n            <h5 class=\"modal-title fw-bold\">\n              {{ isNew ? '新增料理' : '編輯料理' }}\n            </h5>\n            <button type=\"button\" class=\"btn-close\" @click=\"hideModal\"></button>\n          </div>\n\n          <div class=\"modal-body\">\n            <div class=\"row g-4\">\n              <div class=\"col-md-4\">\n                <label class=\"form-label\">圖片網址</label>\n                <input\n                  v-model=\"tempProduct.imageUrl\"\n                  type=\"text\"\n                  class=\"form-control mb-3\"\n                  placeholder=\"請輸入圖片網址\"\n                >\n\n                <div\n                  v-if=\"tempProduct.imageUrl\"\n                  class=\"preview-img\"\n                  :style=\"{ backgroundImage: `url(${tempProduct.imageUrl})` }\"\n                ></div>\n              </div>\n\n              <div class=\"col-md-8\">\n                <div class=\"row g-3\">\n                  <div class=\"col-md-6\">\n                    <label class=\"form-label\">料理名稱</label>\n                    <input\n                      v-model=\"tempProduct.title\"\n                      type=\"text\"\n                      class=\"form-control\"\n                      placeholder=\"例如：炙燒鮭魚握壽司套餐\"\n                    >\n                  </div>\n\n                  <div class=\"col-md-6\">\n                    <label class=\"form-label\">分類</label>\n                    <select v-model=\"tempProduct.category\" class=\"form-select\">\n                      <option value=\"日式料理\">日式料理</option>\n                      <option value=\"韓式料理\">韓式料理</option>\n                    </select>\n                  </div>\n\n                  <div class=\"col-md-4\">\n                    <label class=\"form-label\">單位</label>\n                    <input\n                      v-model=\"tempProduct.unit\"\n                      type=\"text\"\n                      class=\"form-control\"\n                      placeholder=\"份 / 套 / 鍋\"\n                    >\n                  </div>\n\n                  <div class=\"col-md-4\">\n                    <label class=\"form-label\">原價</label>\n                    <input\n                      v-model.number=\"tempProduct.origin_price\"\n                      type=\"number\"\n                      class=\"form-control\"\n                    >\n                  </div>\n\n                  <div class=\"col-md-4\">\n                    <label class=\"form-label\">售價</label>\n                    <input\n                      v-model.number=\"tempProduct.price\"\n                      type=\"number\"\n                      class=\"form-control\"\n                    >\n                  </div>\n\n                  <div class=\"col-12\">\n                    <label class=\"form-label\">短文案</label>\n                    <input\n                      v-model=\"tempProduct.description\"\n                      type=\"text\"\n                      class=\"form-control\"\n                      placeholder=\"例如：入口即化的炙燒鮭魚，搭配醋飯與特製醬汁。\"\n                    >\n                  </div>\n\n                  <div class=\"col-12\">\n                    <label class=\"form-label\">詳細介紹</label>\n                    <textarea\n                      v-model=\"tempProduct.content\"\n                      class=\"form-control\"\n                      rows=\"5\"\n                      placeholder=\"請輸入吸引用戶購買的商品介紹\"\n                    ></textarea>\n                  </div>\n\n                  <div class=\"col-12\">\n                    <div class=\"form-check\">\n                      <input\n                        id=\"isEnabled\"\n                        v-model=\"tempProduct.is_enabled\"\n                        class=\"form-check-input\"\n                        type=\"checkbox\"\n                        :true-value=\"1\"\n                        :false-value=\"0\"\n                      >\n                      <label class=\"form-check-label\" for=\"isEnabled\">\n                        是否啟用\n                      </label>\n                    </div>\n                  </div>\n                </div>\n              </div>\n            </div>\n          </div>\n\n          <div class=\"modal-footer\">\n            <button class=\"btn btn-outline-secondary\" @click=\"hideModal\">\n              取消\n            </button>\n            <button class=\"btn btn-danger\" @click=\"updateProduct\">\n              儲存\n            </button>\n          </div>\n        </div>\n      </div>\n    </div>\n  </div>\n</template>\n\n<script>\nimport Modal from 'bootstrap/js/dist/modal';\n\nconst { VUE_APP_API, VUE_APP_PATH } = process.env;\n\nexport default {\n  data() {\n    return {\n      products: [],\n      tempProduct: {},\n      isNew: false,\n      isLoading: false,\n      productModal: null,\n    };\n  },\n  methods: {\n    getProducts() {\n      this.isLoading = true;\n\n      this.$http\n        .get(`${VUE_APP_API}/api/${VUE_APP_PATH}/admin/products/all`)\n        .then((res) => {\n          this.products = res.data.products || [];\n        })\n        .finally(() => {\n          this.isLoading = false;\n        });\n    },\n\n    openModal(isNew, item) {\n      this.isNew = isNew;\n\n      if (isNew) {\n        this.tempProduct = {\n          title: '',\n          category: '日式料理',\n          origin_price: 0,\n          price: 0,\n          unit: '份',\n          description: '',\n          content: '',\n          imageUrl: '',\n          is_enabled: 1,\n        };\n      } else {\n        this.tempProduct = { ...item };\n      }\n\n      this.productModal.show();\n    },\n\n    hideModal() {\n      this.productModal.hide();\n    },\n\n    updateProduct() {\n      let url = `${VUE_APP_API}/api/${VUE_APP_PATH}/admin/product`;\n      let httpMethod = 'post';\n\n      if (!this.isNew) {\n        url = `${VUE_APP_API}/api/${VUE_APP_PATH}/admin/product/${this.tempProduct.id}`;\n        httpMethod = 'put';\n      }\n\n      this.isLoading = true;\n\n      this.$http[httpMethod](url, { data: this.tempProduct })\n        .then(() => {\n          alert(this.isNew ? '新增成功' : '更新成功');\n          this.hideModal();\n          this.getProducts();\n        })\n        .finally(() => {\n          this.isLoading = false;\n        });\n    },\n\n    deleteProduct(item) {\n      const confirmDelete = window.confirm(`確定要刪除「${item.title}」嗎？`);\n\n      if (!confirmDelete) return;\n\n      this.isLoading = true;\n\n      this.$http\n        .delete(`${VUE_APP_API}/api/${VUE_APP_PATH}/admin/product/${item.id}`)\n        .then(() => {\n          alert('刪除成功');\n          this.getProducts();\n        })\n        .finally(() => {\n          this.isLoading = false;\n        });\n    },\n  },\n  mounted() {\n    this.productModal = new Modal(this.$refs.productModal);\n    this.getProducts();\n  },\n};\n</script>\n\n<style scoped>\n.admin-img {\n  width: 90px;\n  height: 64px;\n  border-radius: 12px;\n  background-size: cover;\n  background-position: center;\n}\n\n.preview-img {\n  height: 260px;\n  border-radius: 18px;\n  background-size: cover;\n  background-position: center;\n  border: 1px solid #eee;\n}\n\n@media (max-width: 768px) {\n  .admin-header {\n    flex-direction: column;\n    align-items: flex-start !important;\n    gap: 16px;\n  }\n\n  .admin-header .btn {\n    width: 100%;\n  }\n}\n</style>"],"mappings":";;;AAmNA,OAAOA,KAAI,MAAO,yBAAyB;AAE3C,IAAAC,YAAA,GAAsCC,OAAO,CAACC,GAAG;EAAzCC,WAAW,GAAAH,YAAA,CAAXG,WAAW;EAAEC,YAAW,GAAAJ,YAAA,CAAXI,YAAW;AAEhC,eAAe;EACbC,IAAI,WAAJA,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,QAAQ,EAAE,EAAE;MACZC,WAAW,EAAE,CAAC,CAAC;MACfC,KAAK,EAAE,KAAK;MACZC,SAAS,EAAE,KAAK;MAChBC,YAAY,EAAE;IAChB,CAAC;EACH,CAAC;EACDC,OAAO,EAAE;IACPC,WAAW,WAAXA,WAAWA,CAAA,EAAG;MAAA,IAAAC,KAAA;MACZ,IAAI,CAACJ,SAAQ,GAAI,IAAI;MAErB,IAAI,CAACK,KAAI,CACNC,GAAG,IAAAC,MAAA,CAAIb,WAAW,WAAAa,MAAA,CAAQZ,YAAY,wBAAqB,EAC3Da,IAAI,CAAC,UAACC,GAAG,EAAK;QACbL,KAAI,CAAC