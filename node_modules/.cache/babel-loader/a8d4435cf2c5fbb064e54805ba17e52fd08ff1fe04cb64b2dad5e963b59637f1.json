{"ast":null,"code":"export default {\n  props: {\n    message: {\n      type: Object,\n      required: true\n    }\n  },\n  emits: ['remove-message'],\n  computed: {\n    toastClass: function toastClass() {\n      return \"toast-\".concat(this.message.style || 'success');\n    },\n    icon: function icon() {\n      if (this.message.style === 'danger') {\n        return '!';\n      }\n      if (this.message.style === 'warning') {\n        return '!';\n      }\n      return '✓';\n    }\n  }\n};","map":{"version":3,"names":["props","message","type","Object","required","emits","computed","toastClass","concat","style","icon"],"sources":["C:\\Users\\ROG Strix\\Desktop\\vue cli\\gui-demo\\src\\components\\Toast.vue"],"sourcesContent":["<template>\n  <div\n    class=\"custom-toast mb-3\"\n    :class=\"toastClass\"\n  >\n    <div class=\"toast-icon\">\n      {{ icon }}\n    </div>\n\n    <div class=\"toast-content\">\n      <h6 class=\"fw-bold mb-1\">\n        {{ message.title }}\n      </h6>\n\n      <p class=\"mb-0\" v-if=\"message.content\">\n        {{ message.content }}\n      </p>\n    </div>\n\n    <button\n      type=\"button\"\n      class=\"toast-close\"\n      @click=\"$emit('remove-message', message.id)\"\n    >\n      ×\n    </button>\n  </div>\n</template>\n\n<script>\nexport default {\n  props: {\n    message: {\n      type: Object,\n      required: true,\n    },\n  },\n  emits: ['remove-message'],\n  computed: {\n    toastClass() {\n      return `toast-${this.message.style || 'success'}`;\n    },\n\n    icon() {\n      if (this.message.style === 'danger') {\n        return '!';\n      }\n\n      if (this.message.style === 'warning') {\n        return '!';\n      }\n\n      return '✓';\n    },\n  },\n};\n</script>\n\n<style scoped>\n.custom-toast {\n  pointer-events: auto;\n  display: flex;\n  align-items: flex-start;\n  gap: 12px;\n  padding: 16px 18px;\n  border-radius: 18px;\n  background: #ffffff;\n  border: 1px solid #eadfd8;\n  box-shadow: 0 16px 40px rgba(50, 30, 20, 0.18);\n  animation: toastSlideIn 0.25s ease;\n}\n\n.toast-icon {\n  flex: 0 0 auto;\n  width: 30px;\n  height: 30px;\n  border-radius: 50%;\n  display: inline-flex;\n  align-items: center;\n  justify-content: center;\n  color: #ffffff;\n  font-weight: 900;\n}\n\n.toast-success .toast-icon {\n  background: #198754;\n}\n\n.toast-danger .toast-icon {\n  background: #dc3545;\n}\n\n.toast-warning .toast-icon {\n  background: #ffc107;\n  color: #3a2b00;\n}\n\n.toast-content {\n  flex: 1;\n  min-width: 0;\n}\n\n.toast-content h6 {\n  color: #2d201a;\n}\n\n.toast-content p {\n  color: #6c757d;\n  font-size: 14px;\n  line-height: 1.6;\n}\n\n.toast-close {\n  border: 0;\n  background: transparent;\n  color: #999;\n  font-size: 22px;\n  line-height: 1;\n  padding: 0;\n}\n\n.toast-close:hover {\n  color: #333;\n}\n\n@keyframes toastSlideIn {\n  from {\n    opacity: 0;\n    transform: translateX(16px);\n  }\n\n  to {\n    opacity: 1;\n    transform: translateX(0);\n  }\n}\n</style>"],"mappings":"AA8BA,eAAe;EACbA,KAAK,EAAE;IACLC,OAAO,EAAE;MACPC,IAAI,EAAEC,MAAM;MACZC,QAAQ,EAAE;IACZ;EACF,CAAC;EACDC,KAAK,EAAE,CAAC,gBAAgB,CAAC;EACzBC,QAAQ,EAAE;IACRC,UAAU,WAAVA,UAAUA,CAAA,EAAG;MACX,gBAAAC,MAAA,CAAgB,IAAI,CAACP,OAAO,CAACQ,KAAI,IAAK,SAAS;IACjD,CAAC;IAEDC,IAAI,WAAJA,IAAIA,CAAA,EAAG;MACL,IAAI,IAAI,CAACT,OAAO,CAACQ,KAAI,KAAM,QAAQ,EAAE;QACnC,OAAO,GAAG;MACZ;MAEA,IAAI,IAAI,CAACR,OAAO,CAACQ,KAAI,KAAM,SAAS,EAAE;QACpC,OAAO,GAAG;MACZ;MAEA,OAAO,GAAG;IACZ;EACF;AACF,CAAC","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}