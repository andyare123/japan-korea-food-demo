{"ast":null,"code":"export default {\n  props: {\n    pages: {\n      type: Object,\n      \"default\": function _default() {\n        return {};\n      }\n    }\n  },\n  methods: {\n    updatePage: function updatePage(page) {\n      this.$emit('emit-pages', page);\n    }\n  }\n};","map":{"version":3,"names":["props","pages","type","Object","default","methods","updatePage","page","$emit"],"sources":["C:\\Users\\ROG Strix\\Desktop\\vue cli\\gui-demo\\src\\components\\Pagination.vue"],"sourcesContent":["<!-- eslint-disable vue/multi-word-component-names -->\n<template>\n  <nav aria-label=\"Page navigation\">\n    <ul class=\"pagination justify-content-center\">\n      <li\n        class=\"page-item\"\n        :class=\"{ disabled: !pages.has_pre }\"\n      >\n        <a\n          class=\"page-link\"\n          href=\"#\"\n          aria-label=\"Previous\"\n          @click.prevent=\"updatePage(pages.current_page - 1)\"\n        >\n          <span aria-hidden=\"true\">&laquo;</span>\n        </a>\n      </li>\n\n      <li\n        v-for=\"page in pages.total_pages\"\n        :key=\"page\"\n        class=\"page-item\"\n        :class=\"{ active: page === pages.current_page }\"\n      >\n        <a\n          class=\"page-link\"\n          href=\"#\"\n          @click.prevent=\"updatePage(page)\"\n        >\n          {{ page }}\n        </a>\n      </li>\n\n      <li\n        class=\"page-item\"\n        :class=\"{ disabled: !pages.has_next }\"\n      >\n        <a\n          class=\"page-link\"\n          href=\"#\"\n          aria-label=\"Next\"\n          @click.prevent=\"updatePage(pages.current_page + 1)\"\n        >\n          <span aria-hidden=\"true\">&raquo;</span>\n        </a>\n      </li>\n    </ul>\n  </nav>\n</template>\n\n<script>\nexport default {\n  props: {\n    pages: {\n      type: Object,\n      default() {\n        return {};\n      },\n    },\n  },\n  methods: {\n    updatePage(page) {\n      this.$emit('emit-pages', page);\n    },\n  },\n};\n</sc