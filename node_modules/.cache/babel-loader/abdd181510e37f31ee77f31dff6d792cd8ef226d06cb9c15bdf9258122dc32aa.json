{"ast":null,"code":"import \"core-js/modules/es.array.concat.js\";\nimport \"core-js/modules/es.array.push.js\";\nimport \"core-js/modules/es.array.reduce.js\";\nimport \"core-js/modules/es.iterator.constructor.js\";\nimport \"core-js/modules/es.iterator.reduce.js\";\nimport \"core-js/modules/es.number.constructor.js\";\nimport \"core-js/modules/es.object.to-string.js\";\nimport \"core-js/modules/es.string.trim.js\";\nexport default {\n  data: function data() {\n    return {\n      isLoading: false,\n      products: [],\n      product: {},\n      status: {\n        loadingItem: ''\n      },\n      form: {\n        user: {\n          name: '',\n          email: '',\n          tel: '',\n          address: ''\n        },\n        message: ''\n      },\n      cart: {\n        carts: [],\n        total: 0,\n        final_total: 0\n      },\n      coupon_code: ''\n    };\n  },\n  computed: {\n    cartCount: function cartCount() {\n      if (!this.cart.carts) {\n        return 0;\n      }\n      return this.cart.carts.reduce(function (total, item) {\n        return total + Number(item.qty || 0);\n      }, 0);\n    }\n  },\n  methods: {\n    getProducts: function getProducts() {\n      var _this = this;\n      var url = \"\".concat(process.env.VUE_APP_API, \"/api/\").concat(process.env.VUE_APP_PATH, \"/products/all\");\n      this.isLoading = true;\n      this.$http.get(url).then(function (response) {\n        _this.products = response.data.products || [];\n      })[\"finally\"](function () {\n        _this.isLoading = false;\n      });\n    },\n    getProduct: function getProduct(id) {\n      this.$router.push(\"/product/\".concat(id));\n    },\n    addCart: function addCart(id) {\n      var _this2 = this;\n      var url = \"\".concat(process.env.VUE_APP_API, \"/api/\").concat(process.env.VUE_APP_PATH, \"/cart\");\n      this.status.loadingItem = id;\n      var cart = {\n        product_id: id,\n        qty: 1\n      };\n      this.$http.post(url, {\n        data: cart\n      }).then(function (res) {\n        _this2.$httpMessageState(res, '加入購物車');\n        _this2.getCart();\n      })[\"finally\"](function () {\n        _this2.status.loadingItem = '';\n      });\n    },\n    getCart: function getCart() {\n      var _this3 = this;\n      var url = \"\".concat(process.env.VUE_APP_API, \"/api/\").concat(process.env.VUE_APP_PATH, \"/cart\");\n      this.isLoading = true;\n      this.$http.get(url).then(function (response) {\n        _this3.cart = response.data.data || {\n          carts: [],\n          total: 0,\n          final_total: 0\n        };\n      })[\"finally\"](function () {\n        _this3.isLoading = false;\n      });\n    },\n    updateCart: function updateCart(item) {\n      var _this4 = this;\n      if (item.qty < 1) {\n        // eslint-disable-next-line no-param-reassign\n        item.qty = 1;\n      }\n      var url = \"\".concat(process.env.VUE_APP_API, \"/api/\").concat(process.env.VUE_APP_PATH, \"/cart/\").concat(item.id);\n      this.isLoading = true;\n      this.status.loadingItem = item.id;\n      var cart = {\n        product_id: item.product_id,\n        qty: item.qty\n      };\n      this.$http.put(url, {\n        data: cart\n      }).then(function (res) {\n        _this4.$httpMessageState(res, '更新購物車');\n        _this4.getCart();\n        window.dispatchEvent(new Event('cart-updated'));\n      })[\"finally\"](function () {\n        _this4.status.loadingItem = '';\n        _this4.isLoading = false;\n      });\n    },\n    removeCartItem: function removeCartItem(id) {\n      var _this5 = this;\n      var url = \"\".concat(process.env.VUE_APP_API, \"/api/\").concat(process.env.VUE_APP_PATH, \"/cart/\").concat(id);\n      this.status.loadingItem = id;\n      this.isLoading = true;\n      this.$http[\"delete\"](url).then(function (response) {\n        _this5.$httpMessageState(response, '移除購物車品項');\n        _this5.getCart();\n        window.dispatchEvent(new Event('cart-updated'));\n      })[\"finally\"](function () {\n        _this5.status.loadingItem = '';\n        _this5.isLoading = false;\n      });\n    },\n    addCouponCode: function addCouponCode() {\n      var _this6 = this;\n      if (!this.cart.carts.length) {\n        alert('購物車目前沒有餐點，請先加入餐點後再套用優惠券');\n        return;\n      }\n      if (!this.coupon_code.trim()) {\n        alert('請輸入優惠券代碼');\n        return;\n      }\n      var url = \"\".concat(process.env.VUE_APP_API, \"/api/\").concat(process.env.VUE_APP_PATH, \"/coupon\");\n      var coupon = {\n        code: this.coupon_code.trim()\n      };\n      this.isLoading = true;\n      this.$http.post(url, {\n        data: coupon\n      }).then(function (response) {\n        _this6.$httpMessageState(response, '套用優惠券');\n        if (response.data.success) {\n          _this6.getCart();\n        } else {\n          alert(response.data.message || '優惠券套用失敗，請確認優惠碼是否正確或是否已啟用');\n        }\n      })[\"catch\"](function (error) {\n        console.log(error);\n        alert('優惠券套用失敗，請確認後台是否有建立並啟用這張優惠券');\n      })[\"finally\"](function () {\n        _this6.isLoading = false;\n      });\n    },\n    createOrder: function createOrder() {\n      var _this7 = this;\n      if (!this.cart.carts.length) {\n        alert('購物車目前沒有餐點，請先加入餐點');\n        return;\n      }\n      var url = \"\".concat(process.env.VUE_APP_API, \"/api/\").concat(process.env.VUE_APP_PATH, \"/order\");\n      var order = this.form;\n      this.isLoading = true;\n      this.$http.post(url, {\n        data: order\n      }).then(function (res) {\n        if (res.data.success) {\n          var orderId = res.data.orderId;\n          _this7.$router.push(\"/checkout/\".concat(orderId));\n        } else {\n          alert(res.data.message || '訂單建立失敗');\n        }\n      })[\"finally\"](function () {\n        _this7.isLoading = false;\n      });\n    }\n  },\n  created: function created() {\n    this.getProducts();\n    this.getCart();\n  }\n};","map":{"version":3,"names":["data","isLoading","products","product","status","loadingItem","form","user","name","email","tel","address","message","cart","carts","total","final_total","coupon_code","computed","cartCount","reduce","item","Number","qty","methods","getProducts","_this","url","concat","process","env","VUE_APP_API","VUE_APP_PATH","$http","get","then","response","getProduct","id","$router","push","addCart","_this2","product_id","post","res","$httpMessageState","getCart","_this3","updateCart","_this4","put","window","dispatchEvent","Event","removeCartItem","_this5","addCouponCode","_this6","length","alert","trim","coupon","code","success","error","console","log","createOrder","_this7","order","orderId","created"],"sources":["C:\\Users\\ROG Strix\\Desktop\\vue cli\\gui-demo\\src\\views\\UserCart.vue"],"sourcesContent":["<!-- eslint-disable vue/no-multiple-template-root -->\n<template>\n  <Loading :active=\"isLoading\"></Loading>\n\n  <div class=\"food-cart-page\">\n    <div class=\"container py-5\">\n      <!-- 頁面標題 -->\n      <div class=\"page-hero mb-5\">\n        <div class=\"hero-content\">\n          <span class=\"hero-badge\">日韓料理訂購平台</span>\n          <h1 class=\"fw-bold mt-3 mb-3\">\n            今天想吃壽司、拉麵，還是韓式炸雞？\n          </h1>\n          <p class=\"text-muted mb-0\">\n            精選日式職人料理與韓式人氣美食，從一人獨享到多人聚餐，\n            快速加入購物車，立即建立訂單。\n          </p>\n        </div>\n      </div>\n\n      <div class=\"row g-4\">\n        <!-- 料理列表 -->\n        <div class=\"col-lg-7\">\n          <div class=\"section-title mb-3\">\n            <h3 class=\"fw-bold mb-1\">精選日韓料理</h3>\n            <p class=\"text-muted mb-0\">\n              挑選喜歡的料理，加入購物車後可套用優惠券。\n            </p>\n          </div>\n\n          <div class=\"row g-4\">\n            <div\n              class=\"col-12 col-md-6\"\n              v-for=\"item in products\"\n              :key=\"item.id\"\n            >\n              <div class=\"food-card\">\n                <div\n                  class=\"food-img\"\n                  :style=\"{ backgroundImage: `url(${item.imageUrl || defaultImage})` }\"\n                >\n                  <span\n                    class=\"food-category\"\n                    :class=\"{ 'korean-tag': item.category === '韓式料理' }\"\n                  >\n                    {{ item.category || '人氣料理' }}\n                  </span>\n                </div>\n\n                <div class=\"food-body\">\n                  <h5 class=\"fw-bold food-title\">\n                    {{ item.title }}\n                  </h5>\n\n                  <p class=\"food-description\">\n                    {{ item.description || '嚴選食材現點現做，適合午餐、晚餐、聚餐與追劇宵夜。' }}\n                  </p>\n\n                  <div class=\"food-price mb-3\">\n                    <del\n                      v-if=\"item.price && item.origin_price !== item.price\"\n                      class=\"text-muted\"\n                    >\n                      原價 {{ $filters.currency(item.origin_price) }}\n                    </del>\n\n                    <div class=\"text-danger fw-bold fs-5\">\n                      特價 {{ $filters.currency(item.price || item.origin_price) }}\n                    </div>\n                  </div>\n\n                  <div class=\"d-grid gap-2\">\n                    <button\n                      type=\"button\"\n                      class=\"btn btn-outline-dark\"\n                      @click=\"getProduct(item.id)\"\n                    >\n                      查看料理\n                    </button>\n\n                    <button\n                      type=\"button\"\n                      class=\"btn btn-danger\"\n                      :disabled=\"status.loadingItem === item.id\"\n                      @click=\"addCart(item.id)\"\n                    >\n                      <span\n                        v-if=\"status.loadingItem === item.id\"\n                        class=\"spinner-grow spinner-grow-sm me-1\"\n                        role=\"status\"\n                      ></span>\n                      加入購物車\n                    </button>\n                  </div>\n                </div>\n              </div>\n            </div>\n          </div>\n\n          <div v-if=\"!products.length && !isLoading\" class=\"empty-box mt-4\">\n            目前尚無料理資料。\n          </div>\n        </div>\n\n        <!-- 購物車 -->\n        <div class=\"col-lg-5\">\n          <div class=\"cart-panel sticky-lg-top\">\n            <div class=\"cart-header mb-3\">\n              <div>\n                <span class=\"small text-danger fw-bold\">YOUR ORDER</span>\n                <h4 class=\"fw-bold mb-1\">我的餐點購物車</h4>\n                <p class=\"text-muted mb-0 small\">\n                  確認餐點數量後，可套用優惠券並送出訂單。\n                </p>\n              </div>\n            </div>\n\n            <div class=\"mb-4\">\n              <router-link to=\"/products\" class=\"btn btn-outline-secondary w-100\">\n                <i class=\"bi bi-arrow-left me-1\"></i>\n                繼續挑選日韓料理\n              </router-link>\n            </div>\n\n            <div v-if=\"cart.carts && cart.carts.length\">\n              <div\n                class=\"cart-item\"\n                v-for=\"item in cart.carts\"\n                :key=\"item.id\"\n              >\n                <button\n                  type=\"button\"\n                  class=\"btn btn-outline-danger btn-sm cart-remove\"\n                  :disabled=\"status.loadingItem === item.id\"\n                  @click=\"removeCartItem(item.id)\"\n                >\n                  <i class=\"bi bi-x\"></i>\n                </button>\n\n                <div\n                  class=\"cart-thumb\"\n                  :style=\"{ backgroundImage: `url(${item.product.imageUrl})` }\"\n                ></div>\n\n                <div class=\"cart-info\">\n                  <div class=\"d-flex align-items-center gap-2 mb-1\">\n                    <span class=\"cart-category\">\n                      {{ item.product.category || '精選料理' }}\n                    </span>\n                    <span class=\"text-success small\" v-if=\"item.coupon\">\n                      已套用優惠\n                    </span>\n                  </div>\n\n                  <h6 class=\"fw-bold mb-2\">\n                    {{ item.product.title }}\n                  </h6>\n\n                  <div class=\"input-group input-group-sm cart-qty\">\n                    <input\n                      type=\"number\"\n                      class=\"form-control\"\n                      min=\"1\"\n                      :disabled=\"item.id === status.loadingItem\"\n                      @change=\"updateCart(item)\"\n                      v-model.number=\"item.qty\"\n                    >\n                    <div class=\"input-group-text\">\n                      {{ item.product.unit }}\n                    </div>\n                  </div>\n                </div>\n\n                <div class=\"cart-price text-end\">\n                  <small\n                    v-if=\"cart.final_total !== cart.total\"\n                    class=\"text-success d-block\"\n                  >\n                    折扣價\n                  </small>\n                  <strong>\n                    {{ $filters.currency(item.final_total) }}\n                  </strong>\n                </div>\n              </div>\n            </div>\n\n            <div v-else class=\"empty-cart\">\n              <i class=\"bi bi-bag-x\"></i>\n              <h5 class=\"fw-bold mt-3 mb-2\">購物車目前沒有餐點</h5>\n              <p class=\"text-muted mb-4\">\n                還沒有加入任何日韓料理，先回到料理列表挑選想吃的餐點吧。\n              </p>\n\n              <router-link to=\"/products\" class=\"btn btn-danger\">\n                <i class=\"bi bi-search me-1\"></i>\n                前往挑選料理\n              </router-link>\n            </div>\n\n            <!-- 金額 -->\n            <div class=\"cart-summary mt-4\">\n              <div class=\"d-flex justify-content-between mb-2\">\n                <span>餐點小計</span>\n                <strong>{{ $filters.currency(cart.total) }}</strong>\n              </div>\n\n              <div\n                class=\"d-flex justify-content-between text-success\"\n                v-if=\"cart.final_total !== cart.total\"\n              >\n                <span>優惠後金額</span>\n                <strong>{{ $filters.currency(cart.final_total) }}</strong>\n              </div>\n\n              <hr>\n\n              <div class=\"d-flex justify-content-between total-line\">\n                <span>應付總額</span>\n                <strong>{{ $filters.currency(cart.final_total || cart.total) }}</strong>\n              </div>\n            </div>\n\n            <!-- 優惠券介紹 -->\n            <div class=\"coupon-box mt-4 mb-3\">\n              <div>\n                <h5 class=\"fw-bold mb-1\">日韓美食優惠券</h5>\n                <p class=\"mb-0 text-muted\">\n                  輸入優惠碼\n                  <strong class=\"text-danger\">JPKR100</strong>\n                  ，滿額享折扣優惠。\n                </p>\n              </div>\n            </div>\n\n            <!-- 優惠券輸入 -->\n            <div class=\"input-group mb-3 coupon-input-group\">\n              <input\n                type=\"text\"\n                class=\"form-control\"\n                v-model.trim=\"coupon_code\"\n                placeholder=\"請輸入優惠碼\"\n                @keyup.enter=\"addCouponCode\"\n              >\n\n              <button\n                class=\"btn btn-outline-danger\"\n                type=\"button\"\n                :disabled=\"isLoading || !cart.carts.length\"\n                @click=\"addCouponCode\"\n              >\n                套用優惠碼\n              </button>\n            </div>\n          </div>\n        </div>\n      </div>\n\n      <!-- 訂單表單 -->\n      <div class=\"order-section my-5\">\n        <div class=\"section-title text-center mb-4\">\n          <span class=\"hero-badge\">ORDER INFO</span>\n          <h3 class=\"fw-bold mt-3 mb-2\">填寫訂購資料</h3>\n          <p class=\"text-muted mb-0\">\n            完成資料後即可建立訂單，前往付款頁確認付款。\n          </p>\n        </div>\n\n        <Form\n          class=\"order-form\"\n          v-slot=\"{ errors }\"\n          @submit=\"createOrder\"\n        >\n          <div class=\"mb-3\">\n            <label for=\"email\" class=\"form-label\">Email</label>\n            <Field\n              id=\"email\"\n              name=\"email\"\n              type=\"email\"\n              class=\"form-control\"\n              :class=\"{ 'is-invalid': errors['email'] }\"\n              placeholder=\"請輸入 Email\"\n              rules=\"email|required\"\n              v-model=\"form.user.email\"\n            ></Field>\n            <ErrorMessage name=\"email\" class=\"invalid-feedback\"></ErrorMessage>\n          </div>\n\n          <div class=\"mb-3\">\n            <label for=\"name\" class=\"form-label\">收件人姓名</label>\n            <Field\n              id=\"name\"\n              name=\"姓名\"\n              type=\"text\"\n              class=\"form-control\"\n              :class=\"{ 'is-invalid': errors['姓名'] }\"\n              placeholder=\"請輸入姓名\"\n              rules=\"required\"\n              v-model=\"form.user.name\"\n            ></Field>\n            <ErrorMessage name=\"姓名\" class=\"invalid-feedback\"></ErrorMessage>\n          </div>\n\n          <div class=\"mb-3\">\n            <label for=\"tel\" class=\"form-label\">收件人電話</label>\n            <Field\n              id=\"tel\"\n              name=\"電話\"\n              type=\"tel\"\n              class=\"form-control\"\n              :class=\"{ 'is-invalid': errors['電話'] }\"\n              placeholder=\"請輸入電話\"\n              rules=\"required\"\n              v-model=\"form.user.tel\"\n            ></Field>\n            <ErrorMessage name=\"電話\" class=\"invalid-feedback\"></ErrorMessage>\n          </div>\n\n          <div class=\"mb-3\">\n            <label for=\"address\" class=\"form-label\">收件人地址</label>\n            <Field\n              id=\"address\"\n              name=\"地址\"\n              type=\"text\"\n              class=\"form-control\"\n              :class=\"{ 'is-invalid': errors['地址'] }\"\n              placeholder=\"請輸入地址\"\n              rules=\"required\"\n              v-model=\"form.user.address\"\n            ></Field>\n            <ErrorMessage name=\"地址\" class=\"invalid-feedback\"></ErrorMessage>\n          </div>\n\n          <div class=\"mb-4\">\n            <label for=\"message\" class=\"form-label\">備註</label>\n            <textarea\n              id=\"message\"\n              class=\"form-control\"\n              rows=\"5\"\n              placeholder=\"例如：不要辣、餐具數量、外送備註、希望送達時間\"\n              v-model=\"form.message\"\n            ></textarea>\n          </div>\n\n          <div class=\"d-grid\">\n            <button\n              class=\"btn btn-danger btn-lg\"\n              type=\"submit\"\n              :disabled=\"!cart.carts.length\"\n            >\n              送出訂單並前往付款\n            </button>\n          </div>\n        </Form>\n      </div>\n    </div>\n  </div>\n</template>\n\n<script>\nexport default {\n  data() {\n    return {\n      isLoading: false,\n      products: [],\n      product: {},\n      status: {\n        loadingItem: '',\n      },\n      form: {\n        user: {\n          name: '',\n          email: '',\n          tel: '',\n          address: '',\n        },\n        message: '',\n      },\n      cart: {\n        carts: [],\n        total: 0,\n        final_total: 0,\n      },\n      coupon_code: '',\n    };\n  },\n  computed: {\n    cartCount() {\n      if (!this.cart.carts) {\n        return 0;\n      }\n\n      return this.cart.carts.reduce((total, item) => total + Number(item.qty || 0), 0);\n    },\n  },\n  methods: {\n    getProducts() {\n      const url = `${process.env.VUE_APP_API}/api/${process.env.VUE_APP_PATH}/products/all`;\n\n      this.isLoading = true;\n\n      this.$http.get(url)\n        .then((response) => {\n          this.products = response.data.products || [];\n        })\n        .finally(() => {\n          this.isLoading = false;\n        });\n    },\n\n    getProduct(id) {\n      this.$router.push(`/product/${id}`);\n    },\n\n    addCart(id) {\n      const url = `${process.env.VUE_APP_API}/api/${process.env.VUE_APP_PATH}/cart`;\n\n      this.status.loadingItem = id;\n\n      const cart = {\n        product_id: id,\n        qty: 1,\n      };\n\n      this.$http.post(url, { data: cart })\n        .then((res) => {\n          this.$httpMessageState(res, '加入購物車');\n          this.getCart();\n        })\n        .finally(() => {\n          this.status.loadingItem = '';\n        });\n    },\n\n    getCart() {\n      const url = `${process.env.VUE_APP_API}/api/${process.env.VUE_APP_PATH}/cart`;\n\n      this.isLoading = true;\n\n      this.$http.get(url)\n        .then((response) => {\n          this.cart = response.data.data || {\n            carts: [],\n            total: 0,\n            final_total: 0,\n          };\n        })\n        .finally(() => {\n          this.isLoading = false;\n        });\n    },\n\n    updateCart(item) {\n      if (item.qty < 1) {\n        // eslint-disable-next-line no-param-reassign\n        item.qty = 1;\n      }\n\n      const url = `${process.env.VUE_APP_API}/api/${process.env.VUE_APP_PATH}/cart/${item.id}`;\n\n      this.isLoading = true;\n      this.status.loadingItem = item.id;\n\n      const cart = {\n        product_id: item.product_id,\n        qty: item.qty,\n      };\n\n      this.$http.put(url, { data: cart })\n        .then((res) => {\n          this.$httpMessageState(res, '更新購物車');\n          this.getCart();\n          window.dispatchEvent(new Event('cart-updated'));\n        })\n        .finally(() => {\n          this.status.loadingItem = '';\n          this.isLoading = false;\n        });\n    },\n\n    removeCartItem(id) {\n      const url = `${process.env.VUE_APP_API}/api/${process.env.VUE_APP_PATH}/cart/${id}`;\n\n      this.status.loadingItem = id;\n      this.isLoading = true;\n\n      this.$http.delete(url)\n        .then((response) => {\n          this.$httpMessageState(response, '移除購物車品項');\n          this.getCart();\n          window.dispatchEvent(new Event('cart-updated'));\n        })\n        .finally(() => {\n          this.status.loadingItem = '';\n          this.isLoading = false;\n        });\n    },\n\n    addCouponCode() {\n      if (!this.cart.carts.length) {\n        alert('購物車目前沒有餐點，請先加入餐點後再套用優惠券');\n        return;\n      }\n\n      if (!this.coupon_code.trim()) {\n        alert('請輸入優惠券代碼');\n        return;\n      }\n\n      const url = `${process.env.VUE_APP_API}/api/${process.env.VUE_APP_PATH}/coupon`;\n\n      const coupon = {\n        code: this.coupon_code.trim(),\n      };\n\n      this.isLoading = true;\n\n      this.$http.post(url, { data: coupon })\n        .then((response) => {\n          this.$httpMessageState(response, '套用優惠券');\n\n          if (response.data.success) {\n            this.getCart();\n          } else {\n            alert(response.data.message || '優惠券套用失敗，請確認優惠碼是否正確或是否已啟用');\n          }\n        })\n        .catch((error) => {\n          console.log(error);\n          alert('優惠券套用失敗，請確認後台是否有建立並啟用這張優惠券');\n        })\n        .finally(() => {\n          this.isLoading = false;\n        });\n    },\n\n    createOrder() {\n      if (!this.cart.carts.length) {\n        alert('購物車目前沒有餐點，請先加入餐點');\n        return;\n      }\n\n      const url = `${process.env.VUE_APP_API}/api/${process.env.VUE_APP_PATH}/order`;\n      const order = this.form;\n\n      this.isLoading = true;\n\n      this.$http.post(url, { data: order })\n        .then((res) => {\n          if (res.data.success) {\n            const { orderId } = res.data;\n            this.$router.push(`/checkout/${orderId}`);\n          } else {\n            alert(res.data.message || '訂單建立失敗');\n          }\n        })\n        .finally(() => {\n          this.isLoading = false;\n        });\n    },\n  },\n  created() {\n    this.getProducts();\n    this.getCart();\n  },\n};\n</script>\n\n