rt\n      }).then(function (res) {\n        _this3.$httpMessageState(res, '加入購物車');\n        if (res.data.success) {\n          _this3.getCart();\n        }\n      })[\"finally\"](function () {\n        _this3.status.loadingItem = '';\n      });\n    }\n  },\n  created: function created() {\n    this.getProduct();\n    this.getCart();\n  }\n};","map":{"version":3,"names":["data","product","cart","carts","total","final_total","isLoading","status","loadingItem","computed","cartCount","reduce","item","Number","qty","methods","getProduct","_this","id","$route","params","url","concat","process","env","VUE_APP_API","VUE_APP_PATH","$http","get","then","response","getCart","_this2","addCart","_this3","product_id","post","res","$httpMessageState","success","created"],"sources":["C:\\Users\\ROG Strix\\Desktop\\vue cli\\gui-demo\\src\\views\\ProductDetail.vue"],"sourcesContent":["<!-- eslint-disable vue/no-multiple-template-root -->\n<template>\n  <Loading :active=\"isLoading\"></Loading>\n\n  <main class=\"detail-page\">\n    <div class=\"container py-5\">\n      <div class=\"detail-topbar mb-4\">\n        <router-link to=\"/products\" class=\"btn btn-outline-secondary\">\n          <i class=\"bi bi-arrow-left me-1\"></i>\n          返回課程列表\n        </router-link>\n\n        <router-link\n          to=\"/cart\"\n          class=\"cart-icon-btn\"\n          title=\"查看購物車\"\n        >\n          <i class=\"bi bi-cart3\"></i>\n          <span v-if=\"cartCount > 0\" class=\"cart-badge\">\n            {{ cartCount }}\n          </span>\n        </router-link>\n      </div>\n\n      <div v-if=\"product.id\">\n        <div class=\"detail-card\">\n          <div class=\"row g-5 align-items-center\">\n            <div class=\"col-lg-6\">\n              <div class=\"image-wrap\">\n                <img\n                  :src=\"product.imageUrl\"\n                  :alt=\"product.title\"\n                  class=\"product-image\"\n                >\n              </div>\n            </div>\n\n            <div class=\"col-lg-6\">\n              <span class=\"badge bg-primary mb-3\">\n                {{ product.category || '精選課程' }}\n              </span>\n\n              <h1 class=\"product-title fw-bold mb-3\">\n                {{ product.title }}\n              </h1>\n\n              <p class=\"product-description text-muted\">\n                {{ product.description || '這門課程適合想提升技能、累積作品集，並快速掌握實務應用的學習者。' }}\n              </p>\n\n              <div class=\"course-content mb-4\">\n                <h5 class=\"fw-bold mb-3\">課程內容</h5>\n                <p class=\"text-muted mb-0\">\n                  {{ product.content || '本課程將帶你完成實務專案，學會頁面切版、元件拆分、路由設計、API 串接、購物車流程與響應式網頁設計。' }}\n                </p>\n              </div>\n\n              <div class=\"course-benefits mb-4\">\n                <h5 class=\"fw-bold mb-3\">這門課適合你，如果你想要：</h5>\n\n                <div class=\"benefit-item\">\n                  <i class=\"bi bi-check-circle-fill\"></i>\n                  <span>學會完整課程內容與實務應用</span>\n                </div>\n\n                <div class=\"benefit-item\">\n                  <i class=\"bi bi-check-circle-fill\"></i>\n                  <span>累積可以放入履歷作品集的專案能力</span>\n                </div>\n\n                <div class=\"benefit-item\">\n                  <i class=\"bi bi-check-circle-fill\"></i>\n                  <span>理解 API 串接、購物流程與前台互動設計</span>\n                </div>\n              </div>\n\n              <div class=\"price-box mb-4\">\n                <div>\n                  <small class=\"text-muted\">課程價格</small>\n\n                  <div>\n                    <del\n                      v-if=\"product.origin_price !== product.price\"\n                      class=\"text-muted me-2\"\n                    >\n                      {{ $filters.currency(product.origin_price) }}\n                    </del>\n\n                    <span class=\"text-danger fw-bold fs-2\">\n                      {{ $filters.currency(product.price) }}\n                    </span>\n                  </div>\n                </div>\n\n                <span class=\"discount-tag\">\n                  限時優惠\n                </span>\n              </div>\n\n              <div class=\"d-grid gap-3 d-md-flex\">\n                <button\n                  type=\"button\"\n                  class=\"btn btn-primary btn-lg\"\n                  :disabled=\"status.loadingItem === product.id\"\n                  @click=\"addCart(product.id)\"\n                >\n                  <span\n                    v-if=\"status.loadingItem === product.id\"\n                    class=\"spinner-grow spinner-grow-sm me-1\"\n                    role=\"status\"\n                  ></span>\n                  加入購物車\n                </button>\n\n                <router-link\n                  to=\"/cart\"\n                  class=\"btn btn-outline-primary btn-lg\"\n                >\n                  前往結帳\n                </router-link>\n              </div>\n            </div>\n          </div>\n        </div>\n\n        <section class=\"learning-section mt-5\">\n          <div class=\"row g-4\">\n            <div class=\"col-md-4\">\n              <div class=\"info-card\">\n                <h5 class=\"fw-bold\">實務導向</h5>\n                <p>透過實際功能操作，理解前台購物流程與 API 串接方式。</p>\n              </div>\n            </div>\n\n            <div class=\"col-md-4\">\n              <div class=\"info-card\">\n                <h5 class=\"fw-bold\">作品集加分</h5>\n                <p>完成後可作為履歷作品，展示 Vue、Router、API 與 RWD 能力。</p>\n              </div>\n            </div>\n\n            <div class=\"col-md-4\">\n              <div class=\"info-card\">\n                <h5 class=\"fw-bold\">彈性學習</h5>\n                <p>依照自己的進度學習，適合想轉職或補強技能的學習者。</p>\n              </div>\n            </div>\n          </div>\n        </section>\n      </div>\n\n      <div v-else class=\"loading-box text-center text-muted py-5\">\n        讀取課程資料中...\n      </div>\n    </div>\n  </main>\n</template>\n\n<script>\nexport default {\n  data() {\n    return {\n      product: {},\n      cart: {\n        carts: [],\n        total: 0,\n        final_total: 0,\n      },\n      isLoading: false,\n      status: {\n        loadingItem: '',\n      },\n    };\n  },\n  computed: {\n    cartCount() {\n      if (!this.cart.carts) {\n        return 0;\n      }\n\n      return this.cart.carts.reduce((total, item) => total + Number(item.qty || 0), 0);\n    },\n  },\n  methods: {\n    getProduct() {\n      const { id } = this.$route.params;\n      const url = `${process.env.VUE_APP_API}/api/${process.env.VUE_APP_PATH}/product/${id}`;\n\n      this.isLoading = true;\n\n      this.$http.get(url)\n        .then((response) => {\n          this.product = response.data.product;\n        })\n        .finally(() => {\n          this.isLoading = false;\n        });\n    },\n\n    getCart() {\n      const url = `${process.env.VUE_APP_API}/api/${process.env.VUE_APP_PATH}/cart`;\n\n      this.$http.get(url)\n        .then((response) => {\n          this.cart = response.data.data || {\n            carts: [],\n            total: 0,\n            final_total: 0,\n          };\n        });\n    },\n\n    addCart(id) {\n      const url = `${process.env.VUE_APP_API}/api/${process.env.VUE_APP_PATH}/cart`;\n\n      this.status.loadingItem = id;\n\n      const cart = {\n        product_id: id,\n        qty: 1,\n      };\n\n      this.$http.post(url, { data: cart })\n        .then((res) => {\n          this.$httpMessageState(res, '加入購物車');\n\n          if (res.data.success) {\n            this.getCart();\n          }\n        })\n        .finally(() => {\n          this.status.loadingItem = '';\n        });\n    },\n  },\n  created() {\n    this.getProduct();\n    this.getCart();\n  },\n};\n</script>\n\n<style scoped>\n.detail-page {\n  min-height: 100vh;\n  background: linear-gradient(180deg, #f5f8ff 0%, #ffffff 48%, #f8f9fa 100%);\n}\n\n.detail-topbar {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n}\n\n.cart-icon-btn {\n  position: relative;\n  width: 58px;\n  height: 58px;\n  border-radius: 50%;\n  display: inline-flex;\n  align-items: center;\n  justify-content: center;\n  color: #ffffff;\n  background: #0d6efd;\n  text-decoration: none;\n  box-shadow: 0 12px 28px rgba(13, 110, 253, 0.28);\n  transition: transform 0.2s ease, box-shadow 0.2s ease;\n}\n\n.cart-icon-btn:hover {\n  color: #ffffff;\n  transform: translateY(-3px);\n  box-shadow: 0 16px 34px rgba(13, 110, 253, 0.36);\n}\n\n.cart-icon-btn i {\n  font-size: 26px;\n}\n\n.cart-badge {\n  position: absolute;\n  top: -6px;\n  right: -6px;\n  min-width: 24px;\n  height: 24px;\n  padding: 0 6px;\n  border-radius: 999px;\n  background: #dc3545;\n  color: #ffffff;\n  font-size: 13px;\n  font-weight: 800;\n  display: inline-flex;\n  align-items: center;\n  justify-content: center;\n  border: 2px solid #ffffff;\n}\n\n.detail-card {\n  padding: 40px;\n  border-radius: 32px;\n  background: #ffffff;\n  box-shadow: 0 18px 48px rgba(30, 60, 120, 0.12);\n}\n\n.image-wrap {\n  overflow: hidden;\n  border-radius: 28px;\n  background: #f8f9fa;\n  box-shadow: 0 14px 36px rgba(30, 60, 120, 0.12);\n}\n\n.product-image {\n  width: 100%;\n  height: 440px;\n  object-fit: cover;\n  display: block;\n}\n\n.product-title {\n  font-size: 40px;\n  line-height: 1.35;\n}\n\n.product-description {\n  font-size: 18px;\n  line-height: 1.8;\n}\n\n.course-content,\n.course-benefits {\n  padding: 22px;\n  border-radius: 22px;\n  background: #f8fbff;\n  border: 1px solid #e5efff;\n}\n\n.course-content p {\n  line-height: 1.8;\n}\n\n.benefit-item {\n  display: flex;\n  align-items: center;\n  gap: 10px;\n  color: #495057;\n  margin-bottom: 10px;\n}\n\n.benefit-item:last-child {\n  margin-bottom: 0;\n}\n\n.benefit-item i {\n  color: #198754;\n}\n\n.price-box {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  gap: 18px;\n  padding: 22px;\n  border-radius: 22px;\n  background: #fff8f3;\n  border: 1px solid #ffe1cf;\n}\n\n.discount-tag {\n  padding: 8px 12px;\n  border-radius: 999px;\n  color: #dc3545;\n  background: #ffe8e8;\n  font-weight: 700;\n  white-space: nowrap;\n}\n\n.info-card {\n  height: 100%;\n  padding: 28px;\n  border-radius: 24px;\n  background: #ffffff;\n  box-shadow: 0 14px 34px rgba(30, 60, 120, 0.09);\n}\n\n.info-card p {\n  color: #6c757d;\n  line-height: 1.7;\n  margin-bottom: 0;\n}\n\n.loading-box {\n  border-radius: 24px;\n  background: #ffffff;\n}\n\n@media (max-width: 768px) {\n  .detail-topbar {\n    gap: 12px;\n  }\n\n  .cart-icon-btn {\n    width: 52px;\n    height: 52px;\n    flex: 0 0 52px;\n  }\n\n  .detail-card {\n    padding: 24px 18px;\n    border-radius: 24px;\n  }\n\n  .product-image {\n    height: 260px;\n  }\n\n  .product-title {\n    font-size: 30px;\n  }\n\n  .product-description {\n    font-size: 16px;\n  }\n\n  .price-box {\n    flex-direction: column;\n    align-items: flex-start;\n  }\n\n  .d-md-flex .btn,\n  .d-grid .btn {\n    width: 100%;\n  }\n}\n</style>"],"mappings":";;;;;;AA+JA,eAAe;EACbA,IAAI,WAAJA,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,OAAO,EAAE,CAAC,CAAC;MACXC,IAAI,EAAE;QACJC,KAAK,EAAE,EAAE;QACTC,KAAK,EAAE,CAAC;QACRC,WAAW,EAAE;MACf,CAAC;MACDC,SAAS,EAAE,KAAK;MAChBC,MAAM,EAAE;QACNC,WAAW,EAAE;MACf;IACF,CAAC;EACH,CAAC;EACDC,QAAQ,EAAE;IACRC,SAAS,WAATA,SAASA,CAAA,EAAG;MACV,IAAI,CAAC,IAAI,CAACR,IAAI,CAACC,KAAK,EAAE;QACpB,OAAO,CAAC;MACV;MAEA,OAAO,IAAI,CAACD,IAAI,CAACC,KAAK,CAACQ,MAAM,CAAC,UAACP,KAAK,EAAEQ,IAAI;QAAA,OAAKR,KAAI,GAAIS,MAAM,CAACD,IAAI,CAACE,GAAE,IAAK,CAAC,CAAC;MAAA,GAAE,CAAC,CAAC;IAClF;EACF,CAAC;EACDC,OAAO,EAAE;IACPC,UAAU,WAAVA,UAAUA,CAAA,EAAG;MAAA,IAAAC,KAAA;MACX,IAAQC,EAAC,GAAM,IAAI,CAACC,MAAM,CAACC,MAAM,CAAzBF,EAAC;MACT,IAAMG,GAAE,MAAAC,MAAA,CAAOC,OAAO,CAACC,GAAG,CAACC,WAAW,WAAAH,MAAA,CAAQC,OAAO,CAACC,GAAG,CAACE,YAAY,eAAAJ,MAAA,CAAYJ,EAAE,CAAE;MAEtF,IAAI,CAACZ,SAAQ,GAAI,IAAI;MAErB,IAAI,CAACqB,KAAK,CAACC,GAAG,CAACP,GAAG,EACfQ,IAAI,CAAC,UAACC,QAAQ,EAAK;QAClBb,KAAI,CAAChB,OAAM,GAAI6B,QAAQ,CAAC9B,I