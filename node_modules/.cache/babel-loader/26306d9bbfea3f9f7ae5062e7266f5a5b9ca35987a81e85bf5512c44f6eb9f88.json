{"ast":null,"code":"import \"core-js/modules/es.array.concat.js\";\nimport \"core-js/modules/es.array.push.js\";\nimport \"core-js/modules/es.object.to-string.js\";\nexport default {\n  data: function data() {\n    return {\n      product: {},\n      isLoading: false,\n      status: {\n        loadingItem: ''\n      }\n    };\n  },\n  methods: {\n    getProduct: function getProduct() {\n      var _this = this;\n      var id = this.$route.params.id;\n      var url = \"\".concat(process.env.VUE_APP_API, \"/api/\").concat(process.env.VUE_APP_PATH, \"/product/\").concat(id);\n      this.isLoading = true;\n      this.$http.get(url).then(function (response) {\n        _this.product = response.data.product;\n      })[\"finally\"](function () {\n        _this.isLoading = false;\n      });\n    },\n    addCart: function addCart(id) {\n      var _this2 = this;\n      var url = \"\".concat(process.env.VUE_APP_API, \"/api/\").concat(process.env.VUE_APP_PATH, \"/cart\");\n      this.status.loadingItem = id;\n      var cart = {\n        product_id: id,\n        qty: 1\n      };\n      this.$http.post(url, {\n        data: cart\n      }).then(function (res) {\n        _this2.$httpMessageState(res, '加入購物車');\n        _this2.$router.push('/user');\n      })[\"finally\"](function () {\n        _this2.status.loadingItem = '';\n      });\n    }\n  },\n  created: function created() {\n    this.getProduct();\n  }\n};","map":{"version":3,"names":["data","product","isLoading","status","loadingItem","methods","getProduct","_this","id","$route","params","url","concat","process","env","VUE_APP_API","VUE_APP_PATH","$http","get","then","response","addCart","_this2","cart","product_id","qty","post","res","$httpMessageState","$router","push","created"],"sources":["C:\\Users\\ROG Strix\\Desktop\\vue cli\\gui-demo\\src\\views\\ProductDetail.vue"],"sourcesContent":["<!-- eslint-disable vue/no-multiple-template-root -->\n<template>\n  <Loading :active=\"isLoading\"></Loading>\n\n  <div class=\"container py-5\">\n    <div class=\"row\" v-if=\"product.id\">\n      <div class=\"col-md-6 mb-4\">\n        <img\n          :src=\"product.imageUrl\"\n          :alt=\"product.title\"\n          class=\"img-fluid rounded product-image\"\n        >\n      </div>\n\n      <div class=\"col-md-6\">\n        <span class=\"badge bg-primary mb-3\">\n          {{ product.category }}\n        </span>\n\n        <h1 class=\"fw-bold mb-3\">\n          {{ product.title }}\n        </h1>\n\n        <p class=\"text-muted product-description\">\n          {{ product.description || '這門課程適合想提升技能、累積作品集，並快速掌握實務應用的學習者。' }}\n        </p>\n\n        <div class=\"mb-4\">\n          <del\n            v-if=\"product.origin_price !== product.price\"\n            class=\"text-muted me-2\"\n          >\n            原價 {{ $filters.currency(product.origin_price) }}\n          </del>\n\n          <div class=\"text-danger fw-bold fs-3\">\n            現在只要 {{ $filters.currency(product.price) }}\n          </div>\n        </div>\n\n        <div class=\"mb-4\">\n          <h5 class=\"fw-bold\">你會學到</h5>\n          <ul class=\"text-muted\">\n            <li>完整課程內容與實務應用</li>\n            <li>適合放入履歷作品集的專案能力</li>\n            <li>從基礎到實作的學習流程</li>\n          </ul>\n        </div>\n\n        <div class=\"d-grid gap-2 d-md-flex\">\n          <button\n            type=\"button\"\n            class=\"btn btn-primary btn-lg\"\n            :disabled=\"status.loadingItem === product.id\"\n            @click=\"addCart(product.id)\"\n          >\n            <span\n              v-if=\"status.loadingItem === product.id\"\n              class=\"spinner-grow spinner-grow-sm me-1\"\n              role=\"status\"\n            ></span>\n            加入購物車\n          </button>\n\n          <button\n            type=\"button\"\n            class=\"btn btn-outline-secondary btn-lg\"\n            @click=\"$router.back()\"\n          >\n            返回課程列表\n          </button>\n        </div>\n      </div>\n    </div>\n\n    <div v-else class=\"text-center text-muted py-5\">\n      讀取課程資料中...\n    </div>\n  </div>\n</template>\n\n<script>\nexport default {\n  data() {\n    return {\n      product: {},\n      isLoading: false,\n      status: {\n        loadingItem: '',\n      },\n    };\n  },\n  methods: {\n    getProduct() {\n      const { id } = this.$route.params;\n      const url = `${process.env.VUE_APP_API}/api/${process.env.VUE_APP_PATH}/product/${id}`;\n\n      this.isLoading = true;\n\n      this.$http.get(url)\n        .then((response) => {\n          this.product = response.data.product;\n        })\n        .finally(() => {\n          this.isLoading = false;\n        });\n    },\n\n    addCart(id) {\n      const url = `${process.env.VUE_APP_API}/api/${process.env.VUE_APP_PATH}/cart`;\n\n      this.status.loadingItem = id;\n\n      const cart = {\n        product_id: id,\n        qty: 1,\n      };\n\n      this.$http.post(url, { data: cart })\n        .then((res) => {\n          this.$httpMessageState(res, '加入購物車');\n          this.$router.push('/user');\n        })\n        .finally(() => {\n          this.status.loadingItem = '';\n        });\n    },\n  },\n  created() {\n    this.getProduct();\n  },\n};\n</script>\n\n<style scoped>\n.product-image {\n  width: 100%;\n  max-height: 420px;\n  object-fit: cover;\n}\n\n.product-description {\n  font-size: 18px;\n  line-height: 1.8;\n}\n\n@media (max-width: 768px) {\n  .product-description {\n    font-size: 16px;\n  }\n}\n</style>"],"mappings":";;;AAkFA,eAAe;EACbA,IAAI,WAAJA,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,OAAO,EAAE,CAAC,CAAC;MACXC,SAAS,EAAE,KAAK;MAChBC,MAAM,EAAE;QACNC,WAAW,EAAE;MACf;IACF,CAAC;EACH,CAAC;EACDC,OAAO,EAAE;IACPC,UAAU,WAAVA,UAAUA,CAAA,EAAG;MAAA,IAAAC,KAAA;MACX,IAAQC,EAAC,GAAM,IAAI,CAACC,MAAM,CAACC,MAAM,CAAzBF,EAAC;MACT,IAAMG,GAAE,MAAAC,MAAA,CAAOC,OAAO,CAACC,GAAG,CAACC,WAAW,WAAAH,MAAA,CAAQC,OAAO,CAACC,GAAG,CAACE,YAAY,eAAAJ,MAAA,CAAYJ,EAAE,CAAE;MAEtF,IAAI,CAACN,SAAQ,GAAI,IAAI;MAErB,IAAI,CAACe,KAAK,CAACC,GAAG,CAACP,GAAG,EACfQ