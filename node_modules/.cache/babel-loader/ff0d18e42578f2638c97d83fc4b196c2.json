 <table class=\"table\">\n                <tbody>\n                  <tr>\n                    <th style=\"width: 100px\">訂單編號</th>\n                    <td>{{ tempOrder.id }}</td>\n                  </tr>\n                  <tr>\n                    <th>下單時間</th>\n                    <td>{{ $filters.date(tempOrder.create_at)}}</td>\n                  </tr>\n                  <tr>\n                    <th>付款時間</th>\n                    <td>\n                      <span v-if=\"tempOrder.paid_date\">\n                        {{ $filters.date(tempOrder.paid_date) }}\n                      </span>\n                      <span v-else>時間不正確</span>\n                    </td>\n                  </tr>\n                  <tr>\n                    <th>付款狀態</th>\n                    <td>\n                      <strong v-if=\"tempOrder.is_paid\" class=\"text-success\">已付款</strong>\n                      <span v-else class=\"text-muted\">尚未付款</span>\n                    </td>\n                  </tr>\n                  <tr>\n                    <th>總金額</th>\n                    <td>\n                      {{ $filters.currency(tempOrder.total) }}\n                    </td>\n                  </tr>\n                </tbody>\n              </table>\n              <h3>選購商品</h3>\n              <table class=\"table\">\n                <thead>\n                  <tr>\n                  </tr>\n                </thead>\n                <tbody>\n                  <tr v-for=\"item in tempOrder.products\" :key=\"item.id\">\n                    <th>\n                      {{ item.product.title }}\n                    </th>\n                    <td>\n                      {{ item.qty }} / {{ item.product.unit }}\n                    </td>\n                    <td class=\"text-end\">\n                      {{ $filters.currency(item.final_total) }}\n                    </td>\n                  </tr>\n                </tbody>\n              </table>\n            </div>\n          </div>\n        </div>\n        <div class=\"modal-footer\">\n          <button type=\"button\" class=\"btn btn-outline-secondary\"\n                  data-bs-dismiss=\"modal\">取消\n          </button>\n          <button type=\"button\" class=\"btn btn-primary\"\n                  @click=\"$emit('update-order', tempOrder)\">確認</button>\n        </div>\n      </div>\n    </div>\n  </div>\n</template>\n<script>\nimport modalMixin from '@/mixins/modalMixins';\n\nexport default {\n  name: 'orderModal',\n  props: {\n    order: {\n      type: Object,\n      default() { return {}; },\n    },\n  },\n  data() {\n    return {\n      status: {},\n      modal: '',\n      tempOrder: {},\n      isPaid: false,\n    };\n  },\n  emits: ['update-product'],\n  mixins: [modalMixin],\n  inject: ['emitter'],\n  watch: {\n    order() {\n      this.tempOrder = this.order;\n      this.isPaid = this.tempOrder.is_paid;\n    },\n  },\n};\n// eslint-disable-next-line linebreak-style\n</script>\n"],"mappings":";;EACOA,KAAK,EAAC,YAAY;EAACC,EAAE,EAAC,cAAc;EAACC,QAAQ,EAAC,IAAI;EAACC,IAAI,EAAC,QAAQ;EAChE,iBAAe,EAAC,mBAAmB;EAAC,aAAW,EAAC,MAAM;EAACC,GAAG,EAAC;;;EACzDJ,KAAK,EAAC,uBAAuB;EAACG,IAAI,EAAC;;;EACjCH,KAAK,EAAC;AAAwB;;EAQ5BA,KAAK,EAAC;AAAY;;EAChBA,KAAK,EAAC;AAAK;;EACTA,KAAK,EAAC;AAAU;;EAEZA,KAAK,EAAC;AAAO;;;;;EAqBjBA,KAAK,EAAC;AAAU;;EAEZA,KAAK,EAAC;AAAO;;;;;;;;;EAsBqBA,KAAK,EAAC;;;;EAC1BA,KAAK,EAAC;;;EAYpBA,KAAK,EAAC;AAAO;;EAaVA,KAAK,EAAC;AAAU;;EAS3BA,KAAK,EAAC;AAAc;;uBA/F/BK,mBAAA,CAwGM,OAxGNC,UAwGM,GAtGJC,mBAAA,CAqGM,OArGNC,UAqGM,GApGJD,mBAAA,CAmGM,OAnGNE,UAmGM,G,4BAlGJF,mBAAA,CAMM;IANDP,KAAK,EAAC;EAAiC,IAC1CO,mBAAA,CAEK;IAFDP,KAAK,EAAC,aAAa;IAACC,EAAE,EAAC;MACzBM,mBAAA,CAAiB,cAAX,MAAI,E,GAEZA,mBAAA,CAC4D;IADpDG,IAAI,EAAC,QAAQ;IAACV,KAAK,EAAC,WAAW;IAC/B,iBAAe,EAAC,OAAO;IAAC,YAAU,EAAC;aAE7CO,mBAAA,CAmFM,OAnFNI,UAmFM,GAlFJJ,mBAAA,CAiFM,OAjFNK,UAiFM,GAhFJL,mBAAA,CAsBM,OAtBNM,UAsBM,G,0BArBJN,mBAAA,CAAa,YAAT,MAAI,QACRA,mBAAA,CAmBQ,SAnBRO,UAmBQ,GAlBOC,KAAA,CAAAC,SAAS,CAACC,IAAI,I,cAA3BZ,mBAAA,CAiBQ,SAAAa,UAAA,GAhB