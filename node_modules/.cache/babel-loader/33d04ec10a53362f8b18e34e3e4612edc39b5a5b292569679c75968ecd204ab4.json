n Object.values(products);\n      }\n      return [];\n    },\n    getOrders: function getOrders() {\n      var _this = this;\n      var currentPage = arguments.length > 0 && arguments[0] !== undefined ? arguments[0] : 1;\n      if (this.isOrderDisplayCleared) {\n        this.orders = {};\n        this.pagination = {};\n        return;\n      }\n      this.currentPage = currentPage;\n      var url = \"\".concat(process.env.VUE_APP_API, \"/api/\").concat(process.env.VUE_APP_PATH, \"/admin/orders?page=\").concat(currentPage);\n      this.isLoading = true;\n      this.$http.get(url).then(function (response) {\n        _this.orders = response.data.orders || {};\n        _this.pagination = response.data.pagination || {};\n      })[\"catch\"](function (error) {\n        console.error('取得訂單失敗:', error);\n        alert('取得訂單失敗，請稍後再試');\n      })[\"finally\"](function () {\n        _this.isLoading = false;\n      });\n    },\n    openModal: function openModal(isNew, item) {\n      this.tempOrder = _objectSpread({}, item);\n      this.isNew = isNew;\n      var orderComponent = this.$refs.orderModal;\n      orderComponent.showModal();\n    },\n    updatePaid: function updatePaid(item) {\n      var _this2 = this;\n      if (!item || !item.id) {\n        alert('找不到訂單編號，無法更新付款狀態');\n        return;\n      }\n      this.isLoading = true;\n      var api = \"\".concat(process.env.VUE_APP_API, \"/api/\").concat(process.env.VUE_APP_PATH, \"/admin/order/\").concat(item.id);\n      var paid = {\n        is_paid: item.is_paid\n      };\n      this.$http.put(api, {\n        data: paid\n      }).then(function (response) {\n        _this2.$httpMessageState(response, '更新付款狀態');\n        _this2.getOrders(_this2.currentPage);\n      })[\"catch\"](function (error) {\n        console.error('更新付款狀態失敗:', error);\n        alert('更新付款狀態失敗，請稍後再試');\n        _this2.getOrders(_this2.currentPage);\n      })[\"finally\"](function () {\n        _this2.isLoading = false;\n      });\n    },\n    clearOrders