lizeStyle","backgroundImage","concat","imageUrl","defaultImage","_hoisted_7","_toDisplayString","category","type","onClick","$event","$options","toggleFavorite","isFavorite","_hoisted_8","_hoisted_9","title","_hoisted_10","description","content","_hoisted_11","origin_price","price","_hoisted_12","_hoisted_13","_hoisted_14","num","_hoisted_15","unit","_hoisted_16","_hoisted_17","decreaseQty","apply","arguments","qty","min","number","increaseQty","_hoisted_18","_hoisted_19","addToCart","_hoisted_20","_createCommentVNode","_hoisted_21","_hoisted_22","recommendedProducts","length","_hoisted_23","_Fragment","_renderList","item","key","_hoisted_24","_hoisted_25","_hoisted_26","_hoisted_27","_hoisted_28","_hoisted_29","_hoisted_30","_hoisted_31","getRecommendReason","_hoisted_32","_hoisted_33","_hoisted_34","_hoisted_35","_hoisted_36","addRecommendedToCart","_hoisted_37","_hoisted_38"],"sources":["C:\\Users\\ROG Strix\\Desktop\\vue cli\\gui-demo\\src\\views\\ProductDetail.vue"],"sourcesContent":["<!-- eslint-disable vue/no-multiple-template-root -->\n<template>\n  <Loading :active=\"isLoading\"></Loading>\n\n  <div class=\"product-detail-page\">\n    <div class=\"container py-5\">\n      <div class=\"mb-4\">\n        <router-link to=\"/products\" class=\"btn btn-outline-secondary\">\n          <i class=\"bi bi-arrow-left me-1\"></i>\n          返回日韓料理\n        </router-link>\n      </div>\n\n      <div v-if=\"product.id\" class=\"detail-card\">\n        <div class=\"row g-5 align-items-start\">\n          <div class=\"col-lg-6\">\n            <div\n              class=\"detail-img\"\n              :style=\"{ backgroundImage: `url(${product.imageUrl || defaultImage})` }\"\n            >\n              <span class=\"detail-category\">\n                {{ product.category || '精選料理' }}\n              </span>\n\n              <button\n                type=\"button\"\n                class=\"favorite-btn\"\n                @click=\"toggleFavorite(product)\"\n              >\n                {{ isFavorite(product.id) ? '❤️' : '🤍' }}\n              </button>\n            </div>\n          </div>\n\n          <div class=\"col-lg-6\">\n            <span class=\"section-label\">FOOD DETAIL</span>\n\n            <h1 class=\"fw-bold mt-3 mb-3\">\n              {{ product.title }}\n            </h1>\n\n            <p class=\"text-muted detail-desc\">\n              {{ product.description || product.content || '日韓人氣料理。' }}\n            </p>\n\n            <div class=\"price-box my-4\">\n              <div>\n                <span class=\"text-muted d-block mb-1\">料理售價</span>\n\n                <del\n                  v-if=\"product.origin_price && product.origin_price !== product.price\"\n                  class=\"text-muted me-2\"\n                >\n                  NT$ {{ product.origin_price }}\n                </del>\n\n                <span class=\"detail-price\">\n                  NT$ {{ product.price }}\n                </span>\n              </div>\n\n              <div class=\"sold-box\">\n                已售出 {{ product.num || 0 }} 份\n              </div>\n            </div>\n\n            <div class=\"detail-info-grid mb-4\">\n              <div>\n                <span>料理分類</span>\n                <strong>{{ product.category || '未分類' }}</strong>\n              </div>\n\n              <div>\n                <span>單位</span>\n                <strong>{{ product.unit || '份' }}</strong>\n              </div>\n            </div>\n\n            <div class=\"qty-card mb-4\">\n              <label class=\"form-label fw-bold\">\n                選擇數量\n              </label>\n\n              <div class=\"input-group qty-control\">\n                <button\n                  type=\"button\"\n                  class=\"btn btn-outline-secondary\"\n                  @click=\"decreaseQty\"\n                >\n                  -\n                </button>\n\n                <input\n                  v-model.number=\"qty\"\n                  type=\"number\"\n                  min=\"1\"\n                  class=\"form-control text-center\"\n                >\n\n                <button\n                  type=\"button\"\n                  class=\"btn btn-outline-secondary\"\n                  @click=\"increaseQty\"\n                >\n                  +\n                </button>\n\n                <span class=\"input-group-text\">\n                  {{ product.unit || '份' }}\n                </span>\n              </div>\n            </div>\n\n            <div class=\"d-flex gap-3 detail-actions\">\n              <button\n                type=\"button\"\n                class=\"btn btn-danger btn-lg flex-fill\"\n                @click=\"addToCart(product.id)\"\n              >\n                <i class=\"bi bi-cart-plus me-1\"></i>\n                加入購物車\n              </button>\n\n              <button\n                type=\"button\"\n                class=\"btn btn-outline-danger btn-lg flex-fill\"\n                @click=\"toggleFavorite(product)\"\n              >\n                {{ isFavorite(product.id) ? '移除收藏' : '加入收藏' }}\n              </button>\n            </div>\n\n            <div class=\"notice-box mt-4\">\n              <h6 class=\"fw-bold mb-2\">\n                <i class=\"bi bi-info-circle me-1\"></i>\n                料理提醒\n              </h6>\n\n              <p class=\"mb-0\">\n                餐點圖片僅供參考，實際內容依店家現場供應為主。若有口味、辣度或餐具需求，可於結帳備註填寫。\n              </p>\n            </div>\n          </div>\n        </div>\n      </div>\n\n      <div v-else-if=\"!isLoading\" class=\"empty-box text-center\">\n        <div class=\"display-5 mb-3\">🍱</div>\n        <h4 class=\"fw-bold\">找不到料理資料</h4>\n        <p class=\"text-muted\">\n          可能是此料理尚未啟用，或商品資料不存在。\n        </p>\n        <router-link to=\"/products\" class=\"btn btn-danger\">\n          返回日韓料理\n        </router-link>\n      </div>\n\n      <!-- 你可能喜歡的料理 -->\n      <section class=\"recommend-section mt-5\">\n        <div class=\"recommend-header mb-4\">\n          <div>\n            <span class=\"section-label\">RECOMMENDED FOR YOU</span>\n            <h3 class=\"fw-bold mt-2 mb-1\">你可能喜歡的料理</h3>\n            <p class=\"text-muted mb-0\">\n              依照這道料理的分類、口味特色、價格區間與人氣程度，推薦相近的日韓料理。\n            </p>\n          </div>\n\n          <router-link to=\"/products\" class=\"btn btn-outline-danger\">\n            查看更多料理\n          </router-link>\n        </div>\n\n        <div v-if=\"recommendedProducts.length\" class=\"row g-4\">\n          <div\n            v-for=\"item in recommendedProducts\"\n            :key=\"item.id\"\n            class=\"col-md-6 col-lg-4\"\n          >\n            <div class=\"recommend-card\">\n              <div\n                class=\"recommend-img\"\n                :style=\"{ backgroundImage: `url(${item.imageUrl || defaultImage})` }\"\n              >\n                <button\n                  type=\"button\"\n                  class=\"favorite-btn\"\n                  @click=\"toggleFavorite(item)\"\n                >\n                  {{ isFavorite(item.id) ? '❤️' : '🤍' }}\n                </button>\n              </div>\n\n              <div class=\"p-4\">\n                <div class=\"d-flex justify-content-between align-items-center mb-2\">\n                  <span class=\"badge bg-light text-dark\">\n                    {{ item.category || '精選料理' }}\n                  </span>\n\n                  <small class=\"text-muted\">\n                    已售出 {{ item.num || 0 }} 份\n                  </small>\n                </div>\n\n                <h5 class=\"fw-bold mb-2\">\n                  {{ item.title }}\n                </h5>\n\n                <p class=\"recommend-reason mb-2\">\n                  <i class=\"bi bi-stars me-1\"></i>\n                  {{ getRecommendReason(item) }}\n                </p>\n\n                <p class=\"text-muted recommend-desc\">\n                  {{ item.description || item.content || '日韓人氣料理。' }}\n                </p>\n\n                <div class=\"mb-3\">\n                  <del\n                    v-if=\"item.origin_price && item.origin_price !== item.price\"\n                    class=\"text-muted me-2\"\n                  >\n                    NT$ {{ item.origin_price }}\n                  </del>\n\n                  <span class=\"h5 text-danger fw-bold\">\n                    NT$ {{ item.price }}\n                  </span>\n                </div>\n\n                <div class=\"d-flex gap-2\">\n                  <router-link\n                    :to=\"`/product/${item.id}`\"\n                    class=\"btn btn-outline-dark flex-fill\"\n                  >\n                    查看詳情\n                  </router-link>\n\n                  <button\n                    type=\"button\"\n                    class=\"btn btn-danger flex-fill\"\n                    @click=\"addRecommendedToCart(item)\"\n                  >\n                    加入購物車\n                  </button>\n                </div>\n              </div>\n            </div>\n          </div>\n        </div>\n\n        <div v-else class=\"recommend-empty text-center\">\n          <div class=\"display-5 mb-3\">🍱</div>\n          <h5 class=\"fw-bold\">目前沒有其他推薦料理</h5>\n          <p class=\"text-muted mb-0\">\n            你可以回到日韓料理頁面查看更多餐點。\n          </p>\n        </div>\n      </section>\n    </div>\n  </div>\n</template>\n\n<script>\nconst { VUE_APP_API, VUE_APP_PATH } = process.env;\n\nexport default {\n  name: 'ProductDetail',\n  inject: ['emitter'],\n  data() {\n    return {\n      product: {},\n      products: [],\n      favorites: JSON.parse(localStorage.getItem('favoriteFoods')) || [],\n      qty: 1,\n      isLoading: false,\n      defaultImage: 'https://images.unsplash.com/photo-1546069901-ba9599a7e63c?w=800',\n    };\n  },\n  computed: {\n    productId() {\n      return this.$route.params.id;\n    },\n\n    recommendedProducts() {\n      if (!this.product || !this.product.id) {\n        return [];\n      }\n\n      return this.products\n        .filter((item) => String(item.id) !== String(this.product.id))\n        .map((item) => ({\n          ...item,\n          recommendScore: this.getRecommendScore(item),\n        }))\n        .sort((a, b) => b.recommendScore - a.recommendScore)\n        .slice(0, 6);\n    },\n  },\n  watch: {\n    '$route.params.id': {\n      handler() {\n        this.qty = 1;\n        this.getProduct();\n        window.scrollTo({\n          top: 0,\n          behavior: 'smooth',\n        });\n      },\n    },\n  },\n  methods: {\n    pushToast(title, content = '', style = 'danger') {\n      this.emitter.emit('push-message', {\n        style,\n        title,\n        content,\n      });\n    },\n\n    getProduct() {\n      if (!this.productId) {\n        this.product = {};\n        return;\n      }\n\n      const url = `${VUE_APP_API}/api/${VUE_APP_PATH}/product/${this.productId}`;\n\n      this.isLoading = true;\n\n      this.$http.get(url)\n        .then((res) => {\n          if (res.data.success && res.data.product) {\n            this.product = res.data.product;\n          } else {\n            this.product = {};\n\n            this.pushToast(\n              '找不到料理資料',\n              res.data.message || '此料理可能尚未啟用或不存在。',\n              'danger',\n            );\n          }\n        })\n        .catch((error) => {\n          console.error('取得料理詳情失敗:', error);\n\n          this.product = {};\n\n          this.pushToast(\n            '取得料理詳情失敗',\n            '請稍後再試，或返回料理列表重新選擇。',\n            'danger',\n          );\n        })\n        .finally(() => {\n          this.isLoading = false;\n        });\n    },\n\n    getProducts() {\n      this.$http\n        .get(`${VUE_APP_API}/api/${VUE_APP_PATH}/products/all`)\n        .then((res) => {\n          this.products = res.data.products || [];\n        })\n        .catch((error) => {\n          console.error('取得推薦料理失敗:', error);\n\n          this.pushToast(\n            '取得推薦料理失敗',\n            '請稍後再試，或重新整理頁面。',\n            'danger',\n          );\n        });\n    },\n\n    increaseQty() {\n      this.qty += 1;\n    },\n\n    decreaseQty() {\n      if (this.qty <= 1) {\n        this.qty = 1;\n        return;\n      }\n\n      this.qty -= 1;\n    },\n\n    addToCart(id) {\n      const qty = Number(this.qty) || 1;\n\n      if (qty < 1) {\n        this.qty = 1;\n\n        this.pushToast(\n          '數量錯誤',\n          '餐點數量至少需要 1 份。',\n          'warning',\n        );\n        return;\n      }\n\n      const data = {\n        product_id: id,\n        qty,\n      };\n\n      this.isLoading = true;\n\n      this.$http\n        .post(`${VUE_APP_API}/api/${VUE_APP_PATH}/cart`, { data })\n        .then((res) => {\n          this.$httpMessageState(res, '加入購物車');\n\n          if (res.data.success) {\n            window.dispatchEvent(new Event('cart-updated'));\n\n            this.pushToast(\n              '已加入購物車',\n              `已成功加入 ${qty} ${this.product?.unit || '份'} ${this.product?.title || '餐點'}。`,\n              'success',\n            );\n          } else {\n            this.pushToast(\n              '加入購物車失敗',\n              res.data.message || '請稍後再試。',\n              'danger',\n            );\n          }\n        })\n        .catch((error) => {\n          console.error('加入購物車失敗:', error);\n\n          this.pushToast(\n            '加入購物車失敗',\n            '請確認網路連線或稍後再試。',\n            'danger',\n          );\n        })\n        .finally(() => {\n          this.isLoading = false;\n        });\n    },\n\n    addRecommendedToCart(item) {\n      const data = {\n        product_id: item.id,\n        qty: 1,\n      };\n\n      this.isLoading = true;\n\n      this.$http\n        .post(`${VUE_APP_API}/api/${VUE_APP_PATH}/cart`, { data })\n        .then((res) => {\n          this.$httpMessageState(res, '加入購物車');\n\n          if (res.data.success) {\n            window.dispatchEvent(new Event('cart-updated'));\n\n            this.pushToast(\n              '已加入購物車',\n              `已成功加入 1 ${item.unit || '份'} ${item.title || '餐點'}。`,\n              'success',\n            );\n          } else {\n            this.pushToast(\n              '加入購物車失敗',\n              res.data.message || '請稍後再試。',\n              'danger',\n            );\n          }\n        })\n        .catch((error) => {\n          console.error('加入推薦料理失敗:', error);\n\n          this.pushToast(\n            '加入購物車失敗',\n            '請確認網路連線或稍後再試。',\n            'danger',\n          );\n        })\n        .finally(() => {\n          this.isLoading = false;\n        });\n    },\n\n    toggleFavorite(item) {\n      if (!item || !item.id) {\n        return;\n      }\n\n      const index = this.favorites.findIndex((food) => food.id === item.id);\n\n      if (index === -1) {\n        this.favorites.push(item);\n\n        this.pushToast(\n          '已加入我的最愛',\n          `${item.title || '料理'} 已加入收藏清單。`,\n          'success',\n        );\n      } else {\n        this.favorites.splice(index, 1);\n\n        this.pushToast(\n          '已移除我的最愛',\n          `${item.title || '料理'} 已從收藏清單移除。`,\n          'warning',\n        );\n      }\n\n      localStorage.setItem('favoriteFoods', JSON.stringify(this.favorites));\n      window.dispatchEvent(new Event('favorites-updated'));\n    },\n\n    isFavorite(id) {\n      return this.favorites.some((item) => String(item.id) === String(id));\n    },\n\n    getRecommendScore(item) {\n      let score = 0;\n\n      const currentCategory = this.product.category || '';\n      const itemCategory = item.category || '';\n\n      const currentText = [\n        this.product.title,\n        this.product.category,\n        this.product.description,\n        this.product.content,\n      ].join(' ').toLowerCase();\n\n      const itemText = [\n        item.title,\n        item.category,\n        item.description,\n        item.content,\n      ].join(' ').toLowerCase();\n\n      if (currentCategory && currentCategory === itemCategory) {\n        score += 60;\n      }\n\n      const keywords = this.extractKeywords(currentText);\n\n      keywords.forEach((word) => {\n        if (itemText.includes(word)) {\n          score += 8;\n        }\n      });\n\n      const currentPrice = Number(this.product.price || 0);\n      const itemPrice = Number(item.price || 0);\n\n      if (currentPrice > 0 && itemPrice > 0) {\n        const priceDiff = Math.abs(currentPrice - itemPrice);\n\n        if (priceDiff <= 50) {\n          score += 20;\n        } else if (priceDiff <= 100) {\n          score += 12;\n        } else if (priceDiff <= 200) {\n          score += 6;\n        }\n      }\n\n      score += Math.min(Number(item.num || 0), 50);\n\n      return score;\n    },\n\n    extractKeywords(text) {\n      const stopWords = [\n        '日式料理',\n        '韓式料理',\n        '料理',\n        '人氣',\n        '精選',\n        '套餐',\n        '一份',\n        '口味',\n        '美味',\n      ];\n\n      return text\n        .replace(/[，。！？、,.!?]/g, ' ')\n        .split(/\\s+/)\n        .map((word) => word.trim())\n        .filter((word) => word.length >= 2)\n        .filter((word) => !stopWords.includes(word))\n        .slice(0, 12);\n    },\n\n    getRecommendReason(item) {\n      if (item.category === this.product.category) {\n        return `同樣屬於 ${item.category}，性質與這道料理相近。`;\n      }\n\n      const currentPrice = Number(this.product.price || 0);\n      const itemPrice = Number(item.price || 0);\n\n      if (currentPrice > 0 && itemPrice > 0 && Math.abs(currentPrice - itemPrice) <= 100) {\n        return '價格區間接近，適合一起比較選購。';\n      }\n\n      if (Number(item.num || 0) > 0) {\n        return '這是目前較受歡迎的人氣料理。';\n      }\n\n      return '這道料理也適合加入你的下一次點餐清單。';\n    },\n  },\n  mounted() {\n    this.getProduct();\n    this.getProducts();\n  },\n};\n</script>\n\n<style scoped>\n.product-detail-page {\n  min-height: 100vh;\n  background:\n    radial-gradient(circle at top left, rgba(220, 53, 69, 0.1), transparent 30%),\n    linear-gradient(180deg, #fff7ef 0%, #ffffff 44%, #fffaf5 100%);\n}\n\n.detail-card {\n  padding: 34px;\n  border-radius: 32px;\n  background: #ffffff;\n  border: 1px solid #f1d8ca;\n  box-shadow: 0 18px 45px rgba(120, 54, 28, 0.1);\n}\n\n.detail-img {\n  position: relative;\n  min-height: 480px;\n  border-radius: 28px;\n  background-size: cover;\n  background-position: center;\n  background-color: #fff4ec;\n  border: 1px solid #f1d8ca;\n  overflow: hidden;\n}\n\n.detail-category {\n  position: absolute;\n  top: 18px;\n  left: 18px;\n  padding: 8px 14px;\n  border-radius: 999px;\n  color: #ffffff;\n  background: rgba(178, 58, 46, 0.95);\n  font-size: 14px;\n  font-weight: 900;\n}\n\n.favorite-btn {\n  position: absolute;\n  top: 18px;\n  right: 18px;\n  width: 46px;\n  height: 46px;\n  border: 0;\n  border-radius: 50%;\n  background: #ffffff;\n  box-shadow: 0 8px 18px rgba(0, 0, 0, 0.18);\n}\n\n.section-label {\n  display: inline-block;\n  color: #b23a2e;\n  font-size: 13px;\n  font-weight: 900;\n  letter-spacing: 1px;\n}\n\n.detail-desc {\n  font-size: 17px;\n  line-height: 1.9;\n}\n\n.price-box {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  gap: 18px;\n  padding: 22px;\n  border-radius: 22px;\n  background: #fff8f2;\n  border: 1px solid #f1d8ca;\n}\n\n.detail-price {\n  color: #b23a2e;\n  font-size: 34px;\n  font-weight: 900;\n}\n\n.sold-box {\n  flex: 0 0 auto;\n  padding: 8px 14px;\n  border-radius: 999px;\n  color: #b23a2e;\n  background: #fff0e7;\n  font-weight: 900;\n}\n\n.detail-info-grid {\n  display: grid;\n  grid-template-columns: repeat(2, minmax(0, 1fr));\n  gap: 14px;\n}\n\n.detail-info-grid div {\n  padding: 18px;\n  border-radius: 18px;\n  background: #fffaf6;\n  border: 1px solid #f1e4dc;\n}\n\n.detail-info-grid span {\n  display: block;\n  margin-bottom: 6px;\n  color: #888;\n  font-size: 13px;\n}\n\n.detail-info-grid strong {\n  color: #333;\n}\n\n.qty-card {\n  padding: 20px;\n  border-radius: 22px;\n  background: #ffffff;\n  border: 1px solid #f1e4dc;\n}\n\n.qty-control {\n  max-width: 260px;\n}\n\n.qty-control .form-control {\n  font-weight: 900;\n}\n\n.notice-box {\n  padding: 18px;\n  border-radius: 18px;\n  color: #6c5b50;\n  background: #fff8e1;\n  border: 1px solid #ffe0a1;\n  line-height: 1.8;\n}\n\n.empty-box {\n  padding: 80px 24px;\n  border-radius: 30px;\n  background: #ffffff;\n  border: 1px solid #f1d8ca;\n  box-shadow: 0 16px 42px rgba(120, 54, 28, 0.1);\n}\n\n.recommend-section {\n  padding: 34px;\n  border-radius: 30px;\n  background: #ffffff;\n  border: 1px solid #f1d8ca;\n  box-shadow: 0 18px 45px rgba(120, 54, 28, 0.09);\n}\n\n.recommend-header {\n  display: flex;\n  justify-content: space-between;\n  align-items: flex-end;\n  gap: 18px;\n}\n\n.recommend-card {\n  height: 100%;\n  overflow: hidden;\n  border-radius: 26px;\n  background: #ffffff;\n  border: 1px solid #f1d8ca;\n  box-shadow: 0 16px 38px rgba(120, 54, 28, 0.09);\n  transition: transform 0.25s ease, box-shadow 0.25s ease;\n}\n\n.recommend-card:hover {\n  transform: translateY(-5px);\n  box-shadow: 0 22px 48px rgba(120, 54, 28, 0.14);\n}\n\n.recommend-img {\n  position: relative;\n  height: 220px;\n  background-size: cover;\n  background-position: center;\n  background-color: #fff4ec;\n}\n\n.recommend-desc {\n  min-height: 48px;\n  line-height: 1.7;\n}\n\n.recommend-reason {\n  min-height: 24px;\n  color: #b23a2e;\n  font-size: 14px;\n  font-weight: 800;\n}\n\n.recommend-empty {\n  padding: 70px 24px;\n  border-radius: 28px;\n  background: #fff8f3;\n  border: 1px dashed #e5c9b8;\n}\n\n@media (max-width: 991px) {\n  .detail-img {\n    min-height: 360px;\n  }\n\n  .price-box {\n    flex-direction: column;\n    align-items: flex-start;\n  }\n\n  .detail-actions {\n    flex-direction: column;\n  }\n\n  .recommend-header {\n    flex-direction: column;\n    align-items: flex-start;\n  }\n\n  .recommend-header .btn {\n    width: 100%;\n  }\n}\n\n@media (max-width: 768px) {\n  .detail-card,\n  .recommend-section {\n    padding: 24px 18px;\n    bo