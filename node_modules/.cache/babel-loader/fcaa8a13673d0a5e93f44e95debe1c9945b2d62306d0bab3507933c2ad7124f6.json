es","productsRes","addToCart","_this4","product_id","post","alert","toggleFavorite","_this5","index","findIndex","push","splice","setItem","stringify","watch","handler","mounted"],"sources":["C:\\Users\\ROG Strix\\Desktop\\vue cli\\gui-demo\\src\\views\\ProductDetail.vue"],"sourcesContent":["<!-- eslint-disable vue/no-multiple-template-root -->\n<template>\n  <Loading :active=\"isLoading\" />\n\n  <div class=\"container py-5\">\n    <div class=\"row g-5 align-items-start\">\n      <div class=\"col-lg-6\">\n        <div\n          class=\"detail-img\"\n          :style=\"{ backgroundImage: `url(${product.imageUrl})` }\"\n        ></div>\n      </div>\n\n      <div class=\"col-lg-6\">\n        <span class=\"badge bg-danger mb-3\">\n          {{ product.category }}\n        </span>\n\n        <h1 class=\"fw-bold mb-3\">\n          {{ product.title }}\n        </h1>\n\n        <p class=\"lead text-muted\">\n          {{ product.description || product.content }}\n        </p>\n\n        <div class=\"selling-box mb-4\">\n          <h5 class=\"fw-bold\">推薦理由</h5>\n          <ul class=\"mb-0\">\n            <li>嚴選食材，保留日韓料理最經典的風味。</li>\n            <li>適合午餐、晚餐、聚餐與追劇宵夜。</li>\n            <li>搭配優惠券與人氣套餐，下單更划算。</li>\n          </ul>\n        </div>\n\n        <div class=\"price-box mb-4\">\n          <del class=\"text-muted me-2\">\n            NT$ {{ product.origin_price }}\n          </del>\n          <span class=\"display-6 fw-bold text-danger\">\n            NT$ {{ product.price }}\n          </span>\n          <span class=\"text-muted ms-2\">/ {{ product.unit }}</span>\n        </div>\n\n        <div class=\"d-flex align-items-center gap-3 mb-4\">\n          <select v-model.number=\"qty\" class=\"form-select qty-select\">\n            <option v-for=\"num in 10\" :key=\"num\" :value=\"num\">\n              {{ num }} 份\n            </option>\n          </select>\n\n          <button class=\"btn btn-danger btn-lg flex-fill\" @click=\"addToCart\">\n            加入購物車\n          </button>\n        </div>\n\n        <button class=\"btn btn-outline-dark w-100\" @click=\"toggleFavorite\">\n          {{ isFavorite ? '已加入我的最愛 ❤️' : '加入我的最愛 🤍' }}\n        </button>\n      </div>\n    </div>\n\n    <section class=\"mt-5\">\n      <h3 class=\"fw-bold mb-4\">你可能也會喜歡</h3>\n\n      <div class=\"row g-4\">\n        <div\n          v-for=\"item in relatedProducts\"\n          :key=\"item.id\"\n          class=\"col-md-4\"\n        >\n          <router-link :to=\"`/product/${item.id}`\" class=\"related-card\">\n            <div\n              class=\"related-img\"\n              :style=\"{ backgroundImage: `url(${item.imageUrl})` }\"\n            ></div>\n            <div class=\"p-3\">\n              <h6 class=\"fw-bold mb-1\">{{ item.title }}</h6>\n              <p class=\"text-danger fw-bold mb-0\">NT$ {{ item.price }}</p>\n            </div>\n          </router-link>\n        </div>\n      </div>\n    </section>\n  </div>\n</template>\n\n<script>\nconst { VUE_APP_API, VUE_APP_PATH } = process.env;\n\nexport default {\n  data() {\n    return {\n      product: {},\n      products: [],\n      qty: 1,\n      favorites: JSON.parse(localStorage.getItem('favoriteFoods')) || [],\n      isLoading: false,\n    };\n  },\n  computed: {\n    isFavorite() {\n      return this.favorites.some((item) => item.id === this.product.id);\n    },\n    relatedProducts() {\n      return this.products\n        .filter((item) => item.category === this.product.category && item.id !== this.product.id)\n        .slice(0, 3);\n    },\n  },\n  methods: {\n    getProduct() {\n      const { id } = this.$route.params;\n      this.isLoading = true;\n\n      Promise.all([\n        this.$http.get(`${VUE_APP_API}/api/${VUE_APP_PATH}/product/${id}`),\n        this.$http.get(`${VUE_APP_API}/api/${VUE_APP_PATH}/products/all`),\n      ])\n        .then(([productRes, productsRes]) => {\n          this.product = productRes.data.product;\n          this.products = productsRes.data.products || [];\n        })\n        .finally(() => {\n          this.isLoading = false;\n        });\n    },\n\n    addToCart() {\n      const data = {\n        product_id: this.product.id,\n        qty: this.qty,\n      };\n\n      this.isLoading = true;\n\n      this.$http\n        .post(`${VUE_APP_API}/api/${VUE_APP_PATH}/cart`, { data })\n        .then(() => {\n          alert('已加入購物車');\n        })\n        .finally(() => {\n          this.isLoading = false;\n        });\n    },\n\n    toggleFavorite() {\n      const index = this.favorites.findIndex((item) => item.id === this.product.id);\n\n      if (index === -1) {\n        this.favorites.push(this.product);\n      } else {\n        this.favorites.splice(index, 1);\n      }\n\n      localStorage.setItem('favoriteFoods', JSON.stringify(this.favorites));\n    },\n  },\n  watch: {\n    '$route.params.id': {\n      handler() {\n        this.getProduct();\n      },\n    },\n  },\n  mounted() {\n    this.getProduct();\n  },\n};\n</script>\n\n<style scoped>\n.detail-img {\n  height: 520px;\n  border-radius: 30px;\n  background-size: cover;\n  background-position: center;\n  box-shadow: 0 20px 46px rgba(0, 0, 0, 0.12);\n}\n\n.selling-box {\n  padding: 24px;\n  border-radius: 22px;\n  background: #fff8ed;\n  border: 1px solid #f2dcc4;\n}\n\n.qty-select {\n  max-width: 140px;\n}\n\n.related-card {\n  display: block;\n  overflow: hidden;\n  border-radius: 22px;\n  color: inherit;\n  text-decoration: none;\n  background: #fff;\n  border: 1px solid #eee;\n}\n\n.related-img {\n  height: 180px;\n  background-size: cover;\n  background-position: center;\n}\n</style>"],"mappings":";;;;;;;;;;;;;;;;;;AAyFA,IAAAA,YAAA,GAAsCC,OAAO,CAACC,GAAG;EAAzCC,WAAW,GAAAH,YAAA,CAAXG,WAAW;EAAEC,YAAW,GAAAJ,YAAA,CAAXI,YAAW;AAEhC,eAAe;EACbC,IAAI,WAAJA,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,OAAO,EAAE,CAAC,CAAC;MACXC,QAAQ,EAAE,EAAE;MACZC,GAAG,EAAE,CAAC;MACNC,SAAS,EAAEC,IAAI,CAACC,KAAK,CAACC,YAAY,CAACC,OAAO,CAAC,eAAe,CAAC,KAAK,EAAE;MAClEC,SAAS,EAAE;IACb,CAAC;EACH,CAAC