\n        } else {\n          _this4.pushToast('加入購物車失敗', res.data.message || '請稍後再試。', 'danger');\n        }\n      })[\"catch\"](function (error) {\n        console.error('加入購物車失敗:', error);\n        _this4.pushToast('加入購物車失敗', '請確認網路連線或稍後再試。', 'danger');\n      })[\"finally\"](function () {\n        _this4.isLoading = false;\n      });\n    },\n    addRecommendedToCart: function addRecommendedToCart(item) {\n      var _this5 = this;\n      var data = {\n        product_id: item.id,\n        qty: 1\n      };\n      this.isLoading = true;\n      this.$http.post(\"\".concat(VUE_APP_API, \"/api/\").concat(VUE_APP_PATH, \"/cart\"), {\n        data: data\n      }).then(function (res) {\n        _this5.$httpMessageState(res, '加入購物車');\n        if (res.data.success) {\n          window.dispatchEvent(new Event('cart-updated'));\n          _this5.pushToast('已加入購物車', \"\\u5DF2\\u6210\\u529F\\u52A0\\u5165 1 \".concat(item.unit || '份', \" \").concat(item.title || '餐點', \"\\u3002\"), 'success');\n        } else {\n          _this5.pushToast('加入購物車失敗', res.data.message || '請稍後再試。', 'danger');\n        }\n      })[\"catch\"](function (error) {\n        console.error('加入推薦料理失敗:', error);\n        _this5.pushToast('加入購物車失敗', '請確認網路連線或稍後再試。', 'danger');\n      })[\"finally\"](function () {\n        _this5.isLoading = false;\n      });\n    },\n    toggleFavorite: function toggleFavorite(item) {\n      if (!item || !item.id) {\n        return;\n      }\n      var index = this.favorites.findIndex(function (food) {\n        return food.id === item.id;\n      });\n      if (index === -1) {\n        this.favorites.push(item);\n        this.pushToast('已加入我的最愛', \"\".concat(item.title || '料理', \" \\u5DF2\\u52A0\\u5165\\u6536\\u85CF\\u6E05\\u55AE\\u3002\"), 'success');\n      } else {\n        this.favorites.splice(index, 1);\n        this.pushToast('已移除我的最愛', \"\".concat(item.title || '料理', \" \\u5DF2\\u5F9E\\u6536\\u85CF\\u6E05\\u55AE\\u79FB\\u9664\\u3002\"), 'warning');\n      }\n      localStorage.setItem('favoriteFoods', JSON.stringify(this.favorites));\n      window.dispatchEvent(new Event('favorites-updated'));\n    },\n    isFavorite: function isFavorite(id) {\n      return this.favorites.some(function (item) {\n        return String(item.id) === String(id);\n      });\n    },\n    getRecommendScore: function getRecommendScore(item) {\n      var score = 0;\n      var currentCategory = this.product.category || '';\n      var itemCategory = item.category || '';\n      var currentText = [this.product.title, this.product.category, this.product.description, this.product.content].join(' ').toLowerCase();\n      var itemText = [item.title, item.category, item.description, item.content].join(' ').toLowerCase();\n      if (currentCategory && currentCategory === itemCategory) {\n        score += 60;\n      }\n      var keywords = this.extractKeywords(currentText);\n      keywords.forEach(function (word) {\n        if (itemText.includes(word)) {\n          score += 8;\n        }\n      });\n      var currentPrice = Number(this.product.price || 0);\n      var itemPrice = Number(item.price || 0);\n      if (currentPrice > 0 && itemPrice > 0) {\n        var priceDiff = Math.abs(currentPrice - itemPrice);\n        if (priceDiff <= 50) {\n          score += 20;\n        } else if (priceDiff <= 100) {\n          score += 12;\n        } else if (priceDiff <= 200) {\n          score += 6;\n        }\n      }\n      score += Math.min(Number(item.num || 0), 50);\n      return score;\n    },\n    extractKeywords: function extractKeywords(text) {\n      var stopWords = ['日式料理', '韓式料理', '料理', '人氣', '精選', '套餐', '一份', '口味', '美味'];\n      return text.replace(/[，。！？、,.!?]/g, ' ').split(/\\s+/).map(function (word) {\n        return word.trim();\n      }).filter(function (word) {\n        return word.length >= 2;\n      }).filter(function (word) {\n        return !stopWords.includes(word);\n      }).slice(0, 12);\n    },\n    getRecommendReason: function getRecommendReason(item) {\n      if (item.category === this.product.category) {\n        return \"\\u540C\\u6A23\\u5C6C\\u65BC \".concat(item.category, \"\\uFF0C\\u6027\\u8CEA\\u8207\\u9019\\u9053\\u6599\\u7406\\u76F8\\u8FD1\\u3002\");\n      }\n      var currentPrice = Number(this.product.price || 0);\n      var itemPrice = Number(item.price || 0);\n      if (currentPrice > 0 && itemPrice > 0 && Math.abs(currentPrice - itemPrice) <= 100) {\n        return '價格區間接近，適合一起比較選購。';\n      }\n      if (Number(item.num || 0) > 0) {\n        return '這是目前較受歡迎的人氣料理。';\n      }\n      return '這道料理也適合加入你的下一次點餐清單。';\n    }\n  },\n  mounted: function mounted() {\n    this.getProduct();\n    this.getProducts();\n  }\n};","map":{"version":3,"names":["_process$env","process","env","VUE_APP_API","VUE_APP_PATH","name","inject","data","product","products","favorites","JSON","parse","localStorage","getItem","qty","isLoading","defaultImage","computed","productId","$route","params","id","recommendedProducts","_this","filter","item","String","map","_objectSpread","recommendScore","getRecommendScore","sort","a","b","slice","watch","handler","getProduct","window","scrollTo","top","behavior","methods","pushToast","title","content","arguments","length","undefined","style","emitter","emit","_this2","url","concat","$http","get","then","res","success","message","error","console","getProducts","_this3","increaseQty","decreaseQty","addToCart","_this4","Number","product_id","post","$httpMessageState","_this4$product","_this4$product2","dispatchEvent","Event","unit","addRecommendedToCart","_this5","toggleFavorite","index","findIndex","food","push","splice","setItem","stringify","isFavorite","some","score","currentCategory","category","itemCategory","currentText","description","join","toLowerCase","itemText","keywords","extractKeywords","forEach","word","includes","currentPrice","price","itemPrice","priceDiff","Math","abs","min","num","text","stopWords","replace","split","trim","getRecommendReason","mounted"],"sources":["C:\\Users\\ROG Strix\\Desktop\\vue cli\\gui-demo\\src\\views\\ProductDetail.vue"],"sourcesContent":["<!-- eslint-disable vue/no-multiple-template-root -->\n<template>\n  <div class=\"product-detail-root\">\n    <Loading :active=\"isLoading\"></Loading>\n    <div class=\"product-detail-page\">\n      <div class=\"container py-5\">\n        <div class=\"mb-4\">\n          <router-link to=\"/products\" class=\"btn btn-outline-secondary\">\n            <i class=\"bi bi-arrow-left me-1\"></i>\n            返回日韓料理\n          </router-link>\n        </div>\n\n        <div v-if=\"product.id\" class=\"detail-card\">\n          <div class=\"row g-5 align-items-start\">\n            <div class=\"col-lg-6\">\n              <div\n                class=\"detail-img\"\n                :style=\"{ backgroundImage: `url(${product.imageUrl || defaultImage})` }\"\n              >\n                <span class=\"detail-category\">\n                  {{ product.category || '精選料理' }}\n                </span>\n\n                <button\n                  type=\"button\"\n                  class=\"favorite-btn\"\n                  @click=\"toggleFavorite(product)\"\n                >\n                  {{ isFavorite(product.id) ? '❤️' : '🤍' }}\n                </button>\n              </div>\n            </div>\n\n            <div class=\"col-lg-6\">\n              <span class=\"section-label\">FOOD DETAIL</span>\n\n              <h1 class=\"fw-bold mt-3 mb-3\">\n                {{ product.title }}\n              </h1>\n\n              <p class=\"text-muted detail-desc\">\n                {{ product.description || product.content || '日韓人氣料理。' }}\n              </p>\n\n              <div class=\"price-box my-4\">\n                <div>\n                  <span class=\"text-muted d-block mb-1\">料理售價</span>\n\n                  <del\n                    v-if=\"product.origin_price && product.origin_price !== product.price\"\n                    class=\"text-muted me-2\"\n                  >\n                    NT$ {{ product.origin_price }}\n                  </del>\n\n                  <span class=\"detail-price\">\n                    NT$ {{ product.price }}\n                  </span>\n                </div>\n\n                <div class=\"sold-box\">\n                  已售出 {{ product.num || 0 }} 份\n                </div>\n              </div>\n\n              <div class=\"detail-info-grid mb-4\">\n                <div>\n                  <span>料理分類</span>\n                  <strong>{{ product.category || '未分類' }}</strong>\n                </div>\n\n                <div>\n                  <span>單位</span>\n                  <strong>{{ product.unit || '份' }}</strong>\n                </div>\n              </div>\n\n              <div class=\"qty-card mb-4\">\n                <label class=\"form-label fw-bold\">\n                  選擇數量\n                </label>\n\n                <div class=\"input-group qty-control\">\n                  <button\n                    type=\"button\"\n                    class=\"btn btn-outline-secondary\"\n                    @click=\"decreaseQty\"\n                  >\n                    -\n                  </button>\n\n                  <input\n                    v-model.number=\"qty\"\n                    type=\"number\"\n                    min=\"1\"\n                    class=\"form-control text-center\"\n                  >\n\n                  <button\n                    type=\"button\"\n                    class=\"btn btn-outline-secondary\"\n                    @click=\"increaseQty\"\n                  >\n                    +\n                  </button>\n\n                  <span class=\"input-group-text\">\n                    {{ product.unit || '份' }}\n                  </span>\n                </div>\n              </div>\n\n              <div class=\"d-flex gap-3 detail-actions\">\n                <button\n                  type=\"button\"\n                  class=\"btn btn-danger btn-lg flex-fill\"\n                  @click=\"addToCart(product.id)\"\n                >\n                  <i class=\"bi bi-cart-plus me-1\"></i>\n                  加入購物車\n                </button>\n\n                <button\n                  type=\"button\"\n                  class=\"btn btn-outline-danger btn-lg flex-fill\"\n                  @click=\"toggleFavorite(product)\"\n                >\n                  {{ isFavorite(product.id) ? '移除收藏' : '加入收藏' }}\n                </button>\n              </div>\n\n              <div class=\"notice-box mt-4\">\n                <h6 class=\"fw-bold mb-2\">\n                  <i class=\"bi bi-info-circle me-1\"></i>\n                  料理提醒\n                </h6>\n\n                <p class=\"mb-0\">\n                  餐點圖片僅供參考，實際內容依店家現場供應為主。若有口味、辣度或餐具需求，可於結帳備註填寫。\n                </p>\n              </div>\n            </div>\n          </div>\n        </div>\n\n        <div v-else-if=\"!isLoading\" class=\"empty-box text-center\">\n          <div class=\"display-5 mb-3\">🍱</div>\n          <h4 class=\"fw-bold\">找不到料理資料</h4>\n          <p class=\"text-muted\">\n            可能是此料理尚未啟用，或商品資料不存在。\n          </p>\n          <router-link to=\"/products\" class=\"btn btn-danger\">\n            返回日韓料理\n          </router-link>\n        </div>\n\n        <!-- 你可能喜歡的料理 -->\n        <section class=\"recommend-section mt-5\">\n          <div class=\"recommend-header mb-4\">\n            <div>\n              <span class=\"section-label\">RECOMMENDED FOR YOU</span>\n              <h3 class=\"fw-bold mt-2 mb-1\">你可能喜歡的料理</h3>\n              <p class=\"text-muted mb-0\">\n                依照這道料理的分類、口味特色、價格區間與人氣程度，推薦相近的日韓料理。\n              </p>\n            </div>\n\n            <router-link to=\"/products\" class=\"btn btn-outline-danger\">\n              查看更多料理\n            </router-link>\n          </div>\n\n          <div v-if=\"recommendedProducts.length\" class=\"row g-4\">\n            <div\n              v-for=\"item in recommendedProducts\"\n              :key=\"item.id\"\n              class=\"col-md-6 col-lg-4\"\n            >\n              <div class=\"recommend-card\">\n                <div\n                  class=\"recommend-img\"\n                  :style=\"{ backgroundImage: `url(${item.imageUrl || defaultImage})` }\"\n                >\n                  <button\n                    type=\"button\"\n                    class=\"favorite-btn\"\n                    @click=\"toggleFavorite(item)\"\n                  >\n                    {{ isFavorite(item.id) ? '❤️' : '🤍' }}\n                  </button>\n                </div>\n\n                <div class=\"p-4\">\n                  <div class=\"d-flex justify-content-between align-items-center mb-2\">\n                    <span class=\"badge bg-light text-dark\">\n                      {{ item.category || '精選料理' }}\n                    </span>\n\n                    <small class=\"text-muted\">\n                      已售出 {{ item.num || 0 }} 份\n                    </small>\n                  </div>\n\n                  <h5 class=\"fw-bold mb-2\">\n                    {{ item.title }}\n                  </h5>\n\n                  <p class=\"recommend-reason mb-2\">\n                    <i class=\"bi bi-stars me-1\"></i>\n                    {{ getRecommendReason(item) }}\n                  </p>\n\n                  <p class=\"text-muted recommend-desc\">\n                    {{ item.description || item.content || '日韓人氣料理。' }}\n                  </p>\n\n                  <div class=\"mb-3\">\n                    <del\n                      v-if=\"item.origin_price && item.origin_price !== item.price\"\n                      class=\"text-muted me-2\"\n                    >\n                      NT$ {{ item.origin_price }}\n                    </del>\n\n                    <span class=\"h5 text-danger fw-bold\">\n                      NT$ {{ item.price }}\n                    </span>\n                  </div>\n\n                  <div class=\"d-flex gap-2\">\n                    <router-link\n                      :to=\"`/product/${item.id}`\"\n                      class=\"btn btn-outline-dark flex-fill\"\n                    >\n                      查看詳情\n                    </router-link>\n\n                    <button\n                      type=\"button\"\n                      class=\"btn btn-danger flex-fill\"\n                      @click=\"addRecommendedToCart(item)\"\n                    >\n                      加入購物車\n                    </button>\n                  </div>\n                </div>\n              </div>\n            </div>\n          </div>\n\n          <div v-else class=\"recommend-empty text-center\">\n            <div class=\"display-5 mb-3\">🍱</div>\n            <h5 class=\"fw-bold\">目前沒有其他推薦料理</h5>\n            <p class=\"text-muted mb-0\">\n              你可以回到日韓料理頁面查看更多餐點。\n            </p>\n          </div>\n        </section>\n      </div>\n    </div>\n  </div>\n</template>\n\n<script>\nconst { VUE_APP_API, VUE_APP_PATH } = process.env;\n\nexport default {\n  name: 'ProductDetail',\n  inject: ['emitter'],\n  data() {\n    return {\n      product: {},\n      products: [],\n      favorites: JSON.parse(localStorage.getItem('favoriteFoods')) || [],\n      qty: 1,\n      isLoading: false,\n      defaultImage: 'https://images.unsplash.com/photo-1546069901-ba9599a7e63c?w=800',\n    };\n  },\n  computed: {\n    productId() {\n      return this.$route.params.id;\n    },\n\n    recommendedProducts() {\n      if (!this.product || !this.product.id) {\n        return [];\n      }\n\n      return this.products\n        .filter((item) => String(item.id) !== String(this.product.id))\n        .map((item) => ({\n          ...item,\n          recommendScore: this.getRecommendScore(item),\n        }))\n        .sort((a, b) => b.recommendScore - a.recommendScore)\n        .slice(0, 6);\n    },\n  },\n  watch: {\n    '$route.params.id': {\n      handler() {\n        this.qty = 1;\n        this.getProduct();\n        window.scrollTo({\n          top: 0,\n          behavior: 'smooth',\n        });\n      },\n    },\n  },\n  methods: {\n    pushToast(title, content = '', style = 'danger') {\n      this.emitter.emit('push-message', {\n        style,\n        title,\n        content,\n      });\n    },\n\n    getProduct() {\n      if (!this.productId) {\n        this.product = {};\n        return;\n      }\n\n      const url = `${VUE_APP_API}/api/${VUE_APP_PATH}/product/${this.productId}`;\n\n      this.isLoading = true;\n\n      this.$http.get(url)\n        .then((res) => {\n          if (res.data.success && res.data.product) {\n            this.product = res.data.product;\n          } else {\n            this.product = {};\n\n            this.pushToast(\n              '找不到料理資料',\n              res.data.message || '此料理可能尚未啟用或不存在。',\n              'danger',\n            );\n          }\n        })\n        .catch((error) => {\n          console.error('取得料理詳情失敗:', error);\n\n          this.product = {};\n\n          this.pushToast(\n            '取得料理詳情失敗',\n            '請稍後再試，或返回料理列表重新選擇。',\n            'danger',\n          );\n        })\n        .finally(() => {\n          this.isLoading = false;\n        });\n    },\n\n    getProducts() {\n      this.$http\n        .get(`${VUE_APP_API}/api/${VUE_APP_PATH}/products/all`)\n        .then((res) => {\n          this.products = res.data.products || [];\n        })\n        .catch((error) => {\n          console.error('取得推薦料理失敗:', error);\n\n          this.pushToast(\n            '取得推薦料理失敗',\n            '請稍後再試，或重新整理頁面。',\n            'danger',\n          );\n        });\n    },\n\n    increaseQty() {\n      this.qty += 1;\n    },\n\n    decreaseQty() {\n      if (this.qty <= 1) {\n        this.qty = 1;\n        return;\n      }\n\n      this.qty -= 1;\n    },\n\n    addToCart(id) {\n      const qty = Number(this.qty) || 1;\n\n      if (qty < 1) {\n        this.qty = 1;\n\n        this.pushToast(\n          '數量錯誤',\n          '餐點數量至少需要 1 份。',\n          'warning',\n        );\n        return;\n      }\n\n      const data = {\n        product_id: id,\n        qty,\n      };\n\n      this.isLoading = true;\n\n      this.$http\n        .post(`${VUE_APP_API}/api/${VUE_APP_PATH}/cart`, { data })\n        .then((res) => {\n          this.$httpMessageState(res, '加入購物車');\n\n          if (res.data.success) {\n            window.dispatchEvent(new Event('cart-updated'));\n\n            this.pushToast(\n              '已加入購物車',\n              `已成功加入 ${qty} ${this.product?.unit || '份'} ${this.product?.title || '餐點'}。`,\n              'success',\n            );\n          } else {\n            this.pushToast(\n              '加入購物車失敗',\n              res.data.message || '請稍後再試。',\n              'danger',\n            );\n          }\n        })\n        .catch((error) => {\n          console.error('加入購物車失敗:', error);\n\n          this.pushToast(\n            '加入購物車失敗',\n            '請確認網路連線或稍後再試。',\n            'danger',\n          );\n        })\n        .finally(() => {\n          this.isLoading = false;\n        });\n    },\n\n    addRecommendedToCart(item) {\n      const data = {\n        product_id: item.id,\n        qty: 1,\n      };\n\n      this.isLoading = true;\n\n      this.$http\n        .post(`${VUE_APP_API}/api/${VUE_APP_PATH}/cart`, { data })\n        .then((res) => {\n          this.$httpMessageState(res, '加入購物車');\n\n          if (res.data.success) {\n            window.dispatchEvent(new Event('cart-updated'));\n\n            this.pushToast(\n              '已加入購物車',\n              `已成功加入 1 ${item.unit || '份'} ${item.title || '餐點'}。`,\n              'success',\n            );\n          } else {\n            this.pushToast(\n              '加入購物車失敗',\n              res.data.message || '請稍後再試。',\n              'danger',\n            );\n          }\n        })\n        .catch((error) => {\n          console.error('加入推薦料理失敗:', error);\n\n          this.pushToast(\n            '加入購物車失敗',\n            '請確認網路連線或稍後再試。',\n            'danger',\n          );\n        })\n        .finally(() => {\n          this.isLoading = false;\n        });\n    },\n\n    toggleFavorite(item) {\n      if (!item || !item.id) {\n        return;\n      }\n\n      const index = this.favorites.findIndex((food) => food.id === item.id);\n\n      if (index === -1) {\n        this.favorites.push(item);\n\n        this.pushToast(\n          '已加入我的最愛',\n          `${item.title || '料理'} 已加入收藏清單。`,\n          'success',\n        );\n      } else {\n        this.favorites.splice(index, 1);\n\n        this.pushToast(\n          '已移除我的最愛',\n          `${item.title || '料理'} 已從收藏清單移除。`,\n          'warning',\n        );\n      }\n\n      localStorage.setItem('favoriteFoods', JSON.stringify(this.favorites));\n      window.dispatchEvent(new Event('favorites-updated'));\n    },\n\n    isFavorite(id) {\n      return this.favorites.some((item) => String(item.id) === String(id));\n    },\n\n    getRecommendScore(item) {\n      let score = 0;\n\n      const currentCategory = this.product.category || '';\n      const itemCategory = item.category || '';\n\n      const currentText = [\n        this.product.title,\n        this.product.category,\n        this.product.description,\n        this.product.content,\n      ].join(' ').toLowerCase();\n\n      const itemText = [\n        item.title,\n        item.category,\n        item.description,\n        item.content,\n      ].join(' ').toLowerCase();\n\n      if (currentCategory && currentCategory === itemCategory) {\n        score += 60;\n      }\n\n      const keywords = this.extractKeywords(currentText);\n\n      keywords.forEach((word) => {\n        if (itemText.includes(word)) {\n          score += 8;\n        }\n      });\n\n      const currentPrice = Number(this.product.price || 0);\n      const itemPrice = Number(item.price || 0);\n\n      if (currentPrice > 0 && itemPrice > 0) {\n        const priceDiff = Math.abs(currentPrice - itemPrice);\n\n        if (priceDiff <= 50) {\n          score += 20;\n        } else if (priceDiff <= 100) {\n          score += 12;\n        } else if (priceDiff <= 200) {\n          score += 6;\n        }\n      }\n\n      score += Math.min(Number(item.num || 0), 50);\n\n      return score;\n    },\n\n    extractKeywords(text) {\n      const stopWords = [\n        '日式料理',\n        '韓式料理',\n        '料理',\n        '人氣',\n        '精選',\n        '套餐',\n        '一份',\n        '口味',\n        '美味',\n      ];\n\n      return text\n        .replace(/[，。！？、,.!?]/g, ' ')\n        .split(/\\s+/)\n        .map((word) => word.trim())\n        .filter((word) => word.length >= 2)\n        .filter((word) => !stopWords.includes(word))\n        .slice(0, 12);\n    },\n\n    getRecommendReason(item) {\n      if (item.category === this.product.category) {\n        return `同樣屬於 ${item.category}，性質與這道料理相近。`;\n      }\n\n      const currentPrice = Number(this.product.price || 0);\n      const itemPrice = Number(item.price || 0);\n\n      if (currentPrice > 0 && itemPrice > 0 && Math.abs(currentPrice - itemPrice) <= 100) {\n        return '價格區間接近，適合一起比較選購。';\n      }\n\n      if (Number(item.num || 0) > 0) {\n        return '這是目前較受歡迎的人氣料理。';\n      }\n\n      return '這道料理也適合加入你的下一次點餐清單。';\n    },\n  },\n  mounted() {\n    this.getProduct();\n    this.getProducts();\n  },\n};\n</script>\n\n<style scoped>\n.product-detail-page {\n  min-height: 100vh;\n  background:\n    radial-gradient(circle at top left, rgba(220, 53, 69, 0.1), transparent 30%),\n    linear-gradient(180deg, #fff7ef 0%, #ffffff 44%, #fffaf5 100%);\n}\n\n.detail-card {\n  padding: 34px;\n  border-radius: 32px;\n  background: #ffffff;\n  border: 1px solid #f1d8ca;\n  box-shadow: 0 18px 45px rgba(120, 54, 28, 0.1);\n}\n\n.detail-img {\n  position: relative;\n  min-height: 480px;\n  border-radius: 28px;\n  background-size: cover;\n  background-position: center;\n  background-color: #fff4ec;\n  border: 1px solid #f1d8ca;\n  overflow: