{"ast":null,"code":"import _objectSpread from \"C:/Users/ROG Strix/Desktop/vue cli/gui-demo/node_modules/@babel/runtime/helpers/esm/objectSpread2.js\";\nimport _typeof from \"C:/Users/ROG Strix/Desktop/vue cli/gui-demo/node_modules/@babel/runtime/helpers/esm/typeof.js\";\nimport \"core-js/modules/es.array.is-array.js\";\nimport \"core-js/modules/es.object.values.js\";\nimport modalMixin from '@/mixins/modalMixins';\nexport default {\n  name: 'OrderModal',\n  props: {\n    order: {\n      type: Object,\n      \"default\": function _default() {\n        return {};\n      }\n    }\n  },\n  emits: ['update-order'],\n  mixins: [modalMixin],\n  inject: ['emitter'],\n  data: function data() {\n    return {\n      status: {},\n      modal: '',\n      tempOrder: {\n        products: [],\n        user: {},\n        total: 0,\n        is_paid: false\n      },\n      isPaid: false\n    };\n  },\n  computed: {\n    orderProducts: function orderProducts() {\n      if (Array.isArray(this.tempOrder.products)) {\n        return this.tempOrder.products;\n      }\n      if (this.tempOrder.products && _typeof(this.tempOrder.products) === 'object') {\n        return Object.values(this.tempOrder.products);\n      }\n      return [];\n    }\n  },\n  watch: {\n    order: {\n      immediate: true,\n      deep: true,\n      handler: function handler() {\n        this.tempOrder = _objectSpread({\n          products: [],\n          user: {},\n          total: 0,\n          is_paid: false\n        }, this.order);\n        this.isPaid = this.tempOrder.is_paid;\n      }\n    }\n  }\n};","map":{"version":3,"names":["modalMixin","name","props","order","type","Object","default","emits","mixins","inject","data","status","modal","tempOrder","products","user","total","is_paid","isPaid","computed","orderProducts","Array","isArray","_typeof","values","watch","immediate","deep","handler","_objectSpread"],"sources":["C:\\Users\\ROG Strix\\Desktop\\vue cli\\gui-demo\\src\\components\\orderModal.vue"],"sourcesContent":["<template>\n  <div\n    id=\"productModal\"\n    ref=\"modal\"\n    class=\"modal fade\"\n    tabindex=\"-1\"\n    role=\"dialog\"\n    aria-labelledby=\"orderModalLabel\"\n    aria-hidden=\"true\"\n  >\n    <div class=\"modal-dialog modal-xl modal-dialog-centered\" role=\"document\">\n      <div class=\"modal-content order-modal border-0\">\n        <!-- Header -->\n        <div class=\"modal-header order-modal-header\">\n          <div>\n            <span class=\"modal-kicker\">ORDER DETAIL</span>\n            <h5 id=\"orderModalLabel\" class=\"modal-title fw-bold mt-1\">\n              訂單細節\n            </h5>\n          </div>\n\n          <button\n            type=\"button\"\n            class=\"btn-close btn-close-white\"\n            data-bs-dismiss=\"modal\"\n            aria-label=\"Close\"\n          ></button>\n        </div>\n\n        <!-- Body -->\n        <div class=\"modal-body p-4 p-lg-5\">\n          <div class=\"order-top-card mb-4\">\n            <div>\n              <span class=\"text-muted small\">訂單編號</span>\n              <h6 class=\"fw-bold mb-0 order-id\">\n                {{ tempOrder.id || '未取得訂單編號' }}\n              </h6>\n            </div>\n\n            <div class=\"text-lg-end\">\n              <span\n                class=\"pay-status\"\n                :class=\"tempOrder.is_paid ? 'paid' : 'unpaid'\"\n              >\n                {{ tempOrder.is_paid ? '已付款' : '尚未付款' }}\n              </span>\n            </div>\n          </div>\n\n          <div class=\"row g-4\">\n            <!-- 用戶資料 -->\n            <div class=\"col-lg-4\">\n              <section class=\"info-card h-100\">\n                <div class=\"section-title mb-4\">\n                  <span class=\"section-icon\">\n                    <i class=\"bi bi-person-lines-fill\"></i>\n                  </span>\n                  <div>\n                    <h5 class=\"fw-bold mb-1\">用戶資料</h5>\n                    <p class=\"text-muted mb-0 small\">\n                      訂購者聯絡資訊\n                    </p>\n                  </div>\n                </div>\n\n                <div class=\"info-list\" v-if=\"tempOrder.user\">\n                  <div class=\"info-row\">\n                    <span>姓名</span>\n                    <strong>{{ tempOrder.user.name || '未填寫' }}</strong>\n                  </div>\n\n                  <div class=\"info-row\">\n                    <span>Email</span>\n                    <strong>{{ tempOrder.user.email || '未填寫' }}</strong>\n                  </div>\n\n                  <div class=\"info-row\">\n                    <span>電話</span>\n                    <strong>{{ tempOrder.user.tel || '未填寫' }}</strong>\n                  </div>\n\n                  <div class=\"info-row\">\n                    <span>地址</span>\n                    <strong>{{ tempOrder.user.address || '未填寫' }}</strong>\n                  </div>\n                </div>\n\n                <div v-else class=\"empty-box\">\n                  尚無用戶資料\n                </div>\n              </section>\n            </div>\n\n            <!-- 訂單資訊 + 商品 -->\n            <div class=\"col-lg-8\">\n              <section class=\"info-card mb-4\">\n                <div class=\"section-title mb-4\">\n                  <span class=\"section-icon\">\n                    <i class=\"bi bi-receipt\"></i>\n                  </span>\n                  <div>\n                    <h5 class=\"fw-bold mb-1\">訂單資訊</h5>\n                    <p class=\"text-muted mb-0 small\">\n                      訂單時間、付款狀態與總金額\n                    </p>\n                  </div>\n                </div>\n\n                <div class=\"order-info-grid\">\n                  <div class=\"order-info-item\">\n                    <span>下單時間</span>\n                    <strong>\n                      {{ tempOrder.create_at ? $filters.date(tempOrder.create_at) : '未取得時間' }}\n                    </strong>\n                  </div>\n\n                  <div class=\"order-info-item\">\n                    <span>付款時間</span>\n                    <strong>\n                      <template v-if=\"tempOrder.paid_date\">\n                        {{ $filters.date(tempOrder.paid_date) }}\n                      </template>\n                      <template v-else>\n                        尚未付款\n                      </template>\n                    </strong>\n                  </div>\n\n                  <div class=\"order-info-item\">\n                    <span>付款狀態</span>\n                    <strong :class=\"tempOrder.is_paid ? 'text-success' : 'text-muted'\">\n                      {{ tempOrder.is_paid ? '已付款' : '尚未付款' }}\n                    </strong>\n                  </div>\n\n                  <div class=\"order-info-item total\">\n                    <span>總金額</span>\n                    <strong>{{ $filters.currency(tempOrder.total || 0) }}</strong>\n                  </div>\n                </div>\n              </section>\n\n              <section class=\"info-card\">\n                <div class=\"section-title mb-4\">\n                  <span class=\"section-icon\">\n                    <i class=\"bi bi-bag-check\"></i>\n                  </span>\n                  <div>\n                    <h5 class=\"fw-bold mb-1\">選購商品</h5>\n                    <p class=\"text-muted mb-0 small\">\n                      本次訂單的餐點明細\n                    </p>\n                  </div>\n                </div>\n\n                <div v-if=\"orderProducts.length\" class=\"table-responsive\">\n                  <table class=\"table align-middle order-table\">\n                    <thead>\n                      <tr>\n                        <th>商品名稱</th>\n                        <th class=\"text-center\">數量</th>\n                        <th class=\"text-end\">小計</th>\n                      </tr>\n                    </thead>\n\n                    <tbody>\n                      <tr v-for=\"item in orderProducts\" :key=\"item.id\">\n                        <td>\n                          <div class=\"product-name\">\n                            <span class=\"product-dot\"></span>\n                            <div>\n                              <strong>\n                                {{ item.product?.title || '未命名商品' }}\n                              </strong>\n                              <small class=\"text-muted d-block\">\n                                {{ item.product?.category || '精選料理' }}\n                              </small>\n                            </div>\n                          </div>\n                        </td>\n\n                        <td class=\"text-center\">\n                          <span class=\"qty-pill\">\n                            {{ item.qty || 0 }} {{ item.product?.unit || '份' }}\n                          </span>\n                        </td>\n\n                        <td class=\"text-end fw-bold text-danger\">\n                          {{ $filters.currency(item.final_total || 0) }}\n                        </td>\n                      </tr>\n                    </tbody>\n\n                    <tfoot>\n                      <tr>\n                        <td colspan=\"2\" class=\"text-end fw-bold\">\n                          訂單總計\n                        </td>\n                        <td class=\"text-end total-price\">\n                          {{ $filters.currency(tempOrder.total || 0) }}\n                        </td>\n                      </tr>\n                    </tfoot>\n                  </table>\n                </div>\n\n                <div v-else class=\"empty-box\">\n                  此訂單尚無商品資料\n                </div>\n              </section>\n            </div>\n          </div>\n        </div>\n\n        <!-- Footer -->\n        <div class=\"modal-footer order-modal-footer\">\n          <button\n            type=\"button\"\n            class=\"btn btn-outline-secondary\"\n            data-bs-dismiss=\"modal\"\n          >\n            關閉\n          </button>\n\n          <button\n            type=\"button\"\n            class=\"btn btn-primary\"\n            @click=\"$emit('update-order', tempOrder)\"\n          >\n            確認更新\n          </button>\n        </div>\n      </div>\n    </div>\n  </div>\n</template>\n\n<script>\nimport modalMixin from '@/mixins/modalMixins';\n\nexport default {\n  name: 'OrderModal',\n  props: {\n    order: {\n      type: Object,\n      default() {\n        return {};\n      },\n    },\n  },\n  emits: ['update-order'],\n  mixins: [modalMixin],\n  inject: ['emitter'],\n  data() {\n    return {\n      status: {},\n      modal: '',\n      tempOrder: {\n        products: [],\n        user: {},\n        total: 0,\n        is_paid: false,\n      },\n      isPaid: false,\n    };\n  },\n  computed: {\n    orderProducts() {\n      if (Array.isArray(this.tempOrder.products)) {\n        return this.tempOrder.products;\n      }\n\n      if (this.tempOrder.products && typeof this.tempOrder.products === 'object') {\n        return Object.values(this.tempOrder.products);\n      }\n\n      return [];\n    },\n  },\n  watch: {\n    order: {\n      immediate: true,\n      deep: true,\n      handler() {\n        this.tempOrder = {\n          products: [],\n          user: {},\n          total: 0,\n          is_paid: false,\n          ...this.order,\n        };\n\n        this.isPaid = this.tempOrder.is_paid;\n      },\n    },\n  },\n};\n</script>\n\n<style scoped>\n.order-modal {\n  overflow: hidden;\n  border-radius: 28px;\n  background: #fffaf6;\n  box-shadow: 0 28px 80px rgba(40, 24, 12, 0.24);\n}\n\n.order-modal-header {\n  padding: 26px 32px;\n  color: #ffffff;\n  background:\n    linear-gradient(135deg, rgba(178, 58, 46, 0.98), rgba(55, 38, 31, 0.98)),\n    #2b211e;\n  border-bottom: 0;\n}\n\n.modal-kicker {\n  display: inline-block;\n  font-size: 12px;\n  font-weight: 900;\n  letter-spacing: 1.5px;\n  opacity: 0.85;\n}\n\n.order-top-card {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  gap: 18px;\n  padding: 22px 24px;\n  border-radius: 22px;\n  background: #ffffff;\n  border: 1px solid #f1d8ca;\n  box-shadow: 0 12px 32px rgba(120, 54, 28, 0.08);\n}\n\n.order-id {\n  word-break: break-all;\n  color: #3b2a22;\n}\n\n.pay-status {\n  display: inline-flex;\n  align-items: center;\n  justify-content: center;\n  min-width: 92px;\n  padding: 8px 14px;\n  border-radius: 999px;\n  font-size: 14px;\n  font-weight: 900;\n}\n\n.pay-status.paid {\n  color: #198754;\n  background: #e9f8ef;\n}\n\n.pay-status.unpaid {\n  color: #b23a2e;\n  background: #fff0e7;\n}\n\n.info-card {\n  padding: 26px;\n  border-radius: 24px;\n  background: #ffffff;\n  border: 1px solid #f1d8ca;\n  box-shadow: 0 14px 36px rgba(120, 54, 28, 0.08);\n}\n\n.section-title {\n  display: flex;\n  align-items: center;\n  gap: 12px;\n}\n\n.section-icon {\n  width: 44px;\n  height: 44px;\n  border-radius: 16px;\n  display: inline-flex;\n  align-items: center;\n  justify-content: center;\n  color: #b23a2e;\n  background: #fff0e7;\n  font-size: 20px;\n  flex-shrink: 0;\n}\n\n.info-list {\n  display: grid;\n  gap: 12px;\n}\n\n.info-row {\n  padding: 14px 16px;\n  border-radius: 16px;\n  background: #fffaf6;\n  border: 1px solid #f1e4dc;\n}\n\n.info-row span,\n.order-info-item span {\n  display: block;\n  margin-bottom: 6px;\n  color: #8a7a70;\n  font-size: 13px;\n  font-weight: 700;\n}\n\n.info-row strong,\n.order-info-item strong {\n  display: block;\n  color: #33251f;\n  line-height: 1.6;\n  word-break: break-word;\n}\n\n.order-info-grid {\n  display: grid;\n  grid-template-columns: repeat(2, minmax(0, 1fr));\n  gap: 14px;\n}\n\n.order-info-item {\n  padding: 16px;\n  border-radius: 18px;\n  background: #fffaf6;\n  border: 1px solid #f1e4dc;\n}\n\n.order-info-item.total strong {\n  color: #b23a2e;\n  font-size: 22px;\n}\n\n.order-table {\n  overflow: hidden;\n  border-radius: 18px;\n}\n\n.order-table thead th {\n  color: #6c5b50;\n  background: #fff3ea;\n  border-bottom: 1px solid #f1d8ca;\n  font-size: 14px;\n}\n\n.order-table tbody td {\n  padding: 16px 12px;\n  border-bottom: 1px solid #f1e4dc;\n}\n\n.product-name {\n  display: flex;\n  align-items: center;\n  gap: 10px;\n}\n\n.product-dot {\n  width: 10px;\n  height: 10px;\n  border-radius: 50%;\n  background: #b23a2e;\n  flex-shrink: 0;\n}\n\n.qty-pill {\n  display: inline-flex;\n  align-items: center;\n  justify-content: center;\n  min-width: 72px;\n  padding: 6px 12px;\n  border-radius: 999px;\n  color: #6c4b3f;\n  background: #fff0e7;\n  font-weight: 800;\n}\n\n.total-price {\n  color: #b23a2e;\n  font-size: 20px;\n  font-weight: 900;\n}\n\n.empty-box {\n  padding: 30px 18px;\n  border-radius: 18px;\n  color: #8a7a70;\n  text-align: center;\n  background: #fff8f2;\n  border: 1px dashed #e5c9b8;\n}\n\n.order-modal-footer {\n  padding: 20px 32px;\n  background: #ffffff;\n  border-top: 1px solid #f1d8ca;\n}\n\n.order-modal-footer .btn {\n  min-width: 108px;\n  font-weight: 800;\n}\n\n@media (max-width: 768px) {\n  .order-modal {\n    border-radius: 18px;\n  }\n\n  .order-modal-header {\n    padding: 22px;\n  }\n\n  .modal-body {\n    padding: 22px !important;\n  }\n\n  .order-top-card {\n    flex-direction: column;\n    align-items: flex-start;\n  }\n\n  .info-card {\n    padding: 20px;\n    border-radius: 20px;\n  }\n\n  .order-info-grid {\n    grid-template-columns: 1fr;\n  }\n\n  .order-modal-footer {\n    padding: 18px 22px;\n  }\n\n  .order-modal-footer .btn {\n    width: 100%;\n  }\n}\n</style>"],"mappings":";;;;AA8OA,OAAOA,UAAS,MAAO,sBAAsB;AAE7C,eAAe;EACbC,IAAI,EAAE,YAAY;EAClBC,KAAK,EAAE;IACLC,KAAK,EAAE;MACLC,IAAI,EAAEC,MAAM;MAAA,oBACZC,QAAOA,CAAA,EAAG;QACR,OAAO,CAAC,CAAC;MACX;IACF;EACF,CAAC;EACDC,KAAK,EAAE,CAAC,cAAc,CAAC;EACvBC,MAAM,EAAE,CAACR,UAAU,CAAC;EACpBS,MAAM,EAAE,CAAC,SAAS,CAAC;EACnBC,IAAI,WAAJA,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,MAAM,EAAE,CAAC,CAAC;MACVC,KAAK,EAAE,EAAE;MACTC,SAAS,EAAE;QACTC,QAAQ,EAAE,EAAE;QACZC,IAAI,EAAE,CAAC,CAAC;QACRC,KAAK,EAAE,CAAC;QACRC,OAAO,EAAE;MACX,CAAC;MACDC,MAAM,EAAE;IACV,CAAC;EACH,CAAC;EACDC,QAAQ,EAAE;IACRC,aAAa,WAAbA,aAAaA,CAAA,EAAG;MACd,IAAIC,KAAK,CAACC,OAAO,CAAC,IAAI,CAACT,SAAS,CAACC,QAAQ,CAAC,EAAE;QAC1C,OAAO,IAAI,CAACD,SAAS,CAACC,QAAQ;MAChC;MAEA,IAAI,IAAI,CAACD,SAAS,CAACC,QAAO,IAAKS,OAAA,CAAO,IAAI,CAACV,SAAS,CAACC,QAAO,MAAM,QAAQ,EAAE;QAC1E,OAAOT,MAAM,CAACmB,MAAM,CAAC,IAAI,CAACX,SAAS,CAACC,QAAQ,CAAC;MAC/C;MAEA,OAAO,EAAE;IACX;EACF,CAAC;EACDW,KAAK,EAAE;IACLtB,KAAK,EAAE;MACLuB,SAAS,EAAE,IAAI;MACfC,IAAI,EAAE,IAAI;MACVC,OAAO,WAAPA,OAAOA,CAAA,EAAG;QACR,IAAI,CAACf,SAAQ,GAAAgB,aAAA;UACXf,QAAQ,EAAE,EAAE;UACZC,IAAI,EAAE,CAAC,CAAC;UACRC,KAAK,EAAE,CAAC;UACRC,OAAO,EAAE;QAAK,GACX,IAAI,CAACd,KAAK,CACd;QAED,IAAI,CAACe,MAAK,GAAI,IAAI,CAACL,SAAS,CAACI,OAAO;MACtC;IACF;EACF;AACF,CAAC","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}