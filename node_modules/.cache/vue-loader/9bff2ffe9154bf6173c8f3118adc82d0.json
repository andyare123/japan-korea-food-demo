CAAC;EACH,CAAC,CAAC,CAAC,CAAC,CAAC","file":"C:/Users/ROG Strix/Desktop/vue cli/gui-demo/src/components/ToastMessages.vue","sourceRoot":"","sourcesContent":["<template>\n  <div class=\"toast-container position-absolute pe-3 top-0 end-0\" style=\"z-index: 1050\">\n    <Toast v-for=\"(msg, key) in messages\" :key=\"key\"\n      :msg=\"msg\"\n    />\n  </div>\n</template>\n\n<script>\nimport Toast from '@/components/Toast.vue';\n\nexport default {\n  components: { Toast },\n  data() {\n    return {\n      messages: [],\n    };\n  },\n  inject: ['emitter'],\n  mounted() {\n    this.emitter.on('push-message', (message) => {\n      const { style = 'success', title, content } = message;\n      this.messages.push({ style, title, content });\n    });\n  },\n};\n</script>\n"]}]}